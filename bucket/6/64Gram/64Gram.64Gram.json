{
    "version": "1.2.0",
    "description": "非官方的 Telegram 桌面版 | Unofficial Telegram Desktop",
    "homepage": "https://github.com/TDesktop-x64/tdesktop",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/TDesktop-x64/tdesktop/releases/download/v1.2.0/64Gram-setup-x64.1.2.0.exe",
            "hash": "35d91d39f64cdcada17ae2fac1d52e23c4a7327eee786685c1fb68382159e0ef"
        }
    },
    "shortcuts": [
        [
            "app\\Telegram.exe",
            "64Gram"
        ]
    ],
    "persist": [
        [
            "app\\tdata",
            "tdata"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/TDesktop-x64/tdesktop/releases/download/v$version/64Gram-setup-x64.$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
