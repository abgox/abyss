{
    "version": "1.2.1",
    "description": "非官方的 Telegram 桌面版 | Unofficial Telegram Desktop",
    "homepage": "https://github.com/TDesktop-x64/tdesktop",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/TDesktop-x64/tdesktop/releases/download/v1.2.1/64Gram-setup-x64.1.2.1.exe",
            "hash": "9cee374b6a4a2035b3bf19b869ef59cf381c5ad93c3a5c954080586f3eeed7b8"
        }
    },
    "shortcuts": [
        [
            "app\\Telegram.exe",
            "64Gram"
        ]
    ],
    "persist": [
        [
            "app\\tdata",
            "tdata"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/TDesktop-x64/tdesktop/releases/download/v$version/64Gram-setup-x64.$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
