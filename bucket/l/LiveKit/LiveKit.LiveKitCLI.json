{
    "version": "2.18.1",
    "description": "LiveKit 的命令行界面 | Command line interface to LiveKit",
    "homepage": "https://livekit.io",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/livekit/livekit-cli/releases/download/v2.18.1/lk_2.18.1_windows_amd64.zip",
            "hash": "840c72b46c275089b69ecb12baa5567f46f4fa7cad5b83443a8466f9ed127b7a"
        },
        "arm64": {
            "url": "https://github.com/livekit/livekit-cli/releases/download/v2.18.1/lk_2.18.1_windows_arm64.zip",
            "hash": "7733211057a346605cf53db6451aacc2cbbad4f5ac3bf239b278dab116c93e7c"
        }
    },
    "extract_to": "app",
    "bin": "app\\lk.exe",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/livekit/livekit-cli/releases/download/v$version/lk_$version_windows_amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/livekit/livekit-cli/releases/download/v$version/lk_$version_windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
