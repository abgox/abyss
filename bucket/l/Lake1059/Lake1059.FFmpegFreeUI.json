{
    "version": "6.1.12",
    "description": "FFmpegFreeUI (3FUI) - ffmpeg 在 Windows 上的轻度专业交互外壳 | FFmpegFreeUI (3FUI) - A lightweight professional interactive shell for ffmpeg on Windows",
    "homepage": "https://github.com/Lake1059/FFmpegFreeUI",
    "license": {
        "identifier": "MIT"
    },
    "suggest": {
        "ffmpeg": [
            "ffmpeg",
            "abyss/Gyan.FFmpeg"
        ]
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/6.1.12/FFmpegFreeUI.x64.exe#/FFmpegFreeUI.exe",
            "hash": "6dec7b7e9cabdd8739fb9c5e19366c8c1215cc91e2036f44e29fee741e116b4f"
        },
        "arm64": {
            "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/6.1.12/FFmpegFreeUI.arm64.exe#/FFmpegFreeUI.exe",
            "hash": "bc645b0d1858c0e993266e815efd2817cd51d38c2b42094f3532d54ad9f2ab4d"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\FFmpegFreeUI.exe",
            "FFmpegFreeUI"
        ]
    ],
    "persist": [
        [
            "app\\Settings.json",
            "Settings.json"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/$version/FFmpegFreeUI.x64.exe#/FFmpegFreeUI.exe"
            },
            "arm64": {
                "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/$version/FFmpegFreeUI.arm64.exe#/FFmpegFreeUI.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
