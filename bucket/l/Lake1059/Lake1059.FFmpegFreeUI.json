{
    "version": "6.1.9",
    "description": "FFmpegFreeUI (3FUI) - ffmpeg 在 Windows 上的轻度专业交互外壳 | FFmpegFreeUI (3FUI) - A lightweight professional interactive shell for ffmpeg on Windows",
    "homepage": "https://github.com/Lake1059/FFmpegFreeUI",
    "license": {
        "identifier": "MIT"
    },
    "suggest": {
        "ffmpeg": [
            "ffmpeg",
            "abyss/Gyan.FFmpeg"
        ]
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/6.1.9/FFmpegFreeUI.x64.exe#/FFmpegFreeUI.exe",
            "hash": "bbd687204c8a37e42505e55ad92a655532a46e8be9c57b0976525fb02f8172e4"
        },
        "arm64": {
            "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/6.1.9/FFmpegFreeUI.arm64.exe#/FFmpegFreeUI.exe",
            "hash": "052d7b96758f8a68b6fbaf69ae268b2c9f534345d4153195c4fcc97ae3e80e31"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\FFmpegFreeUI.exe",
            "FFmpegFreeUI"
        ]
    ],
    "persist": [
        [
            "app\\Settings.json",
            "Settings.json"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/$version/FFmpegFreeUI.x64.exe#/FFmpegFreeUI.exe"
            },
            "arm64": {
                "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/$version/FFmpegFreeUI.arm64.exe#/FFmpegFreeUI.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
