            "hash": "d074586836c206240455e0d11ed99d050af3498bf500217ed09436e607f6b213"
        },
        "arm64": {
            "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/6.1.15/FFmpegFreeUI.arm64.exe#/FFmpegFreeUI.exe",
