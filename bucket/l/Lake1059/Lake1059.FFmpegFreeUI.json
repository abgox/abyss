{
    "version": "6.1.8",
    "description": "FFmpegFreeUI (3FUI) - ffmpeg 在 Windows 上的轻度专业交互外壳 | FFmpegFreeUI (3FUI) - A lightweight professional interactive shell for ffmpeg on Windows",
    "homepage": "https://github.com/Lake1059/FFmpegFreeUI",
    "license": {
        "identifier": "MIT"
    },
    "suggest": {
        "ffmpeg": [
            "ffmpeg",
            "abyss/Gyan.FFmpeg"
        ]
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/6.1.8/FFmpegFreeUI.x64.exe#/FFmpegFreeUI.exe",
            "hash": "e8d8e84506e71afa7e96117ffe75984b470cf039583d6711c95b75864caea9eb"
        },
        "arm64": {
            "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/6.1.8/FFmpegFreeUI.arm64.exe#/FFmpegFreeUI.exe",
            "hash": "a0182b672d58b691d4143c7cd41612cdfaf5fa3b45f9a7d83a49bf5786c677a5"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\FFmpegFreeUI.exe",
            "FFmpegFreeUI"
        ]
    ],
    "persist": [
        [
            "app\\Settings.json",
            "Settings.json"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/$version/FFmpegFreeUI.x64.exe#/FFmpegFreeUI.exe"
            },
            "arm64": {
                "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/$version/FFmpegFreeUI.arm64.exe#/FFmpegFreeUI.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
