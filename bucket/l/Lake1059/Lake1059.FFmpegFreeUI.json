{
    "version": "6.1.16",
    "description": "FFmpegFreeUI (3FUI) - ffmpeg 在 Windows 上的轻度专业交互外壳 | FFmpegFreeUI (3FUI) - A lightweight professional interactive shell for ffmpeg on Windows",
    "homepage": "https://github.com/Lake1059/FFmpegFreeUI",
    "license": {
        "identifier": "MIT"
    },
    "suggest": {
        "ffmpeg": [
            "ffmpeg",
            "abyss/Gyan.FFmpeg"
        ]
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/6.1.16/FFmpegFreeUI.x64.exe#/FFmpegFreeUI.exe",
            "hash": "7d0b01c0c91ce74f6da0d94cb76dcfb317a302ae4c12305650242e9b22d3e738"
        },
        "arm64": {
            "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/6.1.16/FFmpegFreeUI.arm64.exe#/FFmpegFreeUI.exe",
            "hash": "bb77766c7d743ea16a27c8b7ec1322e3ec694e544085ca4c088b8fcd969a1302"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\FFmpegFreeUI.exe",
            "FFmpegFreeUI"
        ]
    ],
    "persist": [
        [
            "app\\Settings.json",
            "Settings.json"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/$version/FFmpegFreeUI.x64.exe#/FFmpegFreeUI.exe"
            },
            "arm64": {
                "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/$version/FFmpegFreeUI.arm64.exe#/FFmpegFreeUI.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
