{
    "version": "6.1.11",
    "description": "FFmpegFreeUI (3FUI) - ffmpeg 在 Windows 上的轻度专业交互外壳 | FFmpegFreeUI (3FUI) - A lightweight professional interactive shell for ffmpeg on Windows",
    "homepage": "https://github.com/Lake1059/FFmpegFreeUI",
    "license": {
        "identifier": "MIT"
    },
    "suggest": {
        "ffmpeg": [
            "ffmpeg",
            "abyss/Gyan.FFmpeg"
        ]
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/6.1.11/FFmpegFreeUI.x64.exe#/FFmpegFreeUI.exe",
            "hash": "1ba8cdaff522ba0880ddd13152d8e9b903717976aac24c7c45123d82b99f3e8e"
        },
        "arm64": {
            "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/6.1.11/FFmpegFreeUI.arm64.exe#/FFmpegFreeUI.exe",
            "hash": "5b5092a92ed12ee0dca9c41cdf6a3be47718fdbecf8d7c8d6498f9111703084d"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\FFmpegFreeUI.exe",
            "FFmpegFreeUI"
        ]
    ],
    "persist": [
        [
            "app\\Settings.json",
            "Settings.json"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/$version/FFmpegFreeUI.x64.exe#/FFmpegFreeUI.exe"
            },
            "arm64": {
                "url": "https://github.com/Lake1059/FFmpegFreeUI/releases/download/$version/FFmpegFreeUI.arm64.exe#/FFmpegFreeUI.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
