{
    "version": "7.1.1",
    "description": "适用于桌面端的简单跨平台双因素 (2FA) 认证器应用程序 | Simple cross-platform two-factor (2FA) authenticator app for desktop",
    "homepage": "https://authme.levminer.com",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Levminer/authme/releases/download/7.1.1/authme-7.1.1-windows-x64.msi#/dl.msi_",
            "hash": "701ef4a2108e1ca77cdf9288224f6c2bb6a1baac789218e7ba04e3d57a47102c"
        }
    },
    "link": "$env:LocalAppData\\com.levminer.authme\\EBWebView\\Default\\Local Storage",
    "cleanup": "$env:LocalAppData\\com.levminer.authme",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Msi"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Uninstall-Msi",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Levminer/authme/releases/download/$version/authme-$version-windows-x64.msi#/dl.msi_"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
