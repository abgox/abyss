{
    "version": "2.0.1",
    "description": "用于为你的离线音乐库批量下载 LRC 同步歌词的工具 | Utility for mass-downloading LRC synced lyrics for your offline music library",
    "homepage": "https://github.com/tranxuanthang/lrcget",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/tranxuanthang/lrcget/releases/download/2.0.1/LRCGET_2.0.1_x64-setup.exe",
            "hash": "68827127338b9e69c0647e3b458955d443b5941be49802c4596d0bc8a355e394"
        }
    },
    "shortcuts": [
        [
            "app\\LRCGET.exe",
            "LRCGET"
        ]
    ],
    "link": "$env:AppData\\net.lrclib.lrcget",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\net.lrclib.lrcget\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/tranxuanthang/lrcget/releases/download/$version/LRCGET_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
