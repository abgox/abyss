{
    "version": "5.5.22",
    "description": "一款受 Postman 启发的开源 API 调试和性能测试桌面应用程序 | An open-source API debugging & performance testing desktop app inspired by Postman",
    "homepage": "https://github.com/lakernote/EasyPostman",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/lakernote/EasyPostman/releases/download/v5.5.22/EasyPostman-5.5.22-windows-x64-portable.zip",
            "hash": "52da621b861a2c548e4a4a92fd6e0ad7b7f46f8dec9daffbbbc4f18d705cbf08"
        }
    },
    "extract_dir": "EasyPostman",
    "extract_to": "app",
    "bin": "app\\EasyPostman.exe",
    "shortcuts": [
        [
            "app\\EasyPostman.exe",
            "EasyPostman"
        ]
    ],
    "link": "$home\\EasyPostman",
    "persist": [
        [
            "app\\app\\data",
            "EasyPostman"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/lakernote/EasyPostman/releases/download/v$version/EasyPostman-$version-windows-x64-portable.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
