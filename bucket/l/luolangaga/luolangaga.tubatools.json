            "hash": "bd075bb7eb00306f51a8ac5db2a8b3d47ee41e879f057541a62f110547a398b5"
        },
        "arm64": {
            "url": "https://github.com/luolangaga/tubatools/releases/download/v1.4.1/TubaWinUi3_Setup_1.4.1_arm64.exe",
