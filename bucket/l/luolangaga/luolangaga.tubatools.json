    "homepage": "https://tubawinui3.cn",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/luolangaga/tubatools/releases/download/v1.4.0/TubaWinUi3_Setup_1.4.0_x64.exe",
            "hash": "8094765097ff68147c86f452515414e453e6ded1f3a2cab373aa20c18b4b3aa1"
        },
        "arm64": {
            "url": "https://github.com/luolangaga/tubatools/releases/download/v1.4.0/TubaWinUi3_Setup_1.4.0_arm64.exe",
            "hash": "f04e84210934d9a718ea2ae2aa5febfc20072a9db3c4c0562dea0c4f67a25a9e"
        }
    },
    "shortcuts": [
        [
            "app\\TubaWinUi3.exe",
            "图吧工具箱WinUi3"
        ]
    ],
    "link": "$env:LocalAppData\\TubaWinUi3",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/luolangaga/tubatools/releases/download/v$version/TubaWinUi3_Setup_$version_x64.exe"
            },
            "arm64": {
                "url": "https://github.com/luolangaga/tubatools/releases/download/v$version/TubaWinUi3_Setup_$version_arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
