{
    "version": "9.1.8",
    "description": "神经网络、深度学习和机器学习模型的可视化工具 | Visualizer for neural network, deep learning and machine learning models",
    "homepage": "https://netron.app",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/lutzroeder/netron/releases/download/v9.1.8/Netron-Setup-9.1.8.exe",
            "hash": "d9aff2e8ea07c6678eddf9bd0e7fe095b677e9215cd660c57e5425a5096604c4"
        }
    },
    "bin": "app\\Netron.exe",
    "shortcuts": [
        [
            "app\\Netron.exe",
            "Netron"
        ]
    ],
    "link": "$env:AppData\\Netron",
    "cleanup": "$env:LocalAppData\\netron-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Netron.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/lutzroeder/netron/releases/download/v$version/Netron-Setup-$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
