{
    "version": "2.0.1",
    "description": "一个以隐私为首要原则的开源知识管理与协作平台 | A privacy-first, open-source platform for knowledge management and collaboration",
    "homepage": "https://logseq.com",
    "license": {
        "identifier": "AGPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/logseq/logseq/releases/download/2.0.1/Logseq-win-x64-2.0.1.zip",
            "hash": "30a4895c3a37c0c5e99ee80842fbbe64194ed2e48ff579ca7dbebd9edfdabf7e"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\Logseq.exe",
            "Logseq"
        ]
    ],
    "link": [
        "$env:AppData\\Logseq",
        "$home\\.logseq"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/logseq/logseq/releases/download/$version/Logseq-win-x64-$version.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
