{
    "version": "1.0.0-beta3",
    "description": "一个现代化的人工智能网关系统，提供统一的 OpenAI（聊天补全、响应）、Anthropic、Gemini 以及人工智能软件开发工具包兼容的应用程序接口 | A modern AI gateway system that provides a unified OpenAI (Chat Completion, Responses), Anthropic, Gemini and AI SDK compatible API",
    "homepage": "https://axonhub.onrender.com/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/looplj/axonhub/releases/download/v1.0.0-beta3/axonhub_1.0.0-beta3_windows_amd64.zip",
            "hash": "fe363aeb55a130282e1dace77834ffe0b0d82c2b9857010a419557fc5d4275cb"
        },
        "arm64": {
            "url": "https://github.com/looplj/axonhub/releases/download/v1.0.0-beta3/axonhub_1.0.0-beta3_windows_arm64.zip",
            "hash": "3f97202db3868677b692aa6a0dae1235041106616a7274a0aae960321293ecaf"
        }
    },
    "extract_to": "app",
    "bin": "app\\axonhub.exe",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/looplj/axonhub/releases/download/v$version/axonhub_$version_windows_amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/looplj/axonhub/releases/download/v$version/axonhub_$version_windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
