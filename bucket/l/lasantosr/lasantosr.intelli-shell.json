{
    "version": "3.4.1",
    "description": "一个功能强大的命令模板和代码片段管理器，适用于你的 shell | A powerful command template and snippet manager for your shell",
    "homepage": "https://lasantosr.github.io/intelli-shell/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/lasantosr/intelli-shell/releases/download/v3.4.1/intelli-shell-x86_64-pc-windows-msvc.zip",
            "hash": "278e90bdd2e711edba26a79ddf97b5289e2dd25dbd76b530260b79b24c08ba92"
        },
        "arm64": {
            "url": "https://github.com/lasantosr/intelli-shell/releases/download/v3.4.1/intelli-shell-aarch64-pc-windows-msvc.zip",
            "hash": "3bc235ab6adbe2dc212563aa369409d7ed84bdc2589729924d1f9be2e46774fb"
        }
    },
    "extract_to": "app",
    "bin": "app\\intelli-shell.exe",
    "link": "$env:AppData\\IntelliShell\\Intelli-Shell",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/lasantosr/intelli-shell/releases/download/v$version/intelli-shell-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/lasantosr/intelli-shell/releases/download/v$version/intelli-shell-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
