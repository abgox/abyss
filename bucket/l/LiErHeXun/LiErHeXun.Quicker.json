{
    "version": "1.45.2.0",
    "description": "指尖工具箱, Windows 效率工具 | A toolbox to improve efficiency on Windows",
    "homepage": "https://getquicker.net/",
    "license": {
        "identifier": "Freemium"
    },
    "architecture": {
        "64bit": {
            "url": "https://getquicker.net/Download/DownloadVersion?version=1.45.2.0&isX64=true#/dl.msi",
            "hash": "15f0ec7bdf88ab643c88c90d787531817d465de1cc5d1ab5c13cfda33dd35b64"
        }
    },
    "extract_dir": "Quicker",
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\Quicker.exe",
            "Quicker"
        ]
    ],
    "link": "$env:LocalAppData\\Quicker",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://getquicker.net/Help/Versions",
        "regex": "version=([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://getquicker.net/Download/DownloadVersion?version=$version&isX64=true#/dl.msi"
            }
        }
    }
}
