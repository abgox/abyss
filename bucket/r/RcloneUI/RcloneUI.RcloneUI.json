{
    "version": "3.7.0",
    "description": "rclone 之上的一个轻便、透明的层（桌面图形用户界面），能以更用户友好的方式管理你的远程存储和任务 | A light, transparent layer (desktop GUI) on top of rclone to manage your remotes & tasks in a more user-friendly way",
    "homepage": "https://rcloneui.com",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/rclone-ui/rclone-ui/releases/download/v3.7.0/Rclone.UI_x64.exe",
            "hash": "1a841364643d6aa15a461949ce66d89974970757afb6893fcae4fb454f930e2d"
        },
        "arm64": {
            "url": "https://github.com/rclone-ui/rclone-ui/releases/download/v3.7.0/Rclone.UI_arm64.exe",
            "hash": "fc6e4715006f44b89aabc674e30599e6e3f38b8540c379f07c1d7c7db6f58718"
        }
    },
    "location": "$env:ProgramFiles\\Rclone UI",
    "link": "$env:AppData\\com.rclone.ui",
    "cleanup": "$env:LocalAppData\\com.rclone.ui",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/rclone-ui/rclone-ui/releases/download/v$version/Rclone.UI_x64.exe"
            },
            "arm64": {
                "url": "https://github.com/rclone-ui/rclone-ui/releases/download/v$version/Rclone.UI_arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
