{
    "version": "3.5.4",
    "description": "rclone 之上的一个轻便、透明的层（桌面图形用户界面），能以更用户友好的方式管理你的远程存储和任务 | A light, transparent layer (desktop GUI) on top of rclone to manage your remotes & tasks in a more user-friendly way",
    "homepage": "https://rcloneui.com/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/rclone-ui/rclone-ui/releases/download/v3.5.4/Rclone.UI_x64.exe",
            "hash": "5ebe9ee8cc3610458faae0590fa3a572c9a12bd67753222fa54c6f061e7a2c49"
        },
        "arm64": {
            "url": "https://github.com/rclone-ui/rclone-ui/releases/download/v3.5.4/Rclone.UI_arm64.exe",
            "hash": "fd5e6da3e466e86cb9a6fd9fa975f54075f3fc1630562c81a68bbc53d65f67c8"
        }
    },
    "location": "$env:ProgramFiles\\Rclone UI",
    "link": "$env:AppData\\com.rclone.ui",
    "cleanup": "$env:LocalAppData\\com.rclone.ui",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/rclone-ui/rclone-ui/releases/download/v$version/Rclone.UI_x64.exe"
            },
            "arm64": {
                "url": "https://github.com/rclone-ui/rclone-ui/releases/download/v$version/Rclone.UI_arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
