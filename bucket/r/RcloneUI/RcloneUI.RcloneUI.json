{
    "version": "3.5.2",
    "description": "rclone 之上的一个轻便、透明的层（桌面图形用户界面），能以更用户友好的方式管理你的远程存储和任务 | A light, transparent layer (desktop GUI) on top of rclone to manage your remotes & tasks in a more user-friendly way",
    "homepage": "https://rcloneui.com/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/rclone-ui/rclone-ui/releases/download/v3.5.2/Rclone.UI_x64.exe",
            "hash": "a52a17285409bd27e298908ee6b1e836bf49b6c7a22f67006a2388cc5064f7ce"
        },
        "arm64": {
            "url": "https://github.com/rclone-ui/rclone-ui/releases/download/v3.5.2/Rclone.UI_arm64.exe",
            "hash": "75f352eae11e3240c38a4236c666aa82dd29fc2e899447109c3ffc854765f2ba"
        }
    },
    "location": "$env:ProgramFiles\\Rclone UI",
    "link": "$env:AppData\\com.rclone.ui",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Require-Admin",
        "A-Install-App -Uninstaller \"$env:ProgramFiles\\Rclone UI\\uninstall.exe\" -ArgumentList '/S'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Require-Admin",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\com.rclone.ui\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/rclone-ui/rclone-ui/releases/download/v$version/Rclone.UI_x64.exe"
            },
            "arm64": {
                "url": "https://github.com/rclone-ui/rclone-ui/releases/download/v$version/Rclone.UI_arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
