{
    "version": "2.0.26",
    "description": "一款基于 todo.txt 语法的开源待办事项管理器 | An open-source todo manager based on the todo.txt syntax",
    "homepage": "https://github.com/ransome1/sleek",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/ransome1/sleek/releases/download/v2.0.26/sleek-2.0.26-win-x64-Setup.exe",
            "hash": "df2fa15bbeee9d049f6d2f52846c91577f5d36eca7eea7134f1289f591b44bb1"
        },
        "arm64": {
            "url": "https://github.com/ransome1/sleek/releases/download/v2.0.26/sleek-2.0.26-win-arm64-Setup.exe",
            "hash": "e9b86077fbdd7db696d9f82ab39d2452b0516f0737fed19d9beff77bf34b4556"
        }
    },
    "shortcuts": [
        [
            "app\\sleek.exe",
            "sleek"
        ]
    ],
    "link": "$env:AppData\\sleek",
    "cleanup": "$env:LocalAppData\\sleek-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall sleek.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ransome1/sleek/releases/download/v$version/sleek-$version-win-x64-Setup.exe"
            },
            "arm64": {
                "url": "https://github.com/ransome1/sleek/releases/download/v$version/sleek-$version-win-arm64-Setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
