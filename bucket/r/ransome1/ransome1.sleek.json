{
    "version": "2.0.24",
    "description": "一款基于 todo.txt 语法的开源待办事项管理器 | An open-source todo manager based on the todo.txt syntax",
    "homepage": "https://github.com/ransome1/sleek",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/ransome1/sleek/releases/download/v2.0.24/sleek-2.0.24-win-x64-Setup.exe",
            "hash": "829a74d5723912843609fa432cfe1c58ee41195ee3dfde2883fcef848a1c1538"
        },
        "arm64": {
            "url": "https://github.com/ransome1/sleek/releases/download/v2.0.24/sleek-2.0.24-win-arm64-Setup.exe",
            "hash": "92d77e024a6b0199058e4469ca3ef2666937d4f6977dbc78029282a7788f9ae7"
        }
    },
    "shortcuts": [
        [
            "app\\sleek.exe",
            "sleek"
        ]
    ],
    "link": "$env:AppData\\sleek",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall sleek.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\sleek-updater\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ransome1/sleek/releases/download/v$version/sleek-$version-win-x64-Setup.exe"
            },
            "arm64": {
                "url": "https://github.com/ransome1/sleek/releases/download/v$version/sleek-$version-win-arm64-Setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
