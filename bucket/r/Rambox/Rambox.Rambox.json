{
    "version": "2.7.0",
    "description": "可将网页应用整合为一体且功能丰富的工具 | Tool for organizing web apps into one application with rich features",
    "homepage": "https://rambox.app",
    "license": {
        "identifier": "Proprietary"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/ramboxapp/download/releases/download/v2.7.0/Rambox-2.7.0-win-x64.exe",
            "hash": "b7317f31d56b950d2ae9a0921e8ab913a50bb269a05a11e442aa04a9d7214293"
        }
    },
    "shortcuts": [
        [
            "app\\Rambox.exe",
            "Rambox"
        ]
    ],
    "link": "$env:AppData\\rambox",
    "cleanup": "$env:LocalAppData\\rambox-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Rambox.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ramboxapp/download/releases/download/v$version/Rambox-$version-win-x64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
