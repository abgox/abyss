{
    "version": "0.11.2",
    "description": "一款专为沉浸式深度阅读体验而设计的开源电子书阅读器 | An open-source ebook reader designed for immersive and deep reading experiences",
    "homepage": "https://readest.com/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/readest/readest/releases/download/v0.11.2/Readest_0.11.2_x64-setup.exe#/dl.7z",
            "hash": "deeb6fcc7ae21faa67486a59b72554fa47dc6619cc2b33b1f033fa9b5987218d"
        },
        "arm64": {
            "url": "https://github.com/readest/readest/releases/download/v0.11.2/Readest_0.11.2_arm64-setup.exe#/dl.7z",
            "hash": "2db7081d16ee0c4b216284d15ba82b601669488aa6dad0a6a900760ac40da168"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\readest.exe",
            "Readest"
        ]
    ],
    "link": "$env:AppData\\com.bilingify.readest",
    "cleanup": "$env:LocalAppData\\com.bilingify.readest",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/readest/readest/releases/download/v$version/Readest_$version_x64-setup.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/readest/readest/releases/download/v$version/Readest_$version_arm64-setup.exe#/dl.7z"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
