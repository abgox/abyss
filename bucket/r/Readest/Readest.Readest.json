{
    "version": "0.10.4",
    "description": "一款专为沉浸式深度阅读体验而设计的开源电子书阅读器 | An open-source ebook reader designed for immersive and deep reading experiences",
    "homepage": "https://readest.com/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/readest/readest/releases/download/v0.10.4/Readest_0.10.4_x64-setup.exe#/dl.7z",
            "hash": "c290301d4bf488bb6d13b1a697200c103761a5abc784875fe7b2eccc1b462cb5"
        },
        "arm64": {
            "url": "https://github.com/readest/readest/releases/download/v0.10.4/Readest_0.10.4_arm64-setup.exe#/dl.7z",
            "hash": "0414c149d7f846cdb0e3494d0a451193ba8157c2a18e5ef2f4826223c54203e9"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\readest.exe",
            "Readest"
        ]
    ],
    "link": "$env:AppData\\com.bilingify.readest",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Remove-TempData \"$env:LocalAppData\\com.bilingify.readest\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/readest/readest/releases/download/v$version/Readest_$version_x64-setup.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/readest/readest/releases/download/v$version/Readest_$version_arm64-setup.exe#/dl.7z"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
