{
    "version": "1.73.5",
    "description": "一个用于在不同云存储提供商之间同步文件和目录的命令行程序 | A command-line program to sync files and directories to and from different cloud storage providers",
    "homepage": "https://rclone.org/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/rclone/rclone/releases/download/v1.73.5/rclone-v1.73.5-windows-amd64.zip",
            "hash": "201567c54304935112b06dfac4ad754786287fb5acfad8889feca8d1cdeba92b",
            "extract_dir": "rclone-v1.73.5-windows-amd64"
        },
        "arm64": {
            "url": "https://github.com/rclone/rclone/releases/download/v1.73.5/rclone-v1.73.5-windows-arm64.zip",
            "hash": "8805406a984115e7cfe3b021a20a983b7060a70f198484cf373d687b6f625923",
            "extract_dir": "rclone-v1.73.5-windows-arm64"
        }
    },
    "extract_to": "app",
    "bin": "app\\rclone.exe",
    "link": "$env:AppData\\rclone",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/rclone/rclone/releases/download/v$version/rclone-v$version-windows-amd64.zip",
                "extract_dir": "rclone-v$version-windows-amd64"
            },
            "arm64": {
                "url": "https://github.com/rclone/rclone/releases/download/v$version/rclone-v$version-windows-arm64.zip",
                "extract_dir": "rclone-v$version-windows-arm64"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
