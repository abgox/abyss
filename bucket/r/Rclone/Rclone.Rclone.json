{
    "version": "1.74.4",
    "description": "一个用于在不同云存储提供商之间同步文件和目录的命令行程序 | A command-line program to sync files and directories to and from different cloud storage providers",
    "homepage": "https://rclone.org",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/rclone/rclone/releases/download/v1.74.4/rclone-v1.74.4-windows-amd64.zip",
            "hash": "ef097ef9de37a57feb7d9f9c7afb34148ad3c65be8025f1d8f7f521554a701ea",
            "extract_dir": "rclone-v1.74.4-windows-amd64"
        },
        "arm64": {
            "url": "https://github.com/rclone/rclone/releases/download/v1.74.4/rclone-v1.74.4-windows-arm64.zip",
            "hash": "72194ad0aaf210d7a55808801191fecc7e175444dab7be7491b7a63074521f3a",
            "extract_dir": "rclone-v1.74.4-windows-arm64"
        }
    },
    "extract_to": "app",
    "bin": "app\\rclone.exe",
    "link": "$env:AppData\\rclone",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/rclone/rclone/releases/download/v$version/rclone-v$version-windows-amd64.zip",
                "extract_dir": "rclone-v$version-windows-amd64"
            },
            "arm64": {
                "url": "https://github.com/rclone/rclone/releases/download/v$version/rclone-v$version-windows-arm64.zip",
                "extract_dir": "rclone-v$version-windows-arm64"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
