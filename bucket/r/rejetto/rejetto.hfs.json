{
    "version": "3.2.0",
    "description": "一个可在你的电脑上运行的网络文件服务器 | A web file server to run on your computer",
    "homepage": "https://github.com/rejetto/hfs",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/rejetto/hfs/releases/download/v3.2.0/hfs-windows-x64-3.2.0.zip",
            "hash": "d1945a7adbf2c534f5a0a990d90b2a4584962486f57854da312d5290ead1e75c"
        }
    },
    "extract_to": "app",
    "bin": [
        [
            "app\\hfs.exe",
            "hfs",
            "--cwd \"$dir\\app\\.hfs\""
        ]
    ],
    "shortcuts": [
        [
            "app\\hfs.exe",
            "HFS",
            "--cwd \"$dir\\app\\.hfs\""
        ]
    ],
    "persist": [
        [
            "app\\.hfs",
            ".hfs"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/rejetto/hfs/releases/download/v$version/hfs-windows-x64-$version.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
