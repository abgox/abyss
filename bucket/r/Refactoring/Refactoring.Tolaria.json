{
    "version": "2026.7.14",
    "description": "一款基于本地优先模式、支持 Markdown 语法的笔记应用，内置 Git 客户端并集成人工智能功能 | A local-first, Markdown-based note app with a built-in Git client and AI integration",
    "homepage": "https://tolaria.md",
    "license": {
        "identifier": "AGPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/refactoringhq/tolaria/releases/download/v2026-07-14/Tolaria_2026.7.14_x64-setup.exe",
            "hash": "84ff6acce6505a9bd106c80d88ee9543798c39193b2ba84e8f11f7bef23ec958"
        }
    },
    "shortcuts": [
        [
            "app\\Tolaria.exe",
            "Tolaria"
        ]
    ],
    "link": "$env:AppData\\com.tolaria.app",
    "cleanup": "$env:LocalAppData\\club.refactoring.tolaria",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Uninstall-App",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(\\d+)-(0)?(\\d+)-(0)?(\\d+)",
        "replace": "${1}.${3}.${5}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/refactoringhq/tolaria/releases/download/v$majorVersion-$match2$minorVersion-$match4$patchVersion/Tolaria_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
