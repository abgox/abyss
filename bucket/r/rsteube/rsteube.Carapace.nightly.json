{
    "version": "2026-03-28",
    "description": "多 shell、多命令、参数补全器 | multi-shell, multi-command, argument completer",
    "homepage": "https://carapace.sh/",
    "license": {
        "identifier": "MIT"
    },
    "notes": [
        "After installation, you need to manually register the completer according to different shells.",
        "Refer to: https://carapace-sh.github.io/carapace-bin/setup.html"
    ],
    "notes_cn": [
        "安装完成后，需要根据不同 Shell 手动注册补全器",
        "具体操作请参考：https://carapace-sh.github.io/carapace-bin/setup.html"
    ],
    "suggest": {
        "PSCompletions": "abyss/abgox.PSCompletions"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/carapace-sh/nightly/releases/download/2026-03-28/carapace-bin_1.6.4-SNAPSHOT-5f9e4c16_windows_amd64.zip",
            "hash": "09bfaeeb213e969db4faeee1e329c9be810b980a665b95915f838eb1d829c38b"
        },
        "arm64": {
            "url": "https://github.com/carapace-sh/nightly/releases/download/2026-03-28/carapace-bin_1.6.4-SNAPSHOT-5f9e4c16_windows_arm64.zip",
            "hash": "e6f7f47f4b0073917c0af3b252b33354a14f93c704239c3b3b1a8fb1f2a3c687"
        }
    },
    "conflicts": [
        "rsteube.Carapace",
        "rsteube.Carapace.nightly"
    ],
    "extract_to": "app",
    "env_set": {
        "CARAPACE_TOOLTIP": "1"
    },
    "bin": "app\\carapace.exe",
    "link": [
        "$env:AppData\\carapace",
        "$env:LocalAppData\\carapace"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/carapace-sh/nightly/releases/latest",
        "regex": "/download/([^/]+)/carapace-bin_(?<ver>[\\d.]+)-SNAPSHOT-(?<hash>[a-f0-9]+)_windows_amd64.zip"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/carapace-sh/nightly/releases/download/$version/carapace-bin_$matchVer-SNAPSHOT-$matchHash_windows_amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/carapace-sh/nightly/releases/download/$version/carapace-bin_$matchVer-SNAPSHOT-$matchHash_windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
