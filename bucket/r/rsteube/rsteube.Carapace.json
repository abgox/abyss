{
    "version": "1.6.6",
    "description": "多 shell、多命令、参数补全器 | multi-shell, multi-command, argument completer",
    "homepage": "https://carapace.sh/",
    "license": {
        "identifier": "MIT"
    },
    "notes_cn": [
        "安装完成后，需要根据不同 Shell 手动注册补全器",
        "具体操作请参考：https://carapace-sh.github.io/carapace-bin/setup.html"
    ],
    "notes": [
        "After installation, you need to manually register the completer according to different shells.",
        "Refer to: https://carapace-sh.github.io/carapace-bin/setup.html"
    ],
    "suggest": {
        "PSCompletions": "abyss/abgox.PSCompletions"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/carapace-sh/carapace-bin/releases/download/v1.6.6/carapace-bin_1.6.6_windows_amd64.zip",
            "hash": "13642a3547758d5e3fcb4518366207bbe8cf2fad009816901a55a42218d8b034"
        },
        "arm64": {
            "url": "https://github.com/carapace-sh/carapace-bin/releases/download/v1.6.6/carapace-bin_1.6.6_windows_arm64.zip",
            "hash": "59d28ddafd15e4a93a7080c0d9731f8becb0911b794619878a4e97fc0e92773d"
        }
    },
    "conflicts": [
        "rsteube.Carapace",
        "rsteube.Carapace.nightly"
    ],
    "extract_to": "app",
    "env_set": {
        "CARAPACE_TOOLTIP": "1"
    },
    "bin": "app\\carapace.exe",
    "link": [
        "$env:AppData\\carapace",
        "$env:LocalAppData\\carapace"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/carapace-sh/carapace-bin/releases/download/v$version/carapace-bin_$version_windows_amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/carapace-sh/carapace-bin/releases/download/v$version/carapace-bin_$version_windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
