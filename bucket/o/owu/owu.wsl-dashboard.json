{
    "version": "0.9.0",
    "description": "一款现代化、高性能且轻量级的 WSL 实例管理控制面板 | A modern, high-performance, and lightweight WSL instance management dashboard",
    "homepage": "https://github.com/owu/wsl-dashboard",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/owu/wsl-dashboard/releases/download/v0.9.0/WSLDashboard.0.9.0.Portable.x64.zip",
            "hash": "84817e52dbed84b9f3b30276497a2540c8183445894f9d6052f4403c683c1218"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\WSLDashboard.0.9.0.Portable.x64.exe",
            "WSL Dashboard"
        ]
    ],
    "link": "$home\\.wsldashboard",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/owu/wsl-dashboard/releases/download/v$version/WSLDashboard.$version.Portable.x64.zip"
            }
        },
        "hash": {
            "mode": "github"
        },
        "shortcuts": [
            [
                "app\\WSLDashboard.$version.Portable.x64.exe",
                "WSL Dashboard"
            ]
        ]
    }
}
