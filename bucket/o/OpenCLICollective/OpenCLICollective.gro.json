{
    "version": "1.0.47",
    "description": "一个只读的命令行界面，用于管理谷歌服务 | A read-only command-line interface for Google services",
    "homepage": "https://github.com/open-cli-collective/google-readonly",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/open-cli-collective/google-readonly/releases/download/v1.0.47/gro_v1.0.47_windows_amd64.zip",
            "hash": "f5894c169098585728c2d3a90718649fa51d61563dfb3acf9b6e9fb91f301a46"
        },
        "arm64": {
            "url": "https://github.com/open-cli-collective/google-readonly/releases/download/v1.0.47/gro_v1.0.47_windows_arm64.zip",
            "hash": "7fac3bf789990cc74a7fca989c13e33e2985394e8161923936f91da3526c4e1c"
        }
    },
    "extract_to": "app",
    "bin": "app\\gro.exe",
    "link": "$home\\.config\\google-readonly",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/open-cli-collective/google-readonly/releases/download/v$version/gro_v$version_windows_amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/open-cli-collective/google-readonly/releases/download/v$version/gro_v$version_windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
