{
    "version": "1.0.38",
    "description": "一个只读的命令行界面，用于管理谷歌服务 | A read-only command-line interface for Google services",
    "homepage": "https://github.com/open-cli-collective/google-readonly",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/open-cli-collective/google-readonly/releases/download/v1.0.38/gro_v1.0.38_windows_amd64.zip",
            "hash": "244494fbc937d7c0633e681117a5aeb72e0edc88a99b4f202239e1273d1ab181"
        },
        "arm64": {
            "url": "https://github.com/open-cli-collective/google-readonly/releases/download/v1.0.38/gro_v1.0.38_windows_arm64.zip",
            "hash": "c637136c308dced2673d9a6231838ecb13c0e01e731b87bfec4c1a8af3e8953e"
        }
    },
    "extract_to": "app",
    "bin": "app\\gro.exe",
    "link": "$home\\.config\\google-readonly",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/open-cli-collective/google-readonly/releases/download/v$version/gro_v$version_windows_amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/open-cli-collective/google-readonly/releases/download/v$version/gro_v$version_windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
