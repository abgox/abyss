{
    "version": "1.0.46",
    "description": "一个只读的命令行界面，用于管理谷歌服务 | A read-only command-line interface for Google services",
    "homepage": "https://github.com/open-cli-collective/google-readonly",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/open-cli-collective/google-readonly/releases/download/v1.0.46/gro_v1.0.46_windows_amd64.zip",
            "hash": "7ec4f1d1c4e2bc0fce628b097fc1c0a187f59d48c4504e4369d2f88aa482d190"
        },
        "arm64": {
            "url": "https://github.com/open-cli-collective/google-readonly/releases/download/v1.0.46/gro_v1.0.46_windows_arm64.zip",
            "hash": "5cfcd5cc9e473128449dce3a8eec20fd35f7e1589feb175b26910e50b8c86af7"
        }
    },
    "extract_to": "app",
    "bin": "app\\gro.exe",
    "link": "$home\\.config\\google-readonly",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/open-cli-collective/google-readonly/releases/download/v$version/gro_v$version_windows_amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/open-cli-collective/google-readonly/releases/download/v$version/gro_v$version_windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
