{
    "version": "1.0.45",
    "description": "一个只读的命令行界面，用于管理谷歌服务 | A read-only command-line interface for Google services",
    "homepage": "https://github.com/open-cli-collective/google-readonly",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/open-cli-collective/google-readonly/releases/download/v1.0.45/gro_v1.0.45_windows_amd64.zip",
            "hash": "73a4b828e9dcf609966cee645893851ce20664719d5ed1eca6afd916b8ccc53a"
        },
        "arm64": {
            "url": "https://github.com/open-cli-collective/google-readonly/releases/download/v1.0.45/gro_v1.0.45_windows_arm64.zip",
            "hash": "fac55a89aede61dccc4959c3d69c88bbb766aae1be2a57ac876ca01496808a0b"
        }
    },
    "extract_to": "app",
    "bin": "app\\gro.exe",
    "link": "$home\\.config\\google-readonly",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/open-cli-collective/google-readonly/releases/download/v$version/gro_v$version_windows_amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/open-cli-collective/google-readonly/releases/download/v$version/gro_v$version_windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
