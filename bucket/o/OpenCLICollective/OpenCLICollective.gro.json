{
    "version": "1.0.44",
    "description": "一个只读的命令行界面，用于管理谷歌服务 | A read-only command-line interface for Google services",
    "homepage": "https://github.com/open-cli-collective/google-readonly",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/open-cli-collective/google-readonly/releases/download/v1.0.44/gro_v1.0.44_windows_amd64.zip",
            "hash": "461c97415fe4b5265bc62ef38311dd1bc707e9a07723eb1ff05447e41e583741"
        },
        "arm64": {
            "url": "https://github.com/open-cli-collective/google-readonly/releases/download/v1.0.44/gro_v1.0.44_windows_arm64.zip",
            "hash": "dded6ec9dcbe368b2ca15314fa6c26b3463860dbf9a49fbfab9fecf4da3cff17"
        }
    },
    "extract_to": "app",
    "bin": "app\\gro.exe",
    "link": "$home\\.config\\google-readonly",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/open-cli-collective/google-readonly/releases/download/v$version/gro_v$version_windows_amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/open-cli-collective/google-readonly/releases/download/v$version/gro_v$version_windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
