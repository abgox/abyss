{
    "version": "0.119.0",
    "description": "一款在终端中运行的开源本地编码代理 | An open-source local coding agent that runs in your terminal",
    "homepage": "https://github.com/openai/codex",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/openai/codex/releases/download/rust-v0.119.0/codex-x86_64-pc-windows-msvc.exe.zip",
            "hash": "7c9ce120506fe8cb4f9894e6fb327f40f7099ef501ed6ff85d44b4b6464da1f0",
            "bin": [
                [
                    "app\\codex-x86_64-pc-windows-msvc.exe",
                    "codex"
                ]
            ]
        },
        "arm64": {
            "url": "https://github.com/openai/codex/releases/download/rust-v0.119.0/codex-aarch64-pc-windows-msvc.exe.zip",
            "hash": "dec74cc69f8898b9aaf9f4ff879442696e73085ed08c0230cd97246423375988",
            "bin": [
                [
                    "app\\codex-aarch64-pc-windows-msvc.exe",
                    "codex"
                ]
            ]
        }
    },
    "extract_to": "app",
    "link": "$home\\.codex",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "rust-(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/openai/codex/releases/download/rust-v$version/codex-x86_64-pc-windows-msvc.exe.zip"
            },
            "arm64": {
                "url": "https://github.com/openai/codex/releases/download/rust-v$version/codex-aarch64-pc-windows-msvc.exe.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
