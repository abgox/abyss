{
    "version": "0.121.0",
    "description": "一款在终端中运行的开源本地编码代理 | An open-source local coding agent that runs in your terminal",
    "homepage": "https://github.com/openai/codex",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/openai/codex/releases/download/rust-v0.121.0/codex-x86_64-pc-windows-msvc.exe.zip",
            "hash": "d5d8e00b684650bcfaf7166331040267ec6284f61867442300fa3d8d0e59594b",
            "bin": [
                [
                    "app\\codex-x86_64-pc-windows-msvc.exe",
                    "codex"
                ]
            ]
        },
        "arm64": {
            "url": "https://github.com/openai/codex/releases/download/rust-v0.121.0/codex-aarch64-pc-windows-msvc.exe.zip",
            "hash": "cafa53f5a2e9a5dae78e1b8affab134d99630fa914728a49a0a409e4edc4d0dc",
            "bin": [
                [
                    "app\\codex-aarch64-pc-windows-msvc.exe",
                    "codex"
                ]
            ]
        }
    },
    "extract_to": "app",
    "link": "$home\\.codex",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "rust-(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/openai/codex/releases/download/rust-v$version/codex-x86_64-pc-windows-msvc.exe.zip"
            },
            "arm64": {
                "url": "https://github.com/openai/codex/releases/download/rust-v$version/codex-aarch64-pc-windows-msvc.exe.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
