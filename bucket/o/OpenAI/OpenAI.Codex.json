    "homepage": "https://github.com/openai/codex",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/openai/codex/releases/download/rust-v0.107.0/codex-x86_64-pc-windows-msvc.exe.zip",
            "hash": "0bacdcb1d83405ca6cd1263a0140cda59fe56075145aa0559e382762643f95cf",
            "bin": [
                [
                    "app\\codex-x86_64-pc-windows-msvc.exe",
                    "codex"
                ]
            ]
        },
        "arm64": {
            "url": "https://github.com/openai/codex/releases/download/rust-v0.107.0/codex-aarch64-pc-windows-msvc.exe.zip",
            "hash": "41ee5e043a15bc63c2b6b6e8463fc3fd4f4ff88b9c3fe681bebd75e9212dff63",
            "bin": [
                [
                    "app\\codex-aarch64-pc-windows-msvc.exe",
                    "codex"
                ]
            ]
        }
    },
    "extract_to": "app",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "rust-(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/openai/codex/releases/download/rust-v$version/codex-x86_64-pc-windows-msvc.exe.zip"
            },
            "arm64": {
                "url": "https://github.com/openai/codex/releases/download/rust-v$version/codex-aarch64-pc-windows-msvc.exe.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
