{
    "version": "0.130.0",
    "description": "一款在终端中运行的开源本地编码代理 | An open-source local coding agent that runs in your terminal",
    "homepage": "https://github.com/openai/codex",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/openai/codex/releases/download/rust-v0.130.0/codex-x86_64-pc-windows-msvc.exe.zip",
            "hash": "1aa3b56bcc825c0425185c5a7c17166cd9d56de673def0b93d48815c867d6356",
            "bin": [
                [
                    "app\\codex-x86_64-pc-windows-msvc.exe",
                    "codex"
                ]
            ]
        },
        "arm64": {
            "url": "https://github.com/openai/codex/releases/download/rust-v0.130.0/codex-aarch64-pc-windows-msvc.exe.zip",
            "hash": "ff9f1c730c33b01aad46b3d02a0d5c699e6af35828cd54cbd24e7132a6c8e6d0",
            "bin": [
                [
                    "app\\codex-aarch64-pc-windows-msvc.exe",
                    "codex"
                ]
            ]
        }
    },
    "extract_to": "app",
    "link": "$home\\.codex",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "rust-(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/openai/codex/releases/download/rust-v$version/codex-x86_64-pc-windows-msvc.exe.zip"
            },
            "arm64": {
                "url": "https://github.com/openai/codex/releases/download/rust-v$version/codex-aarch64-pc-windows-msvc.exe.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
