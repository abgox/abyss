{
    "version": "0.132.0",
    "description": "一款在终端中运行的开源本地编码代理 | An open-source local coding agent that runs in your terminal",
    "homepage": "https://github.com/openai/codex",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/openai/codex/releases/download/rust-v0.132.0/codex-x86_64-pc-windows-msvc.exe.zip",
            "hash": "6bcd3b4051b4d05b3e07d039234d3b86b343d0b3322e36367e6ca39c3e106024",
            "bin": [
                [
                    "app\\codex-x86_64-pc-windows-msvc.exe",
                    "codex"
                ]
            ]
        },
        "arm64": {
            "url": "https://github.com/openai/codex/releases/download/rust-v0.132.0/codex-aarch64-pc-windows-msvc.exe.zip",
            "hash": "c15bef2b184f3ac1d6cdfbdb8e875e9598d0fcda5a9b662be7aaf3b84ae86008",
            "bin": [
                [
                    "app\\codex-aarch64-pc-windows-msvc.exe",
                    "codex"
                ]
            ]
        }
    },
    "extract_to": "app",
    "link": "$home\\.codex",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "rust-(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/openai/codex/releases/download/rust-v$version/codex-x86_64-pc-windows-msvc.exe.zip"
            },
            "arm64": {
                "url": "https://github.com/openai/codex/releases/download/rust-v$version/codex-aarch64-pc-windows-msvc.exe.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
