{
    "version": "5.4.4",
    "description": "集找番、追番、看番的一站式弹幕追番平台 | An all-in-one bullet-screen anime platform for finding, following, and watching anime",
    "homepage": "https://animeko.org/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/open-ani/animeko/releases/download/v5.4.4/ani-5.4.4-windows-x86_64.zip",
            "hash": "cc10818cf7a71e9fb89a048f4093cd442963f0ca6b7ac4e9d46e381970a9dcf4"
        }
    },
    "extract_dir": "Ani",
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\Ani.exe",
            "Animeko"
        ]
    ],
    "link": "$env:AppData\\Him188\\Ani",
    "cleanup": "$env:LocalAppData\\Him188\\Ani",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/open-ani/animeko/releases/download/v$version/ani-$version-windows-x86_64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
