{
    "version": "5.7.1",
    "description": "集找番、追番、看番的一站式弹幕追番平台 | An all-in-one bullet-screen anime platform for finding, following, and watching anime",
    "homepage": "https://animeko.org",
    "license": {
        "identifier": "AGPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/open-ani/animeko/releases/download/v5.7.1/ani-5.7.1-windows-x86_64.zip",
            "hash": "3d32c84155315ff52fa1ec647e9c3ec56acf2bcef0cd48b074e9056cb908d83a"
        }
    },
    "extract_dir": "Ani",
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\Ani.exe",
            "Animeko"
        ]
    ],
    "link": "$env:AppData\\Him188\\Ani",
    "cleanup": "$env:LocalAppData\\Him188\\Ani",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/open-ani/animeko/releases/download/v$version/ani-$version-windows-x86_64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
