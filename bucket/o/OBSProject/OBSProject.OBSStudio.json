{
    "version": "32.2.0",
    "description": "用于视频录制和直播的免费开源软件 | Free and open source software for video recording and live streaming",
    "homepage": "https://obsproject.com",
    "license": {
        "identifier": "GPL-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/obsproject/obs-studio/releases/download/32.2.0/OBS-Studio-32.2.0-Windows-x64.zip",
            "hash": "793c8866796f94b907646c63ac73b9d0df7e98dcdab5b6bfd5baebf153e1ed92"
        },
        "arm64": {
            "url": "https://github.com/obsproject/obs-studio/releases/download/32.2.0/OBS-Studio-32.2.0-Windows-arm64.zip",
            "hash": "5c819148cf916d8621449633f55fa8b80eaf7d51bd5d5afa984d509105484047"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\bin\\64bit\\obs64.exe",
            "OBS Studio"
        ]
    ],
    "link": "$env:AppData\\obs-studio",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/obsproject/obs-studio/releases/download/$version/OBS-Studio-$version-Windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/obsproject/obs-studio/releases/download/$version/OBS-Studio-$version-Windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
