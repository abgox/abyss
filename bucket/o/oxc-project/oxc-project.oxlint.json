{
    "version": "1.74.0",
    "description": "一款高性能 JavaScript 和 TypeScript 代码检查工具 | A high-performance linter for JavaScript and TypeScript",
    "homepage": "https://oxc.rs/docs/guide/usage/linter.html",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/oxc-project/oxc/releases/download/apps_v1.74.0/oxlint-x86_64-pc-windows-msvc.zip",
            "hash": "8de55c7444f8ce53dd7e92e48c83e18c0b2fe5d680179c0daf0fa2eb24048613",
            "bin": [
                [
                    "app\\oxlint-x86_64-pc-windows-msvc.exe",
                    "oxlint"
                ]
            ]
        },
        "arm64": {
            "url": "https://github.com/oxc-project/oxc/releases/download/apps_v1.74.0/oxlint-aarch64-pc-windows-msvc.zip",
            "hash": "c3fe9be0265d52defc5c7f71437233d79d42a9eb9ac5f7fb44a09d6b8d9dc219",
            "bin": [
                [
                    "app\\oxlint-aarch64-pc-windows-msvc.exe",
                    "oxlint"
                ]
            ]
        }
    },
    "extract_to": "app",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "apps_(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/oxc-project/oxc/releases/download/apps_v$version/oxlint-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/oxc-project/oxc/releases/download/apps_v$version/oxlint-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
