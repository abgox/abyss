{
    "version": "1.65.0",
    "description": "一个与 Prettier 兼容的代码格式化工具 | A Prettier-compatible code formatter",
    "homepage": "https://oxc.rs/docs/guide/usage/formatter.html",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/oxc-project/oxc/releases/download/apps_v1.65.0/oxfmt-x86_64-pc-windows-msvc.zip",
            "hash": "bbb15c7986172f68e94b8316872c9bcf21049dbf1fea01ba94924cfb5f9850b2",
            "bin": [
                [
                    "app\\oxfmt-x86_64-pc-windows-msvc.exe",
                    "oxfmt"
                ]
            ]
        },
        "arm64": {
            "url": "https://github.com/oxc-project/oxc/releases/download/apps_v1.65.0/oxfmt-aarch64-pc-windows-msvc.zip",
            "hash": "818413044b0010f0ad61bc568ddbbcdc48af06f8b83b1495fb74d793233d0f12",
            "bin": [
                [
                    "app\\oxfmt-aarch64-pc-windows-msvc.exe",
                    "oxfmt"
                ]
            ]
        }
    },
    "extract_to": "app",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "apps_(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/oxc-project/oxc/releases/download/apps_v$version/oxfmt-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/oxc-project/oxc/releases/download/apps_v$version/oxfmt-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
