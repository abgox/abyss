{
    "version": "1.58.0",
    "description": "一个与 Prettier 兼容的代码格式化工具 | A Prettier-compatible code formatter",
    "homepage": "https://oxc.rs/docs/guide/usage/formatter.html",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/oxc-project/oxc/releases/download/apps_v1.58.0/oxfmt-x86_64-pc-windows-msvc.zip",
            "hash": "a99d2f6a076a8955a2014f8a3dad16146d4c67fdbd44a886091ed3891a384341",
            "bin": [
                [
                    "app\\oxfmt-x86_64-pc-windows-msvc.exe",
                    "oxfmt"
                ]
            ]
        },
        "arm64": {
            "url": "https://github.com/oxc-project/oxc/releases/download/apps_v1.58.0/oxfmt-aarch64-pc-windows-msvc.zip",
            "hash": "aafcd89f355be7f577b269cfb4c23fc9be74963e5ad181476ea0cf9b8d27a173",
            "bin": [
                [
                    "app\\oxfmt-aarch64-pc-windows-msvc.exe",
                    "oxfmt"
                ]
            ]
        }
    },
    "extract_to": "app",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "apps_(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/oxc-project/oxc/releases/download/apps_v$version/oxfmt-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/oxc-project/oxc/releases/download/apps_v$version/oxfmt-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
