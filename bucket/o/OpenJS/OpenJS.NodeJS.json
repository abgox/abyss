{
    "version": "25.9.0",
    "description": "一个免费、开源、跨平台的 JavaScript 运行时环境 | A free, open-source, cross-platform JavaScript runtime environment",
    "homepage": "https://nodejs.org/",
    "license": {
        "identifier": "Freeware"
    },
    "notes": "If you install multiple versions of OpenJS.NodeJS, they will overwrite each other, keeping only the highest version.",
    "notes_cn": "如果同时安装 OpenJS.NodeJS 的多个版本，会相互覆盖，仅保留最高版本",
    "architecture": {
        "64bit": {
            "url": "https://nodejs.org/dist/v25.9.0/node-v25.9.0-x64.msi#/dl.msi_",
            "hash": "e469104e5d0c99f9185fbf17179fbb1d732261e6e1f9d281b6b2308a0126fb6d"
        },
        "arm64": {
            "url": "https://nodejs.org/dist/v25.9.0/node-v25.9.0-arm64.msi#/dl.msi_",
            "hash": "2e95e8cd93bd4ce3336db9afad95d482bb2b29a74300f2a45223412508ece63f"
        }
    },
    "location": "$env:ProgramFiles\\nodejs",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Require-Admin",
        "A-Install-Msi"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Require-Admin",
        "A-Uninstall-Msi"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://github.com/nodejs/node",
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://nodejs.org/dist/v$version/node-v$version-x64.msi#/dl.msi_"
            },
            "arm64": {
                "url": "https://nodejs.org/dist/v$version/node-v$version-arm64.msi#/dl.msi_"
            }
        }
    }
}
