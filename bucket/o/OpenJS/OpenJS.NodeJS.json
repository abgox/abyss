{
    "version": "24.16.0",
    "description": "一个免费、开源、跨平台的 JavaScript 运行时环境 | A free, open-source, cross-platform JavaScript runtime environment",
    "homepage": "https://nodejs.org/",
    "license": {
        "identifier": "Freeware"
    },
    "notes_cn": "如果同时安装 OpenJS.NodeJS 的多个版本，会相互覆盖，仅保留最高版本",
    "notes": "If you install multiple versions of OpenJS.NodeJS, they will overwrite each other, keeping only the highest version.",
    "architecture": {
        "64bit": {
            "url": "https://nodejs.org/dist/v24.16.0/node-v24.16.0-x64.msi#/dl.msi_",
            "hash": "43749d78a28ff11a36cb279407bc13e79bcfb8670e7926e469018d31c2ec6453"
        },
        "arm64": {
            "url": "https://nodejs.org/dist/v24.16.0/node-v24.16.0-arm64.msi#/dl.msi_",
            "hash": "beac2056574ebc523d5feaad7cdc434cb1d752eba076db7ebb4b62bc13ec70b9"
        }
    },
    "location": "$env:ProgramFiles\\nodejs",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Msi"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Uninstall-Msi"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://github.com/nodejs/node",
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://nodejs.org/dist/v$version/node-v$version-x64.msi#/dl.msi_"
            },
            "arm64": {
                "url": "https://nodejs.org/dist/v$version/node-v$version-arm64.msi#/dl.msi_"
            }
        }
    }
}
