{
    "version": "24.14.1",
    "description": "一个免费、开源、跨平台的 JavaScript 运行时环境 | A free, open-source, cross-platform JavaScript runtime environment",
    "homepage": "https://nodejs.org/",
    "license": {
        "identifier": "Freeware"
    },
    "notes": "If you install multiple versions of OpenJS.NodeJS, they will overwrite each other, keeping only the highest version.",
    "notes_cn": "如果同时安装 OpenJS.NodeJS 的多个版本，会相互覆盖，仅保留最高版本",
    "architecture": {
        "64bit": {
            "url": "https://nodejs.org/dist/v24.14.1/node-v24.14.1-x64.msi#/dl.msi_",
            "hash": "fd8ba3e8262738959cad50e6f6e71d689eab7dd09fc7231b51d78abe7852d4ec"
        },
        "arm64": {
            "url": "https://nodejs.org/dist/v24.14.1/node-v24.14.1-arm64.msi#/dl.msi_",
            "hash": "4013ca42741ae0fd599d432985834d0ad4f565b1e4c59f8975d561f105f4af5c"
        }
    },
    "location": "$env:ProgramFiles\\nodejs",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Require-Admin",
        "A-Install-Msi"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Require-Admin",
        "A-Uninstall-Msi"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://nodejs.org/dist/index.json",
        "jsonpath": "$..[?(@.lts != false)].version",
        "regex": "v([\\d.]+).*"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://nodejs.org/dist/v$version/node-v$version-x64.msi#/dl.msi_"
            },
            "arm64": {
                "url": "https://nodejs.org/dist/v$version/node-v$version-arm64.msi#/dl.msi_"
            }
        }
    }
}
