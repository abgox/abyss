{
    "version": "0.21.0",
    "description": "一款适用于在现有工作流程基础上处理同步分支的 Git 客户端 | A Git client for simultaneous branches on top of your existing workflow",
    "homepage": "https://gitbutler.com",
    "license": {
        "identifier": "FSL-1.1-MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://releases.gitbutler.com/releases/release/0.21.0-3133/windows/x86_64/GitButler_0.21.0_x64_en-US.msi#/dl.msi_",
            "hash": "33e5c8aadc96c1e8f626966f2a4522c49b6e56b71045d64dafa37c048db9e800"
        }
    },
    "location": "$env:ProgramFiles\\GitButler",
    "link": [
        "$env:AppData\\com.gitbutler.app",
        "$env:AppData\\gitbutler"
    ],
    "cleanup": "$env:LocalAppData\\com.gitbutler.app",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Msi"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Msi"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'GitButler.GitButler' 'msi'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64#/dl.msi_",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_machine.InstallerSha256"
                }
            }
        }
    }
}
