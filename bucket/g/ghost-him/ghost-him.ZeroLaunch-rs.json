{
    "version": "0.6.12",
    "description": "一款极速、隐私优先的 Windows 智能启动器，精通拼音与模糊匹配；可选本地 AI 语义检索，让错字与意图搜索也能秒速直达 | A Windows smart launcher that understands your typing. It excels at Pinyin and fuzzy matching, and can optionally add AI semantic understanding—so typos and vague queries still get instant results",
    "homepage": "https://zerolaunch.ghost-him.com/",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/ghost-him/ZeroLaunch-rs/releases/download/v0.6.12/zerolaunch-rs_0.6.12_x64-setup.exe",
            "hash": "b01ecf906fbeb2453cc207d8d07190f9f6944ba1ec9ec440fd1df042e6333273"
        },
        "arm64": {
            "url": "https://github.com/ghost-him/ZeroLaunch-rs/releases/download/v0.6.12/zerolaunch-rs_0.6.12_arm64-setup.exe",
            "hash": "910410d7b6d9b617ede57af263bb2963f320083ddb4ad908daac971fcd273ef3"
        }
    },
    "shortcuts": [
        [
            "app\\zerolaunch-rs.exe",
            "zerolaunch-rs"
        ]
    ],
    "link": "$env:AppData\\ZeroLaunch-rs",
    "cleanup": "$env:LocalAppData\\com.zerolaunch-rs.app",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ghost-him/ZeroLaunch-rs/releases/download/v$version/zerolaunch-rs_$version_x64-setup.exe"
            },
            "arm64": {
                "url": "https://github.com/ghost-him/ZeroLaunch-rs/releases/download/v$version/zerolaunch-rs_$version_arm64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
