{
    "version": "7.2.0.92",
    "description": "一个用于管理 Git 仓库的独立用户界面工具 | A standalone UI tool for managing git repositories",
    "homepage": "https://gitextensions.github.io",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/gitextensions/gitextensions/releases/download/v7.2.0/GitExtensions-Portable-x64-7.2.0.92-501f831.zip",
            "hash": "ac192d72434ed315e7bb34305ddcf4987527e69bb8bc4d0fe1b858e001ae142c"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\GitExtensions.exe",
            "GitExtensions"
        ]
    ],
    "persist": [
        [
            "app\\GitExtensions.settings",
            "AppData\\Roaming\\GitExtensions\\GitExtensions\\GitExtensions.settings"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://api.github.com/repositories/85953/releases",
        "jsonpath": "$..browser_download_url",
        "regex": "/v(?<tag>[\\d.]+)/GitExtensions-Portable-(?:x[\\d.]+)-(?<version>[\\d.]+)-(?<commit>[\\w]+).zip"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/gitextensions/gitextensions/releases/download/v$matchTag/GitExtensions-Portable-x64-$version-$matchCommit.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
