{
    "version": "4.8.1",
    "description": "终端中的网易云音乐播放器 | A netease music player in terminal",
    "homepage": "https://github.com/go-musicfox/go-musicfox",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/go-musicfox/go-musicfox/releases/download/v4.8.1/go-musicfox_4.8.1_windows_amd64.zip",
            "hash": "fd7f9403edf9a378a164a4ac8d1fc25e57deebf20ff405ff8d5946cdf15cf784",
            "extract_dir": "go-musicfox_4.8.1_windows_amd64"
        },
        "arm64": {
            "url": "https://github.com/go-musicfox/go-musicfox/releases/download/v4.8.1/go-musicfox_4.8.1_windows_arm64.zip",
            "hash": "77330704d9633bf7abb98711cb4083b1daabbcc0154f3654bd40fa4029104275",
            "extract_dir": "go-musicfox_4.8.1_windows_arm64"
        }
    },
    "extract_to": "app",
    "env_set": {
        "MUSICFOX_ROOT": "$persist_dir\\AppData\\Roaming\\go-musicfox"
    },
    "bin": "app\\musicfox.exe",
    "link": "$env:AppData\\go-musicfox",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/go-musicfox/go-musicfox/releases/download/v$version/go-musicfox_$version_windows_amd64.zip",
                "extract_dir": "go-musicfox_$version_windows_amd64"
            },
            "arm64": {
                "url": "https://github.com/go-musicfox/go-musicfox/releases/download/v$version/go-musicfox_$version_windows_arm64.zip",
                "extract_dir": "go-musicfox_$version_windows_arm64"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
