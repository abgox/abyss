{
    "version": "1.0.58",
    "description": "GitHub Copilot CLI 将 Copilot 编码代理的强大功能直接带到你的终端 | GitHub Copilot CLI brings the power of Copilot coding agent directly to your terminal",
    "homepage": "https://github.com/github/copilot-cli",
    "license": {
        "identifier": "Proprietary"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/github/copilot-cli/releases/download/v1.0.58/copilot-win32-x64.zip",
            "hash": "b69a4caf1f645ffb5fa309f9ea4534dee001323bdc2a13b352b044f6f036d946"
        },
        "arm64": {
            "url": "https://github.com/github/copilot-cli/releases/download/v1.0.58/copilot-win32-arm64.zip",
            "hash": "5ff55f81ba4b82a2f7a3524a589144fcb3efe00c78ad5f5897446d12f96289f6"
        }
    },
    "extract_to": "app",
    "bin": "app\\copilot.exe",
    "link": "$home\\.copilot",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/github/copilot-cli/releases/download/v$version/copilot-win32-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/github/copilot-cli/releases/download/v$version/copilot-win32-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
