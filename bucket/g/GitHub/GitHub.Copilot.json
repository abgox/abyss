{
    "version": "1.0.13",
    "description": "GitHub Copilot CLI 将 Copilot 编码代理的强大功能直接带到你的终端 | GitHub Copilot CLI brings the power of Copilot coding agent directly to your terminal",
    "homepage": "https://github.com/github/copilot-cli",
    "license": {
        "identifier": "Proprietary"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/github/copilot-cli/releases/download/v1.0.13/copilot-win32-x64.zip",
            "hash": "ea610fca685fcce58727f02721ac96aef981d89d9c50527c021455074cf4a087"
        },
        "arm64": {
            "url": "https://github.com/github/copilot-cli/releases/download/v1.0.13/copilot-win32-arm64.zip",
            "hash": "63169c63ec327aee6f7b08a56e226bc8b400a1181195ff855e0380639b25576b"
        }
    },
    "extract_to": "app",
    "bin": "app\\copilot.exe",
    "link": "$home\\.copilot",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/github/copilot-cli/releases/download/v$version/copilot-win32-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/github/copilot-cli/releases/download/v$version/copilot-win32-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
