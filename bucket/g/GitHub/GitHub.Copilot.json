{
    "version": "1.0.33",
    "description": "GitHub Copilot CLI 将 Copilot 编码代理的强大功能直接带到你的终端 | GitHub Copilot CLI brings the power of Copilot coding agent directly to your terminal",
    "homepage": "https://github.com/github/copilot-cli",
    "license": {
        "identifier": "Proprietary"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/github/copilot-cli/releases/download/v1.0.33/copilot-win32-x64.zip",
            "hash": "4dad9297788726c10445b85fdae2398f46bea3c2837cf58ee48ac1feba477f94"
        },
        "arm64": {
            "url": "https://github.com/github/copilot-cli/releases/download/v1.0.33/copilot-win32-arm64.zip",
            "hash": "ad32c3f2de3b8a357a83365c7f2e4bb0ff46bf26ac936eb1ba89803c3fc9a9e5"
        }
    },
    "extract_to": "app",
    "bin": "app\\copilot.exe",
    "link": "$home\\.copilot",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/github/copilot-cli/releases/download/v$version/copilot-win32-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/github/copilot-cli/releases/download/v$version/copilot-win32-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
