{
    "version": "1.0.18",
    "description": "GitHub Copilot CLI 将 Copilot 编码代理的强大功能直接带到你的终端 | GitHub Copilot CLI brings the power of Copilot coding agent directly to your terminal",
    "homepage": "https://github.com/github/copilot-cli",
    "license": {
        "identifier": "Proprietary"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/github/copilot-cli/releases/download/v1.0.18/copilot-win32-x64.zip",
            "hash": "5e1f5a19e00a10ccb341c5b05f3aca67fb77c2f178c5531cf3d3fa36b64e6ef3"
        },
        "arm64": {
            "url": "https://github.com/github/copilot-cli/releases/download/v1.0.18/copilot-win32-arm64.zip",
            "hash": "65698192376073a925f98feafcb89f57c035b75a37ded6861c45bf901955379a"
        }
    },
    "extract_to": "app",
    "bin": "app\\copilot.exe",
    "link": "$home\\.copilot",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/github/copilot-cli/releases/download/v$version/copilot-win32-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/github/copilot-cli/releases/download/v$version/copilot-win32-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
