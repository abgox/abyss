{
    "version": "1.0.71",
    "description": "GitHub Copilot CLI 将 Copilot 编码代理的强大功能直接带到你的终端 | GitHub Copilot CLI brings the power of Copilot coding agent directly to your terminal",
    "homepage": "https://github.com/github/copilot-cli",
    "license": {
        "identifier": "Proprietary"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/github/copilot-cli/releases/download/v1.0.71/copilot-win32-x64.zip",
            "hash": "e4642b2efce3649c49849fde30307242f9a2475133533294a55b881187818471"
        },
        "arm64": {
            "url": "https://github.com/github/copilot-cli/releases/download/v1.0.71/copilot-win32-arm64.zip",
            "hash": "8bf99ff1aed1e8f2efa12140595231fad12bec806d65302fcbf8df108ff22aac"
        }
    },
    "extract_to": "app",
    "bin": "app\\copilot.exe",
    "link": "$home\\.copilot",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/github/copilot-cli/releases/download/v$version/copilot-win32-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/github/copilot-cli/releases/download/v$version/copilot-win32-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
