{
    "version": "2.90.0",
    "description": "gh - GitHub 的官方命令行工具 | gh - GitHub's official command line tool",
    "homepage": "https://cli.github.com/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/cli/cli/releases/download/v2.90.0/gh_2.90.0_windows_amd64.zip",
            "hash": "73fcae688eb64ae67828536c9be90db1e5be3f11691a6fa1c1e5418fd24ee10b"
        },
        "arm64": {
            "url": "https://github.com/cli/cli/releases/download/v2.90.0/gh_2.90.0_windows_arm64.zip",
            "hash": "6c962692ee8285f5b2336455cbe08695ae340dcf433b4b13d8d3d534ebee8ffe"
        }
    },
    "extract_to": "app",
    "bin": "app\\bin\\gh.exe",
    "link": "$env:AppData\\GitHub CLI",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/cli/cli/releases/download/v$version/gh_$version_windows_amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/cli/cli/releases/download/v$version/gh_$version_windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
