{
    "version": "1.0.26",
    "description": "一款面向智能体驱动开发的桌面应用，将并行工作流、GitHub 集成以及拉取请求全生命周期管理整合至同一平台 | A desktop application for agent-driven development that brings parallel workstreams, GitHub integration, and PR lifecycle management into one place",
    "homepage": "https://github.com/github/app",
    "license": {
        "identifier": "Proprietary"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/github/app/releases/download/v1.0.26/GitHub-Copilot-windows-x64-setup.exe",
            "hash": "8ec16a32452cca60a651d59b76e76131efbd69e4efbae01f8fc05036fb827c2b"
        },
        "arm64": {
            "url": "https://github.com/github/app/releases/download/v1.0.26/GitHub-Copilot-windows-arm64-setup.exe",
            "hash": "d0fe46a47607c8376d6197a349f5b655bfd404df9d99801283cdd379a383f1a0"
        }
    },
    "shortcuts": [
        [
            "app\\github.exe",
            "GitHub Copilot"
        ]
    ],
    "link": "$env:AppData\\com.github.githubapp",
    "cleanup": [
        "$env:LocalAppData\\com.github.githubapp",
        "$env:LocalAppData\\github-copilot-sdk"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/github/app/releases/download/v$version/GitHub-Copilot-windows-x64-setup.exe"
            },
            "arm64": {
                "url": "https://github.com/github/app/releases/download/v$version/GitHub-Copilot-windows-arm64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
