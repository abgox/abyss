{
    "version": "7.0.0",
    "description": "菜单栏上的 GitHub 通知 | GitHub notifications on your menu bar",
    "homepage": "https://gitify.io",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/gitify-app/gitify/releases/download/v7.0.0/Gitify-Setup-7.0.0.exe",
            "hash": "d0007eb10407f30eda885495cf7ca0900f04c6a5137dea1daa0c1e96033905a7"
        }
    },
    "shortcuts": [
        [
            "app\\Gitify.exe",
            "Gitify"
        ]
    ],
    "link": "$env:AppData\\gitify",
    "cleanup": "$env:LocalAppData\\gitify-updater",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Gitify.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/gitify-app/gitify/releases/download/v$version/Gitify-Setup-$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
