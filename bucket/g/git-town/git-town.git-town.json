{
    "version": "23.0.1",
    "description": "一款 Git 插件，可新增 Git 命令，让协作软件开发更高效、更安全 | Git plugin that adds Git commands that make collaborative software development more efficient and safe",
    "homepage": "https://www.git-town.com/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/git-town/git-town/releases/download/v23.0.1/git-town_windows_intel_64.zip",
            "hash": "7af10bbc8af7e1d6043df6c07a39cc7da6037c566dd667bdadf24e6a282a1fb9"
        },
        "arm64": {
            "url": "https://github.com/git-town/git-town/releases/download/v23.0.1/git-town_windows_arm_64.zip",
            "hash": "4f8109f5b05676030ea20196df31743703dbd993efcf6356e6b77a789b2b503c"
        }
    },
    "extract_to": "app",
    "bin": "app\\git-town.exe",
    "link": "$env:AppData\\git-town",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/git-town/git-town/releases/download/v$version/git-town_windows_intel_64.zip"
            },
            "arm64": {
                "url": "https://github.com/git-town/git-town/releases/download/v$version/git-town_windows_arm_64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
