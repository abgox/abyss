{
    "version": "24.0.0",
    "description": "一款 Git 插件，可新增 Git 命令，让协作软件开发更高效、更安全 | Git plugin that adds Git commands that make collaborative software development more efficient and safe",
    "homepage": "https://www.git-town.com",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/git-town/git-town/releases/download/v24.0.0/git-town_windows_intel_64.zip",
            "hash": "f0feb3438beafef454a3abe21d71303db2d712e5bc823a752e715f83b822267b"
        },
        "arm64": {
            "url": "https://github.com/git-town/git-town/releases/download/v24.0.0/git-town_windows_arm_64.zip",
            "hash": "9e711e47a798eca69cd53a9921f8afb64f100c41852b3c063ec527de752b3c11"
        }
    },
    "extract_to": "app",
    "bin": "app\\git-town.exe",
    "link": "$env:AppData\\git-town",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/git-town/git-town/releases/download/v$version/git-town_windows_intel_64.zip"
            },
            "arm64": {
                "url": "https://github.com/git-town/git-town/releases/download/v$version/git-town_windows_arm_64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
