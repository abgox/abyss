{
    "version": "23.0.0",
    "description": "一款 Git 插件，可新增 Git 命令，让协作软件开发更高效、更安全 | Git plugin that adds Git commands that make collaborative software development more efficient and safe",
    "homepage": "https://www.git-town.com/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/git-town/git-town/releases/download/v23.0.0/git-town_windows_intel_64.zip",
            "hash": "145719bef6f924ce6f1c6ed9bea4b867f91abc92acd80339a0addcb199de89de"
        },
        "arm64": {
            "url": "https://github.com/git-town/git-town/releases/download/v23.0.0/git-town_windows_arm_64.zip",
            "hash": "ce278f46ba8db6a288f853f488d340840d76a4da15745044aa6c786337b9a5e7"
        }
    },
    "extract_to": "app",
    "bin": "app\\git-town.exe",
    "link": "$env:AppData\\git-town",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/git-town/git-town/releases/download/v$version/git-town_windows_intel_64.zip"
            },
            "arm64": {
                "url": "https://github.com/git-town/git-town/releases/download/v$version/git-town_windows_arm_64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
