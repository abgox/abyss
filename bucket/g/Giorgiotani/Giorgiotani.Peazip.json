{
    "version": "11.0.0",
    "description": "一款免费的文件归档工具和 rar 解压缩器 | A free file archiver utility and rar extractor",
    "homepage": "https://peazip.github.io/",
    "license": {
        "identifier": "LGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/peazip/PeaZip/releases/download/11.0.0/peazip-11.0.0.WIN64.exe",
            "hash": "d772318671dadc45c85ec66b2542b97a03971d9e8b8ce8aa47df9e99cacbdf63"
        }
    },
    "bin": "app\\peazip.exe",
    "shortcuts": [
        [
            "app\\peazip.exe",
            "PeaZip"
        ]
    ],
    "link": "$env:AppData\\PeaZip",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/peazip/PeaZip/releases/download/$version/peazip-$version.WIN64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
