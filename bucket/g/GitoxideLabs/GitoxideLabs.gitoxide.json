            "hash": "b5a32153c94e5894930ae8f53f5e3b1547acf9c27292c191d4a5b7f837005bd2",
            "extract_dir": "gitoxide-max-v0.56.0-aarch64-pc-windows-msvc"
        }
    },
    "extract_to": "app",
    "bin": [
        "app\\gix.exe",
        "app\\ein.exe"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/GitoxideLabs/gitoxide/releases/download/v$version/gitoxide-max-v$version-x86_64-pc-windows-msvc.zip",
                "extract_dir": "gitoxide-max-v$version-x86_64-pc-windows-msvc"
            },
            "arm64": {
                "url": "https://github.com/GitoxideLabs/gitoxide/releases/download/v$version/gitoxide-max-v$version-aarch64-pc-windows-msvc.zip",
                "extract_dir": "gitoxide-max-v$version-aarch64-pc-windows-msvc"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
