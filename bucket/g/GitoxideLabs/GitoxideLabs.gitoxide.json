    "license": {
        "identifier": "Apache-2.0|MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/GitoxideLabs/gitoxide/releases/download/v0.56.0/gitoxide-max-v0.56.0-x86_64-pc-windows-msvc.zip",
            "hash": "dcf4dd4f850637604b1ff5ada804a0750670733ea906e915c5a6e2f1bd7a8aa3",
            "extract_dir": "gitoxide-max-v0.56.0-x86_64-pc-windows-msvc"
