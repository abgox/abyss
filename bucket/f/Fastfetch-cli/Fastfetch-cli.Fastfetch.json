{
    "version": "2.63.0",
    "description": "一款持续维护、功能丰富且注重性能、类 neofetch 的系统信息查看工具 | A maintained, feature-rich and performance oriented, neofetch like system information tool",
    "homepage": "https://github.com/fastfetch-cli/fastfetch",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/2.63.0/fastfetch-windows-amd64.7z",
            "hash": "e104fee770247e3a5814294acb3c92da2c4c04e5cb889dfa3bef54670c990f84"
        },
        "arm64": {
            "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/2.63.0/fastfetch-windows-aarch64.7z",
            "hash": "3530bb597531ff10c4436ea512f5293ceaa92ae0f189de392659d11c9cbdc6d7"
        }
    },
    "extract_to": "app",
    "bin": [
        "app\\fastfetch.exe",
        "app\\flashfetch.exe"
    ],
    "link": "$home\\.config\\fastfetch",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/$version/fastfetch-windows-amd64.7z"
            },
            "arm64": {
                "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/$version/fastfetch-windows-aarch64.7z"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
