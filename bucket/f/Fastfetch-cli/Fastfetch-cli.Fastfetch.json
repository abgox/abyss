{
    "version": "2.63.1",
    "description": "一款持续维护、功能丰富且注重性能、类 neofetch 的系统信息查看工具 | A maintained, feature-rich and performance oriented, neofetch like system information tool",
    "homepage": "https://github.com/fastfetch-cli/fastfetch",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/2.63.1/fastfetch-windows-amd64.7z",
            "hash": "110440f64995009d5db08bc60078aa4dcc0a208d63ce8c029d79643038b349c0"
        },
        "arm64": {
            "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/2.63.1/fastfetch-windows-aarch64.7z",
            "hash": "f1ba6501905edfba12acf796adde95aba33a24ae1c098c01a6a76ecf43d8b781"
        }
    },
    "extract_to": "app",
    "bin": [
        "app\\fastfetch.exe",
        "app\\flashfetch.exe"
    ],
    "link": "$home\\.config\\fastfetch",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/$version/fastfetch-windows-amd64.7z"
            },
            "arm64": {
                "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/$version/fastfetch-windows-aarch64.7z"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
