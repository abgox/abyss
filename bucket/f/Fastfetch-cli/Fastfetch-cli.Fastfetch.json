{
    "version": "2.64.1",
    "description": "一款持续维护、功能丰富且注重性能、类 neofetch 的系统信息查看工具 | A maintained, feature-rich and performance oriented, neofetch like system information tool",
    "homepage": "https://github.com/fastfetch-cli/fastfetch",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/2.64.1/fastfetch-windows-amd64.7z",
            "hash": "77d67e1f3ff37a85e20c143df16c74e6717d059a5fcdf80f43278e75e95923e3"
        },
        "arm64": {
            "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/2.64.1/fastfetch-windows-aarch64.7z",
            "hash": "920612ddc02ecffdec67c91c297442e17631f87ee454be5c97a7bf7547ef77b4"
        }
    },
    "extract_to": "app",
    "bin": [
        "app\\fastfetch.exe",
        "app\\flashfetch.exe"
    ],
    "link": "$home\\.config\\fastfetch",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/$version/fastfetch-windows-amd64.7z"
            },
            "arm64": {
                "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/$version/fastfetch-windows-aarch64.7z"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
