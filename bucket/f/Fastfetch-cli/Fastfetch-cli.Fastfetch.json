{
    "version": "2.66.0",
    "description": "一款持续维护、功能丰富且注重性能、类 neofetch 的系统信息查看工具 | A maintained, feature-rich and performance oriented, neofetch like system information tool",
    "homepage": "https://github.com/fastfetch-cli/fastfetch",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/2.66.0/fastfetch-windows-amd64.7z",
            "hash": "290bc98a4cedf7ff81cf40481718cff465d4f33eb73f67ddd62982bf2155f461"
        },
        "arm64": {
            "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/2.66.0/fastfetch-windows-aarch64.7z",
            "hash": "8613fc985dae3e0205496724f9d8ca950971675c68fb1f19c338259676a669c6"
        }
    },
    "extract_to": "app",
    "bin": [
        "app\\fastfetch.exe",
        "app\\flashfetch.exe"
    ],
    "link": "$home\\.config\\fastfetch",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/$version/fastfetch-windows-amd64.7z"
            },
            "arm64": {
                "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/$version/fastfetch-windows-aarch64.7z"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
