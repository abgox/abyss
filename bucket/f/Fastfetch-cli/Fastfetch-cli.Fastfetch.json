{
    "version": "2.64.0",
    "description": "一款持续维护、功能丰富且注重性能、类 neofetch 的系统信息查看工具 | A maintained, feature-rich and performance oriented, neofetch like system information tool",
    "homepage": "https://github.com/fastfetch-cli/fastfetch",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/2.64.0/fastfetch-windows-amd64.7z",
            "hash": "6f49e324e1c5b2fc1740ccb9bcdb70e2f1b82770dec45002e48b0d0451d5484f"
        },
        "arm64": {
            "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/2.64.0/fastfetch-windows-aarch64.7z",
            "hash": "6a705820765dfa47ec6075d3d4f3a29404f42208874fb770d83a554194ab3681"
        }
    },
    "extract_to": "app",
    "bin": [
        "app\\fastfetch.exe",
        "app\\flashfetch.exe"
    ],
    "link": "$home\\.config\\fastfetch",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/$version/fastfetch-windows-amd64.7z"
            },
            "arm64": {
                "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/$version/fastfetch-windows-aarch64.7z"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
