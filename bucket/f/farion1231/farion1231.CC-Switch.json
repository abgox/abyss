{
    "version": "3.17.0",
    "description": "适用于 Claude Code、Codex、OpenCode、OpenClaw 以及 Gemini CLI 的全方位管理工具 | The All-in-One Manager for Claude Code, Codex, OpenCode, OpenClaw & Gemini CLI",
    "homepage": "https://ccswitch.io",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/farion1231/cc-switch/releases/download/v3.17.0/CC-Switch-v3.17.0-Windows-Portable.zip",
            "hash": "5b42f100ec654c608feadd683c9a8117b026ad301b43467cb248ea5173adda41"
        },
        "arm64": {
            "url": "https://github.com/farion1231/cc-switch/releases/download/v3.17.0/CC-Switch-v3.17.0-Windows-arm64-Portable.zip",
            "hash": "8a5d28a8f7db96cedb42daeab1ea64a5766f0dd34a9150f290ae1428562ccacb"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\cc-switch.exe",
            "CC-Switch"
        ]
    ],
    "link": "$home\\.cc-switch",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/farion1231/cc-switch/releases/download/v$version/CC-Switch-v$version-Windows-Portable.zip"
            },
            "arm64": {
                "url": "https://github.com/farion1231/cc-switch/releases/download/v$version/CC-Switch-v$version-Windows-arm64-Portable.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
