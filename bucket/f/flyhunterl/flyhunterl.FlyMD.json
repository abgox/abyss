{
    "version": "1.4.3",
    "description": "一款轻量级、高性能的 Markdown 编辑器和 PDF 阅读器工具 | A highly responsive and extremely low-resource Markdown editor and PDF reader tool",
    "homepage": "https://flymd.llingfei.com",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/flyhunterl/flymd/releases/download/v1.4.3/flymd_1.4.3_x64-setup.exe",
            "hash": "84a82a1e55358fabaf3156da530a50654a769aea7a88a9379af4a77a7e0c3ab4"
        }
    },
    "shortcuts": [
        [
            "app\\flymd.exe",
            "flymd"
        ]
    ],
    "link": [
        "$env:AppData\\com.flymd",
        "$env:LocalAppData\\com.flymd"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/flyhunterl/flymd/releases/download/v$version/flymd_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
