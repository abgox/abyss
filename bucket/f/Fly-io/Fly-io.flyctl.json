            "hash": "4543e3ba409c5da1c914125884cbd86268988793e44b34141f97c5add36fabe3"
        },
        "arm64": {
            "url": "https://github.com/superfly/flyctl/releases/download/v0.4.68/flyctl_0.4.68_Windows_arm64.zip",
            "hash": "026a35ea782e0657fb09fe8f40b3fe96cd81cf37133134113b971a5c850f5c0f"
        }
    },
    "extract_to": "app",
    "bin": [
        "app\\flyctl.exe",
        [
            "app\\flyctl.exe",
            "fly"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/superfly/flyctl/releases/download/v$version/flyctl_$version_Windows_x86_64.zip"
            },
            "arm64": {
                "url": "https://github.com/superfly/flyctl/releases/download/v$version/flyctl_$version_Windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
