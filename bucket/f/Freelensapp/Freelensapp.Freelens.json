{
    "version": "1.10.3",
    "description": "一个免费且开源的用户界面，专为管理 Kubernetes 集群而设计 | A free and open-source user interface designed for managing Kubernetes clusters",
    "homepage": "https://freelensapp.github.io",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/freelensapp/freelens/releases/download/v1.10.3/Freelens-1.10.3-windows-amd64.msi",
            "hash": "21addcff6698124da6d1cf97e26e100ee17c294cecd1e20be2037d22cc030735"
        },
        "arm64": {
            "url": "https://github.com/freelensapp/freelens/releases/download/v1.10.3/Freelens-1.10.3-windows-arm64.msi",
            "hash": "e69b4bc2d89db7b609be1f9fe14506cb42b25426998fe0ad3ddfd2d7b06eb51f"
        }
    },
    "extract_dir": "freelens",
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\Freelens.exe",
            "Freelens"
        ]
    ],
    "link": [
        "$env:AppData\\Freelens",
        "$home\\.freelens"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/freelensapp/freelens/releases/download/v$version/Freelens-$version-windows-amd64.msi"
            },
            "arm64": {
                "url": "https://github.com/freelensapp/freelens/releases/download/v$version/Freelens-$version-windows-arm64.msi"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
