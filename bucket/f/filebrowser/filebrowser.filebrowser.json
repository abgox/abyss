{
    "version": "2.62.2",
    "description": "Web File Browser 在指定目录内提供文件管理界面，可用于上传、删除、预览和编辑文件 | Web File Browser provides a file managing interface within a specified directory and it can be used to upload, delete, preview and edit your files",
    "homepage": "https://filebrowser.org/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/filebrowser/filebrowser/releases/download/v2.62.2/windows-amd64-filebrowser.zip",
            "hash": "1bfc1a4db202938ae5148ec30a5e2ba08661ac0e8d1b9a3807ad01fb7d6625c8"
        },
        "arm64": {
            "url": "https://github.com/filebrowser/filebrowser/releases/download/v2.62.2/windows-arm64-filebrowser.zip",
            "hash": "4117650a43989468e247f97e7980e9d419004ad2f51ed815d37c7b4ad748726c"
        }
    },
    "extract_to": "app",
    "bin": "app\\filebrowser.exe",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/filebrowser/filebrowser/releases/download/v$version/windows-amd64-filebrowser.zip"
            },
            "arm64": {
                "url": "https://github.com/filebrowser/filebrowser/releases/download/v$version/windows-arm64-filebrowser.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
