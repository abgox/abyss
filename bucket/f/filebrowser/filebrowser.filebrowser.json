{
    "version": "2.63.11",
    "description": "Web File Browser 在指定目录内提供文件管理界面，可用于上传、删除、预览和编辑文件 | Web File Browser provides a file managing interface within a specified directory and it can be used to upload, delete, preview and edit your files",
    "homepage": "https://filebrowser.org/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/filebrowser/filebrowser/releases/download/v2.63.11/windows-amd64-filebrowser.zip",
            "hash": "b82ff5fb6a1ad847b94393ec1259e508e7577481821498c57c556491043bc33d"
        },
        "arm64": {
            "url": "https://github.com/filebrowser/filebrowser/releases/download/v2.63.11/windows-arm64-filebrowser.zip",
            "hash": "6d653aeb5b3fd24dbcf10619c5ed55bf2a666acc6a897f3a0b1d37b8e122512c"
        }
    },
    "extract_to": "app",
    "bin": "app\\filebrowser.exe",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/filebrowser/filebrowser/releases/download/v$version/windows-amd64-filebrowser.zip"
            },
            "arm64": {
                "url": "https://github.com/filebrowser/filebrowser/releases/download/v$version/windows-arm64-filebrowser.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
