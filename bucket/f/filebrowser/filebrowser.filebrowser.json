{
    "version": "2.63.4",
    "description": "Web File Browser 在指定目录内提供文件管理界面，可用于上传、删除、预览和编辑文件 | Web File Browser provides a file managing interface within a specified directory and it can be used to upload, delete, preview and edit your files",
    "homepage": "https://filebrowser.org/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/filebrowser/filebrowser/releases/download/v2.63.4/windows-amd64-filebrowser.zip",
            "hash": "70e9b4586279575807a287ced5c6a2fe1586c099a294bc1e96982c66cec3333c"
        },
        "arm64": {
            "url": "https://github.com/filebrowser/filebrowser/releases/download/v2.63.4/windows-arm64-filebrowser.zip",
            "hash": "83a0c10c2db8ccb7b2011915df0e77894658d22bb92794180c7e16af8de7765a"
        }
    },
    "extract_to": "app",
    "bin": "app\\filebrowser.exe",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/filebrowser/filebrowser/releases/download/v$version/windows-amd64-filebrowser.zip"
            },
            "arm64": {
                "url": "https://github.com/filebrowser/filebrowser/releases/download/v$version/windows-arm64-filebrowser.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
