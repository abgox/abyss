{
    "version": "0.41.0",
    "description": "一款美观、实用的终端邮件客户端 | A beautiful and functional email client for your terminal",
    "homepage": "https://matcha.floatpane.com/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/floatpane/matcha/releases/download/v0.41.0/matcha_0.41.0_windows_amd64.zip",
            "hash": "8b70096ccface46c19326f15d50627f0cb001d39c1222142dfc9af539873b525"
        },
        "arm64": {
            "url": "https://github.com/floatpane/matcha/releases/download/v0.41.0/matcha_0.41.0_windows_arm64.zip",
            "hash": "d053ce360a902db317ba8441e8b83bafeb96911228141bb1cb2dd8950ac4df0d"
        }
    },
    "extract_to": "app",
    "bin": "app\\matcha.exe",
    "link": [
        "$home\\.config\\matcha",
        "$home\\.cache\\matcha"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/floatpane/matcha/releases/download/v$version/matcha_$version_windows_amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/floatpane/matcha/releases/download/v$version/matcha_$version_windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
