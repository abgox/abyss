{
    "version": "0.40.0",
    "description": "一款美观、实用的终端邮件客户端 | A beautiful and functional email client for your terminal",
    "homepage": "https://matcha.floatpane.com/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/floatpane/matcha/releases/download/v0.40.0/matcha_0.40.0_windows_amd64.zip",
            "hash": "813217c7df8bd71360f4988333a80216f90a58a2da51ecb2e3beb083b92ebdd9"
        },
        "arm64": {
            "url": "https://github.com/floatpane/matcha/releases/download/v0.40.0/matcha_0.40.0_windows_arm64.zip",
            "hash": "95b9f6b5e4f9f621045db27cbf3d73d3a2fe1ee3efa87619eb0f3e8f7aa77603"
        }
    },
    "extract_to": "app",
    "bin": "app\\matcha.exe",
    "link": [
        "$home\\.config\\matcha",
        "$home\\.cache\\matcha"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/floatpane/matcha/releases/download/v$version/matcha_$version_windows_amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/floatpane/matcha/releases/download/v$version/matcha_$version_windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
