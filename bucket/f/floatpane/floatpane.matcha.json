{
    "version": "0.38.0",
    "description": "一款美观、实用的终端邮件客户端 | A beautiful and functional email client for your terminal",
    "homepage": "https://matcha.floatpane.com/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/floatpane/matcha/releases/download/v0.38.0/matcha_0.38.0_windows_amd64.zip",
            "hash": "0b17d4138be0070cd599f1a6b9cd3e99ad466185b663eecd5af967bcdb27afa4"
        },
        "arm64": {
            "url": "https://github.com/floatpane/matcha/releases/download/v0.38.0/matcha_0.38.0_windows_arm64.zip",
            "hash": "3438bd6aef39eda1b1aa04fd4bd7758f4423acd77f677d51dc472d02087091bd"
        }
    },
    "extract_to": "app",
    "bin": "app\\matcha.exe",
    "link": [
        "$home\\.config\\matcha",
        "$home\\.cache\\matcha"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/floatpane/matcha/releases/download/v$version/matcha_$version_windows_amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/floatpane/matcha/releases/download/v$version/matcha_$version_windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
