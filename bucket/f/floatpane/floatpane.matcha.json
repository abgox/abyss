{
    "version": "0.40.1",
    "description": "一款美观、实用的终端邮件客户端 | A beautiful and functional email client for your terminal",
    "homepage": "https://matcha.floatpane.com/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/floatpane/matcha/releases/download/v0.40.1/matcha_0.40.1_windows_amd64.zip",
            "hash": "af3d4ccd64b501274d46bfea613e48d431a1e56db75b15d6bbef468295a0f1d1"
        },
        "arm64": {
            "url": "https://github.com/floatpane/matcha/releases/download/v0.40.1/matcha_0.40.1_windows_arm64.zip",
            "hash": "19df503b758d78eed8167ea4cacae304a9867ed48712c1e58aee7805753cca1b"
        }
    },
    "extract_to": "app",
    "bin": "app\\matcha.exe",
    "link": [
        "$home\\.config\\matcha",
        "$home\\.cache\\matcha"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/floatpane/matcha/releases/download/v$version/matcha_$version_windows_amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/floatpane/matcha/releases/download/v$version/matcha_$version_windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
