{
    "version": "0.10.0",
    "description": "使用类 SQL 查询查找文件 | Find files with SQL-like queries",
    "homepage": "https://fselect.rocks/",
    "license": {
        "identifier": "Apache-2.0|MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/jhspetersson/fselect/releases/download/0.10.0/fselect-x86_64-win.zip",
            "hash": "50ab5e6ff85ab643d13ec7e0d6469bf15c8ecb0d50e899fb50145569c48bcf96"
        }
    },
    "extract_to": "app",
    "bin": "app\\fselect.exe",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/jhspetersson/fselect/releases/download/$version/fselect-x86_64-win.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
