{
    "version": "2.1.2",
    "description": "适用于 Windows 的快速文件搜索和应用程序启动器 | Quick file searcher and app launcher with community-made plugins",
    "homepage": "https://www.flowlauncher.com/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Flow-Launcher/Flow.Launcher/releases/download/v2.1.2/Flow-Launcher-Portable.zip",
            "hash": "d4fdc17f0416ab0ce4bd3b25197305567608c964670118b934e91673ddae5ea2"
        }
    },
    "extract_dir": "FlowLauncher\\app-2.1.2",
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\Flow.Launcher.exe",
            "Flow Launcher"
        ]
    ],
    "persist": [
        [
            "app\\UserData",
            "AppData\\Roaming\\FlowLauncher"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Flow-Launcher/Flow.Launcher/releases/download/v$version/Flow-Launcher-Portable.zip"
            }
        },
        "hash": {
            "mode": "github"
        },
        "extract_dir": "FlowLauncher\\app-$version"
    }
}
