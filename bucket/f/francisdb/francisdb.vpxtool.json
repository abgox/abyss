        "arm64": {
            "url": "https://github.com/francisdb/vpxtool/releases/download/v0.33.5/vpxtool-Windows-aarch64-v0.33.5.zip",
            "hash": "5713aafd06f229d457062483f5db5797d5bc9eec0093ceb7693d8fa85a19ff39"
        }
    },
    "extract_to": "app",
    "bin": "app\\vpxtool.exe",
    "link": "$env:AppData\\vpxtool.cfg",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/francisdb/vpxtool/releases/download/v$version/vpxtool-Windows-x86_64-v$version.zip"
            },
            "arm64": {
                "url": "https://github.com/francisdb/vpxtool/releases/download/v$version/vpxtool-Windows-aarch64-v$version.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
