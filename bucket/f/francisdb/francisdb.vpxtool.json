{
    "version": "0.29.1",
    "description": "Visual Pinball 的基于终端的前端和实用程序 | Terminal based frontend and utilities for Visual Pinball",
    "homepage": "https://github.com/francisdb/vpxtool",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/francisdb/vpxtool/releases/download/v0.29.1/vpxtool-Windows-x86_64-v0.29.1.zip",
            "hash": "f5d81b052b5b00034a0f3b2b36c1d8f7a8135e545b56c59e5b11171b915d10bc"
        },
        "arm64": {
            "url": "https://github.com/francisdb/vpxtool/releases/download/v0.29.1/vpxtool-Windows-aarch64-v0.29.1.zip",
            "hash": "39d053eb4356a95d238212764ef8a6f3b82e1b5542875606fc993cfa2a564904"
        }
    },
    "extract_to": "app",
    "bin": "app\\vpxtool.exe",
    "link": "$env:AppData\\vpxtool.cfg",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/francisdb/vpxtool/releases/download/v$version/vpxtool-Windows-x86_64-v$version.zip"
            },
            "arm64": {
                "url": "https://github.com/francisdb/vpxtool/releases/download/v$version/vpxtool-Windows-aarch64-v$version.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
