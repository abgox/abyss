{
    "version": "0.31.1",
    "description": "Visual Pinball 的基于终端的前端和实用程序 | Terminal based frontend and utilities for Visual Pinball",
    "homepage": "https://github.com/francisdb/vpxtool",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/francisdb/vpxtool/releases/download/v0.31.1/vpxtool-Windows-x86_64-v0.31.1.zip",
            "hash": "f93b5836cad3cbf51ec06f4905196e111177d5b6b4a392328710c36faf87f034"
        },
        "arm64": {
            "url": "https://github.com/francisdb/vpxtool/releases/download/v0.31.1/vpxtool-Windows-aarch64-v0.31.1.zip",
            "hash": "5bbfae71973f4ebdb5daeb10a3fbea98337a7dfb968430b6b3955b49e448b3c5"
        }
    },
    "extract_to": "app",
    "bin": "app\\vpxtool.exe",
    "link": "$env:AppData\\vpxtool.cfg",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/francisdb/vpxtool/releases/download/v$version/vpxtool-Windows-x86_64-v$version.zip"
            },
            "arm64": {
                "url": "https://github.com/francisdb/vpxtool/releases/download/v$version/vpxtool-Windows-aarch64-v$version.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
