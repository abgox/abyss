{
    "version": "0.29.3",
    "description": "Visual Pinball 的基于终端的前端和实用程序 | Terminal based frontend and utilities for Visual Pinball",
    "homepage": "https://github.com/francisdb/vpxtool",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/francisdb/vpxtool/releases/download/v0.29.3/vpxtool-Windows-x86_64-v0.29.3.zip",
            "hash": "79eeccbcd8b41fbb1792c85ba402c423b79b0e53894cf79ceb3e24b0268abd77"
        },
        "arm64": {
            "url": "https://github.com/francisdb/vpxtool/releases/download/v0.29.3/vpxtool-Windows-aarch64-v0.29.3.zip",
            "hash": "2c130f7b22ba7ee58b41d9180045b3ca4a11e222c24996ec1bcfb5877df79ddc"
        }
    },
    "extract_to": "app",
    "bin": "app\\vpxtool.exe",
    "link": "$env:AppData\\vpxtool.cfg",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/francisdb/vpxtool/releases/download/v$version/vpxtool-Windows-x86_64-v$version.zip"
            },
            "arm64": {
                "url": "https://github.com/francisdb/vpxtool/releases/download/v$version/vpxtool-Windows-aarch64-v$version.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
