{
    "version": "0.69.0",
    "description": "一款快速的反向代理，它能让位于网络地址转换 (NAT) 或防火墙后的本地服务器暴露在互联网上 | A fast reverse proxy to help you expose a local server behind a NAT or firewall to the internet",
    "homepage": "https://gofrp.org/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/fatedier/frp/releases/download/v0.69.0/frp_0.69.0_windows_amd64.zip",
            "hash": "0e38f6dbe7761d648ca5c6ee323b7309544f48c01e9476f553902f3bc0949089",
            "extract_dir": "frp_0.69.0_windows_amd64"
        },
        "arm64": {
            "url": "https://github.com/fatedier/frp/releases/download/v0.69.0/frp_0.69.0_windows_arm64.zip",
            "hash": "ce49e6ad107005ad148974990ba30b2a7c097fb874b5f95897b8b32c6fc79e07",
            "extract_dir": "frp_0.69.0_windows_arm64"
        }
    },
    "extract_to": "app",
    "bin": [
        [
            "app\\frpc.exe",
            "frpc",
            "-c \"$dir\\app\\frpc.toml\""
        ],
        [
            "app\\frps.exe",
            "frps",
            "-c \"$dir\\app\\frps.toml\""
        ]
    ],
    "persist": [
        [
            "app\\frpc.toml",
            "frpc.toml"
        ],
        [
            "app\\frps.toml",
            "frps.toml"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/fatedier/frp/releases/download/v$version/frp_$version_windows_amd64.zip",
                "extract_dir": "frp_$version_windows_amd64"
            },
            "arm64": {
                "url": "https://github.com/fatedier/frp/releases/download/v$version/frp_$version_windows_arm64.zip",
                "extract_dir": "frp_$version_windows_arm64"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
