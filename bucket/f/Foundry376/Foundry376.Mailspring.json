{
    "version": "1.21.1",
    "description": "一个漂亮，快速，完全开源的邮件客户端 | A beautiful, fast and fully open source mail client",
    "homepage": "https://github.com/Foundry376/Mailspring",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Foundry376/Mailspring/releases/download/1.21.1/MailspringSetup.exe",
            "hash": "22c359509c07e015b11c71cef0e997deff6fd728ce4e97a216ea4c8f659ab957"
        }
    },
    "location": "$env:LocalAppData\\Mailspring",
    "link": "$env:AppData\\Mailspring",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'Update.exe' -ArgumentList '--silent'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Uninstall-App -ArgumentList '--uninstall'",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Foundry376/Mailspring/releases/download/$version/MailspringSetup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
