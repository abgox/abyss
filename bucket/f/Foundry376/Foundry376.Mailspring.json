{
    "version": "1.23.0",
    "description": "一个漂亮，快速，完全开源的邮件客户端 | A beautiful, fast and fully open source mail client",
    "homepage": "https://github.com/Foundry376/Mailspring",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Foundry376/Mailspring/releases/download/1.23.0/MailspringSetup.exe",
            "hash": "0b4e511fe881f8202cc75f0c461c7bdc666f8d87b25dae6137740384e2e00f76"
        }
    },
    "location": "$env:LocalAppData\\Mailspring",
    "link": "$env:AppData\\Mailspring",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'Update.exe' -ArgumentList '--silent'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Uninstall-App -ArgumentList '--uninstall'",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Foundry376/Mailspring/releases/download/$version/MailspringSetup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
