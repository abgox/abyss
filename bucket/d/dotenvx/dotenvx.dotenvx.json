{
    "version": "1.67.0",
    "description": "一款安全的 dotenv | A secure dotenv",
    "homepage": "https://dotenvx.com/",
    "license": {
        "identifier": "BSD-3-Clause"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/dotenvx/dotenvx/releases/download/v1.67.0/dotenvx-1.67.0-windows-x86_64.zip",
            "hash": "56629b7fac73ffc4e84b2aae903e05c3ed82473c99a0fdd1b4a38c2a16d791f8"
        }
    },
    "extract_to": "app",
    "bin": "app\\dotenvx.exe",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/dotenvx/dotenvx/releases/download/v$version/dotenvx-$version-windows-x86_64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
