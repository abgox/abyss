{
    "version": "1.8.0",
    "description": "一个 WinGet 相关的工具，帮您更方便地移除清单、修改清单、分析验证错误等 | A tool related to WinGet that assists you in more conveniently removing manifests, modifying manifests, and analyzing validation errors, and more",
    "homepage": "https://github.com/DuckDuckStudio/Sundry",
    "license": {
        "identifier": "AGPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/DuckDuckStudio/Sundry/releases/download/1.8.0/Sundry.zip",
            "hash": "382eb86fcf051b657dcfafa002eb34cda475484e2e991e250c86c8e6e7da4602"
        },
        "arm64": {
            "url": "https://github.com/DuckDuckStudio/Sundry/releases/download/1.8.0/Sundry.zip",
            "hash": "382eb86fcf051b657dcfafa002eb34cda475484e2e991e250c86c8e6e7da4602"
        }
    },
    "extract_dir": "Release\\pack",
    "extract_to": "app",
    "bin": "app\\sundry.exe",
    "link": "$home\\.config\\DuckStudio\\Sundry",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/DuckDuckStudio/Sundry/releases/download/$version/Sundry.zip"
            },
            "arm64": {
                "url": "https://github.com/DuckDuckStudio/Sundry/releases/download/$version/Sundry.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
