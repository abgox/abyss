    "license": {
        "identifier": "Unknown",
        "url": "https://dcloud.io/license/hbuilder.html"
    },
    "architecture": {
        "64bit": {
            "url": "https://download1.dcloud.net.cn/download/HBuilderX.5.05.2026032417.zip",
            "hash": "3874039f3ca11d00cfb5dbf5fc0897c9651e096b5bdd8bb8e63dab9828d08964"
        }
    },
    "extract_dir": "HBuilderX",
    "extract_to": "app",
    "bin": "app\\HBuilderX.exe",
    "shortcuts": [
        [
            "app\\HBuilderX.exe",
            "HBuilder X"
        ]
    ],
    "link": "$env:AppData\\HBuilder X",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Remove-TempData \"$env:LocalAppData\\HBuilder X\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://download1.dcloud.net.cn/hbuilderx/release.json",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download1.dcloud.net.cn/download/HBuilderX.$version.zip"
            }
        }
    }
}
