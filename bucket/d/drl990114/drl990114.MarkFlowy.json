{
    "version": "0.55.3",
    "description": "一个跨平台 Markdown 编辑器，但是更轻快、更智能、更纯粹 | A cross platform Markdown editor, but it is lighter, smarter, and purer",
    "homepage": "https://www.markflowy.cc/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/drl990114/MarkFlowy/releases/download/v0.55.3/MarkFlowy_v0.55.3_x64-setup.exe",
            "hash": "3c0d78bd492b7e575d1899dc3eb27b4f369d625dd9f0661763b94e3a23be53f9"
        }
    },
    "shortcuts": [
        [
            "app\\markflowy.exe",
            "MarkFlowy"
        ]
    ],
    "link": [
        "$env:AppData\\com.drl990114.markflowy",
        "$home\\.markflowy"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/drl990114/MarkFlowy/releases/download/v$version/MarkFlowy_v$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
