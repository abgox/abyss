{
    "version": "0.81.0",
    "description": "一个跨平台 Markdown 编辑器，但是更轻快、更智能、更纯粹 | A cross platform Markdown editor, but it is lighter, smarter, and purer",
    "homepage": "https://www.markflowy.cc/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/drl990114/MarkFlowy/releases/download/v0.81.0/MarkFlowy_v0.81.0_x64-setup.exe",
            "hash": "39af28348eb3666474bebc01b35fccc4373ce170512bc9876ded52d7f06e02ad"
        }
    },
    "shortcuts": [
        [
            "app\\markflowy.exe",
            "MarkFlowy"
        ]
    ],
    "link": [
        "$env:AppData\\com.drl990114.markflowy",
        "$home\\.markflowy"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/drl990114/MarkFlowy/releases/download/v$version/MarkFlowy_v$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
