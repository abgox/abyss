{
    "version": "1.5.5",
    "description": "一种用于过程分析的 SQL 数据库管理系统 | An analytical in-process SQL database management system",
    "homepage": "http://www.duckdb.org",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/duckdb/duckdb/releases/download/v1.5.5/duckdb_cli-windows-amd64.zip",
            "hash": "e1428b7114a841626b5054723731cbf45c6df91b42ae1a6c355f88fad1f6dc4c"
        },
        "arm64": {
            "url": "https://github.com/duckdb/duckdb/releases/download/v1.5.5/duckdb_cli-windows-arm64.zip",
            "hash": "9d0370d085684e1619ecc5efb2656cde930c50f1418380f0ae9d0379ddf06b12"
        }
    },
    "extract_to": "app",
    "bin": "app\\duckdb.exe",
    "link": "$home\\.duckdb",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/duckdb/duckdb/releases/download/v$version/duckdb_cli-windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/duckdb/duckdb/releases/download/v$version/duckdb_cli-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
