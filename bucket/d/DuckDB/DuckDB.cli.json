{
    "version": "1.5.3",
    "description": "一种用于过程分析的 SQL 数据库管理系统 | An analytical in-process SQL database management system",
    "homepage": "http://www.duckdb.org/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/duckdb/duckdb/releases/download/v1.5.3/duckdb_cli-windows-amd64.zip",
            "hash": "2aba634fab91b3cb3f88cb7a75a9539b47ef240a76f4d4ff8d1e48821c8ccd7f"
        },
        "arm64": {
            "url": "https://github.com/duckdb/duckdb/releases/download/v1.5.3/duckdb_cli-windows-arm64.zip",
            "hash": "cbd135f2999cc75f77b8f4a511e7d2365fa4a77cdc805c439de303380ef0eab4"
        }
    },
    "extract_to": "app",
    "bin": "app\\duckdb.exe",
    "link": "$home\\.duckdb",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/duckdb/duckdb/releases/download/v$version/duckdb_cli-windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/duckdb/duckdb/releases/download/v$version/duckdb_cli-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
