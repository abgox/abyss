{
    "version": "1.88.1",
    "description": "一个 SQL 数据库，您可以像 Git 存储库一样对其进行分叉、克隆、分支、合并、推送和拉取 | A SQL database that you can fork, clone, branch, merge, push and pull just like a Git repository",
    "homepage": "https://www.dolthub.com/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/dolthub/dolt/releases/download/v1.88.1/dolt-windows-amd64.zip",
            "hash": "bae5a4e726cd78f467cf2e12bfa16adfb03d9a6020fe613cf47e17f0806880e8",
            "extract_dir": "dolt-windows-amd64"
        }
    },
    "extract_to": "app",
    "bin": "app\\bin\\dolt.exe",
    "link": "$home\\.dolt",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/dolthub/dolt/releases/download/v$version/dolt-windows-amd64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
