    "homepage": "https://keystats.vercel.app/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/debugtheworldbot/keyStats/releases/download/v1.44/KeyStats-Windows-1.44.zip",
            "hash": "8a6cd25ed7b1d26072114275248e39d26d84baea34836764793be414ee8fa2ee"
        }
    },
    "extract_to": "app",
    "bin": "app\\KeyStats.exe",
    "shortcuts": [
        [
            "app\\KeyStats.exe",
            "KeyStats"
        ]
