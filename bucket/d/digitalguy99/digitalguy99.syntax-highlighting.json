{
    "version": "3.3.0",
    "description": "PowerShell 的语法高亮显示 | Syntax highlighting for PowerShell",
    "homepage": "https://github.com/digitalguy99/pwsh-syntax-highlighting",
    "license": {
        "identifier": "MIT"
    },
    "notes_cn": [
        "它与 PSCompletions 模块存在冲突",
        "如果需要一起使用，必须遵循以下导入顺序",
        " ",
        " Import-Module syntax-highlighting",
        " Import-Module PSCompletions"
    ],
    "notes": [
        "It conflicts with the PSCompletions module.",
        "If they need to be used together, the following import order must be followed.",
        " ",
        " Import-Module syntax-highlighting",
        " Import-Module PSCompletions"
    ],
    "architecture": {
        "64bit": {
            "url": "https://cdn.powershellgallery.com/packages/syntax-highlighting.3.3.0.nupkg",
            "hash": "882a0ed68291c87f27375428e28cab1644e04fa5c53608937dda467b92de5a63"
        },
        "arm64": {
            "url": "https://cdn.powershellgallery.com/packages/syntax-highlighting.3.3.0.nupkg",
            "hash": "882a0ed68291c87f27375428e28cab1644e04fa5c53608937dda467b92de5a63"
        }
    },
    "psmodule": {
        "name": "syntax-highlighting"
    },
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromPowerShellGallery"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://cdn.powershellgallery.com/packages/syntax-highlighting.$version.nupkg"
            },
            "arm64": {
                "url": "https://cdn.powershellgallery.com/packages/syntax-highlighting.$version.nupkg"
            }
        }
    }
}
