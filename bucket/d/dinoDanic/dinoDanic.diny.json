{
    "version": "0.5.5",
    "description": "根据 git diff 生成有意义的提交信息 | Generate meaningful commit messages from git diff",
    "homepage": "https://diny-cli.vercel.app/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/dinoDanic/diny/releases/download/v0.5.5/diny_Windows_x86_64.zip",
            "hash": "35fad90a39c4a1241feb650fb1a7ec6771dff8e6e53eceae1c6d949bb453164d"
        },
        "arm64": {
            "url": "https://github.com/dinoDanic/diny/releases/download/v0.5.5/diny_Windows_arm64.zip",
            "hash": "298dd2f236a1a1b12c8d5b6ff1dccfa2af5d76594706a705797c20360846deb6"
        }
    },
    "extract_to": "app",
    "bin": "app\\diny.exe",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/dinoDanic/diny/releases/download/v$version/diny_Windows_x86_64.zip"
            },
            "arm64": {
                "url": "https://github.com/dinoDanic/diny/releases/download/v$version/diny_Windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
