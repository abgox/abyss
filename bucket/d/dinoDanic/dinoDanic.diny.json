{
    "version": "0.7.5",
    "description": "根据 git diff 生成有意义的提交信息 | Generate meaningful commit messages from git diff",
    "homepage": "https://diny-cli.vercel.app/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/dinoDanic/diny/releases/download/v0.7.5/diny_Windows_x86_64.zip",
            "hash": "f32f905c8b8696954658789a19d6bbdf02f511c9425cd37798b34374297be66d"
        },
        "arm64": {
            "url": "https://github.com/dinoDanic/diny/releases/download/v0.7.5/diny_Windows_arm64.zip",
            "hash": "69350454001d8bf3081abeed5184aa711ac4dc2b40e2d618412b5ac791cdaac8"
        }
    },
    "extract_to": "app",
    "bin": "app\\diny.exe",
    "link": "$home\\.config\\diny",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/dinoDanic/diny/releases/download/v$version/diny_Windows_x86_64.zip"
            },
            "arm64": {
                "url": "https://github.com/dinoDanic/diny/releases/download/v$version/diny_Windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
