{
    "version": "0.6",
    "description": "根据 git diff 生成有意义的提交信息 | Generate meaningful commit messages from git diff",
    "homepage": "https://diny-cli.vercel.app/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/dinoDanic/diny/releases/download/v0.6/diny_Windows_x86_64.zip",
            "hash": "f7f5a55f593bdc5699f796cf2d88a614244897e75f908b0be9229ed262698009"
        },
        "arm64": {
            "url": "https://github.com/dinoDanic/diny/releases/download/v0.6/diny_Windows_arm64.zip",
            "hash": "cc4459fff0e99879ef162beb310288566e1709c94f07b92745d77d14ee6793d0"
        }
    },
    "extract_to": "app",
    "bin": "app\\diny.exe",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/dinoDanic/diny/releases/download/v$version/diny_Windows_x86_64.zip"
            },
            "arm64": {
                "url": "https://github.com/dinoDanic/diny/releases/download/v$version/diny_Windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
