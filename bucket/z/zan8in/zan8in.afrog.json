{
    "version": "3.5.5",
    "description": "一款适用于漏洞赏金、渗透测试和红队演练的安全工具 | A Security Tool for Bug Bounty, Pentest and Red Teaming",
    "homepage": "https://github.com/zan8in/afrog",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/zan8in/afrog/releases/download/v3.5.5/afrog_3.5.5_windows_amd64.zip",
            "hash": "6a025bf62d939b2dc9453c5920a8ce735628971aa0948f4ece47283a983a09bb"
        },
        "arm64": {
            "url": "https://github.com/zan8in/afrog/releases/download/v3.5.5/afrog_3.5.5_windows_arm64.zip",
            "hash": "8f0a37fee95589692bed0f4f2279e8aff9687f88879d41ede5302ebdb0c4dd6f"
        }
    },
    "extract_to": "app",
    "bin": "app\\afrog.exe",
    "link": "$home\\.config\\afrog",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zan8in/afrog/releases/download/v$version/afrog_$version_windows_amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/zan8in/afrog/releases/download/v$version/afrog_$version_windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
