{
    "version": "3.5.1",
    "description": "一款适用于漏洞赏金、渗透测试和红队演练的安全工具 | A Security Tool for Bug Bounty, Pentest and Red Teaming",
    "homepage": "https://github.com/zan8in/afrog",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/zan8in/afrog/releases/download/v3.5.1/afrog_3.5.1_windows_amd64.zip",
            "hash": "a4b1a799fa5c2fa87d321eb1b4978da180bb5538206d8f430b918dc3d684db0b"
        },
        "arm64": {
            "url": "https://github.com/zan8in/afrog/releases/download/v3.5.1/afrog_3.5.1_windows_arm64.zip",
            "hash": "3b30ceee7bd1a41790b13ebbd8671520eee1832c99ebcc59badd0f859731b238"
        }
    },
    "extract_to": "app",
    "bin": "app\\afrog.exe",
    "link": "$home\\.config\\afrog",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zan8in/afrog/releases/download/v$version/afrog_$version_windows_amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/zan8in/afrog/releases/download/v$version/afrog_$version_windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
