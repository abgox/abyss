{
    "version": "3.5.2",
    "description": "一款适用于漏洞赏金、渗透测试和红队演练的安全工具 | A Security Tool for Bug Bounty, Pentest and Red Teaming",
    "homepage": "https://github.com/zan8in/afrog",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/zan8in/afrog/releases/download/v3.5.2/afrog_3.5.2_windows_amd64.zip",
            "hash": "418dd993e2f3378b97957aeadf896e6343b3f2792eed88516753376e365e004d"
        },
        "arm64": {
            "url": "https://github.com/zan8in/afrog/releases/download/v3.5.2/afrog_3.5.2_windows_arm64.zip",
            "hash": "c24506408487d560cda515cfc92065c40167e9d78be3fea7ecbd0149f364d3a7"
        }
    },
    "extract_to": "app",
    "bin": "app\\afrog.exe",
    "link": "$home\\.config\\afrog",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zan8in/afrog/releases/download/v$version/afrog_$version_windows_amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/zan8in/afrog/releases/download/v$version/afrog_$version_windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
