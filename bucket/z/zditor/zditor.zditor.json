{
    "version": "1.7.1",
    "description": "一款类似 Typora 的文档编辑器，拥有更快的性能、智能 AI 辅助和 Git 集成 | A Typora-like document editor with faster performance, smart AI assistance, and Git integration",
    "homepage": "https://www.zditor.com",
    "license": {
        "identifier": "Unknown"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/zditor/zditor-docs/releases/download/zditor-v1.7.1/zditor_1.7.1_x64-setup.exe",
            "hash": "d586f3e21eb8e726b0d79035f52530c78263602aaf6a6edcce9215ab804bd1b1"
        }
    },
    "shortcuts": [
        [
            "app\\zditor.exe",
            "zditor"
        ]
    ],
    "link": "$env:AppData\\com.zditor.ai",
    "cleanup": "$env:LocalAppData\\com.zditor.ai",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "zditor-(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zditor/zditor-docs/releases/download/zditor-v$version/zditor_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
