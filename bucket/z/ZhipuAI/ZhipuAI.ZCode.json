{
    "version": "3.3.3",
    "description": "一款专为长周期任务打造、由 Z.ai 提供技术支持的全功能智能自主开发环境（ADE） | A full-featured Agentic Development Environment (ADE) built for Long Horizon Tasks, powered by Z.ai",
    "homepage": "https://zcode.z.ai",
    "license": {
        "identifier": "Proprietary"
    },
    "architecture": {
        "64bit": {
            "url": "https://cdn-zcode.z.ai/zcode/electron/releases/3.3.3/ZCode-3.3.3-win-x64.exe",
            "hash": "9799670b6cfb7b1e7ae87af3ebec6a440360fe39749e7cfd9274656f042a541d"
        }
    },
    "shortcuts": [
        [
            "app\\ZCode.exe",
            "ZCode"
        ]
    ],
    "link": [
        "$home\\.zcode",
        "$home\\ZCodeProject",
        "$env:AppData\\ZCode"
    ],
    "cleanup": "$env:LocalAppData\\@zcodedesktop-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall ZCode.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://zcode.z.ai/api/v2/releases/latest?target=windows&arch=x86_64",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://cdn-zcode.z.ai/zcode/electron/releases/$version/ZCode-$version-win-x64.exe"
            }
        }
    }
}
