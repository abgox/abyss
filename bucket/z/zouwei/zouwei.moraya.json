{
    "version": "0.41.13",
    "description": "极致优雅的开源 Markdown AI Agent | An extremely elegant open-source Markdown AI Agent",
    "homepage": "https://moraya.app",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/zouwei/moraya/releases/download/v0.41.13/Moraya_0.41.13_win_x64-setup.exe",
            "hash": "b4028b64ac43ca52f475a335c6186a788e17146f137604730c7d61270949dc70"
        }
    },
    "shortcuts": [
        [
            "app\\moraya.exe",
            "Moraya"
        ]
    ],
    "link": [
        "$env:AppData\\com.moraya.app",
        "$home\\.moraya"
    ],
    "cleanup": "$env:LocalAppData\\com.moraya.app",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zouwei/moraya/releases/download/v$version/Moraya_$version_win_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
