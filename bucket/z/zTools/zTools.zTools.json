{
    "version": "2.6.0",
    "description": "一个高性能、可扩展的应用启动器和插件平台 | A High-Performance, Extensible Application Launcher and Plugin Platform",
    "homepage": "https://github.com/ZToolsCenter/ZTools",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/ZToolsCenter/ZTools/releases/download/v2.6.0/ZTools-2.6.0-win-x64-setup.exe",
            "hash": "6272c907a0faa7bccc01cb7ee64bccec36c3b58e0c10cd54934d203a38e2b054"
        }
    },
    "shortcuts": [
        [
            "app\\ZTools.exe",
            "ZTools"
        ]
    ],
    "link": "$env:AppData\\ZTools",
    "cleanup": "$env:LocalAppData\\ztools-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall ZTools.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ZToolsCenter/ZTools/releases/download/v$version/ZTools-$version-win-x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
