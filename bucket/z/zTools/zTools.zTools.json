{
    "version": "2.4.0",
    "description": "一个高性能、可扩展的应用启动器和插件平台 | A High-Performance, Extensible Application Launcher and Plugin Platform",
    "homepage": "https://github.com/ZToolsCenter/ZTools",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/ZToolsCenter/ZTools/releases/download/v2.4.0/ZTools-2.4.0-win-x64-setup.exe",
            "hash": "827329cd103e5f917aa7e12b2f8f570db06c079380d54d3d3ccf981c1f54a1d9"
        }
    },
    "shortcuts": [
        [
            "app\\ZTools.exe",
            "ZTools"
        ]
    ],
    "link": "$env:AppData\\ZTools",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall ZTools.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\ztools-updater\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ZToolsCenter/ZTools/releases/download/v$version/ZTools-$version-win-x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
