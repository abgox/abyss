{
    "version": "1.5.0-pre",
    "description": "一款高性能的多人协作代码编辑器，由 Atom 和 Tree-sitter 的开发者打造 | A high-performance, multiplayer code editor from the creators of Atom and Tree-sitter",
    "homepage": "https://zed.dev/",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/zed-industries/zed/releases/download/v1.5.0-pre/Zed-x86_64.exe",
            "hash": "bf6aa877b033f1a245b502a88ac0cf5d0bb1b61ec422b81758ce1c53776c83b9"
        },
        "arm64": {
            "url": "https://github.com/zed-industries/zed/releases/download/v1.5.0-pre/Zed-aarch64.exe",
            "hash": "7e8d5ab8e4c2064def7a1b002319181769972ade7223dae511041342a34aeea9"
        }
    },
    "conflicts": [
        "ZedIndustries.Zed",
        "ZedIndustries.Zed.Preview"
    ],
    "env_add_path": "app\\bin",
    "commands": "zed",
    "shortcuts": [
        [
            "app\\Zed.exe",
            "Zed Preview"
        ]
    ],
    "link": [
        "$env:AppData\\Zed",
        "$env:LocalAppData\\Zed"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-PreVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zed-industries/zed/releases/download/v$version/Zed-x86_64.exe"
            },
            "arm64": {
                "url": "https://github.com/zed-industries/zed/releases/download/v$version/Zed-aarch64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
