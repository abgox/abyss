{
    "version": "1.4.1-pre",
    "description": "一款高性能的多人协作代码编辑器，由 Atom 和 Tree-sitter 的开发者打造 | A high-performance, multiplayer code editor from the creators of Atom and Tree-sitter",
    "homepage": "https://zed.dev/",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/zed-industries/zed/releases/download/v1.4.1-pre/Zed-x86_64.exe",
            "hash": "e12fcf4ede2d16f7de8a55eb9f39cb0bae3ba5046b374b1a8761c76ca4f99dc7"
        },
        "arm64": {
            "url": "https://github.com/zed-industries/zed/releases/download/v1.4.1-pre/Zed-aarch64.exe",
            "hash": "1d513e8f15e8eb4a6ebd9567c0fbefa6d48b507e8ded148db0c57e2ae101e461"
        }
    },
    "conflicts": [
        "ZedIndustries.Zed",
        "ZedIndustries.Zed.Preview"
    ],
    "env_add_path": "app\\bin",
    "commands": "zed",
    "shortcuts": [
        [
            "app\\Zed.exe",
            "Zed Preview"
        ]
    ],
    "link": [
        "$env:AppData\\Zed",
        "$env:LocalAppData\\Zed"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-PreVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zed-industries/zed/releases/download/v$version/Zed-x86_64.exe"
            },
            "arm64": {
                "url": "https://github.com/zed-industries/zed/releases/download/v$version/Zed-aarch64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
