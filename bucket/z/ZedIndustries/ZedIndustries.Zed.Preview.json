{
    "version": "0.233.0-pre",
    "description": "一款高性能的多人协作代码编辑器，由 Atom 和 Tree-sitter 的开发者打造 | A high-performance, multiplayer code editor from the creators of Atom and Tree-sitter",
    "homepage": "https://zed.dev/",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/zed-industries/zed/releases/download/v0.233.0-pre/Zed-x86_64.exe",
            "hash": "29196916996204a3134dea77caf7719969afbb3e0c47d2c8b3638036783e6cbe"
        },
        "arm64": {
            "url": "https://github.com/zed-industries/zed/releases/download/v0.233.0-pre/Zed-aarch64.exe",
            "hash": "3bf3a08305d9e8e29f0a9951d5b2e5cfc5ec10ab577a630212413b1f631c07b8"
        }
    },
    "conflicts": [
        "ZedIndustries.Zed",
        "ZedIndustries.Zed.Preview"
    ],
    "env_add_path": "app\\bin",
    "commands": "zed",
    "shortcuts": [
        [
            "app\\Zed.exe",
            "Zed Preview"
        ]
    ],
    "link": [
        "$env:AppData\\Zed",
        "$env:LocalAppData\\Zed"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-PreVersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zed-industries/zed/releases/download/v$version/Zed-x86_64.exe"
            },
            "arm64": {
                "url": "https://github.com/zed-industries/zed/releases/download/v$version/Zed-aarch64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
