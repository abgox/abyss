{
    "version": "1.12.0",
    "description": "一款高性能的多人协作代码编辑器，由 Atom 和 Tree-sitter 的开发者打造 | A high-performance, multiplayer code editor from the creators of Atom and Tree-sitter",
    "homepage": "https://zed.dev",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/zed-industries/zed/releases/download/v1.12.0/Zed-x86_64.exe",
            "hash": "fe419c17ebfb9b1d87e0c671b9a16804dd25cf452b60933a2456dc533fbd14f0"
        },
        "arm64": {
            "url": "https://github.com/zed-industries/zed/releases/download/v1.12.0/Zed-aarch64.exe",
            "hash": "4fcf6f902f5b3778dac768b0d1e3526ff38b279c07e17250f64d45245813eb3d"
        }
    },
    "conflicts": [
        "ZedIndustries.Zed",
        "ZedIndustries.Zed.Preview"
    ],
    "env_add_path": "app\\bin",
    "commands": "zed",
    "shortcuts": [
        [
            "app\\Zed.exe",
            "Zed"
        ]
    ],
    "link": [
        "$env:AppData\\Zed",
        "$env:LocalAppData\\Zed"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zed-industries/zed/releases/download/v$version/Zed-x86_64.exe"
            },
            "arm64": {
                "url": "https://github.com/zed-industries/zed/releases/download/v$version/Zed-aarch64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
