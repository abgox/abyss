{
    "version": "1.2.6",
    "description": "一款高性能的多人协作代码编辑器，由 Atom 和 Tree-sitter 的开发者打造 | A high-performance, multiplayer code editor from the creators of Atom and Tree-sitter",
    "homepage": "https://zed.dev/",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/zed-industries/zed/releases/download/v1.2.6/Zed-x86_64.exe",
            "hash": "e30dbba632bc39bec0e26345298ce80298a25bbb2d4564cdef495350d719bbe0"
        },
        "arm64": {
            "url": "https://github.com/zed-industries/zed/releases/download/v1.2.6/Zed-aarch64.exe",
            "hash": "109a59f7a55a66423b188279007c917108897747893510164720d6f7e247b543"
        }
    },
    "conflicts": [
        "ZedIndustries.Zed",
        "ZedIndustries.Zed.Preview"
    ],
    "env_add_path": "app\\bin",
    "commands": "zed",
    "shortcuts": [
        [
            "app\\Zed.exe",
            "Zed"
        ]
    ],
    "link": [
        "$env:AppData\\Zed",
        "$env:LocalAppData\\Zed"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zed-industries/zed/releases/download/v$version/Zed-x86_64.exe"
            },
            "arm64": {
                "url": "https://github.com/zed-industries/zed/releases/download/v$version/Zed-aarch64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
