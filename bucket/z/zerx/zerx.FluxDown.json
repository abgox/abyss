{
    "version": "0.2.0",
    "description": "一款基于 Rust 开发的下载管理器，支持 HTTP、FTP、BitTorrent 以及 HLS/DASH 流媒体协议 | A Rust-powered download manager with HTTP, FTP, BitTorrent and HLS/DASH streaming support",
    "homepage": "https://fluxdown.zerx.dev",
    "license": {
        "identifier": "Unknown"
    },
    "architecture": {
        "64bit": {
            "url": "https://fluxdown.zerx.dev/api/download/FluxDown-0.2.0-windows-x64-setup.exe?tag=v0.2.0",
            "hash": "2553beeebf441d21b5accd3886bcc1ba9e49a7d87aebede01d3b48e19e96f435"
        },
        "arm64": {
            "url": "https://fluxdown.zerx.dev/api/download/FluxDown-0.2.0-windows-arm64-setup.exe?tag=v0.2.0",
            "hash": "3253250bb4ccbdff9a192ad55ffec072ee4fe9c6ce7daa38baade34d5007af30"
        }
    },
    "shortcuts": [
        [
            "app\\flux_down.exe",
            "FluxDown"
        ]
    ],
    "link": [
        "$env:AppData\\FluxDown",
        "$env:LocalAppData\\FluxDown"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "$release = (Invoke-RestMethod 'https://fluxdown.zerx.dev/api/changelog').releases[0]",
            "$version = $release.tag -replace '^v'",
            "$dl = $release.assets | Where-Object { $_.name -match 'windows-x64-setup.exe$' } | Select-Object -First 1 | Select-Object -ExpandProperty download_url",
            "$url = 'https://fluxdown.zerx.dev' + $dl",
            "\"ver:$version;\"",
            "\"x64:$url;\"",
            "\"arm64:$($url.Replace('x64','arm64'));\""
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64"
            },
            "arm64": {
                "url": "$matchArm64"
            }
        }
    }
}
