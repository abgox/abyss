{
    "version": "3.32.1",
    "description": "一个开源桌面应用程序，它将您的 Gmail 使用体验从浏览器带到桌面 | An open-source desktop application that brings your Gmail experience out of the browser and onto your desktop",
    "homepage": "https://meru.so/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/zoidsh/meru/releases/download/v3.32.1/Meru-Setup-3.32.1.exe",
            "hash": "1c1e9ff2acee98d2265b8c272fe261a2e74c8e5bb9491ca9600614c1a371d56c"
        },
        "arm64": {
            "url": "https://github.com/zoidsh/meru/releases/download/v3.32.1/Meru-Setup-3.32.1.exe",
            "hash": "1c1e9ff2acee98d2265b8c272fe261a2e74c8e5bb9491ca9600614c1a371d56c"
        }
    },
    "shortcuts": [
        [
            "app\\Meru.exe",
            "Meru"
        ]
    ],
    "link": "$env:AppData\\Meru",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Meru.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\meru-updater\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zoidsh/meru/releases/download/v$version/Meru-Setup-$version.exe"
            },
            "arm64": {
                "url": "https://github.com/zoidsh/meru/releases/download/v$version/Meru-Setup-$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
