{
    "version": "3.46.0",
    "description": "一个开源桌面应用程序，它将您的 Gmail 使用体验从浏览器带到桌面 | An open-source desktop application that brings your Gmail experience out of the browser and onto your desktop",
    "homepage": "https://meru.so/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/zoidsh/meru/releases/download/v3.46.0/Meru-Setup-3.46.0.exe",
            "hash": "f7f67e0616953696672c7532d2da476ca41727d62664b0edfee6fa6ae8cfbd8e"
        },
        "arm64": {
            "url": "https://github.com/zoidsh/meru/releases/download/v3.46.0/Meru-Setup-3.46.0.exe",
            "hash": "f7f67e0616953696672c7532d2da476ca41727d62664b0edfee6fa6ae8cfbd8e"
        }
    },
    "shortcuts": [
        [
            "app\\Meru.exe",
            "Meru"
        ]
    ],
    "link": "$env:AppData\\Meru",
    "cleanup": "$env:LocalAppData\\meru-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Meru.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zoidsh/meru/releases/download/v$version/Meru-Setup-$version.exe"
            },
            "arm64": {
                "url": "https://github.com/zoidsh/meru/releases/download/v$version/Meru-Setup-$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
