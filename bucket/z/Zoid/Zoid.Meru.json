{
    "version": "3.56.3",
    "description": "一个开源桌面应用程序，它将您的 Gmail 使用体验从浏览器带到桌面 | An open-source desktop application that brings your Gmail experience out of the browser and onto your desktop",
    "homepage": "https://meru.so",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/zoidsh/meru/releases/download/v3.56.3/Meru-Setup-3.56.3.exe",
            "hash": "4a03b10741c9cd775cbfa851441ae08e76cd5ccae1b6c0d84c2d46fdcfd0b837"
        },
        "arm64": {
            "url": "https://github.com/zoidsh/meru/releases/download/v3.56.3/Meru-Setup-3.56.3.exe",
            "hash": "4a03b10741c9cd775cbfa851441ae08e76cd5ccae1b6c0d84c2d46fdcfd0b837"
        }
    },
    "shortcuts": [
        [
            "app\\Meru.exe",
            "Meru"
        ]
    ],
    "link": "$env:AppData\\Meru",
    "cleanup": "$env:LocalAppData\\meru-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Meru.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zoidsh/meru/releases/download/v$version/Meru-Setup-$version.exe"
            },
            "arm64": {
                "url": "https://github.com/zoidsh/meru/releases/download/v$version/Meru-Setup-$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
