{
    "version": "3.48.0",
    "description": "一个开源桌面应用程序，它将您的 Gmail 使用体验从浏览器带到桌面 | An open-source desktop application that brings your Gmail experience out of the browser and onto your desktop",
    "homepage": "https://meru.so/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/zoidsh/meru/releases/download/v3.48.0/Meru-Setup-3.48.0.exe",
            "hash": "835580aebe125e69656570c33f1fab05605a47fb752db193b0d6285e5aed4fd6"
        },
        "arm64": {
            "url": "https://github.com/zoidsh/meru/releases/download/v3.48.0/Meru-Setup-3.48.0.exe",
            "hash": "835580aebe125e69656570c33f1fab05605a47fb752db193b0d6285e5aed4fd6"
        }
    },
    "shortcuts": [
        [
            "app\\Meru.exe",
            "Meru"
        ]
    ],
    "link": "$env:AppData\\Meru",
    "cleanup": "$env:LocalAppData\\meru-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Meru.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zoidsh/meru/releases/download/v$version/Meru-Setup-$version.exe"
            },
            "arm64": {
                "url": "https://github.com/zoidsh/meru/releases/download/v$version/Meru-Setup-$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
