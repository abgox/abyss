{
    "version": "3.0.12",
    "description": "一个 AI 助手 | An AI assistant",
    "homepage": "https://www.kimi.com/",
    "license": {
        "identifier": "Unknown",
        "url": "https://kimi.moonshot.cn/user/agreement/modeluse"
    },
    "architecture": {
        "64bit": {
            "url": "https://kimi-img.moonshot.cn/app/download/windows/kimi_3.0.12.exe",
            "hash": "55316c8b567fbfc294805ba8a1c75c2fb60e2045ecfd0adcfb98df37100f08f9"
        }
    },
    "shortcuts": [
        [
            "app\\Kimi 智能助手.exe",
            "Kimi 智能助手"
        ]
    ],
    "link": [
        "$env:AppData\\kimi",
        "$env:LocalAppData\\KimiAppCache"
    ],
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'MoonshotAI.Kimi' 'exe'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_user.InstallerSha256"
                }
            }
        }
    }
}
