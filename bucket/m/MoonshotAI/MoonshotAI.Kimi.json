{
    "version": "3.0.27",
    "description": "一个 AI 助手 | An AI assistant",
    "homepage": "https://www.kimi.com",
    "license": {
        "identifier": "Unknown",
        "url": "https://kimi.moonshot.cn/user/agreement/modeluse"
    },
    "architecture": {
        "64bit": {
            "url": "https://kimi-img.moonshot.cn/app/upgrade/Kimi-Setup-3.0.27.exe",
            "hash": "319cbf3bdfe920f0a77a8cc6ee54753998faea750576e7f18da68e40ee0f3e38"
        }
    },
    "shortcuts": [
        [
            "app\\Kimi 智能助手.exe",
            "Kimi 智能助手"
        ]
    ],
    "link": [
        "$env:AppData\\kimi",
        "$env:LocalAppData\\KimiAppCache"
    ],
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'MoonshotAI.Kimi' 'exe'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_user.InstallerSha256"
                }
            }
        }
    }
}
