{
    "version": "150.0",
    "description": "一款易于设置和定制的免费电子邮件应用程序 | A free email application that's easy to set up and customize",
    "homepage": "https://www.thunderbird.net/",
    "license": {
        "identifier": "Freeware",
        "url": "https://www.mozilla.org/en-US/foundation/licensing/"
    },
    "architecture": {
        "64bit": {
            "url": "https://download-installer.cdn.mozilla.net/pub/thunderbird/releases/150.0/win64/en-US/Thunderbird%20Setup%20150.0.exe",
            "hash": "d60a4d724669d34c87ca61425ddaf08fd5284f54d966cdcb1d523f732b9ae300"
        }
    },
    "shortcuts": [
        [
            "app\\thunderbird.exe",
            "Thunderbird"
        ],
        [
            "app\\thunderbird.exe",
            "Thunderbird Profile Manager",
            "-P"
        ]
    ],
    "link": [
        "$env:AppData\\Thunderbird",
        "$env:LocalAppData\\Thunderbird"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall\\helper.exe' -ArgumentList '/S','/PreventRebootRequired=true',\"/InstallDirectoryPath='$dir\\app'\""
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'Mozilla.Thunderbird' 'exe'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_machine.InstallerSha256"
                }
            }
        }
    }
}
