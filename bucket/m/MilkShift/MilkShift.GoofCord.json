{
    "version": "2.2.0",
    "description": "一款可高度配置且注重隐私的 Discord 客户端 | A highly configurable and privacy minded discord client",
    "homepage": "https://github.com/Milkshiift/GoofCord",
    "license": {
        "identifier": "OSL-3.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Milkshiift/GoofCord/releases/download/v2.2.0/GoofCord-Setup-x64.exe",
            "hash": "df072afbeff68ad7d875febce0bf5eaee75a21c5a6c5ce940f8b6fa89f8f3f55"
        },
        "arm64": {
            "url": "https://github.com/Milkshiift/GoofCord/releases/download/v2.2.0/GoofCord-Setup-arm64.exe",
            "hash": "0afa0cf94bb57a076f01bc75a00e567c1e547da4b864ee7eb3d8b7e36a76f51a"
        }
    },
    "shortcuts": [
        [
            "app\\GoofCord.exe",
            "GoofCord"
        ]
    ],
    "link": "$env:AppData\\goofcord",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall GoofCord.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\goofcord-updater\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Milkshiift/GoofCord/releases/download/v$version/GoofCord-Setup-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/Milkshiift/GoofCord/releases/download/v$version/GoofCord-Setup-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
