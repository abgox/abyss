{
    "version": "2.1.1",
    "description": "一款可高度配置且注重隐私的 Discord 客户端 | A highly configurable and privacy minded discord client",
    "homepage": "https://github.com/Milkshiift/GoofCord",
    "license": {
        "identifier": "OSL-3.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Milkshiift/GoofCord/releases/download/v2.1.1/GoofCord-Setup-x64.exe",
            "hash": "a24019c048ae2cadcb12cd38e78eb9645009970da6085f7b1814cd27d2ea20ae"
        },
        "arm64": {
            "url": "https://github.com/Milkshiift/GoofCord/releases/download/v2.1.1/GoofCord-Setup-arm64.exe",
            "hash": "4eca981029fbefda233edf1c5a89ccc5e25d34d48d0bb2d16c5c0eb70808339e"
        }
    },
    "shortcuts": [
        [
            "app\\GoofCord.exe",
            "GoofCord"
        ]
    ],
    "link": "$env:AppData\\goofcord",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall GoofCord.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\goofcord-updater\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Milkshiift/GoofCord/releases/download/v$version/GoofCord-Setup-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/Milkshiift/GoofCord/releases/download/v$version/GoofCord-Setup-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
