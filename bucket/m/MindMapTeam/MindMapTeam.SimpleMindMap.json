{
    "version": "0.18.4",
    "description": "一个还算强大的 Web 思维导图 | A relatively powerful web mind map",
    "homepage": "https://github.com/wanglin2/mind-map",
    "license": {
        "identifier": "Freemium"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/wanglin2/mind-map/releases/download/0.18.4/Setup.0.18.4.exe",
            "hash": "348a4224fecb1e02d1f7ecb705db726a2c0a96add35e69ec3dfafdd5527a1cbf"
        }
    },
    "shortcuts": [
        [
            "app\\思绪思维导图.exe",
            "思绪思维导图"
        ]
    ],
    "link": "$env:AppData\\thoughts",
    "cleanup": "$env:LocalAppData\\thoughts-updater",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall 思绪思维导图.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/wanglin2/mind-map/releases/download/$version/Setup.$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
