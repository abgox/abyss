{
    "version": "0.10.0",
    "description": "一个原生的 Windows 和 Linux（Wayland/X11）PDF 浏览器，带有可配置的快捷键绑定 | A native pdf viewer for Windows and Linux (Wayland/X11) with configurable keybindings",
    "homepage": "https://github.com/vincent-uden/miro",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/vincent-uden/miro/releases/download/v0.10.0/miro-pdf.exe",
            "hash": "09009fe8364ad359085c06806a8ab81f2d8c0834c0ba5012713cd2fd4131c4c2"
        }
    },
    "bin": "miro-pdf.exe",
    "shortcuts": [
        [
            "miro-pdf.exe",
            "Miro PDF"
        ]
    ],
    "link": "$home\\.config\\miro-pdf",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/vincent-uden/miro/releases/download/v$version/miro-pdf.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
