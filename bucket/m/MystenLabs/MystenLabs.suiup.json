{
    "version": "0.0.12",
    "description": "Sui 生态系统中命令行界面工具的安装程序和管理器 | The installer and manager for CLI tools in the Sui ecosystem",
    "homepage": "https://github.com/MystenLabs/suiup",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/MystenLabs/suiup/releases/download/v0.0.12/suiup-Windows-msvc-x86_64.zip",
            "hash": "2b3fda8fe114d14fdebc4f2a3d5ca687e9239bd5dda3e6b7508e79024972c67c"
        },
        "arm64": {
            "url": "https://github.com/MystenLabs/suiup/releases/download/v0.0.12/suiup-Windows-msvc-arm64.zip",
            "hash": "5ec861403d9cbf75aeac38464bd7bbdd0b0c10b5ec6fe2fe5d484abc3345136a"
        }
    },
    "extract_to": "app",
    "env_set": {
        "SUIUP_DISABLE_UPDATE_WARNINGS": "true"
    },
    "env_add_path_expand": "$env:LocalAppData\\bin",
    "bin": "app\\suiup.exe",
    "link": "$env:LocalAppData\\suiup",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/MystenLabs/suiup/releases/download/v$version/suiup-Windows-msvc-x86_64.zip"
            },
            "arm64": {
                "url": "https://github.com/MystenLabs/suiup/releases/download/v$version/suiup-Windows-msvc-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
