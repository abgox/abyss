{
    "version": "0.0.14",
    "description": "Sui 生态系统中命令行界面工具的安装程序和管理器 | The installer and manager for CLI tools in the Sui ecosystem",
    "homepage": "https://github.com/MystenLabs/suiup",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/MystenLabs/suiup/releases/download/v0.0.14/suiup-Windows-msvc-x86_64.zip",
            "hash": "19f56b2eaa6d53c993d580899ede40ed3d8cb92ebf6372af12658a07ddf6a991"
        },
        "arm64": {
            "url": "https://github.com/MystenLabs/suiup/releases/download/v0.0.14/suiup-Windows-msvc-arm64.zip",
            "hash": "a6ebdb100be4d8f50a11fafb7aa05df91ae933eac80a6577d801b5dbe1487035"
        }
    },
    "extract_to": "app",
    "env_set": {
        "SUIUP_DISABLE_UPDATE_WARNINGS": "true"
    },
    "env_add_path_expand": "$env:LocalAppData\\bin",
    "bin": "app\\suiup.exe",
    "link": "$env:LocalAppData\\suiup",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/MystenLabs/suiup/releases/download/v$version/suiup-Windows-msvc-x86_64.zip"
            },
            "arm64": {
                "url": "https://github.com/MystenLabs/suiup/releases/download/v$version/suiup-Windows-msvc-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
