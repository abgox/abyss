{
    "version": "0.3.0",
    "description": "基于 Avalonia 构建、适用于 PowerShell 的跨平台桌面图形用户界面框架 | Cross-platform Desktop GUI framework for PowerShell powered by Avalonia",
    "homepage": "https://github.com/mdgrs-mei/GliderUI",
    "license": {
        "identifier": "MIT"
    },
    "url": "https://cdn.powershellgallery.com/packages/gliderui.0.3.0.nupkg",
    "hash": "c7e6b561879a38ce72ba0c3ca715d83be38fde77b2b72b5b64ebc360bcf5a941",
    "psmodule": {
        "name": "GliderUI"
    },
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromPowerShellGallery"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "url": "https://cdn.powershellgallery.com/packages/gliderui.$version.nupkg"
    }
}
