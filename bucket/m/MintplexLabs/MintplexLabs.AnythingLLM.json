{
    "version": "1.12.1",
    "description": "集桌面与 Docker 功能于一体的 AI 应用程序，内置 RAG、AI 代理等多种功能 | The all-in-one Desktop & Docker AI application with built-in RAG, AI agents, and more",
    "homepage": "https://anythingllm.com/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://cdn.anythingllm.com/latest/AnythingLLMDesktop.exe",
            "hash": "af8c16f22215fad4dee4d66941c8469156c903faf08ca8abe6fdb5e73c4d95c8"
        },
        "arm64": {
            "url": "https://cdn.anythingllm.com/latest/AnythingLLMDesktop-Arm64.exe",
            "hash": "62101ce05f4c0777e1e2fdcfad7e4f4e6ce92c25fdee395c699760961bc55721"
        }
    },
    "shortcuts": [
        [
            "app\\AnythingLLM.exe",
            "AnythingLLM"
        ]
    ],
    "link": "$env:AppData\\anythingllm-desktop",
    "cleanup": "$env:LocalAppData\\anythingllm-desktop-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall AnythingLLM.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://github.com/Mintplex-Labs/anything-llm",
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://cdn.anythingllm.com/latest/AnythingLLMDesktop.exe"
            },
            "arm64": {
                "url": "https://cdn.anythingllm.com/latest/AnythingLLMDesktop-Arm64.exe"
            }
        }
    }
}
