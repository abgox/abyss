{
    "version": "1.14.0",
    "description": "集桌面与 Docker 功能于一体的 AI 应用程序，内置 RAG、AI 代理等多种功能 | The all-in-one Desktop & Docker AI application with built-in RAG, AI agents, and more",
    "homepage": "https://anythingllm.com/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://cdn.anythingllm.com/latest/AnythingLLMDesktop.exe",
            "hash": "7b5aaf27fc49001f60449078c11b91b24464142ec6a525de407f3dd3fbda93cc"
        },
        "arm64": {
            "url": "https://cdn.anythingllm.com/latest/AnythingLLMDesktop-Arm64.exe",
            "hash": "b927ac8e012c88931556d25e15d620bdb508598424c99dcb685f0f8449d32087"
        }
    },
    "shortcuts": [
        [
            "app\\AnythingLLM.exe",
            "AnythingLLM"
        ]
    ],
    "link": "$env:AppData\\anythingllm-desktop",
    "cleanup": "$env:LocalAppData\\anythingllm-desktop-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall AnythingLLM.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://github.com/Mintplex-Labs/anything-llm",
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://cdn.anythingllm.com/latest/AnythingLLMDesktop.exe"
            },
            "arm64": {
                "url": "https://cdn.anythingllm.com/latest/AnythingLLMDesktop-Arm64.exe"
            }
        }
    }
}
