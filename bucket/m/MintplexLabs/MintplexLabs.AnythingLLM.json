{
    "version": "1.15.0",
    "description": "集桌面与 Docker 功能于一体的 AI 应用程序，内置 RAG、AI 代理等多种功能 | The all-in-one Desktop & Docker AI application with built-in RAG, AI agents, and more",
    "homepage": "https://anythingllm.com",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Mintplex-Labs/anything-llm/releases/download/v1.15.0/AnythingLLMDesktop.exe",
            "hash": "11478d5701163e84387550f30497526c88d4a483edee7475f0810529ffa03944"
        },
        "arm64": {
            "url": "https://github.com/Mintplex-Labs/anything-llm/releases/download/v1.15.0/AnythingLLMDesktop-Arm64.exe",
            "hash": "0b0c5e51665062113d8166ab75f86317fdd386734f3224765e32207dac538d62"
        }
    },
    "shortcuts": [
        [
            "app\\AnythingLLM.exe",
            "AnythingLLM"
        ]
    ],
    "link": "$env:AppData\\anythingllm-desktop",
    "cleanup": "$env:LocalAppData\\anythingllm-desktop-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall AnythingLLM.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://github.com/Mintplex-Labs/anything-llm",
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Mintplex-Labs/anything-llm/releases/download/v$version/AnythingLLMDesktop.exe"
            },
            "arm64": {
                "url": "https://github.com/Mintplex-Labs/anything-llm/releases/download/v$version/AnythingLLMDesktop-Arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
