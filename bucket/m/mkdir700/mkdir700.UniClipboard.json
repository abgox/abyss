{
    "version": "0.19.0",
    "description": "隐私优先的、点对点加密传输的跨设备剪贴板同步工具 | Privacy-first, encrypted peer-to-peer, cross-device clipboard synchronization tool",
    "homepage": "https://uniclipboard.app",
    "license": {
        "identifier": "AGPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/UniClipboard/UniClipboard/releases/download/v0.19.0/UniClipboard_0.19.0_x64-setup.exe",
            "hash": "d09f3b161e7e05683894fc571ed2a7e9d5bbd4f8a93b7cf159d8d7df72218b7f"
        },
        "arm64": {
            "url": "https://github.com/UniClipboard/UniClipboard/releases/download/v0.19.0/UniClipboard_0.19.0_arm64-setup.exe",
            "hash": "63f07512380c0ba3d3ef012b396a31285ff54bf6fb592405c74bfc50d71a831e"
        }
    },
    "shortcuts": [
        [
            "app\\UniClipboard.exe",
            "UniClipboard"
        ]
    ],
    "link": "$env:LocalAppData\\app.uniclipboard.desktop",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/UniClipboard/UniClipboard/releases/download/v$version/UniClipboard_$version_x64-setup.exe"
            },
            "arm64": {
                "url": "https://github.com/UniClipboard/UniClipboard/releases/download/v$version/UniClipboard_$version_arm64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
