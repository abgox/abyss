{
    "version": "3.10",
    "description": "可让你轻松配置 Windows 系统内置的自动登录机制 | Enables you to easily configure Windows' built-in autologon mechanism",
    "homepage": "https://learn.microsoft.com/sysinternals/downloads/autologon",
    "license": {
        "identifier": "Proprietary"
    },
    "architecture": {
        "64bit": {
            "url": "https://download.sysinternals.com/files/AutoLogon.zip",
            "hash": "9a477624ea6488acfbd2cefcc392fac082383a3a8db1c6d867af1b410f4731b7",
            "bin": [
                [
                    "app\\Autologon64.exe",
                    "autologon",
                    "/accepteula"
                ]
            ],
            "shortcuts": [
                [
                    "app\\Autologon64.exe",
                    "Autologon",
                    "/accepteula"
                ]
            ]
        },
        "arm64": {
            "url": "https://download.sysinternals.com/files/AutoLogon.zip",
            "hash": "9a477624ea6488acfbd2cefcc392fac082383a3a8db1c6d867af1b410f4731b7",
            "bin": [
                [
                    "app\\Autologon64a.exe",
                    "autologon",
                    "/accepteula"
                ]
            ],
            "shortcuts": [
                [
                    "app\\Autologon64a.exe",
                    "Autologon",
                    "/accepteula"
                ]
            ]
        }
    },
    "extract_to": "app",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'Microsoft.Sysinternals.Autologon' 'zip'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_machine.InstallerSha256"
                }
            },
            "arm64": {
                "url": "$matchArm64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.arm64_machine.InstallerSha256"
                }
            }
        }
    }
}
