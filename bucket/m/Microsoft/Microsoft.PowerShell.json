{
    "version": "7.5.6",
    "description": "pwsh - 一个跨平台的 PowerShell Core | pwsh - A cross-platform PowerShell Core",
    "homepage": "https://github.com/PowerShell/PowerShell",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.5.6/PowerShell-7.5.6.msixbundle",
            "hash": "596a9fb9cc6836a7432e736895cd63f2b0267dfe67ec6c660f1a1e719f9bb2ce"
        },
        "arm64": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.5.6/PowerShell-7.5.6.msixbundle",
            "hash": "596a9fb9cc6836a7432e736895cd63f2b0267dfe67ec6c660f1a1e719f9bb2ce"
        }
    },
    "env_set_shared": {
        "POWERSHELL_UPDATECHECK": {
            "value": "Off",
            "owner": [
                "Microsoft.PowerShell",
                "Microsoft.PowerShell.Preview"
            ]
        },
        "POWERSHELL_TELEMETRY_OPTOUT": {
            "value": "1",
            "owner": [
                "Microsoft.PowerShell",
                "Microsoft.PowerShell.Preview"
            ]
        }
    },
    "commands": "pwsh",
    "link": [
        "$home\\Documents\\PowerShell",
        "$env:AppData\\Microsoft\\Windows\\PowerShell"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "if ($PSVersionTable.PSEdition -eq 'Core' -and !$PSVersionTable.PSVersion.PreReleaseLabel) {",
        "    if ($PSUICulture -like 'zh*') {",
        "       Write-Host \"不能在 PowerShell 中安装、更新、卸载 PowerShell\" -ForegroundColor Red",
        "    }",
        "    else {",
        "       Write-Host \"You cannot $cmd PowerShell in PowerShell.\" -ForegroundColor Red",
        "    }",
        "   exit 1",
        "}",
        "A-New-Link",
        "A-Add-MsixPackage 'Microsoft.PowerShell_8wekyb3d8bbwe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "if ($PSVersionTable.PSEdition -eq 'Core' -and !$PSVersionTable.PSVersion.PreReleaseLabel) {",
        "    if ($PSUICulture -like 'zh*') {",
        "       Write-Host \"不能在 PowerShell 中安装、更新、卸载 PowerShell\" -ForegroundColor Red",
        "    }",
        "    else {",
        "       Write-Host \"You cannot $cmd PowerShell in PowerShell.\" -ForegroundColor Red",
        "    }",
        "   exit 1",
        "}",
        "A-Remove-MsixPackage",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/PowerShell/PowerShell/releases/download/v$version/PowerShell-$version.msixbundle"
            },
            "arm64": {
                "url": "https://github.com/PowerShell/PowerShell/releases/download/v$version/PowerShell-$version.msixbundle"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
