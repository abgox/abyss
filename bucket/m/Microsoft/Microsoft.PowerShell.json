{
    "version": "7.6.0",
    "description": "pwsh - 一个跨平台的 PowerShell Core | pwsh - A cross-platform PowerShell Core",
    "homepage": "https://github.com/PowerShell/PowerShell",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.6.0/PowerShell-7.6.0.msixbundle",
            "hash": "f14326a4d9f61b61e78ffdee253e8d139e979e27849a12a7482778cf89136a48"
        },
        "arm64": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.6.0/PowerShell-7.6.0.msixbundle",
            "hash": "f14326a4d9f61b61e78ffdee253e8d139e979e27849a12a7482778cf89136a48"
        }
    },
    "env_set": {
        "POWERSHELL_UPDATECHECK": "Off",
        "POWERSHELL_TELEMETRY_OPTOUT": "1"
    },
    "commands": "pwsh",
    "link": "$home\\Documents\\PowerShell",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "if ($PSVersionTable.PSEdition -eq 'Core' -and !$PSVersionTable.PSVersion.PreReleaseLabel) {",
        "    if ($PSUICulture -like 'zh*') {",
        "       Write-Host \"不能在 PowerShell 中安装、更新、卸载 PowerShell\" -ForegroundColor Red",
        "    }",
        "    else {",
        "       Write-Host \"You cannot $cmd PowerShell in PowerShell.\" -ForegroundColor Red",
        "    }",
        "   exit 1",
        "}",
        "A-New-Link",
        "A-Add-MsixPackage 'Microsoft.PowerShell_8wekyb3d8bbwe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "if ($PSVersionTable.PSEdition -eq 'Core' -and !$PSVersionTable.PSVersion.PreReleaseLabel) {",
        "    if ($PSUICulture -like 'zh*') {",
        "       Write-Host \"不能在 PowerShell 中安装、更新、卸载 PowerShell\" -ForegroundColor Red",
        "    }",
        "    else {",
        "       Write-Host \"You cannot $cmd PowerShell in PowerShell.\" -ForegroundColor Red",
        "    }",
        "   exit 1",
        "}",
        "A-Remove-MsixPackage",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/PowerShell/PowerShell/releases/download/v$version/PowerShell-$version.msixbundle"
            },
            "arm64": {
                "url": "https://github.com/PowerShell/PowerShell/releases/download/v$version/PowerShell-$version.msixbundle"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
