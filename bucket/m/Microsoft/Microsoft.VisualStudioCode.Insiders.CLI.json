{
    "version": "1.129.0-815db7",
    "description": "(Insiders 版本) vscode - 一个轻量级、功能强大，插件生态丰富的文件编辑器 | (Insiders Edition) vscode - A lightweight but powerful source code editor",
    "homepage": "https://code.visualstudio.com",
    "license": {
        "identifier": "Microsoft Pre-Release Software License",
        "url": "https://code.visualstudio.com/license/insiders"
    },
    "architecture": {
        "64bit": {
            "url": "https://update.code.visualstudio.com/1.129.0-insider/cli-win32-x64/insider#/dl.7z",
            "hash": "fcf775de79b084fdebbaedb98cb1bef218927723566b1de1432d2b7881de6235"
        },
        "arm64": {
            "url": "https://update.code.visualstudio.com/1.129.0-insider/cli-win32-arm64/insider#/dl.7z",
            "hash": "ab5bc3fc081a8cd1b634f7aaf9da49d693e5d79e49c20c71e6358ab77fec2594"
        }
    },
    "extract_to": "app",
    "bin": "app\\code-insiders.exe",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "$res = Invoke-RestMethod 'https://update.code.visualstudio.com/api/update/cli-win32-x64/insider/latest'",
            "\"$($res.productVersion)-$($res.hash)\""
        ],
        "regex": "(?<version>.+)-insider-(?<hash>[0-9a-f]{6})[0-9a-f]*",
        "replace": "${version}-${hash}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://update.code.visualstudio.com/$matchHead-insider/cli-win32-x64/insider#/dl.7z",
                "hash": {
                    "url": "https://update.code.visualstudio.com/api/update/cli-win32-x64/insider/latest",
                    "jsonpath": "$.sha256hash"
                }
            },
            "arm64": {
                "url": "https://update.code.visualstudio.com/$matchHead-insider/cli-win32-arm64/insider#/dl.7z",
                "hash": {
                    "url": "https://update.code.visualstudio.com/api/update/cli-win32-arm64/insider/latest",
                    "jsonpath": "$.sha256hash"
                }
            }
        }
    }
}
