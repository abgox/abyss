{
    "version": "7.7.0-preview.1",
    "description": "pwsh - 一个跨平台的 PowerShell Core | pwsh - A cross-platform PowerShell Core",
    "homepage": "https://github.com/PowerShell/PowerShell",
    "license": {
        "identifier": "MIT"
    },
    "notes_cn": [
        "Microsoft.PowerShell.Preview 不使用 Link 进行数据持久化",
        "因为它和 Microsoft.PowerShell 共用数据",
        "参考: https://abyss.abgox.com/faq/shared-data"
    ],
    "notes": [
        "Microsoft.PowerShell.Preview does not use Link for data persistence.",
        "Because it shares the data with Microsoft.PowerShell.",
        "Refer to: https://abyss.abgox.com/faq/shared-data"
    ],
    "suggest": {
        "PowerShell": "abyss/Microsoft.PowerShell"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.7.0-preview.1/PowerShellPreview-7.7.0-preview.1.msixbundle",
            "hash": "fb9a2a584030b48a1fd5a8bfb3c95e9c8b8ff8aae3e21305bfe16a33d805e81c"
        },
        "arm64": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.7.0-preview.1/PowerShellPreview-7.7.0-preview.1.msixbundle",
            "hash": "fb9a2a584030b48a1fd5a8bfb3c95e9c8b8ff8aae3e21305bfe16a33d805e81c"
        }
    },
    "env_set_shared": {
        "POWERSHELL_UPDATECHECK": {
            "value": "Off",
            "owner": [
                "Microsoft.PowerShell",
                "Microsoft.PowerShell-LTS",
                "Microsoft.PowerShell.Preview"
            ]
        },
        "POWERSHELL_TELEMETRY_OPTOUT": {
            "value": "1",
            "owner": [
                "Microsoft.PowerShell",
                "Microsoft.PowerShell-LTS",
                "Microsoft.PowerShell.Preview"
            ]
        }
    },
    "commands": "pwsh-preview",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "if ($PSVersionTable.PSEdition -eq 'Core' -and $PSVersionTable.PSVersion.PreReleaseLabel) {",
        "    if ($PSUICulture -like 'zh*') {",
        "       Write-Host \"不能在 PowerShell Preview 中安装、更新、卸载 PowerShell Preview\" -ForegroundColor Red",
        "    }",
        "    else {",
        "       Write-Host \"You cannot $cmd PowerShell Preview in PowerShell Preview.\" -ForegroundColor Red",
        "    }",
        "   exit 1",
        "}",
        "A-Add-MsixPackage 'Microsoft.PowerShellPreview_8wekyb3d8bbwe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "if ($PSVersionTable.PSEdition -eq 'Core' -and $PSVersionTable.PSVersion.PreReleaseLabel) {",
        "    if ($PSUICulture -like 'zh*') {",
        "       Write-Host \"不能在 PowerShell Preview 中安装、更新、卸载 PowerShell Preview\" -ForegroundColor Red",
        "    }",
        "    else {",
        "       Write-Host \"You cannot $cmd PowerShell Preview in PowerShell Preview.\" -ForegroundColor Red",
        "    }",
        "   exit 1",
        "}",
        "A-Remove-MsixPackage",
        "# A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-PreVersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/PowerShell/PowerShell/releases/download/v$version/PowerShellPreview-$version.msixbundle"
            },
            "arm64": {
                "url": "https://github.com/PowerShell/PowerShell/releases/download/v$version/PowerShellPreview-$version.msixbundle"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
