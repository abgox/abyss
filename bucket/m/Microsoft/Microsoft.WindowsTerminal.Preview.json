{
    "version": "1.25.622.0",
    "description": "新的 Windows 终端，为 Windows 提供标签命令行体验 | The new Windows Terminal, a tabbed command line experience for Windows",
    "homepage": "https://github.com/microsoft/terminal",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/microsoft/terminal/releases/download/v1.25.622.0/Microsoft.WindowsTerminalPreview_1.25.622.0_8wekyb3d8bbwe.msixbundle",
            "hash": "156f20dea6f58b27f44180ce616c2745170010273281e62a2d7e2740c450e9eb"
        },
        "arm64": {
            "url": "https://github.com/microsoft/terminal/releases/download/v1.25.622.0/Microsoft.WindowsTerminalPreview_1.25.622.0_8wekyb3d8bbwe.msixbundle",
            "hash": "156f20dea6f58b27f44180ce616c2745170010273281e62a2d7e2740c450e9eb"
        }
    },
    "link": "$env:LocalAppData\\Packages\\Microsoft.WindowsTerminalPreview_8wekyb3d8bbwe\\LocalState",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "$parentId = (Get-Process | Where-Object { $_.Id -eq $PID }).Parent.Id",
        "$processName = (Get-Process | Where-Object { $_.Id -eq $parentId }).ProcessName",
        "if ($processName -eq 'WindowsTerminal') {",
        "    if ($PSUICulture -like 'zh*') {",
        "       Write-Host \"不能在 WindowsTerminal 中安装、更新、卸载 WindowsTerminal\" -ForegroundColor Red",
        "    }",
        "    else {",
        "       Write-Host \"You cannot $cmd WindowsTerminal in WindowsTerminal.\" -ForegroundColor Red",
        "    }",
        "   exit 1",
        "}",
        "A-New-Link",
        "A-Add-MsixPackage 'Microsoft.WindowsTerminalPreview_8wekyb3d8bbwe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "$parentId = (Get-Process | Where-Object { $_.Id -eq $PID }).Parent.Id",
        "$processName = (Get-Process | Where-Object { $_.Id -eq $parentId }).ProcessName",
        "if ($processName -eq 'WindowsTerminal') {",
        "    if ($PSUICulture -like 'zh*') {",
        "       Write-Host \"不能在 WindowsTerminal 中安装、更新、卸载 WindowsTerminal\" -ForegroundColor Red",
        "    }",
        "    else {",
        "       Write-Host \"You cannot $cmd WindowsTerminal in WindowsTerminal.\" -ForegroundColor Red",
        "    }",
        "   exit 1",
        "}",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Remove-MsixPackage"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'Microsoft.WindowsTerminal.Preview' 'msixbundle'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_machine.InstallerSha256"
                }
            },
            "arm64": {
                "url": "$matchArm64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.arm64_machine.InstallerSha256"
                }
            }
        }
    }
}
