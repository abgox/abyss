{
    "version": "0.98.0",
    "description": "一组实用程序，供高级用户调整和简化他们的 Windows 体验以提高生产力 | A set of utilities for power users to tune and streamline their Windows experience for greater productivity",
    "homepage": "https://github.com/microsoft/PowerToys",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/microsoft/PowerToys/releases/download/v0.98.0/PowerToysUserSetup-0.98.0-x64.exe",
            "hash": "0dbc8d647d17751d2a6b9e6976f4e48055bc054d2601e3724813260243430d4b"
        },
        "arm64": {
            "url": "https://github.com/microsoft/PowerToys/releases/download/v0.98.0/PowerToysUserSetup-0.98.0-arm64.exe",
            "hash": "6ff46f1ae83bfd9632b54fa5247d18ce70e3051c2cff0ee55d45979cf84b243a"
        }
    },
    "location": "$env:LocalAppData\\PowerToys",
    "link": "$env:LocalAppData\\Microsoft\\PowerToys",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Require-Admin",
        "Expand-DarkArchive \"$dir\\$fname\" \"$dir\\.tmp\"",
        "Get-ChildItem $dir -Recurse -Filter '*.msi' | Select-Object -First 1 | ForEach-Object { Move-Item $_.FullName \"$dir\\dl.msi\" -Force }",
        "Remove-Item \"$dir\\.tmp\", \"$dir\\$fname\" -Force -Recurse -ErrorAction SilentlyContinue",
        "A-Install-Msi -ArgumentList '/i', \"`\"$dir\\dl.msi`\"\", '/passive', '/norestart'",
        "A-Hold-App"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Uninstall-Manually \"$env:LocalAppData\\PowerToys\"",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/microsoft/PowerToys/releases/download/v$version/PowerToysUserSetup-$version-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/microsoft/PowerToys/releases/download/v$version/PowerToysUserSetup-$version-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
