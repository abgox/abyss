{
    "version": "14.51.36231.0",
    "description": "Microsoft Visual C++ v14 可再发行组件包（x64） | The Microsoft Visual C++ v14 Redistributable Package (x64)",
    "homepage": "https://learn.microsoft.com/cpp/windows/latest-supported-vc-redist",
    "license": {
        "identifier": "Proprietary"
    },
    "notes_cn": "由于 Scoop 的命名限制, 'Microsoft.VCRedist.2015+.x64' 被命名为 'Microsoft.VCRedist.2015plus.x64'",
    "notes": "Due to Scoop's naming limit, 'Microsoft.VCRedist.2015+.x64' is named 'Microsoft.VCRedist.2015plus.x64'",
    "architecture": {
        "64bit": {
            "url": "https://download.visualstudio.microsoft.com/download/pr/c1bd4f2c-3672-468e-8480-7ed419dbb641/90E48ADE404E4576D023ABFA374F323555F233982A8805EA9AC63DCA9491A16B/VC_redist.x64.exe",
            "hash": "90e48ade404e4576d023abfa374f323555f233982a8805ea9ac63dca9491a16b"
        }
    },
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Burn"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Uninstall-Burn"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'Microsoft.VCRedist.2015+.x64' 'exe'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_machine.InstallerSha256"
                }
            }
        }
    }
}
