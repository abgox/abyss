{
    "version": "7.6.0",
    "description": "pwsh - 一个跨平台的 PowerShell Core | pwsh - A cross-platform PowerShell Core",
    "homepage": "https://github.com/PowerShell/PowerShell",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.6.0/PowerShell-LTS-7.6.0.msixbundle",
            "hash": "3c305450adb6e77c49e1abd2664ea1649f7939e44d64eeb23f33fd3cb47bde35"
        },
        "arm64": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.6.0/PowerShell-LTS-7.6.0.msixbundle",
            "hash": "3c305450adb6e77c49e1abd2664ea1649f7939e44d64eeb23f33fd3cb47bde35"
        }
    },
    "conflicts": [
        "Microsoft.PowerShell",
        "Microsoft.PowerShell-LTS"
    ],
    "env_set_shared": {
        "POWERSHELL_UPDATECHECK": {
            "value": "Off",
            "owner": [
                "Microsoft.PowerShell",
                "Microsoft.PowerShell-LTS",
                "Microsoft.PowerShell.Preview"
            ]
        },
        "POWERSHELL_TELEMETRY_OPTOUT": {
            "value": "1",
            "owner": [
                "Microsoft.PowerShell",
                "Microsoft.PowerShell-LTS",
                "Microsoft.PowerShell.Preview"
            ]
        }
    },
    "commands": "pwsh",
    "link": [
        "$home\\Documents\\PowerShell",
        "$env:AppData\\Microsoft\\Windows\\PowerShell"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "if ($PSVersionTable.PSEdition -eq 'Core' -and !$PSVersionTable.PSVersion.PreReleaseLabel) {",
        "    if ($PSUICulture -like 'zh*') {",
        "       Write-Host \"不能在 PowerShell 中安装、更新、卸载 PowerShell\" -ForegroundColor Red",
        "    }",
        "    else {",
        "       Write-Host \"You cannot $cmd PowerShell in PowerShell.\" -ForegroundColor Red",
        "    }",
        "   exit 1",
        "}",
        "A-New-Link",
        "A-Add-MsixPackage 'Microsoft.PowerShell-LTS_8wekyb3d8bbwe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "if ($PSVersionTable.PSEdition -eq 'Core' -and !$PSVersionTable.PSVersion.PreReleaseLabel) {",
        "    if ($PSUICulture -like 'zh*') {",
        "       Write-Host \"不能在 PowerShell 中安装、更新、卸载 PowerShell\" -ForegroundColor Red",
        "    }",
        "    else {",
        "       Write-Host \"You cannot $cmd PowerShell in PowerShell.\" -ForegroundColor Red",
        "    }",
        "   exit 1",
        "}",
        "A-Remove-MsixPackage",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/PowerShell/PowerShell/releases/download/v$version/PowerShell-LTS-$version.msixbundle"
            },
            "arm64": {
                "url": "https://github.com/PowerShell/PowerShell/releases/download/v$version/PowerShell-LTS-$version.msixbundle"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
