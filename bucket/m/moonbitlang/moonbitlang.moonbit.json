{
    "version": "0.1.20260713-0.10.4-0.1.20260713",
    "description": "MoonBit 是一种类似 Rust 的语言（支持垃圾回收），也是一个为 WebAssembly 体验优化的工具链 | MoonBit is a Rust-like language (with GC support) and toolchain optimized for WebAssembly experience",
    "homepage": "https://www.moonbitlang.com",
    "license": {
        "identifier": "Apache-2.0,AGPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": [
                "https://cli.moonbitlang.cn/binaries/latest/moonbit-windows-x86_64.zip",
                "https://cli.moonbitlang.cn/cores/core-latest.zip"
            ],
            "hash": [
                "4eee8de1da47e8541469f690b1e4fcb3f662d3a8ef6435b5ba73ec883f938e00",
                "2aeb47967050030437479e21ee61f5312bdbca05867b37b913ade8972080b880"
            ]
        }
    },
    "extract_to": [
        "app\\.moon",
        "app\\.moon\\lib"
    ],
    "env_set": {
        "MOON_HOME": "$dir\\app\\.moon"
    },
    "env_add_path": "app\\.moon\\bin",
    "persist": [
        [
            "app\\.moon\\registry",
            ".moon\\registry"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "Push-Location \"$dir\\app\\.moon\\lib\\core\"",
        "moon.exe bundle --warn-list -a --all --quiet 2>$null",
        "moon.exe bundle --warn-list -a --target wasm-gc --quiet 2>$null",
        "Pop-Location",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "$versionList = @()",
            "Invoke-RestMethod 'https://cli.moonbitlang.com/version.json' | Select-Object -ExpandProperty items | ForEach-Object {",
            "    if ($_.version -match '[\\d.]+') { $versionList += $Matches[0] }",
            "}",
            "$versionList -join '-'"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": [
                    "https://cli.moonbitlang.cn/binaries/latest/moonbit-windows-x86_64.zip",
                    "https://cli.moonbitlang.cn/cores/core-latest.zip"
                ]
            }
        }
    }
}
