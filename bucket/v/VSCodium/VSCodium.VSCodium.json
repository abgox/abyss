    "homepage": "https://vscodium.com/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/VSCodium/vscodium/releases/download/1.112.01907/VSCodiumUserSetup-x64-1.112.01907.exe",
            "hash": "9cbdabfbaa65da602e5293613c7ced780467c877eaa2fb14b84f451ebf4188e2"
        },
        "arm64": {
            "url": "https://github.com/VSCodium/vscodium/releases/download/1.112.01907/VSCodiumUserSetup-arm64-1.112.01907.exe",
            "hash": "887a32573f24c376e918791173abcbf87f146f3ca6b3ede04fc754206f616544"
        }
    },
    "env_add_path": "app\\bin",
    "commands": "codium",
    "shortcuts": [
        [
            "app\\VSCodium.exe",
            "VSCodium"
        ]
    ],
    "link": [
        "$env:AppData\\VSCodium",
        "$home\\.vscode-oss"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/VSCodium/vscodium/releases/download/$version/VSCodiumUserSetup-x64-$version.exe"
            },
            "arm64": {
                "url": "https://github.com/VSCodium/vscodium/releases/download/$version/VSCodiumUserSetup-arm64-$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
