{
    "version": "0.0.6",
    "description": "一款优先本地运行的桌面邮件客户端 | A local-first desktop email client",
    "homepage": "https://pebble.byebug.cn/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/QingJ01/Pebble/releases/download/v0.0.6/Pebble_0.0.6_x64-setup.exe",
            "hash": "407cf3e87742addef54221782b7d8ed903f2a2cb89c9ed2eb3509fed13a6e562"
        }
    },
    "shortcuts": [
        [
            "app\\pebble.exe",
            "Pebble"
        ]
    ],
    "link": "$env:AppData\\com.qingj01.pebble",
    "cleanup": "$env:LocalAppData\\com.qingj01.pebble",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/QingJ01/Pebble/releases/download/v$version/Pebble_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
