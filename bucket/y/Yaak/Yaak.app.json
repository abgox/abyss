{
    "version": "2026.5.0",
    "description": "一款快速、注重隐私的 API 客户端，支持 REST、GraphQL、SSE、WebSocket 和 gRPC | A fast, privacy-first API client for REST, GraphQL, SSE, WebSocket, and gRPC",
    "homepage": "https://yaak.app",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/mountain-loop/yaak/releases/download/v2026.5.0/Yaak_2026.5.0_x64-setup.exe",
            "hash": "29a9cb37473c3a0de234f8af4130b02f85537f17ac4b411bafc08411f1555f9f"
        }
    },
    "shortcuts": [
        [
            "app\\yaak-app.exe",
            "Yaak"
        ]
    ],
    "link": "$env:AppData\\app.yaak.desktop",
    "cleanup": "$env:LocalAppData\\app.yaak.desktop",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/mountain-loop/yaak/releases/download/v$version/Yaak_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
