{
    "version": "5.103.2",
    "description": "Yandex Music 是一项寻找和收听音乐和播客的服务，可为每位用户提供个性化推荐 | Yandex Music is a service for finding and listening to music and podcasts that provides personalized recommendations for each user",
    "homepage": "https://music.yandex.com/",
    "license": {
        "identifier": "Proprietary",
        "url": "https://yandex.com/legal/"
    },
    "architecture": {
        "64bit": {
            "url": "https://music-desktop-application.s3.yandex.net/stable/Yandex_Music_x64_5.103.2.exe",
            "hash": "c6cc940f456dfa7c407d6cc4dbba0c1ea07bff99c22bba712a237ed6536f5ee6"
        }
    },
    "shortcuts": [
        [
            "app\\Яндекс Музыка.exe",
            "Яндекс Музыка"
        ]
    ],
    "link": "$env:AppData\\YandexMusic",
    "cleanup": "$env:LocalAppData\\yandexmusic-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Яндекс Музыка.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'Yandex.Music' 'exe'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_user.InstallerSha256"
                }
            }
        }
    }
}
