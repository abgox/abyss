    "homepage": "https://github.com/hoowhoami/EchoMusic",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/hoowhoami/EchoMusic/releases/download/v2.1.7/EchoMusic-2.1.7-Windows-Setup-x64.exe",
            "hash": "0a83648f34c8c40d74bc5478c31d4d2f8f002b5edfd8c365b938478886e0cf9c"
        },
        "arm64": {
            "url": "https://github.com/hoowhoami/EchoMusic/releases/download/v2.1.7/EchoMusic-2.1.7-Windows-Setup-arm64.exe",
            "hash": "72948dd18b9e16d7c0ce0bddc4618f6bfe6ecbba17169c133e8c4aed4abedc9d"
        }
    },
    "shortcuts": [
        [
            "app\\EchoMusic.exe",
            "EchoMusic"
        ]
    ],
    "link": [
        "$env:AppData\\echo-music",
        "$env:AppData\\echo-music-nodejs"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall EchoMusic.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\echo-music-updater\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/hoowhoami/EchoMusic/releases/download/v$version/EchoMusic-$version-Windows-Setup-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/hoowhoami/EchoMusic/releases/download/v$version/EchoMusic-$version-Windows-Setup-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
