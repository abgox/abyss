{
    "version": "2.2.8",
    "description": "一个简约的第三方酷狗音乐概念版 | A simple third-party KuGou Concept Music",
    "homepage": "https://github.com/hoowhoami/EchoMusic",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/hoowhoami/EchoMusic/releases/download/v2.2.8/EchoMusic-2.2.8-Windows-Setup-x64.exe",
            "hash": "7a182e007f7d24bce1eb18297d2104bbd720cf386cb8d87f0bf67a16606138cb"
        },
        "arm64": {
            "url": "https://github.com/hoowhoami/EchoMusic/releases/download/v2.2.8/EchoMusic-2.2.8-Windows-Setup-arm64.exe",
            "hash": "c4f7baba079d90533259cf8dac2da1b6bbed8f18fd208ef1a36bd7e2275365ce"
        }
    },
    "shortcuts": [
        [
            "app\\EchoMusic.exe",
            "EchoMusic"
        ]
    ],
    "link": [
        "$env:AppData\\echo-music",
        "$env:AppData\\echo-music-nodejs"
    ],
    "cleanup": "$env:LocalAppData\\echo-music-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall EchoMusic.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/hoowhoami/EchoMusic/releases/download/v$version/EchoMusic-$version-Windows-Setup-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/hoowhoami/EchoMusic/releases/download/v$version/EchoMusic-$version-Windows-Setup-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
