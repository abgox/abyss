{
    "version": "2.2.5",
    "description": "一个简约的第三方酷狗音乐概念版 | A simple third-party KuGou Concept Music",
    "homepage": "https://github.com/hoowhoami/EchoMusic",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/hoowhoami/EchoMusic/releases/download/v2.2.5/EchoMusic-2.2.5-Windows-Setup-x64.exe",
            "hash": "970ae6a7b877d8ef4f50b2a46220a8074b16a151fc2a717e25969bad1ed14df3"
        },
        "arm64": {
            "url": "https://github.com/hoowhoami/EchoMusic/releases/download/v2.2.5/EchoMusic-2.2.5-Windows-Setup-arm64.exe",
            "hash": "2d8ab05f415a59ed725896a1aba54331a62b6809c81b4048007033997f2bd919"
        }
    },
    "shortcuts": [
        [
            "app\\EchoMusic.exe",
            "EchoMusic"
        ]
    ],
    "link": [
        "$env:AppData\\echo-music",
        "$env:AppData\\echo-music-nodejs"
    ],
    "cleanup": "$env:LocalAppData\\echo-music-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall EchoMusic.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/hoowhoami/EchoMusic/releases/download/v$version/EchoMusic-$version-Windows-Setup-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/hoowhoami/EchoMusic/releases/download/v$version/EchoMusic-$version-Windows-Setup-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
