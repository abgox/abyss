{
    "version": "1.1.2",
    "description": "一个简约的第三方酷狗音乐概念版 | A simple third-party KuGou Concept Music",
    "homepage": "https://github.com/hoowhoami/EchoMusic",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/hoowhoami/EchoMusic/releases/download/v1.1.2/EchoMusic-1.1.2-Windows-Setup.exe",
            "hash": "273d71da02753cd5c1e1cf23ffbc4a1de86f00bd9824e0a2d452a3ed05161ccc"
        }
    },
    "shortcuts": [
        [
            "app\\EchoMusic.exe",
            "EchoMusic"
        ]
    ],
    "link": "$env:AppData\\com.hoowhoami\\EchoMusic",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Require-Admin",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Require-Admin",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/hoowhoami/EchoMusic/releases/download/v$version/EchoMusic-$version-Windows-Setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
