{
    "version": "2.2.3",
    "description": "一个简约的第三方酷狗音乐概念版 | A simple third-party KuGou Concept Music",
    "homepage": "https://github.com/hoowhoami/EchoMusic",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/hoowhoami/EchoMusic/releases/download/v2.2.3/EchoMusic-2.2.3-Windows-Setup-x64.exe",
            "hash": "79d0d5e08c706cd0cdd960b539e4082cf2819b8442623efc5bd054f08ada0f7f"
        },
        "arm64": {
            "url": "https://github.com/hoowhoami/EchoMusic/releases/download/v2.2.3/EchoMusic-2.2.3-Windows-Setup-arm64.exe",
            "hash": "236f0e5b20e639d0494fe8e2381852f3924a95d4f90885bbd1d2a1857f415b53"
        }
    },
    "shortcuts": [
        [
            "app\\EchoMusic.exe",
            "EchoMusic"
        ]
    ],
    "link": [
        "$env:AppData\\echo-music",
        "$env:AppData\\echo-music-nodejs"
    ],
    "cleanup": "$env:LocalAppData\\echo-music-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall EchoMusic.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/hoowhoami/EchoMusic/releases/download/v$version/EchoMusic-$version-Windows-Setup-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/hoowhoami/EchoMusic/releases/download/v$version/EchoMusic-$version-Windows-Setup-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
