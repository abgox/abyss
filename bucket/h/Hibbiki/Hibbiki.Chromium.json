{
    "version": "146.0.7680.80-r1582197",
    "description": "适用于 Windows 64 位的稳定版 Chromium 构建版本 | Stable Chromium build for Windows 64-bit, nothing fancy",
    "homepage": "https://github.com/Hibbiki/chromium-win64",
    "license": {
        "identifier": "BSD-3-Clause"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Hibbiki/chromium-win64/releases/download/v146.0.7680.80-r1582197/mini_installer.exe",
            "hash": "bfcf1d84f043ef9d1e68cb1af4196441dda35c540216e445dea599ce76fd730a"
        }
    },
    "conflicts": [
        "Hibbiki.Chromium",
        "eloston.ungoogled-chromium"
    ],
    "location": "$env:LocalAppData\\Chromium",
    "link": "$env:LocalAppData\\Chromium\\User Data",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller \"$env:LocalAppData\\Chromium\\Application\\chrome.exe\" -ArgumentList '--silent','--install'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Uninstall-Manually \"$env:LocalAppData\\Chromium\\Application\"",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Hibbiki/chromium-win64/releases/download/v$version/mini_installer.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
