{
    "version": "0.161.0",
    "description": "最受欢迎的开源静态网站生成器之一 | One of the most popular open-source static site generators",
    "homepage": "https://gohugo.io/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/gohugoio/hugo/releases/download/v0.161.0/hugo_0.161.0_windows-amd64.zip",
            "hash": "6258bb6beff7889083bf2007921484b3a9a4b38df13825be952037078dfe91d3"
        },
        "arm64": {
            "url": "https://github.com/gohugoio/hugo/releases/download/v0.161.0/hugo_0.161.0_windows-arm64.zip",
            "hash": "4f220678436b7b1ef3967c3053b36909786bfa29144c154e58a8e9297a529567"
        }
    },
    "extract_to": "app",
    "bin": "app\\hugo.exe",
    "cleanup": "$env:LocalAppData\\hugo_cache",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/gohugoio/hugo/releases/download/v$version/hugo_$version_windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/gohugoio/hugo/releases/download/v$version/hugo_$version_windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
