{
    "version": "0.160.1",
    "description": "最受欢迎的开源静态网站生成器之一 | One of the most popular open-source static site generators",
    "homepage": "https://gohugo.io/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/gohugoio/hugo/releases/download/v0.160.1/hugo_0.160.1_windows-amd64.zip",
            "hash": "e73d65ab5d6576a69d51bed4a0dcc90bc2ac5875014cc1263d97a57ed88b81ad"
        },
        "arm64": {
            "url": "https://github.com/gohugoio/hugo/releases/download/v0.160.1/hugo_0.160.1_windows-arm64.zip",
            "hash": "480c3a9e91180a738642537b0efefdc2310284c0dc5327e6e899f6ff5ef33ae3"
        }
    },
    "extract_to": "app",
    "bin": "app\\hugo.exe",
    "cleanup": "$env:LocalAppData\\hugo_cache",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/gohugoio/hugo/releases/download/v$version/hugo_$version_windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/gohugoio/hugo/releases/download/v$version/hugo_$version_windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
