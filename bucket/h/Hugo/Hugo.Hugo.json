{
    "version": "0.161.1",
    "description": "最受欢迎的开源静态网站生成器之一 | One of the most popular open-source static site generators",
    "homepage": "https://gohugo.io/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/gohugoio/hugo/releases/download/v0.161.1/hugo_0.161.1_windows-amd64.zip",
            "hash": "7f8d030b37600c60bf2a782611257e6a768934fbe7724c1f3a1a501e6724cf0d"
        },
        "arm64": {
            "url": "https://github.com/gohugoio/hugo/releases/download/v0.161.1/hugo_0.161.1_windows-arm64.zip",
            "hash": "6465311bceab1421eb91a54e9f0e6ed674977d8ec04d0292a3f2fe4d63d87a19"
        }
    },
    "extract_to": "app",
    "bin": "app\\hugo.exe",
    "cleanup": "$env:LocalAppData\\hugo_cache",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/gohugoio/hugo/releases/download/v$version/hugo_$version_windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/gohugoio/hugo/releases/download/v$version/hugo_$version_windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
