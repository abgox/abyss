{
    "version": "0.162.1",
    "description": "最受欢迎的开源静态网站生成器之一 | One of the most popular open-source static site generators",
    "homepage": "https://gohugo.io/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/gohugoio/hugo/releases/download/v0.162.1/hugo_0.162.1_windows-amd64.zip",
            "hash": "c0f4ffa937218cc1781aa9d422d14570b5054e7254a10d0b7a0844b2d4ba14f4"
        },
        "arm64": {
            "url": "https://github.com/gohugoio/hugo/releases/download/v0.162.1/hugo_0.162.1_windows-arm64.zip",
            "hash": "cb1074a54ed266f203373268c92173307c89875d6cf19d591a4ff8b759539756"
        }
    },
    "extract_to": "app",
    "bin": "app\\hugo.exe",
    "cleanup": "$env:LocalAppData\\hugo_cache",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/gohugoio/hugo/releases/download/v$version/hugo_$version_windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/gohugoio/hugo/releases/download/v$version/hugo_$version_windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
