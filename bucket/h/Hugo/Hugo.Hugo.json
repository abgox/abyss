{
    "version": "0.163.2",
    "description": "最受欢迎的开源静态网站生成器之一 | One of the most popular open-source static site generators",
    "homepage": "https://gohugo.io/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/gohugoio/hugo/releases/download/v0.163.2/hugo_0.163.2_windows-amd64.zip",
            "hash": "ab6020807fe2dda1140c30471bbd9adaeca9f3752977c1a058fd19e5567ae75f"
        },
        "arm64": {
            "url": "https://github.com/gohugoio/hugo/releases/download/v0.163.2/hugo_0.163.2_windows-arm64.zip",
            "hash": "1b315194c7a28ce296490fd0dff2e151aa6a8753ca96010084254b39be1f3c36"
        }
    },
    "extract_to": "app",
    "bin": "app\\hugo.exe",
    "cleanup": "$env:LocalAppData\\hugo_cache",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/gohugoio/hugo/releases/download/v$version/hugo_$version_windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/gohugoio/hugo/releases/download/v$version/hugo_$version_windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
