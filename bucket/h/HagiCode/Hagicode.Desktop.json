{
    "version": "0.1.56",
    "description": "本地化 AI 代码助手，隐私保护，效率提升 | Localized AI code assistant, privacy protection, enhanced efficiency",
    "homepage": "https://hagicode.com/desktop/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/HagiCode-org/desktop/releases/download/v0.1.56/Hagicode.Desktop.Setup.0.1.56.exe",
            "hash": "3e34118cd8c0ce3ae58267c1afadeb8efea652a6457e44644628f61b55b3ce3e"
        }
    },
    "shortcuts": [
        [
            "app\\Hagicode Desktop.exe",
            "Hagicode Desktop"
        ]
    ],
    "link": "$env:AppData\\Hagicode Desktop",
    "cleanup": "$env:LocalAppData\\hagicode-desktop-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Hagicode Desktop.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/HagiCode-org/desktop/releases/download/v$version/Hagicode.Desktop.Setup.$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
