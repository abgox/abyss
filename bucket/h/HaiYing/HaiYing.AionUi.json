{
    "version": "2.1.16",
    "description": "一款免费、本地化、开源的图形用户界面应用，适用于 Gemini CLI、Claude Code、Codex、Qwen Code 等 | Free, local, open-source GUI app for Gemini CLI, Claude Code, Codex, Qwen Code, and more",
    "homepage": "https://github.com/iOfficeAI/AionUi",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/iOfficeAI/AionUi/releases/download/v2.1.16/AionUi-2.1.16-win-x64.exe",
            "hash": "3ebdbdfa89c0df9e2a582a6dceccbb9630bcb5dc0d6484c0c8a4bd2687df7b0a"
        },
        "arm64": {
            "url": "https://github.com/iOfficeAI/AionUi/releases/download/v2.1.16/AionUi-2.1.16-win-arm64.exe",
            "hash": "4a4ae8d745cd5ebd40b2fbcde477e2faedfe6ee9afbce2679c2781d2d1d623a1"
        }
    },
    "shortcuts": [
        [
            "app\\AionUi.exe",
            "AionUi"
        ]
    ],
    "link": "$env:AppData\\AionUi",
    "cleanup": "$env:LocalAppData\\aionui-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall AionUi.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/iOfficeAI/AionUi/releases/download/v$version/AionUi-$version-win-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/iOfficeAI/AionUi/releases/download/v$version/AionUi-$version-win-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
