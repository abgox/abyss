{
    "version": "2.1.33",
    "description": "一款免费、本地化、开源的图形用户界面应用，适用于 Gemini CLI、Claude Code、Codex、Qwen Code 等 | Free, local, open-source GUI app for Gemini CLI, Claude Code, Codex, Qwen Code, and more",
    "homepage": "https://github.com/iOfficeAI/AionUi",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/iOfficeAI/AionUi/releases/download/v2.1.33/AionUi-2.1.33-win-x64.exe",
            "hash": "76ebda90273838a2bb1cd0ba4c42fb0b72093bf43f237106865fa35f2e195eca"
        },
        "arm64": {
            "url": "https://github.com/iOfficeAI/AionUi/releases/download/v2.1.33/AionUi-2.1.33-win-arm64.exe",
            "hash": "d77b6044b0f7a43b829758be47ce1757a8bfe25c3196a6efd7ed3affda0a25b5"
        }
    },
    "shortcuts": [
        [
            "app\\AionUi.exe",
            "AionUi"
        ]
    ],
    "link": "$env:AppData\\AionUi",
    "cleanup": "$env:LocalAppData\\aionui-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall AionUi.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/iOfficeAI/AionUi/releases/download/v$version/AionUi-$version-win-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/iOfficeAI/AionUi/releases/download/v$version/AionUi-$version-win-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
