{
    "version": "0.5.7",
    "description": "美观且便于分享的屏幕录制内容 | Beautiful, shareable screen recordings",
    "homepage": "https://cap.so",
    "license": {
        "identifier": "AGPL-3.0-or-later|MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://cap.so/download/windows#/dl.exe",
            "hash": "9d1e86887537766a09e0eb986e97f1f034fb515192f94807b20c794347c25d74"
        }
    },
    "shortcuts": [
        [
            "app\\Cap.exe",
            "Cap"
        ]
    ],
    "link": "$env:AppData\\so.cap.desktop",
    "cleanup": "$env:LocalAppData\\so.cap.desktop",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://github.com/CapSoftware/Cap",
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "cap-(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://cap.so/download/windows#/dl.exe"
            }
        }
    }
}
