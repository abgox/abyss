{
    "version": "2.7.2",
    "description": "适用于 Windows 的极其轻量级的开源媒体播放器 | An extremely light-weight, open source media player for Windows",
    "homepage": "https://github.com/clsid2/mpc-hc",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/clsid2/mpc-hc/releases/download/2.7.2/MPC-HC.2.7.2.x64.zip",
            "hash": "658b755c069ac3c3ed6265378baad3e7d270be12bd9642abd5b402b9f95a54ed",
            "shortcuts": [
                [
                    "app\\mpc-hc64.exe",
                    "MPC-HC"
                ]
            ]
        }
    },
    "extract_to": "app",
    "persist": [
        [
            "app\\mpc-hc64.ini",
            "mpc-hc64.ini"
        ],
        [
            "app\\mpc-hc.ini",
            "mpc-hc.ini"
        ],
        [
            "app\\default.mpcpl",
            "default.mpcpl"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/clsid2/mpc-hc/releases/download/$version/MPC-HC.$version.x64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
