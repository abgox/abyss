{
    "version": "0.8.5",
    "description": "开源轻量跨平台原生 AI 终端 | Open-source lightweight cross-platform AI-native terminal",
    "homepage": "https://terax.app",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/crynta/terax-ai/releases/download/v0.8.5/Terax_0.8.5_x64-setup.exe",
            "hash": "c27a07ed445474d1aa8cdc66baefa7f7014ca97b02fd960c6e06eb4180924238"
        }
    },
    "shortcuts": [
        [
            "app\\terax.exe",
            "Terax"
        ]
    ],
    "link": "$env:AppData\\app.crynta.terax",
    "cleanup": [
        "$env:LocalAppData\\app.crynta.terax",
        "$home\\.cache\\terax"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/crynta/terax-ai/releases/download/v$version/Terax_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
