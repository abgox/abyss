{
    "version": "28.30.1600",
    "description": "一个 Windows 上的第三方文件管理器 | A file manager for Windows",
    "homepage": "https://www.xyplorer.com/index.php",
    "license": {
        "identifier": "Proprietary",
        "url": "https://www.xyplorer.com/purchase.php"
    },
    "architecture": {
        "64bit": {
            "url": "https://www.xyplorer.com/download/xyplorer64_28.30.1600.zip",
            "hash": "7bb459bfc2d9c87403c0e7c35874b9b39a99376fdf2d98160e83abf69f5f6274"
        }
    },
    "extract_to": "app",
    "bin": "app\\XYplorer.exe",
    "shortcuts": [
        [
            "app\\XYplorer.exe",
            "XYplorer"
        ]
    ],
    "link": "$env:AppData\\XYplorer64",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "$fname = Join-Path 'app' (Get-ChildItem $dir\\app -File -Filter XYplorer64*.exe | Select-Object -First 1).Name",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://www.xyplorer.com",
        "regex": "version.+?(([\\d.]+){3,})"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://www.xyplorer.com/download/xyplorer64_$version.zip"
            }
        }
    }
}
