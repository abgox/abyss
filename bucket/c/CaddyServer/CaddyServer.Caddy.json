            "hash": "94ba71226d30a07d8eca3f971e88222fafb13f8bc46f391ed01afd6780f9c030"
        },
        "arm64": {
            "url": "https://github.com/caddyserver/caddy/releases/download/v2.11.3/caddy_2.11.3_windows_arm64.zip",
