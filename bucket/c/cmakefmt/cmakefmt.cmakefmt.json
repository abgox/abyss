{
    "version": "1.4.2",
    "description": "一款极速的 CMake 文件格式化工具 | A lightning-fast CMake file formatter",
    "homepage": "https://cmakefmt.dev/",
    "license": {
        "identifier": "MIT|Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/cmakefmt/cmakefmt/releases/download/v1.4.2/cmakefmt-1.4.2-x86_64-pc-windows-msvc.zip",
            "hash": "3488e61b11c85a2b69cbabb93ed53ec5f8885bab89715f305b30e51f59a16c0b",
            "extract_dir": "cmakefmt-1.4.2-x86_64-pc-windows-msvc"
        }
    },
    "extract_to": "app",
    "bin": "app\\cmakefmt.exe",
    "link": "$home\\.cmakefmt.yaml",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/cmakefmt/cmakefmt/releases/download/v$version/cmakefmt-$version-x86_64-pc-windows-msvc.zip",
                "extract_dir": "cmakefmt-$version-x86_64-pc-windows-msvc"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
