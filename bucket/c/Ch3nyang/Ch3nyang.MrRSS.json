    "homepage": "https://mrrss.ch3nyang.top",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/WCY-dt/MrRSS/releases/download/v1.3.24/MrRSS-1.3.24-windows-amd64-portable.zip",
            "hash": "1bc8f29f6669d12497053b6e6bd09f1811373578860ccbbcfafe8284cb73803f"
        },
        "arm64": {
            "url": "https://github.com/WCY-dt/MrRSS/releases/download/v1.3.24/MrRSS-1.3.24-windows-arm64-portable.zip",
            "hash": "dbc6c7e91ad42b8685f78c1b3ab354dd58b8fe55f84abeec1d561ac2dcefab69"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\MrRSS.exe",
            "MrRSS"
        ]
    ],
    "persist": [
        [
            "app\\data",
            "AppData\\Roaming\\MrRSS"
        ]
    ],
    "cleanup": "$env:AppData\\MrRSS.exe",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/WCY-dt/MrRSS/releases/download/v$version/MrRSS-$version-windows-amd64-portable.zip"
            },
            "arm64": {
                "url": "https://github.com/WCY-dt/MrRSS/releases/download/v$version/MrRSS-$version-windows-arm64-portable.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
