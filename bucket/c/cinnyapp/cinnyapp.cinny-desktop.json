{
    "version": "4.11.2",
    "description": "一款主要注重简洁、优雅且安全界面的 matrix 客户端 | A matrix client focusing primarily on simple, elegant and secure interface",
    "homepage": "https://github.com/cinnyapp/cinny-desktop",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/cinnyapp/cinny-desktop/releases/download/v4.11.2/Cinny_desktop-x86_64.msi#/dl.msi_",
            "hash": "96f915bbe1b118a86324be2d8538670791b3a7af969b1409b963698127cfc358"
        }
    },
    "location": "$env:ProgramFiles\\Cinny",
    "link": "$env:AppData\\in.cinny.app",
    "cleanup": "$env:LocalAppData\\in.cinny.app",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Msi"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Msi"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/cinnyapp/cinny-desktop/releases/download/v$version/Cinny_desktop-x86_64.msi#/dl.msi_"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
