{
    "version": "1.8.5",
    "description": "面向 Windows 桌面工作的本地优先时间追踪工具 | Local-first time tracking for Windows desktop work",
    "homepage": "https://github.com/Ceceliaee/patina",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Ceceliaee/patina/releases/download/v1.8.5/Patina_1.8.5_x64-setup.exe",
            "hash": "706a2ab8fea325a3c9bd40582e3dba3e08be6fb1a6fba09dc1cc3f2a12d8ca82"
        }
    },
    "shortcuts": [
        [
            "app\\Patina.exe",
            "Patina"
        ]
    ],
    "link": "$env:AppData\\Patina",
    "cleanup": "$env:LocalAppData\\Patina",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Ceceliaee/patina/releases/download/v$version/Patina_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
