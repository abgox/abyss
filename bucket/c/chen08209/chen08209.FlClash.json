{
    "version": "0.8.94",
    "description": "基于 ClashMeta 的多平台代理客户端，简单易用，开源无广告 | A multi-platform proxy client based on ClashMeta,simple and easy to use, open-source and ad-free",
    "homepage": "https://github.com/chen08209/FlClash",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/chen08209/FlClash/releases/download/v0.8.94/FlClash-0.8.94-windows-amd64-setup.exe",
            "hash": "6a1e836fa437ee0c60897d58fead23f38cf6e31e99b1cd96d756b9ada4ddfc5c"
        }
    },
    "shortcuts": [
        [
            "app\\FlClash.exe",
            "FlClash"
        ]
    ],
    "link": "$env:AppData\\com.follow\\clash",
    "cleanup": "$env:LocalAppData\\com.follow\\clash",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/chen08209/FlClash/releases/download/v$version/FlClash-$version-windows-amd64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
