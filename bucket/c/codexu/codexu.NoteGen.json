{
    "version": "0.27.7",
    "description": "一款跨平台的 Markdown AI 笔记软件 | A cross-platform Markdown AI note-taking software",
    "homepage": "https://notegen.top/",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/codexu/note-gen/releases/download/note-gen-v0.27.7/NoteGen_0.27.7_x64-setup.exe",
            "hash": "20077c32c65a55eff03815d1c3f1efb781bd4faa06a8ffb816a62944a034f58f"
        }
    },
    "shortcuts": [
        [
            "app\\note-gen.exe",
            "NoteGen"
        ]
    ],
    "link": "$env:AppData\\com.codexu.NoteGen",
    "cleanup": "$env:LocalAppData\\com.codexu.NoteGen",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "note-gen-(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/codexu/note-gen/releases/download/note-gen-v$version/NoteGen_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
