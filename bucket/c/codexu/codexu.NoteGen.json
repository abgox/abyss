{
    "version": "0.32.1",
    "description": "一款跨平台的 Markdown AI 笔记软件 | A cross-platform Markdown AI note-taking software",
    "homepage": "https://notegen.top",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/codexu/note-gen/releases/download/note-gen-v0.32.1/NoteGen_0.32.1_x64-setup.exe",
            "hash": "aa92b66f6a07a507490d1ce0e71f7aaed292f9adad0988497e4d940b661cb434"
        }
    },
    "shortcuts": [
        [
            "app\\note-gen.exe",
            "NoteGen"
        ]
    ],
    "link": "$env:AppData\\com.codexu.NoteGen",
    "cleanup": "$env:LocalAppData\\com.codexu.NoteGen",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "note-gen-(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/codexu/note-gen/releases/download/note-gen-v$version/NoteGen_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
