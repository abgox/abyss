{
    "version": "1.5.9",
    "description": "一款美观、无损且支持 GPU 加速的 RAW 图像编辑器 | A beautiful, non-destructive, and GPU-accelerated RAW image editor",
    "homepage": "https://github.com/CyberTimon/RapidRAW",
    "license": {
        "identifier": "AGPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/CyberTimon/RapidRAW/releases/download/v1.5.9/01_RapidRAW_v1.5.9_windows_x64.exe",
            "hash": "5ddbc8cb401ef8612cc29941d074896d6ee7273a7dd45c0b3f7d5a141ad545a9"
        }
    },
    "shortcuts": [
        [
            "app\\RapidRAW.exe",
            "RapidRAW"
        ]
    ],
    "link": "$env:AppData\\io.github.CyberTimon.RapidRAW",
    "cleanup": "$env:LocalAppData\\io.github.CyberTimon.RapidRAW",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/CyberTimon/RapidRAW/releases/download/v$version/01_RapidRAW_v$version_windows_x64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
