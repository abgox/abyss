{
    "version": "1.2.9.2059",
    "description": "跨设备的通用粘贴板 | Universal Pasteboard Across Devices",
    "homepage": "https://crosspaste.com/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/CrossPaste/crosspaste-desktop/releases/download/1.2.9.2059/crosspaste-1.2.9-2059-windows-amd64.zip",
            "hash": "1f4598337366ccbba50874989da03a52629a28c4b29e13bf18f3e6b7c2ed98b1"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\bin\\CrossPaste.exe",
            "CrossPaste"
        ]
    ],
    "link": "$home\\.crosspaste",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/CrossPaste/crosspaste-desktop/releases/download/$matchHead.$buildVersion/crosspaste-$matchHead-$buildVersion-windows-amd64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
