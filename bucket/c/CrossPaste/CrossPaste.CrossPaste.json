{
    "version": "2.1.4.2340",
    "description": "跨设备的通用粘贴板 | Universal Pasteboard Across Devices",
    "homepage": "https://crosspaste.com/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/CrossPaste/crosspaste-desktop/releases/download/2.1.4.2340/crosspaste-2.1.4-2340-windows-amd64.zip",
            "hash": "d335edb9c8126338f5cd3975364174f489bcab5000f8ee46270f846dd4af3530"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\bin\\CrossPaste.exe",
            "CrossPaste"
        ]
    ],
    "link": "$home\\.crosspaste",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/CrossPaste/crosspaste-desktop/releases/download/$matchHead.$buildVersion/crosspaste-$matchHead-$buildVersion-windows-amd64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
