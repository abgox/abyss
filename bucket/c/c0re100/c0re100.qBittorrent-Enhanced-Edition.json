{
    "version": "5.2.3.10",
    "description": "非官方的 qBittorrent BitTorrent 客户端（增强版） | Unofficial qBittorrent BitTorrent client (Enhanced Edition)",
    "homepage": "https://github.com/c0re100/qBittorrent-Enhanced-Edition",
    "license": {
        "identifier": "GPL-2.0-or-later|GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/c0re100/qBittorrent-Enhanced-Edition/releases/download/release-5.2.3.10/qbittorrent_enhanced_5.2.3.10_x64_setup.exe",
            "hash": "5b19a1e734505a64d077a994bb9f8bcd52569308841fe4372f75c55df47d0340"
        }
    },
    "conflicts": [
        "qBittorrent.qBittorrent",
        "c0re100.qBittorrent-Enhanced-Edition"
    ],
    "shortcuts": [
        [
            "app\\qbittorrent.exe",
            "qBittorrent"
        ]
    ],
    "link": "$env:AppData\\qBittorrent",
    "cleanup": "$env:LocalAppData\\qBittorrent",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninst.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "release-(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/c0re100/qBittorrent-Enhanced-Edition/releases/download/release-$version/qbittorrent_enhanced_$version_x64_setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
