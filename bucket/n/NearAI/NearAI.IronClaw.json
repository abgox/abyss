{
    "version": "1.0.0-rc.1",
    "description": "安全、开源的 OpenClaw 替代方案，运行在 NEAR AI 云的加密环境中 | The secure, open-source alternative to OpenClaw that runs in encrypted enclaves on NEAR AI Cloud",
    "homepage": "https://www.ironclaw.com",
    "license": {
        "identifier": "Apache-2.0|MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/nearai/ironclaw/releases/download/ironclaw-v1.0.0-rc.1/ironclaw-x86_64-pc-windows-msvc.tar.gz",
            "hash": "c758815eb495f163b5a69f8591452ee0d2346ef3b7b88d0342ddda26f2c5287d",
            "extract_dir": "ironclaw-x86_64-pc-windows-msvc"
        }
    },
    "extract_to": "app",
    "bin": "app\\ironclaw.exe",
    "link": "$home\\.ironclaw",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "ironclaw-(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/nearai/ironclaw/releases/download/ironclaw-v$version/ironclaw-x86_64-pc-windows-msvc.tar.gz"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
