{
    "version": "1.3.14",
    "description": "适用于 YouTube、TikTok 及 1000 多个平台的免费开源视频下载器 | Free Open Source Video Downloader for YouTube, TikTok, and 1000+ Platforms",
    "homepage": "https://vidbee.org",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/nexmoe/VidBee/releases/download/v1.3.14/vidbee-1.3.14-setup.exe",
            "hash": "f4df95fb29ae791a0478c256a27c99e2de3eb4b57f0a0ee90ef63b67b1301ffb"
        }
    },
    "shortcuts": [
        [
            "app\\vidbee.exe",
            "vidbee"
        ]
    ],
    "link": "$env:AppData\\vidbee",
    "cleanup": "$env:LocalAppData\\vidbee-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall vidbee.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/nexmoe/VidBee/releases/download/v$version/vidbee-$version-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
