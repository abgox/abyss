{
    "version": "0.12.4",
    "description": "一个旨在重构 Vim 的文本编辑器项目 | A project that seeks to aggressively refactor Vim",
    "homepage": "https://neovim.io",
    "license": {
        "identifier": "Apache-2.0|Vim"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/neovim/neovim/releases/download/v0.12.4/nvim-win64.zip",
            "hash": "9fc3572829ffd13debb6e32555da2c8cc02555568260a9fc4cf1f65bbcca319c"
        }
    },
    "extract_dir": "nvim-win64",
    "extract_to": "app",
    "bin": [
        "app\\bin\\nvim.exe",
        "app\\bin\\xxd.exe"
    ],
    "shortcuts": [
        [
            "app\\bin\\nvim.exe",
            "Neovim"
        ]
    ],
    "link": [
        "$env:LocalAppData\\nvim",
        "$env:LocalAppData\\nvim-data"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/neovim/neovim/releases/download/v$version/nvim-win64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
