{
    "version": "0.112.3-nightly.31",
    "description": "一种用 Rust 编写的新型 shell | A new type of shell written in Rust",
    "homepage": "https://www.nushell.sh/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/nushell/nightly/releases/download/0.112.3-nightly.31+94ac885/nu-0.112.3-nightly.31-x86_64-pc-windows-msvc.zip",
            "hash": "7ca592ba7c343a883c8bfde3614e5ebf1aaca1c420f2388c55bb46b81d901077"
        },
        "arm64": {
            "url": "https://github.com/nushell/nightly/releases/download/0.112.3-nightly.31+94ac885/nu-0.112.3-nightly.31-aarch64-pc-windows-msvc.zip",
            "hash": "cea47614e25fd1e5607771b84b6b4ce2310eb14c7b9c5b4633aaf4ed72ad8f21"
        }
    },
    "conflicts": [
        "Nushell.Nushell",
        "Nushell.Nushell.Nightly"
    ],
    "extract_to": "app",
    "bin": "app\\nu.exe",
    "shortcuts": [
        [
            "app\\nu.exe",
            "Nushell",
            "--execute \"cd ~\""
        ]
    ],
    "link": [
        "$env:AppData\\nushell",
        "$env:LocalAppData\\nushell"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-NewestVersionFromGithub"
        ],
        "regex": "(.+)(?<hash>\\+.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/nushell/nightly/releases/download/$version$matchHash/nu-$version-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/nushell/nightly/releases/download/$version$matchHash/nu-$version-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
