{
    "version": "0.114.2-nightly.4",
    "description": "一种用 Rust 编写的新型 shell | A new type of shell written in Rust",
    "homepage": "https://www.nushell.sh",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/nushell/nightly/releases/download/0.114.2-nightly.4+addca5c/nu-0.114.2-nightly.4-x86_64-pc-windows-msvc.zip",
            "hash": "03f9a4e2b0cdda1e3ee4e1b93d7c6d407552c03b6fac20b92d99c7fac0e9b96b"
        },
        "arm64": {
            "url": "https://github.com/nushell/nightly/releases/download/0.114.2-nightly.4+addca5c/nu-0.114.2-nightly.4-aarch64-pc-windows-msvc.zip",
            "hash": "a4961f65739ef164ff365ac73a34afd1ec8430e3b8fab695247a0a0ea83a598d"
        }
    },
    "conflicts": [
        "Nushell.Nushell",
        "Nushell.Nushell.Nightly"
    ],
    "extract_to": "app",
    "bin": "app\\nu.exe",
    "shortcuts": [
        [
            "app\\nu.exe",
            "Nushell",
            "--execute \"cd ~\""
        ]
    ],
    "link": [
        "$env:AppData\\nushell",
        "$env:LocalAppData\\nushell"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-NewestVersionFromGithub"
        ],
        "regex": "(.+)(?<hash>\\+.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/nushell/nightly/releases/download/$version$matchHash/nu-$version-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/nushell/nightly/releases/download/$version$matchHash/nu-$version-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
