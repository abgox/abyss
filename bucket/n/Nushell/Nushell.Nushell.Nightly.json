{
    "version": "0.113.2-nightly.10",
    "description": "一种用 Rust 编写的新型 shell | A new type of shell written in Rust",
    "homepage": "https://www.nushell.sh/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/nushell/nightly/releases/download/0.113.2-nightly.10+1407abe/nu-0.113.2-nightly.10-x86_64-pc-windows-msvc.zip",
            "hash": "d424f5c2371cbaba9b05b0be3b4db87213be95b0c80883f66c16a3e119e599c2"
        },
        "arm64": {
            "url": "https://github.com/nushell/nightly/releases/download/0.113.2-nightly.10+1407abe/nu-0.113.2-nightly.10-aarch64-pc-windows-msvc.zip",
            "hash": "39abc31ea29ec50d123fb71a783c49f09a5fa6cca1c484e126a6cdb24ce40bc0"
        }
    },
    "conflicts": [
        "Nushell.Nushell",
        "Nushell.Nushell.Nightly"
    ],
    "extract_to": "app",
    "bin": "app\\nu.exe",
    "shortcuts": [
        [
            "app\\nu.exe",
            "Nushell",
            "--execute \"cd ~\""
        ]
    ],
    "link": [
        "$env:AppData\\nushell",
        "$env:LocalAppData\\nushell"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-NewestVersionFromGithub"
        ],
        "regex": "(.+)(?<hash>\\+.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/nushell/nightly/releases/download/$version$matchHash/nu-$version-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/nushell/nightly/releases/download/$version$matchHash/nu-$version-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
