{
    "version": "0.113.2-nightly.2",
    "description": "一种用 Rust 编写的新型 shell | A new type of shell written in Rust",
    "homepage": "https://www.nushell.sh/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/nushell/nightly/releases/download/0.113.2-nightly.2+0b74c28/nu-0.113.2-nightly.2-x86_64-pc-windows-msvc.zip",
            "hash": "fb3b8431af7d9f0d1a532cb8986759642edc1975a11f6b6c55d585e5d868894b"
        },
        "arm64": {
            "url": "https://github.com/nushell/nightly/releases/download/0.113.2-nightly.2+0b74c28/nu-0.113.2-nightly.2-aarch64-pc-windows-msvc.zip",
            "hash": "e4b624862a757f91252d3bac54069f3f00e5c802e5a3e107c3c70a3b78896d9c"
        }
    },
    "conflicts": [
        "Nushell.Nushell",
        "Nushell.Nushell.Nightly"
    ],
    "extract_to": "app",
    "bin": "app\\nu.exe",
    "shortcuts": [
        [
            "app\\nu.exe",
            "Nushell",
            "--execute \"cd ~\""
        ]
    ],
    "link": [
        "$env:AppData\\nushell",
        "$env:LocalAppData\\nushell"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-NewestVersionFromGithub"
        ],
        "regex": "(.+)(?<hash>\\+.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/nushell/nightly/releases/download/$version$matchHash/nu-$version-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/nushell/nightly/releases/download/$version$matchHash/nu-$version-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
