{
    "version": "0.112.2-nightly.1",
    "description": "一种用 Rust 编写的新型 shell | A new type of shell written in Rust",
    "homepage": "https://www.nushell.sh/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/nushell/nightly/releases/download/0.112.2-nightly.1+b59287a/nu-0.112.2-nightly.1-x86_64-pc-windows-msvc.zip",
            "hash": "65de112cca5e89205e66291874aeb11af889a228c8a203bdee3b4e48df06cc74"
        },
        "arm64": {
            "url": "https://github.com/nushell/nightly/releases/download/0.112.2-nightly.1+b59287a/nu-0.112.2-nightly.1-aarch64-pc-windows-msvc.zip",
            "hash": "dda1d6f1d1720f3f91e58e6ccbe219b320236c2f418ca33fe84f0bc8e51e4940"
        }
    },
    "conflicts": [
        "Nushell.Nushell",
        "Nushell.Nushell.Nightly"
    ],
    "extract_to": "app",
    "bin": "app\\nu.exe",
    "shortcuts": [
        [
            "app\\nu.exe",
            "Nushell",
            "--execute \"cd ~\""
        ]
    ],
    "link": [
        "$env:AppData\\nushell",
        "$env:LocalAppData\\nushell"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-NewestVersionFromGithubAPI"
        ],
        "regex": "(.+)(?<hash>\\+.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/nushell/nightly/releases/download/$version$matchHash/nu-$version-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/nushell/nightly/releases/download/$version$matchHash/nu-$version-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
