{
    "version": "2.7.9",
    "description": "一款极简主义的护眼提醒应用，旨在减轻长时间使用屏幕时的眼睛疲劳 | A minimalist eye-care reminder app designed to reduce eye strain during extended screen usage",
    "homepage": "https://blinkeye.app",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/nomandhoni-cs/blink-eye/releases/download/v2.7.9/Blink.Eye_2.7.9_x64-setup.exe",
            "hash": "239d3070fc7450be89d1c54d77994c8862f075f349b16898dd0804938b4f63b2"
        }
    },
    "shortcuts": [
        [
            "app\\Blink-Eye.exe",
            "Blink Eye"
        ]
    ],
    "link": "$env:AppData\\com.blinkeye.app",
    "cleanup": "$env:LocalAppData\\com.blinkeye.app",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/nomandhoni-cs/blink-eye/releases/download/v$version/Blink.Eye_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
