{
    "version": "0.71.4",
    "description": "通过单点登录 (SSO) 、多因素认证 (MFA) 和精细化访问控制，将您的设备接入基于 WireGuard® 的安全 overlay 网络 | Connect your devices into a secure WireGuard®-based overlay network with SSO, MFA and granular access controls",
    "homepage": "https://netbird.io/",
    "license": {
        "identifier": "BSD-3-Clause"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/netbirdio/netbird/releases/download/v0.71.4/netbird_installer_0.71.4_windows_amd64.exe",
            "hash": "d0ab33eb8f25bf5584a165c78e7c8e790df8738222c0b9da35ffd2a273b82100"
        },
        "arm64": {
            "url": "https://github.com/netbirdio/netbird/releases/download/v0.71.4/netbird_installer_0.71.4_windows_arm64.exe",
            "hash": "d14885750523c352a2b7a15df3105788d87b71cfce4ba117e284cdaf5dff9878"
        }
    },
    "location": "$env:ProgramFiles\\Netbird",
    "link": "$env:ProgramData\\Netbird",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'netbird_uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/netbirdio/netbird/releases/download/v$version/netbird_installer_$version_windows_amd64.exe"
            },
            "arm64": {
                "url": "https://github.com/netbirdio/netbird/releases/download/v$version/netbird_installer_$version_windows_arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
