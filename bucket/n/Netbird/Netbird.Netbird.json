{
    "version": "0.70.1",
    "description": "通过单点登录 (SSO) 、多因素认证 (MFA) 和精细化访问控制，将您的设备接入基于 WireGuard® 的安全 overlay 网络 | Connect your devices into a secure WireGuard®-based overlay network with SSO, MFA and granular access controls",
    "homepage": "https://netbird.io/",
    "license": {
        "identifier": "BSD-3-Clause"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/netbirdio/netbird/releases/download/v0.70.1/netbird_installer_0.70.1_windows_amd64.exe",
            "hash": "df0736c36c8aa49ca8b998a10aa4c2ecb5ffcce1b28e6af34a6e4f0be56b4ae6"
        },
        "arm64": {
            "url": "https://github.com/netbirdio/netbird/releases/download/v0.70.1/netbird_installer_0.70.1_windows_arm64.exe",
            "hash": "b3f5d1a297bb670f2265539949fde071b74f3abac78940b65f8a02596ae31fbf"
        }
    },
    "location": "$env:ProgramFiles\\Netbird",
    "link": "$env:ProgramData\\Netbird",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'netbird_uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/netbirdio/netbird/releases/download/v$version/netbird_installer_$version_windows_amd64.exe"
            },
            "arm64": {
                "url": "https://github.com/netbirdio/netbird/releases/download/v$version/netbird_installer_$version_windows_arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
