{
    "version": "0.1.20",
    "description": "一款跨平台的 SSH 和 SFTP 客户端 | A cross-platform SSH and SFTP client",
    "homepage": "https://nashaofu.github.io/shell360/",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/nashaofu/shell360/releases/download/v0.1.20/Shell360_0.1.20_x64-setup.exe",
            "hash": "7c8da3893e3bf3f28364dc0ac3b073d3e135f104bf80b98e0cae2ed910143293"
        },
        "arm64": {
            "url": "https://github.com/nashaofu/shell360/releases/download/v0.1.20/Shell360_0.1.20_arm64-setup.exe",
            "hash": "b49a166a4ef8759cf1685ffc3b127f51753f04172a4fdf16d44aac0b1004d784"
        }
    },
    "shortcuts": [
        [
            "app\\shell360.exe",
            "Shell360"
        ]
    ],
    "link": [
        "$env:AppData\\com.nashaofu.shell360",
        "$env:LocalAppData\\com.nashaofu.shell360"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-TempData \"$env:LocalAppData\\com.nashaofu.shell360\\EBWebView\",\"$env:LocalAppData\\com.nashaofu.shell360\\logs\"",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/nashaofu/shell360/releases/download/v$version/Shell360_$version_x64-setup.exe"
            },
            "arm64": {
                "url": "https://github.com/nashaofu/shell360/releases/download/v$version/Shell360_$version_arm64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
