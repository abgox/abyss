{
    "version": "0.2.3",
    "description": "一款跨平台的 SSH 和 SFTP 客户端 | A cross-platform SSH and SFTP client",
    "homepage": "https://nashaofu.github.io/shell360/",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/nashaofu/shell360/releases/download/v0.2.3/Shell360_0.2.3_x64-setup.exe",
            "hash": "b2eaebb44f76bd888ef5fdb4c95182c52ec8b9005b6df86a3d0a229228008386"
        },
        "arm64": {
            "url": "https://github.com/nashaofu/shell360/releases/download/v0.2.3/Shell360_0.2.3_arm64-setup.exe",
            "hash": "a45411de706a4ee9776d79615578a2e0e1ef45bd10767cf9058304231e8c4eb8"
        }
    },
    "shortcuts": [
        [
            "app\\shell360.exe",
            "Shell360"
        ]
    ],
    "link": [
        "$env:AppData\\com.nashaofu.shell360",
        "$env:LocalAppData\\com.nashaofu.shell360"
    ],
    "cleanup": [
        "$env:LocalAppData\\com.nashaofu.shell360\\EBWebView",
        "$env:LocalAppData\\com.nashaofu.shell360\\logs"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/nashaofu/shell360/releases/download/v$version/Shell360_$version_x64-setup.exe"
            },
            "arm64": {
                "url": "https://github.com/nashaofu/shell360/releases/download/v$version/Shell360_$version_arm64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
