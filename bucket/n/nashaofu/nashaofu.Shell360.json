{
    "version": "0.1.21",
    "description": "一款跨平台的 SSH 和 SFTP 客户端 | A cross-platform SSH and SFTP client",
    "homepage": "https://nashaofu.github.io/shell360/",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/nashaofu/shell360/releases/download/v0.1.21/Shell360_0.1.21_x64-setup.exe",
            "hash": "cfed666ecc1dea03066d0e96bf0e29440c0e16c4b61949dfb603ee7b4dafba1a"
        },
        "arm64": {
            "url": "https://github.com/nashaofu/shell360/releases/download/v0.1.21/Shell360_0.1.21_arm64-setup.exe",
            "hash": "dd5c825eb8d9a8f236e31324384364c82af179b3be688a527f5b1f2b8c8e9c01"
        }
    },
    "shortcuts": [
        [
            "app\\shell360.exe",
            "Shell360"
        ]
    ],
    "link": [
        "$env:AppData\\com.nashaofu.shell360",
        "$env:LocalAppData\\com.nashaofu.shell360"
    ],
    "cleanup": [
        "$env:LocalAppData\\com.nashaofu.shell360\\EBWebView",
        "$env:LocalAppData\\com.nashaofu.shell360\\logs"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/nashaofu/shell360/releases/download/v$version/Shell360_$version_x64-setup.exe"
            },
            "arm64": {
                "url": "https://github.com/nashaofu/shell360/releases/download/v$version/Shell360_$version_arm64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
