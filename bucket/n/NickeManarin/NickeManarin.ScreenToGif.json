{
    "version": "2.43",
    "description": "屏幕、摄像头和画板录像，并有内置编辑器 | Screen, webcam and sketchboard recorder with an integrated editor",
    "homepage": "https://www.screentogif.com/",
    "license": {
        "identifier": "MS-PL"
    },
    "suggest": {
        "ffmpeg": [
            "ffmpeg",
            "abyss/Gyan.FFmpeg"
        ]
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/NickeManarin/ScreenToGif/releases/download/2.43/ScreenToGif.2.43.Portable.x64.zip",
            "hash": "f8d1770c260a5631942d4c75235ee7e68803d06cd474e183a92e25ecca501e43"
        },
        "arm64": {
            "url": "https://github.com/NickeManarin/ScreenToGif/releases/download/2.43/ScreenToGif.2.43.Portable.Arm64.zip",
            "hash": "bb9aa445e30b23ae80b537096127b6ab84ed1fd56cb1b2f7b00b6d3622b35f63"
        }
    },
    "extract_to": "app",
    "bin": "app\\ScreenToGif.exe",
    "shortcuts": [
        [
            "app\\ScreenToGif.exe",
            "ScreenToGif"
        ]
    ],
    "link": "$env:AppData\\ScreenToGif",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/NickeManarin/ScreenToGif/releases/download/$version/ScreenToGif.$version.Portable.x64.zip"
            },
            "arm64": {
                "url": "https://github.com/NickeManarin/ScreenToGif/releases/download/$version/ScreenToGif.$version.Portable.Arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
