{
    "version": "3.7.1",
    "description": "一个文本编辑器 | A text editor",
    "homepage": "https://github.com/cxasm/notepad--",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/cxasm/notepad--/releases/download/notepad-v3.7.1/Notepad--v3.7.1-win10-portable.zip",
            "hash": "4d1887c776c7bae7817ec063fda219c7cf6d98cc9d98d54e40268ad40f3dfddf"
        }
    },
    "extract_to": "app",
    "bin": "app\\Notepad--.exe",
    "shortcuts": [
        [
            "app\\Notepad--.exe",
            "Notepad--"
        ]
    ],
    "link": "$env:AppData\\notepad",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "notepad-(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/cxasm/notepad--/releases/download/notepad-v$version/Notepad--v$version-win10-portable.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
