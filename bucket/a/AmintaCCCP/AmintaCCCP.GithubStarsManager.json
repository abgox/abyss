{
    "version": "0.7.0",
    "description": "一款用于管理 GitHub 仓库的收藏/点赞的应用 | An app for managing github starred repositories",
    "homepage": "https://gsm.aminta.top",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/AmintaCCCP/GithubStarsManager/releases/download/v0.7.0/GitHub.Stars.Manager.Setup.0.7.0.exe",
            "hash": "294df8e652bb244ca8036b1117502362567192ae2073369a3664e8131a9b6f3f"
        }
    },
    "shortcuts": [
        [
            "app\\GitHub Stars Manager.exe",
            "GitHub Stars Manager"
        ]
    ],
    "link": "$env:AppData\\github-stars-manager",
    "cleanup": "$env:LocalAppData\\github-stars-manager-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall GitHub Stars Manager.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AmintaCCCP/GithubStarsManager/releases/download/v$version/GitHub.Stars.Manager.Setup.$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
