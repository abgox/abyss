{
    "version": "0.6.9",
    "description": "一款用于管理 GitHub 仓库的收藏/点赞的应用 | An app for managing github starred repositories",
    "homepage": "https://gsm.aminta.top",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/AmintaCCCP/GithubStarsManager/releases/download/v0.6.9/GitHub.Stars.Manager.Setup.0.6.9.exe",
            "hash": "1d65e4b8746dc9cc991b34e107bf36b3d2da0fcba464cb8300b7bb364ce91528"
        }
    },
    "shortcuts": [
        [
            "app\\GitHub Stars Manager.exe",
            "GitHub Stars Manager"
        ]
    ],
    "link": "$env:AppData\\github-stars-manager",
    "cleanup": "$env:LocalAppData\\github-stars-manager-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall GitHub Stars Manager.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AmintaCCCP/GithubStarsManager/releases/download/v$version/GitHub.Stars.Manager.Setup.$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
