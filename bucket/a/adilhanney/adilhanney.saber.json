{
    "version": "1.35.0",
    "description": "一款专为手写设计的笔记应用 | The notes app built for handwriting",
    "homepage": "https://saber.adil.hanney.org",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/saber-notes/saber/releases/download/v1.35.0/SaberInstaller_v1.35.0.exe",
            "hash": "1bea21d206aa4436eba98587ab4c5b9aec39eb6d534015058a63ea273aad1ff5"
        }
    },
    "shortcuts": [
        [
            "app\\saber.exe",
            "Saber"
        ]
    ],
    "link": [
        "$env:AppData\\com.adilhanney\\Saber",
        "$home\\Documents\\Saber"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/saber-notes/saber/releases/download/v$version/SaberInstaller_v$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
