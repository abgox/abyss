{
    "version": "3.2.0",
    "description": "一款基于 Flutter 开发、支持本地及自建曲库的跨平台音乐播放器 | A cross-platform music player for local and self-hosted libraries, built with Flutter",
    "homepage": "https://github.com/AfalpHy/sylvakru",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/AfalpHy/sylvakru/releases/download/v3.2.0/Sylvakru-3.2.0-Windows.zip",
            "hash": "df4356a035fc30c07a6c8b4892ffeecee427811a4ae49fe3dd4c89bd3aa52aa1"
        }
    },
    "extract_dir": "Release",
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\Sylvakru.exe",
            "Sylvakru"
        ]
    ],
    "link": "$env:AppData\\com.afalphy\\sylvakru",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AfalpHy/sylvakru/releases/download/v$version/Sylvakru-$version-Windows.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
