{
    "version": "2.1.1",
    "description": "一款基于 Flutter 的跨平台音乐播放器 | A cross-platform music player based on Flutter",
    "homepage": "https://github.com/AfalpHy/ParticleMusic",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/AfalpHy/ParticleMusic/releases/download/v2.1.1/ParticleMusic-2.1.1-Windows.zip",
            "hash": "10cd4c9b85bbbe06bc421a0198431110efb12afca12162ef800a8c98d25fa34f"
        }
    },
    "extract_dir": "Release",
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\ParticleMusic.exe",
            "ParticleMusic"
        ]
    ],
    "link": "$env:AppData\\com.afalphy\\particle_music",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AfalpHy/ParticleMusic/releases/download/v$version/ParticleMusic-$version-Windows.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
