{
    "version": "5.4.0",
    "description": "一款面向开发者的免费开源代码片段管理器 | A free and open source code snippet manager for developers",
    "homepage": "https://masscode.io/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/massCodeIO/massCode/releases/download/v5.4.0/massCode-5.4.0-x64.exe",
            "hash": "b15252cf0493063e17bc14024f8f19b57e2dca3197e26d0c6d5d9b508c5c799a"
        }
    },
    "shortcuts": [
        [
            "app\\massCode.exe",
            "massCode"
        ]
    ],
    "link": [
        "$env:AppData\\masscode",
        "$home\\massCode"
    ],
    "cleanup": "$env:LocalAppData\\masscode-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall massCode.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/massCodeIO/massCode/releases/download/v$version/massCode-$version-x64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
