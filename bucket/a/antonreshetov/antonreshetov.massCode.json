{
    "version": "5.1.0",
    "description": "一款面向开发者的免费开源代码片段管理器 | A free and open source code snippet manager for developers",
    "homepage": "https://masscode.io/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/massCodeIO/massCode/releases/download/v5.1.0/massCode-5.1.0-x64.exe",
            "hash": "70b17d3c4a28e763b7bcd43fbc5de74205c7bbd2217d07609efb17f21fca12c6"
        }
    },
    "shortcuts": [
        [
            "app\\massCode.exe",
            "massCode"
        ]
    ],
    "link": [
        "$env:AppData\\masscode",
        "$home\\massCode"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall massCode.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\masscode-updater\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/massCodeIO/massCode/releases/download/v$version/massCode-$version-x64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
