{
    "version": "1.0.6",
    "description": "一款现代化的开源视频编辑器，配备专业的时间轴界面 | A modern, open-source video editor featuring a professional timeline interface",
    "homepage": "https://clypra.abdulkabirmusa.com",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/AIEraDev/Clypra/releases/download/v1.0.6/Clypra_1.0.6_x64-setup.exe",
            "hash": "dc5d3dba9ec2bfdbf9c35438fb38e88b85c5d8874842bde76a3f43bb1036a928"
        }
    },
    "shortcuts": [
        [
            "app\\Clypra.exe",
            "Clypra"
        ]
    ],
    "link": "$env:AppData\\com.clypra.editor",
    "cleanup": "$env:LocalAppData\\com.clypra.editor",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AIEraDev/Clypra/releases/download/v$version/Clypra_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
