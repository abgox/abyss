{
    "version": "3.6.0",
    "description": "一款功能齐全的下载管理器 | A full-featured download manager",
    "homepage": "https://github.com/AnInsomniacy/motrix-next",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v3.6.0/MotrixNext_3.6.0_x64-setup.exe",
            "hash": "b69ebd5b726adb5a168c5b1427ac24cd238932042460fadca59a72d024f0010d"
        },
        "arm64": {
            "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v3.6.0/MotrixNext_3.6.0_arm64-setup.exe",
            "hash": "fc694476110986a9d53435068d803172c98b5f7125409b64da1e47af91cb8d58"
        }
    },
    "shortcuts": [
        [
            "app\\motrix-next.exe",
            "MotrixNext"
        ]
    ],
    "link": "$env:AppData\\com.motrix.next",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\com.motrix.next\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v$version/MotrixNext_$version_x64-setup.exe"
            },
            "arm64": {
                "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v$version/MotrixNext_$version_arm64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
