{
    "version": "3.8.8",
    "description": "一款功能齐全的下载管理器 | A full-featured download manager",
    "homepage": "https://github.com/AnInsomniacy/motrix-next",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v3.8.8/MotrixNext_3.8.8_x64-setup.exe",
            "hash": "363af34ba8f31d084936864411d961acd0de2c488803d14b234c1bf620b76f7b"
        },
        "arm64": {
            "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v3.8.8/MotrixNext_3.8.8_arm64-setup.exe",
            "hash": "b39a5f434164274a6af7dde5a30893042ff8f268ba5acaabcb4b4c46846a8923"
        }
    },
    "location": "$env:ProgramFiles\\MotrixNext",
    "link": "$env:AppData\\com.motrix.next",
    "cleanup": "$env:LocalAppData\\com.motrix.next",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v$version/MotrixNext_$version_x64-setup.exe"
            },
            "arm64": {
                "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v$version/MotrixNext_$version_arm64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
