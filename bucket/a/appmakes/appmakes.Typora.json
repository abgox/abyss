{
    "version": "1.13.4",
    "description": "一个 Markdown 编辑器和阅读器，所见即所得 | A Markdown editor and reader",
    "homepage": "https://typora.io/",
    "license": {
        "identifier": "Proprietary",
        "url": "https://support.typora.io/License-Agreement/"
    },
    "architecture": {
        "64bit": {
            "url": "https://download.typora.io/windows/typora-setup-x64.exe",
            "hash": "4f38ae1a7a7a56160d62a9779c1c90c5b5ff87e764faec1dc3e1a75c2fb98ea9"
        },
        "arm64": {
            "url": "https://download.typora.io/windows/typora-setup-arm64.exe",
            "hash": "4678549e1537521f90abeb297866c574848e59aa7794dfc86577cc8c344e767c"
        }
    },
    "bin": "app\\Typora.exe",
    "shortcuts": [
        [
            "app\\Typora.exe",
            "Typora"
        ]
    ],
    "link": "$env:AppData\\Typora",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Require-Admin",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Require-Admin",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://typora.io/releases/stable",
        "regex": "<h2>([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.typora.io/windows/typora-setup-x64.exe"
            },
            "arm64": {
                "url": "https://download.typora.io/windows/typora-setup-arm64.exe"
            }
        }
    }
}
