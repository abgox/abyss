{
    "version": "0.43.0",
    "description": "一个受 Magit 启发的 Git 终端用户界面 (TUI) | A terminal user interface (TUI) for Git inspired by Magit",
    "homepage": "https://github.com/altsem/gitu",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/altsem/gitu/releases/download/v0.43.0/gitu-v0.43.0-x86_64-pc-windows-msvc.zip",
            "hash": "9debbc715166f038cf86f80cc4602f04efaf10ef173329286a592cf2826f9be3",
            "extract_dir": "gitu-v0.43.0-x86_64-pc-windows-msvc"
        }
    },
    "extract_to": "app",
    "bin": "app\\gitu.exe",
    "link": "$env:AppData\\gitu",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/altsem/gitu/releases/download/v$version/gitu-v$version-x86_64-pc-windows-msvc.zip",
                "extract_dir": "gitu-v$version-x86_64-pc-windows-msvc"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
