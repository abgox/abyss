{
    "version": "1.21459.1",
    "description": "Claude 桌面客户端 - 你电脑上的 AI 伙伴。快速、专注，专为深度工作而设计 | Claude Desktop Client - Your AI partner on desktop. Fast, focused, and designed for deep work",
    "homepage": "https://claude.com",
    "license": {
        "identifier": "Proprietary"
    },
    "architecture": {
        "64bit": {
            "url": "https://downloads.claude.ai/releases/win32/x64/1.21459.1/Claude-85cb5c02268829ab7605f76dfa13a4217159ca9f.msix",
            "hash": "671418ad3164c9cea847e1f0b5f5f0db21a62eb1a6a0276b94d3ef8a32adb753"
        },
        "arm64": {
            "url": "https://downloads.claude.ai/releases/win32/arm64/1.21459.1/Claude-85cb5c02268829ab7605f76dfa13a4217159ca9f.msix",
            "hash": "1812197a450f181a7757aa339a1405e7a499566ac3edb9fc21d8c144a54ddb65"
        }
    },
    "msix": "Claude_pzs8sxrjxfjjc",
    "link": [
        "$env:LocalAppData\\Packages\\Claude_pzs8sxrjxfjjc\\LocalCache\\Roaming\\Claude",
        "$env:LocalAppData\\Packages\\Claude_pzs8sxrjxfjjc\\LocalCache\\Roaming\\Claude-3p"
    ],
    "cleanup": "$env:ProgramData\\Claude",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'Anthropic.Claude' 'msix'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_machine.InstallerSha256"
                }
            },
            "arm64": {
                "url": "$matchArm64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.arm64_machine.InstallerSha256"
                }
            }
        }
    }
}
