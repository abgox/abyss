{
    "version": "8.5.3",
    "description": "一款适用于所有平台、功能丰富的 GraphQL 客户端 | A beautiful feature-rich GraphQL Client for all platforms",
    "homepage": "https://altairgraphql.dev/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/altair-graphql/altair/releases/download/v8.5.3/altair_8.5.3_x64_win.exe",
            "hash": "2bed89cab131b703bc59ec50f86eaab7b4440fd3db881fef1d934a320c767df5"
        }
    },
    "shortcuts": [
        [
            "app\\Altair GraphQL Client.exe",
            "Altair GraphQL Client"
        ]
    ],
    "link": "$env:AppData\\Altair GraphQL Client",
    "cleanup": "$env:LocalAppData\\altair-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Altair GraphQL Client.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/altair-graphql/altair/releases/download/v$version/altair_$version_x64_win.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
