{
    "version": "1.0.0",
    "description": "一个跨平台桌宠 | A cross-platform desktop pet",
    "homepage": "https://github.com/ayangweb/BongoCat",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/ayangweb/BongoCat/releases/download/v1.0.0/BongoCat_1.0.0_x64-setup.exe#/dl.7z",
            "hash": "ec491da61334a445321d2e30634f9c60e9ca84a9825eadb2f66ce5852a4a79b1"
        },
        "arm64": {
            "url": "https://github.com/ayangweb/BongoCat/releases/download/v1.0.0/BongoCat_1.0.0_arm64-setup.exe#/dl.7z",
            "hash": "7d46179510826004301bd9e729fe3637c53b22f2e5be5926ce9b805df6104687"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\bongo-cat.exe",
            "BongoCat"
        ]
    ],
    "link": "$env:AppData\\com.ayangweb.BongoCat",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Remove-TempData \"$env:LocalAppData\\com.ayangweb.BongoCat\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ayangweb/BongoCat/releases/download/v$version/BongoCat_$version_x64-setup.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/ayangweb/BongoCat/releases/download/v$version/BongoCat_$version_arm64-setup.exe#/dl.7z"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
