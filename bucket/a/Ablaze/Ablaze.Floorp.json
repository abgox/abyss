{
    "version": "12.13.0",
    "description": "Floorp 基于 Firefox 构建，是一款具备卓越隐私保护功能和高度灵活性的新型浏览器 | Floorp is built on Firefox, and is a new browser with excellent privacy & flexibility",
    "homepage": "https://floorp.app/",
    "license": {
        "identifier": "MPL-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Floorp-Projects/Floorp/releases/download/v12.13.0/floorp-windows-x86_64.installer.exe",
            "hash": "f9c54c19ca29a3f2902549fd0246f2fabba5680f7b425b143f3aa037ed2b6b74"
        }
    },
    "location": "$env:ProgramFiles\\Ablaze Floorp",
    "link": "$env:AppData\\Floorp",
    "cleanup": "$env:LocalAppData\\Floorp",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'uninstall\\helper.exe' -ArgumentList '/S', '/PreventRebootRequired=true'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Floorp-Projects/Floorp/releases/download/v$version/floorp-windows-x86_64.installer.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
