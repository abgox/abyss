{
    "version": "0.23.3",
    "description": "一款全面的生产力工具，旨在帮助你管理任务、培养新习惯并优化时间 | A comprehensive productivity app designed to help you manage tasks, develop new habits, and optimize your time",
    "homepage": "https://whph.ahmetcetinkaya.me",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/ahmet-cetinkaya/whph/releases/download/v0.23.3/whph-v0.23.3-windows-setup.exe",
            "hash": "b6e09c44e98526cc4400adbd564935009cd186bbdfbb1b8e2e29947ce62f6512"
        }
    },
    "shortcuts": [
        [
            "app\\whph.exe",
            "WHPH"
        ]
    ],
    "link": "$env:AppData\\whph",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ahmet-cetinkaya/whph/releases/download/v$version/whph-v$version-windows-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
