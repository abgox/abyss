{
    "version": "0.5.2",
    "description": "用于现实软件的自主智能编程平台 | Agentic Coding Platform for Real Software",
    "homepage": "https://qoder.com/",
    "license": {
        "identifier": "Unknown",
        "url": "https://qoder.com/product-service"
    },
    "architecture": {
        "64bit": {
            "url": "https://download.qoder.com/release/0.5.2/QoderUserSetup-x64.exe",
            "hash": "83c49a511e4a1175f36f05a7a105eb9ea55838953fe752688a7d93cbc3bd38c6"
        }
    },
    "env_add_path": "app\\bin",
    "commands": "qoder",
    "shortcuts": [
        [
            "app\\Qoder.exe",
            "Qoder"
        ]
    ],
    "link": [
        "$env:AppData\\Qoder",
        "$home\\.qoder"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://center.qoder.sh/algo/api/update/win32-x64-user/stable/0.0.0",
        "jsonpath": "$.productVersion"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.qoder.com/release/$version/QoderUserSetup-x64.exe"
            }
        }
    }
}
