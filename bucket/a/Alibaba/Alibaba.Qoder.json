{
    "version": "0.9.0",
    "description": "用于现实软件的自主智能编程平台 | Agentic Coding Platform for Real Software",
    "homepage": "https://qoder.com/",
    "license": {
        "identifier": "Unknown",
        "url": "https://qoder.com/product-service"
    },
    "architecture": {
        "64bit": {
            "url": "https://download.qoder.com/release/0.9.0/QoderUserSetup-x64.exe",
            "hash": "18bde379b0f2ccaff4c1b31bd34a869ba0a88159bff9b133b663ae3daf486b7c"
        }
    },
    "env_add_path": "app\\bin",
    "commands": "qoder",
    "shortcuts": [
        [
            "app\\Qoder.exe",
            "Qoder"
        ]
    ],
    "link": [
        "$env:AppData\\Qoder",
        "$home\\.qoder"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://github.com/QoderAI/changelog",
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.qoder.com/release/$version/QoderUserSetup-x64.exe"
            }
        }
    }
}
