{
    "version": "1.14.0",
    "description": "用于现实软件的自主智能编程平台 | Agentic Coding Platform for Real Software",
    "homepage": "https://qoder.com",
    "license": {
        "identifier": "Unknown",
        "url": "https://qoder.com/product-service"
    },
    "architecture": {
        "64bit": {
            "url": "https://download.qoder.com/release/1.14.0/QoderUserSetup-x64.exe",
            "hash": "e3bedb211e69e7b81405dae3bb39978f8e49f77919844d7327060b4f77df70f9"
        }
    },
    "env_add_path": "app\\bin",
    "commands": "qoder",
    "shortcuts": [
        [
            "app\\Qoder.exe",
            "Qoder"
        ]
    ],
    "link": [
        "$env:AppData\\Qoder",
        "$home\\.qoder"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://github.com/QoderAI/changelog",
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.qoder.com/release/$version/QoderUserSetup-x64.exe"
            }
        }
    }
}
