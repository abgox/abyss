{
    "version": "0.11.5",
    "description": "一个开源的 Notion 替代品，数据和定制由你掌控 | An open-source alternative to Notion. You are in charge of your data and customizations",
    "homepage": "https://www.appflowy.io/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/AppFlowy-IO/AppFlowy/releases/download/0.11.5/AppFlowy-0.11.5-windows-x86_64.zip",
            "hash": "c927cbbb920139a8cfb5fe2462bf2823163885f7a75f5956d614320409c4eeef"
        }
    },
    "extract_dir": "AppFlowy",
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\AppFlowy.exe",
            "AppFlowy"
        ]
    ],
    "link": "$env:AppData\\io.appflowy",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AppFlowy-IO/AppFlowy/releases/download/$version/AppFlowy-$version-windows-x86_64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
