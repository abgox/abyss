{
    "version": "1.2.7",
    "description": "一款免费、跨平台的开源双栏并排式文件管理器 | Free cross platform open source file manager with two panels side by side",
    "homepage": "https://doublecmd.sourceforge.io",
    "license": {
        "identifier": "GPL-2.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/doublecmd/doublecmd/releases/download/v1.2.7/doublecmd-1.2.7.x86_64-win64.exe",
            "hash": "b89809c01e6ffd8785dd197d79891b31832fbcba8af7b10c4c89c6d9c584e2fe"
        }
    },
    "shortcuts": [
        [
            "app\\doublecmd.exe",
            "Double Commander"
        ]
    ],
    "link": "$env:AppData\\doublecmd",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/doublecmd/doublecmd/releases/download/v$version/doublecmd-$version.x86_64-win64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
