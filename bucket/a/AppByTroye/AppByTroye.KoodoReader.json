{
    "version": "2.3.4",
    "description": "一个跨平台的电子书阅读器 | A cross-platform ebook reader",
    "homepage": "https://koodo.960960.xyz/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/koodo-reader/koodo-reader/releases/download/v2.3.4/Koodo-Reader-2.3.4-x64-Win.zip",
            "hash": "f4fa1b86f83881ef8fa179a59b4ee45aa62f8d0eec55a16b6e7d6ea9f1723644"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\Koodo Reader.exe",
            "Koodo Reader"
        ]
    ],
    "link": "$env:AppData\\koodo-reader",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/koodo-reader/koodo-reader/releases/download/v$version/Koodo-Reader-$version-x64-Win.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
