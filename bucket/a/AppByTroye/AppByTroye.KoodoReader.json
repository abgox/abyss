{
    "version": "2.4.0",
    "description": "一个跨平台的电子书阅读器 | A cross-platform ebook reader",
    "homepage": "https://koodo.960960.xyz",
    "license": {
        "identifier": "AGPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/koodo-reader/koodo-reader/releases/download/v2.4.0/Koodo-Reader-2.4.0-x64-Win.zip",
            "hash": "4b95e767de8f1a379ce06272e24cc4dd838bbc29f515c8f8cb25435f2edd236d"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\Koodo Reader.exe",
            "Koodo Reader"
        ]
    ],
    "link": "$env:AppData\\koodo-reader",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/koodo-reader/koodo-reader/releases/download/v$version/Koodo-Reader-$version-x64-Win.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
