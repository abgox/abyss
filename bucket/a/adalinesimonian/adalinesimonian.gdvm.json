{
    "version": "0.14.0",
    "description": "Godot 版本管理器 (gdvm) 是一款旨在简化 Godot 引擎不同版本的安装、管理和切换的工具 | Godot Version Manager (gdvm) is a tool designed to simplify the installation, management, and switching between different versions of the Godot Engine",
    "homepage": "https://gdvm.io",
    "license": {
        "identifier": "ISC"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/adalinesimonian/gdvm/releases/download/v0.14.0/gdvm-x86_64-pc-windows-msvc.exe#/gdvm.exe",
            "hash": "b94dec56e8e91d94c28bdaa18af4bc47283f041f6730c3c84111e2d739871b16"
        },
        "arm64": {
            "url": "https://github.com/adalinesimonian/gdvm/releases/download/v0.14.0/gdvm-aarch64-pc-windows-msvc.exe#/gdvm.exe",
            "hash": "4899426f9d6daa48408824b8e21d346f644b50bb13ce445518db001a0466ec1a"
        }
    },
    "extract_to": "app",
    "bin": "app\\gdvm.exe",
    "link": "$home\\.gdvm",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/adalinesimonian/gdvm/releases/download/v$version/gdvm-x86_64-pc-windows-msvc.exe#/gdvm.exe"
            },
            "arm64": {
                "url": "https://github.com/adalinesimonian/gdvm/releases/download/v$version/gdvm-aarch64-pc-windows-msvc.exe#/gdvm.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
