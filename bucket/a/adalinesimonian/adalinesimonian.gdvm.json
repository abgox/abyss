{
    "version": "0.15.0",
    "description": "Godot 版本管理器 (gdvm) 是一款旨在简化 Godot 引擎不同版本的安装、管理和切换的工具 | Godot Version Manager (gdvm) is a tool designed to simplify the installation, management, and switching between different versions of the Godot Engine",
    "homepage": "https://gdvm.io",
    "license": {
        "identifier": "ISC"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/adalinesimonian/gdvm/releases/download/v0.15.0/gdvm-x86_64-pc-windows-msvc.exe#/gdvm.exe",
            "hash": "da370f236c7eed3a739ff25a3fa9ebbd5f310d3b0f2e8467bc9b4e2c968ac76c"
        },
        "arm64": {
            "url": "https://github.com/adalinesimonian/gdvm/releases/download/v0.15.0/gdvm-aarch64-pc-windows-msvc.exe#/gdvm.exe",
            "hash": "99ce6596ac0470bd2f4c1bfe4692f9a7a1829974bcbd43ecab8bcb607a5499f8"
        }
    },
    "extract_to": "app",
    "bin": "app\\gdvm.exe",
    "link": "$home\\.gdvm",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/adalinesimonian/gdvm/releases/download/v$version/gdvm-x86_64-pc-windows-msvc.exe#/gdvm.exe"
            },
            "arm64": {
                "url": "https://github.com/adalinesimonian/gdvm/releases/download/v$version/gdvm-aarch64-pc-windows-msvc.exe#/gdvm.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
