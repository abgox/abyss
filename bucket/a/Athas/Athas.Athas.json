{
    "version": "0.4.7",
    "description": "轻量级代码编辑器 | A lightweight code editor",
    "homepage": "https://athas.dev/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/athasdev/athas/releases/download/v0.4.7/Athas_0.4.7_x64-setup.exe",
            "hash": "1c2cb9a1d13f15813d4ff9ce866add88312761670a2c64dfa80e2ae07136b4fa"
        }
    },
    "shortcuts": [
        [
            "app\\athas-code.exe",
            "Athas"
        ]
    ],
    "link": "$env:AppData\\com.code.athas",
    "cleanup": "$env:LocalAppData\\com.code.athas",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/athasdev/athas/releases/download/v$version/Athas_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
