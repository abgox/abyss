{
    "version": "0.7.2",
    "description": "轻量级代码编辑器 | A lightweight code editor",
    "homepage": "https://athas.dev/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/athasdev/athas/releases/download/v0.7.2/Athas_0.7.2_x64-setup.exe",
            "hash": "bb9ff8635cfa5b22c3752e36136f2f5f0d15e7c8f6854395dbef63f711fda23c"
        }
    },
    "shortcuts": [
        [
            "app\\athas-code.exe",
            "Athas"
        ]
    ],
    "link": "$env:AppData\\com.code.athas",
    "cleanup": "$env:LocalAppData\\com.code.athas",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/athasdev/athas/releases/download/v$version/Athas_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
