{
    "version": "0.8.2",
    "description": "轻量级代码编辑器 | A lightweight code editor",
    "homepage": "https://athas.dev",
    "license": {
        "identifier": "AGPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/athasdev/athas/releases/download/v0.8.2/Athas_0.8.2_x64-setup.exe",
            "hash": "c56eb75e96d8b28cd7063e464fd2c85a64d13d22ffd5faf7783a2a070eca39aa"
        }
    },
    "shortcuts": [
        [
            "app\\athas-code.exe",
            "Athas"
        ]
    ],
    "link": "$env:AppData\\com.code.athas",
    "cleanup": "$env:LocalAppData\\com.code.athas",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/athasdev/athas/releases/download/v$version/Athas_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
