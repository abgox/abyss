{
    "version": "3.7.6",
    "description": "一款现代化、多协议的文件管理器与 FTP 客户端，内置人工智能、云端同步功能，并配备军用级加密技术 | A modern, multi-protocol file manager and FTP client with integrated AI, cloud sync, and military-grade encryption",
    "homepage": "https://www.aeroftp.app/",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/axpdev-lab/aeroftp/releases/download/v3.7.6/AeroFTP_3.7.6_x64-setup.exe",
            "hash": "26318e95247aa5346c0718ec36b3feee8cb96e2c025e492026d98c951ab9a67e"
        }
    },
    "env_add_path": "app",
    "commands": [
        "aeroftp",
        "aeroftp-cli",
        "aerorsync_serve"
    ],
    "shortcuts": [
        [
            "app\\aeroftp.exe",
            "AeroFTP"
        ]
    ],
    "link": [
        "$env:AppData\\aeroftp",
        "$env:AppData\\com.aeroftp.AeroFTP"
    ],
    "cleanup": "$env:LocalAppData\\com.aeroftp.AeroFTP",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/axpdev-lab/aeroftp/releases/download/v$version/AeroFTP_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
