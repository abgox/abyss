{
    "version": "0.3.21",
    "description": "基于 Zig 构建的快速、功能丰富的 Neovim 图形界面 | Fast, feature-rich Neovim GUI built with Zig",
    "homepage": "https://github.com/akiyosi/zonvie",
    "license": {
        "identifier": "MIT"
    },
    "suggest": {
        "Neovim": "abyss/Neovim.Neovim"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/akiyosi/zonvie/releases/download/v0.3.21/zonvie-v0.3.21-windows-x64.zip",
            "hash": "caea8be43da78818d9400cbfdba5877aec83865a75433783811e086da09efb77"
        },
        "arm64": {
            "url": "https://github.com/akiyosi/zonvie/releases/download/v0.3.21/zonvie-v0.3.21-windows-arm64.zip",
            "hash": "8b2e11ac5fe494482c73777d428ffdfc90e1d993389ddb7435e4a9f009a0cd4e"
        }
    },
    "extract_to": "app",
    "bin": "app\\zonvie.exe",
    "shortcuts": [
        [
            "app\\zonvie.exe",
            "Zonvie"
        ]
    ],
    "link": "$env:AppData\\zonvie",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/akiyosi/zonvie/releases/download/v$version/zonvie-v$version-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/akiyosi/zonvie/releases/download/v$version/zonvie-v$version-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
