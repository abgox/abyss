{
    "version": "0.3.17",
    "description": "基于 Zig 构建的快速、功能丰富的 Neovim 图形界面 | Fast, feature-rich Neovim GUI built with Zig",
    "homepage": "https://github.com/akiyosi/zonvie",
    "license": {
        "identifier": "MIT"
    },
    "suggest": {
        "Neovim": "abyss/Neovim.Neovim"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/akiyosi/zonvie/releases/download/v0.3.17/zonvie-v0.3.17-windows-x64.zip",
            "hash": "c6a69fb84516e39028ce5e0ce3c14e7353177996e25fac89c10711e907799083"
        },
        "arm64": {
            "url": "https://github.com/akiyosi/zonvie/releases/download/v0.3.17/zonvie-v0.3.17-windows-arm64.zip",
            "hash": "e69f1a0f1663c45a7df28ee7076ce931e7234055ef7e68f400b2a7c0bdce429b"
        }
    },
    "extract_to": "app",
    "bin": "app\\zonvie.exe",
    "shortcuts": [
        [
            "app\\zonvie.exe",
            "Zonvie"
        ]
    ],
    "link": "$env:AppData\\zonvie",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/akiyosi/zonvie/releases/download/v$version/zonvie-v$version-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/akiyosi/zonvie/releases/download/v$version/zonvie-v$version-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
