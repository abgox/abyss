{
    "version": "0.3.20",
    "description": "基于 Zig 构建的快速、功能丰富的 Neovim 图形界面 | Fast, feature-rich Neovim GUI built with Zig",
    "homepage": "https://github.com/akiyosi/zonvie",
    "license": {
        "identifier": "MIT"
    },
    "suggest": {
        "Neovim": "abyss/Neovim.Neovim"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/akiyosi/zonvie/releases/download/v0.3.20/zonvie-v0.3.20-windows-x64.zip",
            "hash": "6b7d68de07e7532766da7ac7676d1af4a6754cbc114b72a2f2a80d76a2fc2d0e"
        },
        "arm64": {
            "url": "https://github.com/akiyosi/zonvie/releases/download/v0.3.20/zonvie-v0.3.20-windows-arm64.zip",
            "hash": "639557fae67a67cc13165f5780c0796ddb9fd53baa3790650e5e6c321ed31c64"
        }
    },
    "extract_to": "app",
    "bin": "app\\zonvie.exe",
    "shortcuts": [
        [
            "app\\zonvie.exe",
            "Zonvie"
        ]
    ],
    "link": "$env:AppData\\zonvie",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/akiyosi/zonvie/releases/download/v$version/zonvie-v$version-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/akiyosi/zonvie/releases/download/v$version/zonvie-v$version-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
