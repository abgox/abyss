    "homepage": "https://github.com/akiyosi/zonvie",
    "license": {
        "identifier": "MIT"
    },
    "suggest": {
        "Neovim": "abyss/Neovim.Neovim"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/akiyosi/zonvie/releases/download/v0.3.23/zonvie-v0.3.23-windows-x64.zip",
            "hash": "b0e5fa2134c091efe06fab9a35d43ba8be196d2e85eb8ee2488a6835c20af1c0"
        },
        "arm64": {
            "url": "https://github.com/akiyosi/zonvie/releases/download/v0.3.23/zonvie-v0.3.23-windows-arm64.zip",
            "hash": "02c4c74e021fbd06eaa0b09632e242bcaa0a7acd252cd22f06cd63cf6df0f6b8"
        }
    },
    "extract_to": "app",
    "bin": "app\\zonvie.exe",
    "shortcuts": [
        [
            "app\\zonvie.exe",
            "Zonvie"
        ]
    ],
    "link": "$env:AppData\\zonvie",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/akiyosi/zonvie/releases/download/v$version/zonvie-v$version-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/akiyosi/zonvie/releases/download/v$version/zonvie-v$version-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
