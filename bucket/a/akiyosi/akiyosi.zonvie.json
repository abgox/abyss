{
    "version": "0.3.19",
    "description": "基于 Zig 构建的快速、功能丰富的 Neovim 图形界面 | Fast, feature-rich Neovim GUI built with Zig",
    "homepage": "https://github.com/akiyosi/zonvie",
    "license": {
        "identifier": "MIT"
    },
    "suggest": {
        "Neovim": "abyss/Neovim.Neovim"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/akiyosi/zonvie/releases/download/v0.3.19/zonvie-v0.3.19-windows-x64.zip",
            "hash": "edcc7de844de6b6c84a3fe2b359c2e37f9e643f6d83af10c6bcbf7ec57499c8d"
        },
        "arm64": {
            "url": "https://github.com/akiyosi/zonvie/releases/download/v0.3.19/zonvie-v0.3.19-windows-arm64.zip",
            "hash": "4a4cc681eaed9a6d5bb14067f73513eb6a4a31fb29dbd9881098f6dfc6cf028f"
        }
    },
    "extract_to": "app",
    "bin": "app\\zonvie.exe",
    "shortcuts": [
        [
            "app\\zonvie.exe",
            "Zonvie"
        ]
    ],
    "link": "$env:AppData\\zonvie",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/akiyosi/zonvie/releases/download/v$version/zonvie-v$version-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/akiyosi/zonvie/releases/download/v$version/zonvie-v$version-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
