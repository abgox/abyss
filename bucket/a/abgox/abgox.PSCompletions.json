{
    "version": "6.8.0",
    "description": "一个补全管理器，旨在为 PowerShell 带来更出色、更简便的 Tab 补全体验 | A completion manager for a better and simpler tab-completion experience in PowerShell",
    "homepage": "https://pscompletions.abgox.com",
    "license": {
        "identifier": "MIT"
    },
    "notes_cn": [
        "使用此模块: Import-Module PSCompletions",
        "将它写入 $Profile 中，即可在每次启动时自动加载。"
    ],
    "notes": [
        "Use this module: Import-Module PSCompletions",
        "Add to $Profile to auto-import on startup."
    ],
    "url": "https://cdn.powershellgallery.com/packages/pscompletions.6.8.0.nupkg",
    "hash": "d7503aec3d4880099d164c3d9347bd26f1675e117c9cbbf09792f1b1132a5f01",
    "psmodule": {
        "name": "PSCompletions"
    },
    "commands": [
        "psc",
        "PSCompletions"
    ],
    "persist": [
        [
            "completions",
            "completions"
        ],
        [
            "data.json",
            "data.json"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "if (Test-Path \"$dir\\completions.original\") {",
        "    Get-ChildItem \"$dir\\completions.original\" | Copy-Item -Destination \"$dir\\completions\" -Recurse -Force",
        "}",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromPowerShellGallery"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "url": "https://cdn.powershellgallery.com/packages/pscompletions.$version.nupkg"
    }
}
