{
    "version": "6.10.0",
    "description": "一个补全管理器，旨在为 PowerShell 带来更出色、更简便的 Tab 补全体验 | A completion manager for a better and simpler tab-completion experience in PowerShell",
    "homepage": "https://pscompletions.abgox.com",
    "license": {
        "identifier": "MIT"
    },
    "notes_cn": [
        "使用此模块: Import-Module PSCompletions",
        "将它写入 $Profile 中，即可在每次启动时自动加载。"
    ],
    "notes": [
        "Use this module: Import-Module PSCompletions",
        "Add to $Profile to auto-import on startup."
    ],
    "url": "https://cdn.powershellgallery.com/packages/pscompletions.6.10.0.nupkg",
    "hash": "9f2bf9c6d143d2dc0c50a531b964f9f6ff30393077405914ca7d746ef8e38cb7",
    "psmodule": {
        "name": "PSCompletions"
    },
    "commands": [
        "psc",
        "PSCompletions"
    ],
    "persist": [
        [
            "data",
            "data"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromPowerShellGallery"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "url": "https://cdn.powershellgallery.com/packages/pscompletions.$version.nupkg"
    }
}
