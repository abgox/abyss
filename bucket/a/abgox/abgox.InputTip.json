    "notes": [
        "It is recommended to use abgox.InputTip-zip.",
        "abgox.InputTip is the exe version and is not recommended for use.",
        "Refer to: https://inputtip.abgox.com/docs/zip-vs-exe"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/abgox/InputTip/releases/download/v3.6.11/InputTip.exe",
            "hash": "bfcdf032b89d9eb098431b3b9ea0b427802970791a69f637df343cd67eb098e3"
        }
    },
    "extract_to": "app",
    "bin": "app\\InputTip.exe",
    "shortcuts": [
        [
            "app\\InputTip.exe",
            "InputTip"
        ]
    ],
    "persist": [
        [
            "app\\data",
            "AppData\\Roaming\\com.abgox\\InputTip"
        ]
    ],
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/abgox/InputTip/releases/download/v$version/InputTip.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
