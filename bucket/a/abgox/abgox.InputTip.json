{
    "version": "3.0.0",
    "description": "一款轻量的 Windows 输入法状态管理工具，帮助你随时感知和切换输入法状态 | A lightweight Windows IME state management tool to help you perceive and switch IME states at any time",
    "homepage": "https://inputtip.abgox.com/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "notes_cn": [
        "推荐使用 abgox.InputTip-zip",
        "abgox.InputTip 是 exe 版本，不推荐使用",
        "参考: https://inputtip.abgox.com/docs/zip-vs-exe"
    ],
    "notes": [
        "It is recommended to use abgox.InputTip-zip.",
        "abgox.InputTip is the exe version and is not recommended for use.",
        "Refer to: https://inputtip.abgox.com/docs/zip-vs-exe"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/abgox/InputTip/releases/download/v3.0.0/InputTip.exe",
            "hash": "de0a25e0113a5e9646242bc7f0f8ea48493857bdabba0394aa82b9d7e2640482"
        }
    },
    "bin": "InputTip.exe",
    "shortcuts": [
        [
            "InputTip.exe",
            "InputTip"
        ]
    ],
    "persist": [
        [
            "data",
            "AppData\\Roaming\\com.abgox\\InputTip"
        ]
    ],
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/abgox/InputTip/releases/download/v$version/InputTip.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
