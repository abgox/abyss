    "homepage": "https://inputtip.abgox.com",
    "license": {
        "identifier": "AGPL-3.0-or-later"
    },
    "notes_cn": [
        "推荐使用 abgox.InputTip-zip。",
        "abgox.InputTip 是 exe 版本，不推荐使用。",
        "参考: https://inputtip.abgox.com/docs/zip-vs-exe"
