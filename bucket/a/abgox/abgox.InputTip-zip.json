{
    "version": "3.0.0",
    "description": "一款轻量的 Windows 输入法状态管理工具，帮助你随时感知和切换输入法状态 | A lightweight Windows IME state management tool to help you perceive and switch IME states at any time",
    "homepage": "https://inputtip.abgox.com/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/abgox/InputTip/releases/download/v3.0.0/InputTip.zip",
            "hash": "4bb5859fd30a5d0286afdfbe0bf99ffd6ae66eecaadebd49ce08cb512960d540"
        }
    },
    "extract_dir": "InputTip-main",
    "extract_to": "app",
    "bin": [
        [
            "app\\src\\AutoHotkey\\AutoHotkey64.exe",
            "InputTip",
            "$dir\\app\\src\\InputTip.ahk"
        ]
    ],
    "shortcuts": [
        [
            "app\\src\\AutoHotkey\\AutoHotkey64.exe",
            "InputTip",
            "\"$dir\\app\\src\\InputTip.ahk\"",
            "app\\src\\temp\\icon\\default-app.ico"
        ]
    ],
    "persist": [
        [
            "app\\src\\data",
            "AppData\\Roaming\\com.abgox\\InputTip"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/abgox/InputTip/releases/download/v$version/InputTip.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
