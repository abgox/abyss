{
    "version": "2026.04.14",
    "description": "(zip 版本) 输入法状态管理: 实时提示 + 状态切换 | (zip version) An input method state management tool: real-time tip + state switching",
    "homepage": "https://inputtip.abgox.com/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/abgox/InputTip/releases/download/v2026.04.14/InputTip.zip",
            "hash": "83159391b1bab9b6cb964f15a1600e9a7f43e10766540eee61889b8ca153bc70"
        }
    },
    "extract_dir": "InputTip-main",
    "extract_to": "app",
    "bin": [
        [
            "app\\src\\AutoHotkey\\AutoHotkey64.exe",
            "InputTip",
            "$dir\\app\\src\\InputTip.ahk"
        ]
    ],
    "shortcuts": [
        [
            "app\\src\\AutoHotkey\\AutoHotkey64.exe",
            "InputTip",
            "\"$dir\\app\\src\\InputTip.ahk\"",
            "app\\src\\InputTipIcon\\default\\app.ico"
        ]
    ],
    "persist": [
        [
            "app\\src\\InputTip.ini",
            "InputTip.ini"
        ],
        [
            "app\\src\\InputTipSymbol",
            "InputTipSymbol"
        ],
        [
            "app\\src\\InputTipCursor",
            "InputTipCursor"
        ],
        [
            "app\\src\\InputTipIcon",
            "InputTipIcon"
        ],
        [
            "app\\src\\plugins",
            "plugins"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/abgox/InputTip/releases/download/v$version/InputTip.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
