{
    "version": "3.2.0",
    "description": "一款轻量的 Windows 输入法状态管理工具，帮助你随时感知和切换输入法状态 | A lightweight Windows IME state management tool to help you perceive and switch IME states at any time",
    "homepage": "https://inputtip.abgox.com/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/abgox/InputTip/releases/download/v3.2.0/InputTip.zip",
            "hash": "f6d5607fa1f12e3371efaef458573ec4a4f5f6b8efea9a186c00a9752640bf91"
        }
    },
    "extract_dir": "InputTip-main",
    "extract_to": "app",
    "bin": [
        [
            "app\\src\\AutoHotkey\\AutoHotkey64.exe",
            "InputTip",
            "$dir\\app\\src\\InputTip.ahk"
        ]
    ],
    "shortcuts": [
        [
            "app\\src\\AutoHotkey\\AutoHotkey64.exe",
            "InputTip",
            "\"$dir\\app\\src\\InputTip.ahk\"",
            "app\\src\\temp\\icon\\default-app.ico"
        ]
    ],
    "persist": [
        [
            "app\\src\\data",
            "AppData\\Roaming\\com.abgox\\InputTip"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "if (Test-Path \"$persist_dir\\InputTip.ini\") {",
        "   'InputTip.ini','InputTipIcon','InputTipCursor','InputTipSymbol','plugins' | Foreach-Object {",
        "       Copy-Item \"$persist_dir\\$_\" \"$dir\\app\\src\\$_\" -Recurse -Force -ErrorAction SilentlyContinue",
        "       Remove-Item \"$persist_dir\\$_\" -Recurse -Force -ErrorAction SilentlyContinue",
        "   }",
        "}",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/abgox/InputTip/releases/download/v$version/InputTip.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
