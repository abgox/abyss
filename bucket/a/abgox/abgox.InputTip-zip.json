{
    "version": "3.6.6",
    "description": "规则驱动的输入法状态管理器 · 即时 · 强大 · 高效 | Rule-driven Input Method Status Manager · Instant · Powerful · Productive",
    "homepage": "https://inputtip.abgox.com/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/abgox/InputTip/releases/download/v3.6.6/InputTip.zip",
            "hash": "885e7d80b135993bee6b8a5ad1a5def70171c7c983fad8c84f6073d58ec0cdc6"
        }
    },
    "extract_dir": "InputTip-main",
    "extract_to": "app",
    "bin": [
        [
            "app\\src\\AutoHotkey\\AutoHotkey64.exe",
            "InputTip",
            "$dir\\app\\src\\InputTip.ahk"
        ]
    ],
    "shortcuts": [
        [
            "app\\src\\AutoHotkey\\AutoHotkey64.exe",
            "InputTip",
            "\"$dir\\app\\src\\InputTip.ahk\"",
            "app\\src\\temp\\icon\\default-app.ico"
        ]
    ],
    "persist": [
        [
            "app\\src\\data",
            "AppData\\Roaming\\com.abgox\\InputTip"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "if (Test-Path \"$persist_dir\\InputTip.ini\") {",
        "   'InputTip.ini','InputTipIcon','InputTipCursor','InputTipSymbol','plugins' | Foreach-Object {",
        "       Copy-Item \"$persist_dir\\$_\" \"$dir\\app\\src\\$_\" -Recurse -Force -ErrorAction SilentlyContinue",
        "       Remove-Item \"$persist_dir\\$_\" -Recurse -Force -ErrorAction SilentlyContinue",
        "   }",
        "}",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/abgox/InputTip/releases/download/v$version/InputTip.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
