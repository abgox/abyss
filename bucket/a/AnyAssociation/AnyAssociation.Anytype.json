{
    "version": "0.56.0",
    "description": "本地优先、端到端加密的软件，用于创建和存储任务、笔记、想法、文档、工作流等 | Local-first, E2E encrypted software for creating and storing tasks, notes, ideas, documents, workflows, and more",
    "homepage": "https://anytype.io",
    "license": {
        "identifier": "Proprietary"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/anyproto/anytype-ts/releases/download/v0.56.0/Anytype.Setup.0.56.0.exe",
            "hash": "43a778d6956f22e9e43d3eefe0b1f9cd5a7973c2eedfce59b1a88e0215161506"
        }
    },
    "shortcuts": [
        [
            "app\\Anytype.exe",
            "Anytype"
        ]
    ],
    "link": "$env:AppData\\anytype",
    "cleanup": "$env:LocalAppData\\anytype-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Anytype.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/anyproto/anytype-ts/releases/download/v$version/Anytype.Setup.$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
