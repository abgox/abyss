{
    "version": "2.2.0",
    "description": "一款免费、开源、快速发展的现代文件管理器 (explorer) 应用程序 | A free, open-source, quickly evolving, modern file manager (explorer) app",
    "homepage": "https://sigma-file-manager.vercel.app",
    "license": {
        "identifier": "Unknown"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/aleksey-hoffman/sigma-file-manager/releases/download/v2.2.0/Sigma-File-Manager-2.2.0-windows-setup.exe",
            "hash": "1deb6a2672e5c98f3160f8b626afb2ae178c37a8b42a543c73a30e75c467ceeb"
        }
    },
    "shortcuts": [
        [
            "app\\Sigma file manager.exe",
            "Sigma file manager"
        ]
    ],
    "link": "$env:AppData\\com.sigma-file-manager.app",
    "cleanup": "$env:LocalAppData\\com.sigma-file-manager.app",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/aleksey-hoffman/sigma-file-manager/releases/download/v$version/Sigma-File-Manager-$version-windows-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
