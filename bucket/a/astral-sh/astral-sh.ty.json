{
    "version": "0.0.59",
    "description": "一款速度极快的 Python 类型检查器和语言服务器，用 Rust 编写 | An extremely fast Python type checker and language server, written in Rust",
    "homepage": "https://docs.astral.sh/ty",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/astral-sh/ty/releases/download/0.0.59/ty-x86_64-pc-windows-msvc.zip",
            "hash": "0e5ef0fd783ef5921259edd404dd4f000a75732660bf5247f70e6a3713efa55f"
        },
        "arm64": {
            "url": "https://github.com/astral-sh/ty/releases/download/0.0.59/ty-aarch64-pc-windows-msvc.zip",
            "hash": "99a4647736b1ba6e1d24551e1726188cfe128304f00e2f3a056a1a53d252d179"
        }
    },
    "extract_to": "app",
    "bin": "app\\ty.exe",
    "link": [
        "$env:AppData\\ty",
        "$env:LocalAppData\\ty"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Remove-Link",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/astral-sh/ty/releases/download/$version/ty-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/astral-sh/ty/releases/download/$version/ty-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
