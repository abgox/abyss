{
    "version": "0.0.22",
    "description": "一款速度极快的 Python 类型检查器和语言服务器，用 Rust 编写 | An extremely fast Python type checker and language server, written in Rust",
    "homepage": "https://docs.astral.sh/ty/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/astral-sh/ty/releases/download/0.0.22/ty-x86_64-pc-windows-msvc.zip",
            "hash": "109b353d3cae66575a075c9823b82eeb34be6edaca08de93cae1882598dba07f"
        },
        "arm64": {
            "url": "https://github.com/astral-sh/ty/releases/download/0.0.22/ty-aarch64-pc-windows-msvc.zip",
            "hash": "12743157240a0aae0ec47ea606aaa29a85b621441b803bba834236b9e9d4b5cc"
        }
    },
    "extract_to": "app",
    "bin": "app\\ty.exe",
    "link": [
        "$env:AppData\\ty",
        "$env:LocalAppData\\ty"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Remove-Link",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/astral-sh/ty/releases/download/$version/ty-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/astral-sh/ty/releases/download/$version/ty-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
