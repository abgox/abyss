    "homepage": "https://mailpit.axllent.org/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/axllent/mailpit/releases/download/v1.30.1/mailpit-windows-amd64.zip",
            "hash": "efe727d63b28361b47f6a81bf4054a03a77940178b9f67107928e6c1a483c34b"
        },
        "arm64": {
            "url": "https://github.com/axllent/mailpit/releases/download/v1.30.1/mailpit-windows-arm64.zip",
            "hash": "2b6c5dd19e7fd07ecdd16b61869ed1a50b76430627778f72f23d3a6d738fdc0b"
        }
    },
    "extract_to": "app",
    "bin": "app\\mailpit.exe",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/axllent/mailpit/releases/download/v$version/mailpit-windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/axllent/mailpit/releases/download/v$version/mailpit-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
