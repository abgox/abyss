{
    "version": "1.30.0",
    "description": "一款小巧、高效、低内存占用、无依赖、跨平台的电子邮件测试工具及面向开发者的 API | A small, fast, low memory, zero-dependency, multi-platform email testing tool & API for developers",
    "homepage": "https://mailpit.axllent.org/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/axllent/mailpit/releases/download/v1.30.0/mailpit-windows-amd64.zip",
            "hash": "f0862cb24ce52735c7d73d6a6ebe6752aea933f9deba6ccbb064ca562ee0ad98"
        },
        "arm64": {
            "url": "https://github.com/axllent/mailpit/releases/download/v1.30.0/mailpit-windows-arm64.zip",
            "hash": "76adabcc04b90ed7fbaa8a7f98e091838f5d85348a4a9b34a38c11c6dd7373ac"
        }
    },
    "extract_to": "app",
    "bin": "app\\mailpit.exe",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/axllent/mailpit/releases/download/v$version/mailpit-windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/axllent/mailpit/releases/download/v$version/mailpit-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
