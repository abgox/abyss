{
    "version": "1.1.0",
    "description": "面向各类 AI 编程智能体的中枢，用于管理 MCP 服务、便携的 Skills 及项目配置 | A hub to manage MCP servers, portable skills, and project configs for all your AI coding agents",
    "homepage": "https://aghub.akr.moe/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/AkaraChen/aghub/releases/download/v1.1.0/aghub_1.1.0_x64-setup.exe",
            "hash": "21d44056d1ea11065ad4c2500262fd296fdd12f0f41367a59d001f2f5480d4be"
        }
    },
    "shortcuts": [
        [
            "app\\aghub.exe",
            "aghub"
        ]
    ],
    "link": [
        "$env:AppData\\com.akrc.aghub",
        "$env:LocalAppData\\com.akrc.aghub"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AkaraChen/aghub/releases/download/v$version/aghub_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
