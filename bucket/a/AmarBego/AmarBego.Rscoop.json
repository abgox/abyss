{
    "version": "1.9.8",
    "description": "一款 Scoop 的桌面图形化界面 | A desktop GUI for Scoop",
    "homepage": "https://amarbego.github.io/Rscoop",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/AmarBego/Rscoop/releases/download/v1.9.8/rscoop.exe",
            "hash": "8070f6f4d75b8c8f25c237d989557f883e9d5de00df6b6032b9a6a7f342cae1c"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\rscoop.exe",
            "Rscoop"
        ]
    ],
    "link": "$env:AppData\\com.rscoop.app",
    "cleanup": [
        "$env:LocalAppData\\rscoop",
        "$env:LocalAppData\\com.rscoop.app"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AmarBego/Rscoop/releases/download/v$version/rscoop.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
