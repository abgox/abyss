{
    "version": "1.9.7",
    "description": "一款 Scoop 的桌面图形化界面 | A desktop GUI for Scoop",
    "homepage": "https://amarbego.github.io/Rscoop",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/AmarBego/Rscoop/releases/download/v1.9.7/rscoop.exe",
            "hash": "e935328acf63453dfd6b5a4b8995110806cd33be2c7cd799d2395b9d0789837c"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\rscoop.exe",
            "Rscoop"
        ]
    ],
    "link": [
        "$env:AppData\\com.rscoop.app",
        "$env:LocalAppData\\com.rscoop.app"
    ],
    "cleanup": "$env:LocalAppData\\rscoop",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AmarBego/Rscoop/releases/download/v$version/rscoop.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
