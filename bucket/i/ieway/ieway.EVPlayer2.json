{
    "version": "4.8.2",
    "description": "在线观看加密视频的播放器 | A player that allows online viewing of encrypted videos",
    "homepage": "https://www.ieway.cn/evplayer2.html",
    "license": {
        "identifier": "Proprietary"
    },
    "architecture": {
        "64bit": {
            "url": "https://ctpublic.ieway.cn/public/download/EVPlayer2_v4.8.2.exe",
            "hash": "c8cfa973d702ec0d8ae038649b306c095649e4d1202f0342746e5a10f798778e"
        }
    },
    "location": "$env:ProgramFiles\\EVPlayer2",
    "link": "$env:LocalAppData\\EVPlayer2",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'Uninstaller\\unins000.exe' -ArgumentList '/VerySilent'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App -ArgumentList '/VerySilent'"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://www.ieway.cn/evplayer2.html",
        "regex": "EVPlayer2_v([\\d.]+).exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://ctpublic.ieway.cn/public/download/EVPlayer2_v$version.exe"
            }
        }
    }
}
