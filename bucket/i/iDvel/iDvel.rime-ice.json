{
    "version": "nightly",
    "description": "Rime 小狼毫配置: 雾凇拼音输入方案 | Rime Weasel Configuration: ice-Pinyin",
    "homepage": "https://github.com/iDvel/rime-ice",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "notes_cn": "请在小狼毫(Rime)中进行重新部署。",
    "notes": "Please redeploy in Rime Weasel.",
    "suggest": {
        "rime": "abyss/Rime.Weasel"
    },
    "url": "https://github.com/iDvel/rime-ice/releases/download/nightly/full.zip",
    "hash": "36a9e7f1c95b82ffb99743e0c5c4ce95d83c9a430aac59f84ef3cbfab6145068",
    "extract_to": "app",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Ensure-Directory \"$env:AppData\\Rime\"",
        "Write-Host \"Copying $dir\\app\\* => $env:AppData\\Rime\" -ForegroundColor Yellow",
        "Copy-Item $dir\\app\\* $env:AppData\\Rime -Recurse -Force"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "(Get-ChildItem \"$dir\\app\" -Recurse -File).FullName.Replace(\"$dir\\app\", \"$env:AppData\\Rime\") | Remove-Item -Force -Recurse -ErrorAction SilentlyContinue"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ]
}
