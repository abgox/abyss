{
    "version": "1.6.2",
    "description": "一款开源、简洁、高颜值的酷狗音乐第三方客户端 | An open-source, concise, and aesthetically pleasing third-party client for KuGou Music",
    "homepage": "https://music.moekoe.cn/",
    "license": {
        "identifier": "GPL-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/iAJue/MoeKoeMusic/releases/download/v1.6.2/MoeKoe_Music_Setup_v1.6.2.exe",
            "hash": "e394cd9791b0afa21baf87c08637b35227989f529fed4408362e6b9da095a978"
        }
    },
    "shortcuts": [
        [
            "app\\MoeKoe Music.exe",
            "MoeKoe Music"
        ]
    ],
    "link": "$env:AppData\\moekoemusic",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall MoeKoe Music.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\moekoemusic-updater\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/iAJue/MoeKoeMusic/releases/download/v$version/MoeKoe_Music_Setup_v$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
