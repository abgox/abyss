    "homepage": "https://idursun.github.io/jjui/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/idursun/jjui/releases/download/v0.10.4/jjui-0.10.4-windows-amd64.zip",
            "hash": "dd3930c4612ec1b5ce0e9ef846a22f8227dd0bc6d6d5b71c4a36d47c76552680",
            "bin": [
                [
                    "app\\jjui-0.10.4-windows-amd64.exe",
                    "jjui"
                ]
            ]
        },
        "arm64": {
            "url": "https://github.com/idursun/jjui/releases/download/v0.10.4/jjui-0.10.4-windows-arm64.zip",
            "hash": "94fdc085e47d8a6eee5192c3211c734ffcc24c8cd1cdea13359503dcfc633838",
            "bin": [
                [
                    "app\\jjui-0.10.4-windows-arm64.exe",
                    "jjui"
                ]
            ]
        }
    },
    "extract_to": "app",
    "link": [
        "$env:AppData\\jjui",
        "$env:LocalAppData\\jjui"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/idursun/jjui/releases/download/v$version/jjui-$version-windows-amd64.zip",
                "bin": [
                    [
                        "app\\jjui-$version-windows-amd64.exe",
                        "jjui"
                    ]
                ]
            },
            "arm64": {
                "url": "https://github.com/idursun/jjui/releases/download/v$version/jjui-$version-windows-arm64.zip",
                "bin": [
                    [
                        "app\\jjui-$version-windows-arm64.exe",
                        "jjui"
                    ]
                ]
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
