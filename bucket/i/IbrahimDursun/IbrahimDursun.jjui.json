{
    "version": "0.10.0",
    "description": "Jujutsu UI (jjui) 是一个文本用户界面 (TUI)，专为与 Jujutsu 版本控制系统交互而设计 | Jujutsu UI (jjui) is a Text User Interface (TUI) designed for interacting with the Jujutsu version control system",
    "homepage": "https://idursun.github.io/jjui/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/idursun/jjui/releases/download/v0.10.0/jjui-0.10.0-windows-amd64.zip",
            "hash": "df66999ec8ac6aab354e71db05a8920416d452c617ff122a853f9e062a9a6969"
        },
        "arm64": {
            "url": "https://github.com/idursun/jjui/releases/download/v0.10.0/jjui-0.10.0-windows-arm64.zip",
            "hash": "ec0e1fb12087bcd4c14a6ee5e1713bab94d3f3dcdd667e7c749507e124e88297"
        }
    },
    "extract_to": "app",
    "env_set": {
        "JJUI_CONFIG_DIR": "$persist_dir\\AppData\\Roaming\\jjui"
    },
    "bin": "app\\jjui.exe",
    "link": [
        "$env:AppData\\jjui",
        "$env:LocalAppData\\jjui"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "Get-ChildItem -Path $dir -Filter 'jjui*.exe' -Recurse | Select-Object -First 1 | Rename-Item -NewName 'jjui.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/idursun/jjui/releases/download/v$version/jjui-$version-windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/idursun/jjui/releases/download/v$version/jjui-$version-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
