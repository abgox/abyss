    "homepage": "https://idursun.github.io/jjui/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/idursun/jjui/releases/download/v0.10.5/jjui-0.10.5-windows-amd64.zip",
            "hash": "2623b2b21512123c921b02586c7d2654792f0b38516a41e08d294d3e0cf66dc0",
            "bin": [
                [
                    "app\\jjui-0.10.5-windows-amd64.exe",
                    "jjui"
                ]
            ]
        },
        "arm64": {
            "url": "https://github.com/idursun/jjui/releases/download/v0.10.5/jjui-0.10.5-windows-arm64.zip",
            "hash": "8dbcbe5a06b8ad6cdd3c06757f3ef7c3667dcae55307b58703ff9b37c6e1c6a0",
            "bin": [
                [
                    "app\\jjui-0.10.5-windows-arm64.exe",
                    "jjui"
                ]
            ]
        }
    },
    "extract_to": "app",
    "link": [
        "$env:AppData\\jjui",
        "$env:LocalAppData\\jjui"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/idursun/jjui/releases/download/v$version/jjui-$version-windows-amd64.zip",
                "bin": [
                    [
                        "app\\jjui-$version-windows-amd64.exe",
                        "jjui"
                    ]
                ]
            },
            "arm64": {
                "url": "https://github.com/idursun/jjui/releases/download/v$version/jjui-$version-windows-arm64.zip",
                "bin": [
                    [
                        "app\\jjui-$version-windows-arm64.exe",
                        "jjui"
                    ]
                ]
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
