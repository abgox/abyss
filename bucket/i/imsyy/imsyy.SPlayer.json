{
    "version": "3.1.0",
    "description": "一个简约的音乐播放器 | A simple music player",
    "homepage": "http://splayer.imsyy.top/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/imsyy/SPlayer/releases/download/v3.1.0/SPlayer-3.1.0-x64-setup.exe",
            "hash": "67374d799988f6e03d245a64c2b9dea1f9e68dc5e64858f982c5bbac88a1c00d"
        },
        "arm64": {
            "url": "https://github.com/imsyy/SPlayer/releases/download/v3.1.0/SPlayer-3.1.0-arm64-setup.exe",
            "hash": "246128cd9311f85999939ce7547950d12e07a8868121b6ba73f8e95b0a6b12c5"
        }
    },
    "shortcuts": [
        [
            "app\\SPlayer.exe",
            "SPlayer"
        ]
    ],
    "link": "$env:AppData\\SPlayer",
    "cleanup": "$env:LocalAppData\\splayer-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall SPlayer.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/imsyy/SPlayer/releases/download/v$version/SPlayer-$version-x64-setup.exe"
            },
            "arm64": {
                "url": "https://github.com/imsyy/SPlayer/releases/download/v$version/SPlayer-$version-arm64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
