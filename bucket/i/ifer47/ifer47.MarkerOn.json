{
    "version": "2.4.1",
    "description": "支持点击穿透模式的轻量级开源屏幕标注工具 | Lightweight open-source screen annotation tool with click-through mode",
    "homepage": "https://ifer47.github.io/markeron",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/ifer47/markeron/releases/download/v2.4.1/MarkerOn_2.4.1_x64-setup.exe",
            "hash": "86f67bb909d816236397f881709e7fc4d9786da1ae3d19f759768273016f5a6c"
        }
    },
    "shortcuts": [
        [
            "app\\MarkerOn.exe",
            "MarkerOn"
        ]
    ],
    "link": "$env:AppData\\com.markeron.app",
    "cleanup": "$env:LocalAppData\\com.markeron.app",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ifer47/markeron/releases/download/v$version/MarkerOn_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
