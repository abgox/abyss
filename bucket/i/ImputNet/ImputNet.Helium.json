{
    "version": "0.12.5.1",
    "description": "这款基于 Chromium 的网页浏览器是为用户精心打造的。它默认具备出色的隐私保护功能，拥有公正的广告拦截能力，没有冗余内容，也不会带来干扰 | The Chromium-based web browser made for people, with love. Best privacy by default, unbiased ad-blocking, no bloat and no noise",
    "homepage": "https://helium.computer/",
    "license": {
        "identifier": "GPL-3.0-only|BSD-3-Clause"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/imputnet/helium-windows/releases/download/0.12.5.1/helium_0.12.5.1_x64-windows.zip",
            "hash": "a89446495332f4922df3e37bdd05f7c19aa33cc6b5db6b770577c98268fc5d0e",
            "extract_dir": "helium_0.12.5.1_x64-windows"
        },
        "arm64": {
            "url": "https://github.com/imputnet/helium-windows/releases/download/0.12.5.1/helium_0.12.5.1_arm64-windows.zip",
            "hash": "0ae083d311f842d6d0ed57c800c32eee75cc67cd3874e74c8cdf93874287ad04",
            "extract_dir": "helium_0.12.5.1_arm64-windows"
        }
    },
    "extract_to": "app",
    "bin": [
        [
            "app\\chrome.exe",
            "helium"
        ]
    ],
    "shortcuts": [
        [
            "app\\chrome.exe",
            "Helium"
        ]
    ],
    "link": "$env:LocalAppData\\imput\\Helium",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/imputnet/helium-windows/releases/download/$version/helium_$version_x64-windows.zip",
                "extract_dir": "helium_$version_x64-windows"
            },
            "arm64": {
                "url": "https://github.com/imputnet/helium-windows/releases/download/$version/helium_$version_arm64-windows.zip",
                "extract_dir": "helium_$version_arm64-windows"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
