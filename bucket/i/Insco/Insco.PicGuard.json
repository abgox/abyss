{
    "version": "5.5.1",
    "description": "给图片添加水印, 防止被恶意使用 | Your pictures, your signature",
    "homepage": "https://www.picguard.app/",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/picguard/picguard/releases/download/v5.5.1/picguard-5.5.1-windows-setup-x64.exe",
            "hash": "1e139132718f0e23aa8580126f04fdda477c0c175d504f4b5f344e2d2e7a17c3"
        }
    },
    "shortcuts": [
        [
            "app\\PicGuard.exe",
            "PicGuard"
        ]
    ],
    "link": "$env:AppData\\Insco\\PicGuard",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/picguard/picguard/releases/download/v$version/picguard-$version-windows-setup-x64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
