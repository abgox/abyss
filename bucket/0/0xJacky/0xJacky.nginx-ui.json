{
    "version": "2.4.3",
    "description": "另一个适用于 Nginx 的 Web 用户界面 | Yet another Web UI for Nginx",
    "homepage": "https://nginxui.com",
    "license": {
        "identifier": "AGPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/0xJacky/nginx-ui/releases/download/v2.4.3/nginx-ui-windows-64.zip",
            "hash": "8e30c31fe4479c415c94da347e57a02464a133fbc787674c1e8ba30453072859"
        }
    },
    "extract_to": "app",
    "bin": "app\\nginx-ui.exe",
    "link": "$env:LocalAppData\\nginx-ui",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/0xJacky/nginx-ui/releases/download/v$version/nginx-ui-windows-64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
