{
    "version": "2.3.10",
    "description": "另一个适用于 Nginx 的 Web 用户界面 | Yet another Web UI for Nginx",
    "homepage": "https://nginxui.com/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/0xJacky/nginx-ui/releases/download/v2.3.10/nginx-ui-windows-64.zip",
            "hash": "4585511aa7f915cb971b58e50ba6dac500a04e62d1649f16abadf9b8c244c826"
        }
    },
    "extract_to": "app",
    "bin": "app\\nginx-ui.exe",
    "link": "$env:LocalAppData\\nginx-ui",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/0xJacky/nginx-ui/releases/download/v$version/nginx-ui-windows-64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
