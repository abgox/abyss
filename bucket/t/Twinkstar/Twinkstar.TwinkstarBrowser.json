{
    "version": "11.3.1000.2607",
    "description": "星愿浏览器，一款方便，可靠，简洁的浏览器 | Twinkstar Browser is a convenient, reliable and simple browser",
    "homepage": "https://www.twinkstar.com",
    "license": {
        "identifier": "Freeware"
    },
    "architecture": {
        "64bit": {
            "url": "https://d1.twinkstar.com/win/Twinkstar_v11.3.1000.2607_Release2.exe",
            "hash": "c0e4ff5a9ef067769e017d509a5f82f8e7bf4c56ad0f4ec18ac7ef74d8b1daf5"
        }
    },
    "location": "$env:ProgramFiles\\Twinkstar Browser",
    "link": "$env:LocalAppData\\Twinkstar\\User Data",
    "cleanup": "$env:LocalAppData\\Twinkstar",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'Uninstall.exe' -ArgumentList '-silent'",
        "A-Hold-App"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Uninstall-Manually",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'Twinkstar.TwinkstarBrowser' 'exe'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_machine.InstallerSha256"
                }
            }
        }
    }
}
