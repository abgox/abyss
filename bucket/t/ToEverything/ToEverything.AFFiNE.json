{
    "version": "0.27.2",
    "description": "一款注重隐私、本地优先、开源且即用型的 Notion 与 Miro 替代方案 | A privacy-focused, local-first, open-source, and ready-to-use alternative for Notion & Miro",
    "homepage": "https://affine.pro",
    "license": {
        "identifier": "Unknown"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/toeverything/AFFiNE/releases/download/v0.27.2/affine-0.27.2-stable-windows-x64.nsis.exe",
            "hash": "8c99fbbda75b38b06e725cdd9e41120a114d118377f2d39f303c610641980f9f"
        },
        "arm64": {
            "url": "https://github.com/toeverything/AFFiNE/releases/download/v0.27.2/affine-0.27.2-stable-windows-arm64.nsis.exe",
            "hash": "2d9529a96990bd47b168a64aed7e4cb2865d14fe6b580348b4935016144cbc2b"
        }
    },
    "shortcuts": [
        [
            "app\\AFFiNE.exe",
            "AFFiNE"
        ]
    ],
    "link": "$env:AppData\\AFFiNE",
    "cleanup": "$env:LocalAppData\\affine-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall AFFiNE.exe' -ArgumentList '/CurrentUser','/S',\"/D=$dir\\app\""
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/toeverything/AFFiNE/releases/download/v$version/affine-$version-stable-windows-x64.nsis.exe"
            },
            "arm64": {
                "url": "https://github.com/toeverything/AFFiNE/releases/download/v$version/affine-$version-stable-windows-arm64.nsis.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
