{
    "version": "0.27.3",
    "description": "一款注重隐私、本地优先、开源且即用型的 Notion 与 Miro 替代方案 | A privacy-focused, local-first, open-source, and ready-to-use alternative for Notion & Miro",
    "homepage": "https://affine.pro",
    "license": {
        "identifier": "Unknown"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/toeverything/AFFiNE/releases/download/v0.27.3/affine-0.27.3-stable-windows-x64.nsis.exe",
            "hash": "10e19e21135d5843219c1ef4152eb2286b4ae207a8cf5bbeb0a98f3d7ebbe494"
        },
        "arm64": {
            "url": "https://github.com/toeverything/AFFiNE/releases/download/v0.27.3/affine-0.27.3-stable-windows-arm64.nsis.exe",
            "hash": "da03bf074dccb17c62aa9c717062a898ad2594c5c11e5c215f6f11c5c4e16bf2"
        }
    },
    "shortcuts": [
        [
            "app\\AFFiNE.exe",
            "AFFiNE"
        ]
    ],
    "link": "$env:AppData\\AFFiNE",
    "cleanup": "$env:LocalAppData\\affine-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall AFFiNE.exe' -ArgumentList '/CurrentUser','/S',\"/D=$dir\\app\""
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/toeverything/AFFiNE/releases/download/v$version/affine-$version-stable-windows-x64.nsis.exe"
            },
            "arm64": {
                "url": "https://github.com/toeverything/AFFiNE/releases/download/v$version/affine-$version-stable-windows-arm64.nsis.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
