{
    "version": "1.2.4",
    "description": "适用于 TOML 的工具包，提供了格式化工具、代码检查工具和语言服务器，帮助您维护整洁且一致的 TOML 文件 | A toolkit for TOML that provides a Formatter, Linter, and Language Server to help you maintain clean and consistent TOML files",
    "homepage": "http://tombi-toml.github.io/tombi",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/tombi-toml/tombi/releases/download/v1.2.4/tombi-cli-1.2.4-x86_64-pc-windows-msvc.zip",
            "hash": "868d5b9c41503b910fcbdb00e636a5a67c00af168444bffee7297aac3fff00ba"
        },
        "arm64": {
            "url": "https://github.com/tombi-toml/tombi/releases/download/v1.2.4/tombi-cli-1.2.4-aarch64-pc-windows-msvc.zip",
            "hash": "a3501d0f52a3ae53e30fc5f28dba924a702360ebc0f351b8bdf828b6489df3f8"
        }
    },
    "extract_to": "app",
    "bin": "app\\tombi.exe",
    "link": "$env:AppData\\tombi",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/tombi-toml/tombi/releases/download/v$version/tombi-cli-$version-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/tombi-toml/tombi/releases/download/v$version/tombi-cli-$version-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
