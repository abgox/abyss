{
    "version": "0.61.8",
    "description": "你的个人 AI 超级智能。私密、简单且极其强大 | Your Personal AI super intelligence. Private, Simple and extremely powerful",
    "homepage": "https://tinyhumans.ai",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/tinyhumansai/openhuman/releases/download/v0.61.8/OpenHuman_0.61.8_x64-setup.exe",
            "hash": "47b5a26d5d704af9ee31afdd9237c1d14d7e59caa8ee53f2cea93f681827468a"
        }
    },
    "shortcuts": [
        [
            "app\\OpenHuman.exe",
            "OpenHuman"
        ]
    ],
    "link": "$home\\.openhuman",
    "cleanup": "$env:LocalAppData\\com.openhuman.app",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/tinyhumansai/openhuman/releases/download/v$version/OpenHuman_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
