{
    "version": "0.57.40",
    "description": "你的个人 AI 超级智能。私密、简单且极其强大 | Your Personal AI super intelligence. Private, Simple and extremely powerful",
    "homepage": "https://tinyhumans.ai/",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/tinyhumansai/openhuman/releases/download/v0.57.40/OpenHuman_0.57.40_x64-setup.exe",
            "hash": "524500a8c3aa8b343163be5e96e15ae95ff957e2331ded71604a16be1c8d2166"
        }
    },
    "shortcuts": [
        [
            "app\\OpenHuman.exe",
            "OpenHuman"
        ]
    ],
    "link": "$home\\.openhuman",
    "cleanup": "$env:LocalAppData\\com.openhuman.app",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/tinyhumansai/openhuman/releases/download/v$version/OpenHuman_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
