{
    "version": "1.11.2",
    "description": "澜音，一个跨平台的音乐播放器应用，提供插件运行框架与播放功能 | A cross-platform music player application that provides a plug-in running framework and playback functions",
    "homepage": "https://ceru.docs.shiqianjiang.cn/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/timeshiftsauce/CeruMusic/releases/download/v1.11.2/ceru-music-1.11.2-win-x64-setup.exe",
            "hash": "9c0ab37ee26d5f26da5385a203b189414316cae5d2a8f9ba93efcb6f9c9b99c6"
        }
    },
    "shortcuts": [
        [
            "app\\ceru-music.exe",
            "澜音"
        ]
    ],
    "link": "$env:AppData\\ceru-music",
    "cleanup": "$env:LocalAppData\\ceru-music-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall ceru-music.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/timeshiftsauce/CeruMusic/releases/download/v$version/ceru-music-$version-win-x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
