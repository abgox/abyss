{
    "version": "0.102.2",
    "description": "一款免费开源、跨平台的分层式笔记应用程序，专注于构建大型个人知识库 | A free and open-source, cross-platform hierarchical note taking application with focus on building large personal knowledge bases",
    "homepage": "https://github.com/TriliumNext/Trilium",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/TriliumNext/Trilium/releases/download/v0.102.2/TriliumNotes-v0.102.2-windows-x64.zip",
            "hash": "12506f0adf203800005c396924b18c9c3c687110dd438f88d1182a05b23f30b3"
        },
        "arm64": {
            "url": "https://github.com/TriliumNext/Trilium/releases/download/v0.102.2/TriliumNotes-v0.102.2-windows-arm64.zip",
            "hash": "b640d5673c2b212e53e60a0df439e73a79a5c03c7dbddec3e25cbfbdba9c2f3c"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\trilium.exe",
            "Trilium Notes"
        ]
    ],
    "link": "$env:AppData\\trilium-data",
    "cleanup": "$env:AppData\\trilium",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/TriliumNext/Trilium/releases/download/v$version/TriliumNotes-v$version-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/TriliumNext/Trilium/releases/download/v$version/TriliumNotes-v$version-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
