{
    "version": "0.104.0",
    "description": "一款免费开源、跨平台的分层式笔记应用程序，专注于构建大型个人知识库 | A free and open-source, cross-platform hierarchical note taking application with focus on building large personal knowledge bases",
    "homepage": "https://github.com/TriliumNext/Trilium",
    "license": {
        "identifier": "AGPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/TriliumNext/Trilium/releases/download/v0.104.0/TriliumNotes-v0.104.0-windows-x64.zip",
            "hash": "0c4c559e85e0d92f48e23bc6d375b1ed8959d22c523bcd5cd5b08ecb435ef0e0"
        },
        "arm64": {
            "url": "https://github.com/TriliumNext/Trilium/releases/download/v0.104.0/TriliumNotes-v0.104.0-windows-arm64.zip",
            "hash": "58b1a777242c181f734f232f4c8a471c0dea25e41bf35af8ceef81d45e544e0e"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\trilium.exe",
            "Trilium Notes"
        ]
    ],
    "link": "$env:AppData\\trilium-data",
    "cleanup": "$env:AppData\\trilium",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/TriliumNext/Trilium/releases/download/v$version/TriliumNotes-v$version-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/TriliumNext/Trilium/releases/download/v$version/TriliumNotes-v$version-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
