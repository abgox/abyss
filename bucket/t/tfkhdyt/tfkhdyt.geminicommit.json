{
    "version": "0.8.0",
    "description": "使用 Google Gemini AI 为您编写 git 提交消息的 CLI | CLI that writes git commit messages for you with Google Gemini AI",
    "homepage": "https://github.com/tfkhdyt/geminicommit",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/tfkhdyt/geminicommit/releases/download/v0.8.0/gmc-v0.8.0-windows-amd64.zip",
            "hash": "e1ada3b3ee0dc8fd858651d5d686fbbdd4132dc7e3809b834302d59d3528d88d"
        }
    },
    "extract_to": "app",
    "bin": "app\\gmc.exe",
    "link": "$env:AppData\\geminicommit",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/tfkhdyt/geminicommit/releases/download/v$version/gmc-v$version-windows-amd64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
