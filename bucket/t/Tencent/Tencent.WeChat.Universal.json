{
    "version": "4.1.7.33",
    "description": "微信，腾讯的一款聊天通讯工具 | A chat communication tool by Tencent",
    "homepage": "https://www.wechat.com/",
    "license": {
        "identifier": "Unknown",
        "url": "https://www.wechat.com/zh_CN/service_terms.html"
    },
    "architecture": {
        "64bit": {
            "url": "https://dldir1v6.qq.com/weixin/Universal/Windows/WeChatWin_4.1.7.exe",
            "hash": "4d593773cdfb5f5d1cbbccadc96a0024a99f40fdd3f14af891fe732ca02169e7"
        }
    },
    "location": "$env:ProgramFiles\\Tencent\\Weixin",
    "link": [
        "$env:AppData\\Tencent\\xwechat",
        "$home\\Documents\\xwechat_files"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Require-Admin",
        "A-Install-App -Uninstaller \"$env:ProgramFiles\\Tencent\\Weixin\\Uninstall.exe\" -ArgumentList '/S'",
        "# 安装程序会清理 $env:AppData\\Tencent\\xwechat，所以安装完成后再进行链接"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Require-Admin",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'Tencent.WeChat.Universal' 'exe'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_machine.InstallerSha256"
                }
            }
        }
    }
}
