{
    "version": "22.20",
    "description": "QQ 音乐，腾讯的音乐平台 | A music platform by Tencent",
    "homepage": "https://y.qq.com/",
    "license": {
        "identifier": "Unknown",
        "url": "https://y.qq.com/i/user_terms.html"
    },
    "architecture": {
        "64bit": {
            "url": "https://c.y.qq.com/cgi-bin/file_redirect.fcg?bid=dldir&file=ecosfile%2Fmusic_clntupate%2Fpc%2Fother%2FQQMusic_Setup_2220.exe&sign=1-f8e3bb3df6c08dae9b0044042328c19a0c188142e9451d187a8a7ac1c97d7288-69e76e1e#/dl.exe",
            "hash": "059a8cb42ec19fc8e42f13ac267255eb59df074d433e8270cad692aee536e167"
        }
    },
    "shortcuts": [
        [
            "app\\QQMusic\\QQMusic.exe",
            "QQ音乐"
        ]
    ],
    "link": "$env:AppData\\Tencent\\QQMusic",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "$InstallLocation = '\"' + \"$dir\\app\" + '\"'",
        "A-Install-App -ArgumentList 'silence=1', 'runafterinstall=no', \"installdir=$InstallLocation\"",
        "A-Hold-App"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Uninstall-Manually 'app'",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'Tencent.QQMusic' ''",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64#/dl.exe",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_machine.InstallerSha256"
                }
            }
        }
    }
}
