{
    "version": "9.9.30.48517",
    "description": "(NT 版本) QQ，腾讯的一款聊天通讯工具 | (NT version) A chat communication tool by Tencent",
    "homepage": "https://im.qq.com/",
    "license": {
        "identifier": "Unknown",
        "url": "https://rule.tencent.com/rule/46a15f24-e42c-4cb6-a308-2347139b1201"
    },
    "architecture": {
        "64bit": {
            "url": "https://dldir1v6.qq.com/qqfile/qq/QQNT/Windows/QQ_9.9.30_260429_x64_01.exe",
            "hash": "3d991ee6cc920a73272a72d6be934144f045852b86cc557ad45341f321565859"
        }
    },
    "location": "$env:ProgramFiles\\Tencent\\QQNT",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "$DataDir = \"$home\\Documents\\Tencent Files\"",
        "$PersistDir = $DataDir.Replace($home, $persist_dir)",
        "$SubDir1 = Get-ChildItem $DataDir -Directory -Depth 2 | ForEach-Object { if ($_.FullName -like \"$DataDir\\*\\nt_qq\") { Split-Path (Split-Path $_.FullName -Parent) -Leaf } }",
        "$SubDir2 = Get-ChildItem $PersistDir -Directory -Depth 2 | ForEach-Object { if ($_.FullName -like \"$PersistDir\\*\\nt_qq\") { Split-Path (Split-Path $_.FullName -Parent) -Leaf } }",
        "$LinkPaths = @()",
        "@($SubDir1) + @($SubDir2) | Select-Object -Unique | ForEach-Object { $LinkPaths += Join-Path $DataDir \"$_\\nt_qq\" }",
        "$LinkPaths += Join-Path $DataDir \"nt_qq\"",
        "A-New-LinkDirectory $LinkPaths",
        "A-Install-App -ArgumentList '/S'",
        "A-Hold-App"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Deny-Update",
        "A-Uninstall-Manually",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'Tencent.QQ.NT' 'exe'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_machine.InstallerSha256"
                }
            }
        }
    }
}
