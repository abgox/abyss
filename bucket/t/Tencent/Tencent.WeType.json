{
    "version": "1.4.3.9",
    "description": "微信输入法，由腾讯的微信团队开发 | An input method developed by the WeChat team of Tencent",
    "homepage": "https://z.weixin.qq.com/",
    "license": {
        "identifier": "Unknown",
        "url": "https://wetype.wxqcloud.qq.com/page/article/index/14.html"
    },
    "architecture": {
        "64bit": {
            "url": "https://download.z.weixin.qq.com/app/win/WeTypeSetup_1.4.3.9_3.exe",
            "hash": "7b3b69870b56fe013ad5d40ab52198a6f5baf8cb0794beed97c330c56f895633"
        },
        "arm64": {
            "url": "https://download.z.weixin.qq.com/app/win/WeTypeSetup_1.4.3.9_3.exe",
            "hash": "7b3b69870b56fe013ad5d40ab52198a6f5baf8cb0794beed97c330c56f895633"
        }
    },
    "location": "$env:ProgramFiles\\Tencent\\WeType",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -ArgumentList '/s'",
        "A-Hold-App"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Deny-Update",
        "A-Uninstall-Manually"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'Tencent.WeType' 'exe'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_machine.InstallerSha256"
                }
            },
            "arm64": {
                "url": "$matchArm64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.arm64_machine.InstallerSha256"
                }
            }
        }
    }
}
