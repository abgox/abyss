{
    "version": "2.1.0.16",
    "description": "微信输入法，由腾讯的微信团队开发 | An input method developed by the WeChat team of Tencent",
    "homepage": "https://z.weixin.qq.com/",
    "license": {
        "identifier": "Unknown",
        "url": "https://wetype.wxqcloud.qq.com/page/article/index/14.html"
    },
    "architecture": {
        "64bit": {
            "url": "https://download.z.weixin.qq.com/app/win/WeTypeSetup_2.1.0.16_3.exe",
            "hash": "65244e804a0b15e484e4523d4cee443a7b427a14bb6d12b8eccf72eee61ef108"
        },
        "arm64": {
            "url": "https://download.z.weixin.qq.com/app/win/WeTypeSetup_2.1.0.16_3.exe",
            "hash": "65244e804a0b15e484e4523d4cee443a7b427a14bb6d12b8eccf72eee61ef108"
        }
    },
    "location": "$env:ProgramFiles\\Tencent\\WeType",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -ArgumentList '/s'",
        "A-Hold-App"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Deny-Update",
        "A-Uninstall-Manually"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'Tencent.WeType' 'exe'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_machine.InstallerSha256"
                }
            },
            "arm64": {
                "url": "$matchArm64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.arm64_machine.InstallerSha256"
                }
            }
        }
    }
}
