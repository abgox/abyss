{
    "version": "1.2.1",
    "description": "一款开源屏幕录制器和编辑器，适合制作操作讲解、演示、产品视频等内容 | An open-source screen recorder and editor for walkthroughs, demos, product videos, and more",
    "homepage": "https://recordly.dev/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/webadderall/Recordly/releases/download/v1.2.1/Recordly-windows-x64.exe",
            "hash": "2473f947d96f68bb871383d00f8be3750397720b910a6f85d48cfa3b452dbf74"
        }
    },
    "shortcuts": [
        [
            "app\\Recordly.exe",
            "Recordly"
        ]
    ],
    "link": "$env:AppData\\Recordly",
    "cleanup": "$env:LocalAppData\\recordly-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Recordly.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/webadderall/Recordly/releases/download/v$version/Recordly-windows-x64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
