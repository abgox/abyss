{
    "version": "0.16.3",
    "description": "一个轻量级、高性能且可扩展的 WebAssembly 运行时 | A lightweight, high-performance, and extensible WebAssembly runtime",
    "homepage": "https://wasmedge.org/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/WasmEdge/WasmEdge/releases/download/0.16.3/WasmEdge-0.16.3-windows-msvc.zip",
            "hash": "fc4d3e248c2eac83f759d5d02a09fe14e8187e2a4c0e385fecdc2af15aa84c72"
        }
    },
    "extract_to": "app",
    "bin": [
        "app\\bin\\wasmedge.exe",
        "app\\bin\\wasmedgec.exe"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/WasmEdge/WasmEdge/releases/download/$version/WasmEdge-$version-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
