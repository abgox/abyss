{
    "version": "1.3.0",
    "description": "开源免费的 HTTP(S) 流量捕获软件 | Open source free capture HTTP(S) traffic software",
    "homepage": "https://github.com/wanghongenpin/proxypin",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/wanghongenpin/proxypin/releases/download/v1.3.0/proxypin-windows-setup.exe",
            "hash": "264fe634e1b6a06d45c5bc684e888e85e175603094da89e99dbb9a246a1e2454"
        }
    },
    "shortcuts": [
        [
            "app\\ProxyPin.exe",
            "ProxyPin"
        ]
    ],
    "link": [
        "$home\\.proxypin",
        "$env:AppData\\com.proxy.pin\\ProxyPin"
    ],
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/wanghongenpin/proxypin/releases/download/v$version/proxypin-windows-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
