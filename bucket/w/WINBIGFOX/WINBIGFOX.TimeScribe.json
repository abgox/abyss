{
    "version": "1.14.0",
    "description": "一款现代、灵活的时间跟踪应用程序，用于记录和管理个人工作时间 | A modern, flexible time tracking app for capturing and managing personal working hours",
    "homepage": "https://github.com/WINBIGFOX/TimeScribe",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/WINBIGFOX/TimeScribe/releases/download/v1.14.0/TimeScribe-1.14.0-setup.exe",
            "hash": "06d0ac1bec8a4cac968ddc160f30b9e11219a9ccabb7c857b8c0756dba3f5770"
        }
    },
    "shortcuts": [
        [
            "app\\timescribe.exe",
            "TimeScribe"
        ]
    ],
    "link": "$env:AppData\\timescribe",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall timescribe.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/WINBIGFOX/TimeScribe/releases/download/v$version/TimeScribe-$version-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
