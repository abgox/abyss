{
    "version": "1.0.55",
    "description": "工作回顾与 AI 日报助手 | Work review and AI daily report assistant",
    "homepage": "https://github.com/wm94i/Work_Review",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/wm94i/Work_Review/releases/download/v1.0.55/Work_Review_1.0.55_x64-setup.exe",
            "hash": "3032f5968cf2a1e6317060e987c0c40c92fa35b1d91665c003d6cd4c61bc1be4"
        }
    },
    "shortcuts": [
        [
            "app\\Work_Review.exe",
            "Work Review"
        ]
    ],
    "link": "$env:AppData\\work-review",
    "cleanup": "$env:LocalAppData\\com.workreview.app",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/wm94i/Work_Review/releases/download/v$version/Work_Review_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
