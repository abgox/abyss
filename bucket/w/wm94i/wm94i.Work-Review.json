{
    "version": "1.0.41",
    "description": "工作回顾与 AI 日报助手 | Work review and AI daily report assistant",
    "homepage": "https://github.com/wm94i/Work_Review",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/wm94i/Work_Review/releases/download/v1.0.41/Work_Review_1.0.41_x64-setup.exe",
            "hash": "aebb80b961fbe0caabda6368b863fec02e0c5527787438350326fd9dc80bb732"
        }
    },
    "location": "$env:LocalAppData\\Work Review",
    "link": "$env:AppData\\work-review",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/wm94i/Work_Review/releases/download/v$version/Work_Review_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
