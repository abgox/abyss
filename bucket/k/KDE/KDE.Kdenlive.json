{
    "version": "26.04.1",
    "description": "免费开源的视频编辑器 | Free and Open Source Video Editor",
    "homepage": "https://kdenlive.org/",
    "license": {
        "identifier": "GPL-3.0-only",
        "url": "https://invent.kde.org/multimedia/kdenlive/-/blob/HEAD/COPYING"
    },
    "architecture": {
        "64bit": {
            "url": "https://download.kde.org/stable/kdenlive/26.04/windows/kdenlive-26.04.1.exe",
            "hash": "6eb87f934ce9b37d5c0d8d584227dc970d5b31279a77d95a07add6bd39ad7902"
        }
    },
    "location": "$env:ProgramFiles\\kdenlive",
    "link": "$env:LocalAppData\\kdenliverc",
    "cleanup": "$env:LocalAppData\\kdenlive",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'KDE.Kdenlive' 'exe'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_user.InstallerSha256"
                }
            }
        }
    }
}
