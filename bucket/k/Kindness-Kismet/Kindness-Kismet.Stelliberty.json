{
    "version": "1.2.280",
    "description": "基于 Flutter 和 Rust 构建的现代跨平台 Clash 客户端 | A modern cross-platform Clash client built with Flutter and Rust",
    "homepage": "https://github.com/Kindness-Kismet/Stelliberty",
    "license": {
        "identifier": "Unknown"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Kindness-Kismet/Stelliberty/releases/download/v1.2.280/Stelliberty-v1.2.280-windows-x64-setup.exe",
            "hash": "bf63e2f71d76f79973771ad352f64c62666412b4165085b0bfda3fcb8e9ca7cb"
        }
    },
    "shortcuts": [
        [
            "app\\stelliberty.exe",
            "Stelliberty"
        ]
    ],
    "link": "$env:AppData\\stelliberty",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Uninstall-Manually 'app'",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Kindness-Kismet/Stelliberty/releases/download/v$version/Stelliberty-v$version-windows-x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
