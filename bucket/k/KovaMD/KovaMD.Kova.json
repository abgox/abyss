{
    "version": "0.6.16",
    "description": "可将纯 Markdown 文本转化为精致幻灯片的 Markdown 演示编辑器，支持实时预览、多种版式、主题设置以及 PPTX 格式导出 | Markdown presentation editor that turns plain Markdown into polished slides with live preview, multiple layouts, theming, and PPTX export",
    "homepage": "https://kova.md",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/KovaMD/Kova/releases/download/v0.6.16/Kova_0.6.16_x64-setup.exe",
            "hash": "38cf160c8c33ede164537404a66f728eb6a354e0814f1072e87aa24a17d54156"
        }
    },
    "shortcuts": [
        [
            "app\\Kova.exe",
            "Kova"
        ]
    ],
    "link": [
        "$env:AppData\\kova",
        "$env:AppData\\md.kova.app"
    ],
    "cleanup": "$env:LocalAppData\\md.kova.app",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/KovaMD/Kova/releases/download/v$version/Kova_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
