{
    "version": "1.7.23",
    "description": "轻量级的开源项目管理工具 | Lightweight task management tool",
    "homepage": "https://www.dootask.com/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/kuaifan/dootask/releases/download/v1.7.23/DooTask-v1.7.23-win-x64.exe",
            "hash": "2f955e67c0ac88517bc1ddb23115a261aaea1e1a85cec0fdbe9d914dfbd87eb2"
        },
        "arm64": {
            "url": "https://github.com/kuaifan/dootask/releases/download/v1.7.23/DooTask-v1.7.23-win-arm64.exe",
            "hash": "0f08ae338da50d076b6bc8960284cdd17353b123efef02a4cd2a01ccd96acb8c"
        }
    },
    "shortcuts": [
        [
            "app\\DooTask.exe",
            "DooTask"
        ]
    ],
    "link": "$env:AppData\\DooTask",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall DooTask.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\dootask-updater\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/kuaifan/dootask/releases/download/v$version/DooTask-v$version-win-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/kuaifan/dootask/releases/download/v$version/DooTask-v$version-win-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
