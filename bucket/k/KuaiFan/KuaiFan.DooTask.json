{
    "version": "1.7.55",
    "description": "轻量级的开源项目管理工具 | Lightweight task management tool",
    "homepage": "https://www.dootask.com/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/kuaifan/dootask/releases/download/v1.7.55/DooTask-v1.7.55-win-x64.exe",
            "hash": "d6ac47bf99f99f39142f6a9b77ca103877fb8af2b952f96efd01f0db1e7a39ef"
        },
        "arm64": {
            "url": "https://github.com/kuaifan/dootask/releases/download/v1.7.55/DooTask-v1.7.55-win-arm64.exe",
            "hash": "702553cdaf9640af276c0595fc98fde09b9e4df73b60231d00c5204ff78a5c67"
        }
    },
    "shortcuts": [
        [
            "app\\DooTask.exe",
            "DooTask"
        ]
    ],
    "link": "$env:AppData\\DooTask",
    "cleanup": "$env:LocalAppData\\dootask-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall DooTask.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/kuaifan/dootask/releases/download/v$version/DooTask-v$version-win-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/kuaifan/dootask/releases/download/v$version/DooTask-v$version-win-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
