{
    "version": "3.4.0",
    "description": "一款基于 PicGo 的图片上传与管理工具 | An image upload and manage tool, base on PicGo",
    "homepage": "https://piclist.cn/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Kuingsmile/PicList/releases/download/v3.4.0/PicList-Setup-3.4.0-x64.exe",
            "hash": "6f44365c395e2d692f1e78064e4777692b8226df48eacec4dd7fc768619b81b7"
        }
    },
    "shortcuts": [
        [
            "app\\PicList.exe",
            "PicList"
        ]
    ],
    "link": "$env:AppData\\piclist",
    "cleanup": "$env:LocalAppData\\piclist-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall PicList.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Kuingsmile/PicList/releases/download/v$version/PicList-Setup-$version-x64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
