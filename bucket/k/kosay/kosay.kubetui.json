{
    "version": "1.13.0",
    "description": "用于实时监控和探索 Kubernetes 资源的 TUI 工具 | TUI tool for real-time monitoring and exploration of Kubernetes resources",
    "homepage": "https://github.com/sarub0b0/kubetui",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/sarub0b0/kubetui/releases/download/v1.13.0/kubetui-x86_64-pc-windows-msvc.exe#/kubetui.exe",
            "hash": "febc2b49ea0ac4411d38839ea2d45104b31bcbdba4b048734fad5da73b5a1438"
        }
    },
    "bin": "kubetui.exe",
    "link": "$home\\.config\\kubetui",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/sarub0b0/kubetui/releases/download/v$version/kubetui-x86_64-pc-windows-msvc.exe#/kubetui.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
