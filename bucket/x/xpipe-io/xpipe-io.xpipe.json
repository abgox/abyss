{
    "version": "22.9",
    "description": "一种新型的 shell 连接枢纽和远程文件管理器，它允许你从本地机器访问你的整个服务器基础设施 | A new type of shell connection hub and remote file manager that allows you to access your entire server infrastructure from your local machine",
    "homepage": "https://xpipe.io/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/xpipe-io/xpipe/releases/download/22.9/xpipe-installer-windows-x86_64.msi",
            "hash": "3ba079d832cdd204858f1e1038e9d2336baa4d4215f168a72a8c3b1d423dbb94"
        },
        "arm64": {
            "url": "https://github.com/xpipe-io/xpipe/releases/download/22.9/xpipe-installer-windows-arm64.msi",
            "hash": "8acea709e1716e038b22782d25ff9cfe8cf75f67ff11b8fc3e6c1dc055aca0f9"
        }
    },
    "extract_to": "app",
    "bin": "app\\bin\\xpipe.exe",
    "shortcuts": [
        [
            "app\\xpiped.exe",
            "XPipe"
        ]
    ],
    "link": "$home\\.xpipe",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/xpipe-io/xpipe/releases/download/$version/xpipe-installer-windows-x86_64.msi"
            },
            "arm64": {
                "url": "https://github.com/xpipe-io/xpipe/releases/download/$version/xpipe-installer-windows-arm64.msi"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
