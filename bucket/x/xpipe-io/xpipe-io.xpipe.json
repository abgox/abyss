{
    "version": "22.10",
    "description": "一种新型的 shell 连接枢纽和远程文件管理器，它允许你从本地机器访问你的整个服务器基础设施 | A new type of shell connection hub and remote file manager that allows you to access your entire server infrastructure from your local machine",
    "homepage": "https://xpipe.io/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/xpipe-io/xpipe/releases/download/22.10/xpipe-installer-windows-x86_64.msi",
            "hash": "faa38e2afc9d849939ecf19c0ea1a12ecdf3e7e35dbebd6d56328b491bd2c190"
        },
        "arm64": {
            "url": "https://github.com/xpipe-io/xpipe/releases/download/22.10/xpipe-installer-windows-arm64.msi",
            "hash": "cd487d2cc8536fbc8d8e2583e4548d355b90d3ab329157155503a4d7cc886ff8"
        }
    },
    "extract_to": "app",
    "bin": "app\\bin\\xpipe.exe",
    "shortcuts": [
        [
            "app\\xpiped.exe",
            "XPipe"
        ]
    ],
    "link": "$home\\.xpipe",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/xpipe-io/xpipe/releases/download/$version/xpipe-installer-windows-x86_64.msi"
            },
            "arm64": {
                "url": "https://github.com/xpipe-io/xpipe/releases/download/$version/xpipe-installer-windows-arm64.msi"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
