{
    "version": "2.2.2",
    "description": "系统级音频捕获 & 云端与本地 ASR 一体化桌面应用 | System-Level Audio Capture & Cloud and Local ASR in One Desktop App",
    "homepage": "https://github.com/XimilalaXiang/DeLive",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/XimilalaXiang/DeLive/releases/download/v2.2.2/DeLive-2.2.2-x64.exe",
            "hash": "488388caef827e29d86c5109a7fcb3fc3106bfe0707b11a0a5c78578cea1655c"
        }
    },
    "shortcuts": [
        [
            "app\\DeLive.exe",
            "DeLive"
        ]
    ],
    "link": "$env:AppData\\delive",
    "cleanup": "$env:LocalAppData\\delive-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall DeLive.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/XimilalaXiang/DeLive/releases/download/v$version/DeLive-$version-x64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
