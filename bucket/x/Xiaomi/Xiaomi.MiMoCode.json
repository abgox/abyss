{
    "version": "0.1.8",
    "description": "面向开发者的终端原生 AI 编程助手 | A terminal-native AI coding assistant for developers",
    "homepage": "https://mimo.xiaomi.com/mimocode",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/XiaomiMiMo/MiMo-Code/releases/download/v0.1.8/mimocode-windows-x64.zip",
            "hash": "a14fb115efb8ff5f100329f2209ba95fb6ab6e0456fb29decd745c3dde6bded2"
        },
        "arm64": {
            "url": "https://github.com/XiaomiMiMo/MiMo-Code/releases/download/v0.1.8/mimocode-windows-arm64.zip",
            "hash": "afdb031f1c142f847503fea96d19bb3d2ac678ca33bb61be20f0ce6d554a3114"
        }
    },
    "extract_to": "app",
    "bin": "app\\mimo.exe",
    "link": [
        "$home\\.config\\mimocode",
        "$home\\.cache\\mimocode",
        "$home\\.local\\share\\mimocode"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/XiaomiMiMo/MiMo-Code/releases/download/v$version/mimocode-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/XiaomiMiMo/MiMo-Code/releases/download/v$version/mimocode-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
