{
    "version": "0.1.5",
    "description": "面向开发者的终端原生 AI 编程助手 | A terminal-native AI coding assistant for developers",
    "homepage": "https://mimo.xiaomi.com/mimocode",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/XiaomiMiMo/MiMo-Code/releases/download/v0.1.5/mimocode-windows-x64.zip",
            "hash": "604ee70010de82519765eb9f0728313c498c6eb5717a1640c73dae844a7161e1"
        },
        "arm64": {
            "url": "https://github.com/XiaomiMiMo/MiMo-Code/releases/download/v0.1.5/mimocode-windows-arm64.zip",
            "hash": "db0c5b62296e46f2fbb03e8e8bcc6e7977605345624337537b31cb682ddc6b80"
        }
    },
    "extract_to": "app",
    "bin": "app\\mimo.exe",
    "link": [
        "$home\\.config\\mimocode",
        "$home\\.cache\\mimocode",
        "$home\\.local\\share\\mimocode"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/XiaomiMiMo/MiMo-Code/releases/download/v$version/mimocode-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/XiaomiMiMo/MiMo-Code/releases/download/v$version/mimocode-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
