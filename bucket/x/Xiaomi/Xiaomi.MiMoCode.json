            "url": "https://github.com/XiaomiMiMo/MiMo-Code/releases/download/v0.1.7/mimocode-windows-x64.zip",
            "hash": "d48c144ace6f988088a3e9eeca2c05430cfe288ffce05871f98012914c7a6b08"
        },
        "arm64": {
            "url": "https://github.com/XiaomiMiMo/MiMo-Code/releases/download/v0.1.7/mimocode-windows-arm64.zip",
            "hash": "0932632243e65237069700928617adf97f1d2a81877bd5d638d929392d0d2c7a"
        }
    },
    "extract_to": "app",
    "bin": "app\\mimo.exe",
    "link": [
        "$home\\.config\\mimocode",
        "$home\\.cache\\mimocode",
        "$home\\.local\\share\\mimocode"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/XiaomiMiMo/MiMo-Code/releases/download/v$version/mimocode-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/XiaomiMiMo/MiMo-Code/releases/download/v$version/mimocode-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
