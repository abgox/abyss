            "hash": "1a2ef4bc07229b269f94197dcb7006c6f826086ac7b304762c24a1f041e5e214"
        },
        "arm64": {
            "url": "https://github.com/XiaomiMiMo/MiMo-Code/releases/download/v0.1.6/mimocode-windows-arm64.zip",
            "hash": "007e5ca68f9f3c125477122a97c41cd481ad330465aca76034d91de97dab578c"
        }
    },
    "extract_to": "app",
    "bin": "app\\mimo.exe",
    "link": [
        "$home\\.config\\mimocode",
        "$home\\.cache\\mimocode",
        "$home\\.local\\share\\mimocode"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/XiaomiMiMo/MiMo-Code/releases/download/v$version/mimocode-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/XiaomiMiMo/MiMo-Code/releases/download/v$version/mimocode-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
