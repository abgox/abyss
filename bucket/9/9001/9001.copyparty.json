{
    "version": "1.20.14",
    "description": "便携式文件服务器，集加速可续传上传、重复数据删除、WebDAV、SFTP、FTP、TFTP、零配置、媒体索引器、缩略图等众多功能于一体 | Portable file server with accelerated resumable uploads, dedup, WebDAV, SFTP, FTP, TFTP, zeroconf, media indexer, thumbnails++ all in one file",
    "homepage": "https://github.com/9001/copyparty",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/9001/copyparty/releases/download/v1.20.14/copyparty.exe",
            "hash": "c3b6a32123c8b3df782cf9a35c36bdb91213ad332f17e3144ec5c9f376560dd0"
        }
    },
    "bin": "copyparty.exe",
    "link": "$env:AppData\\copyparty",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/9001/copyparty/releases/download/v$version/copyparty.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
