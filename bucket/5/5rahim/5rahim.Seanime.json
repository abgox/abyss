            "hash": "78c246a4b020087553f521d05bf993bd90908bd79249e11d0c7c7320e4177d04"
        }
    },
    "shortcuts": [
        [
            "app\\Seanime Denshi.exe",
            "Seanime Denshi"
        ]
    ],
    "link": "$env:AppData\\Seanime",
    "cleanup": [
        "$env:AppData\\seanime-denshi",
        "$env:LocalAppData\\app.seanime.desktop"
    ],
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Seanime Denshi.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/5rahim/seanime/releases/download/v$version/seanime-denshi-$version_Windows_x64.exe"
