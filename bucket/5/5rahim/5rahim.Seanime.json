{
    "version": "3.8.0",
    "description": "免费开源的媒体服务器，为动漫爱好者提供丰富功能 | Free and open-source media server packed with features for anime and manga enthusiasts",
    "homepage": "https://seanime.rahim.app/",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/5rahim/seanime/releases/download/v3.8.0/seanime-denshi-3.8.0_Windows_x64.exe",
            "hash": "f5d110fa8fc591e3deb8903d435ffaa76dac3a6938a18e09aaaa3875f4d219a6"
        }
    },
    "shortcuts": [
        [
            "app\\Seanime Denshi.exe",
            "Seanime Denshi"
        ]
    ],
    "link": "$env:AppData\\Seanime",
    "cleanup": [
        "$env:AppData\\seanime-denshi",
        "$env:LocalAppData\\app.seanime.desktop"
    ],
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Seanime Denshi.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/5rahim/seanime/releases/download/v$version/seanime-denshi-$version_Windows_x64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
