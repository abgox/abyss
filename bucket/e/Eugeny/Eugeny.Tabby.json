{
    "version": "1.0.232",
    "description": "一个现代终端 | A terminal for a more modern age",
    "homepage": "https://tabby.sh/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Eugeny/tabby/releases/download/v1.0.232/tabby-1.0.232-portable-x64.zip",
            "hash": "a45bcef05fdb05ff46e43044b08f7c8f873054229f809c424bbc5fbebf5b76f3"
        },
        "arm64": {
            "url": "https://github.com/Eugeny/tabby/releases/download/v1.0.232/tabby-1.0.232-portable-arm64.zip",
            "hash": "26d08a9bbe0ff3a423d13275d73127465e183e9c9316583f33ad67d63fec49f8"
        }
    },
    "extract_to": "app",
    "bin": "app\\Tabby.exe",
    "shortcuts": [
        [
            "app\\Tabby.exe",
            "Tabby"
        ]
    ],
    "persist": [
        [
            "app\\data",
            "AppData\\Roaming\\tabby"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Eugeny/tabby/releases/download/v$version/tabby-$version-portable-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/Eugeny/tabby/releases/download/v$version/tabby-$version-portable-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
