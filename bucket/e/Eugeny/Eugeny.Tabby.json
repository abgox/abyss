{
    "version": "1.0.231",
    "description": "一个现代终端 | A terminal for a more modern age",
    "homepage": "https://tabby.sh/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Eugeny/tabby/releases/download/v1.0.231/tabby-1.0.231-portable-x64.zip",
            "hash": "8827ae4a5234d51c8439f7f5dc332c95a42011d9af25d8244252871e2f627658"
        },
        "arm64": {
            "url": "https://github.com/Eugeny/tabby/releases/download/v1.0.231/tabby-1.0.231-portable-arm64.zip",
            "hash": "8a7d33e6e1f6a564bc178b553acba26d335601ab1995d6910bbbac659813bf19"
        }
    },
    "extract_to": "app",
    "bin": "app\\Tabby.exe",
    "shortcuts": [
        [
            "app\\Tabby.exe",
            "Tabby"
        ]
    ],
    "persist": [
        [
            "app\\data",
            "AppData\\Roaming\\tabby"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Eugeny/tabby/releases/download/v$version/tabby-$version-portable-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/Eugeny/tabby/releases/download/v$version/tabby-$version-portable-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
