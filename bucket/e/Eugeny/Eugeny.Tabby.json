{
    "version": "1.0.235",
    "description": "一个现代终端 | A terminal for a more modern age",
    "homepage": "https://tabby.sh",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Eugeny/tabby/releases/download/v1.0.235/tabby-1.0.235-portable-x64.zip",
            "hash": "192ee1f402e046f8be5a31118da1dfa38aa290387e7e57dceafcc0b3dfd1a835"
        },
        "arm64": {
            "url": "https://github.com/Eugeny/tabby/releases/download/v1.0.235/tabby-1.0.235-portable-arm64.zip",
            "hash": "45cee415564bc4ba9d5004bda62fe102a4b3306002a8147d63eab75cb24574d3"
        }
    },
    "extract_to": "app",
    "bin": "app\\Tabby.exe",
    "shortcuts": [
        [
            "app\\Tabby.exe",
            "Tabby"
        ]
    ],
    "persist": [
        [
            "app\\data",
            "AppData\\Roaming\\tabby"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Eugeny/tabby/releases/download/v$version/tabby-$version-portable-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/Eugeny/tabby/releases/download/v$version/tabby-$version-portable-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
