{
    "version": "1.0.233",
    "description": "一个现代终端 | A terminal for a more modern age",
    "homepage": "https://tabby.sh/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Eugeny/tabby/releases/download/v1.0.233/tabby-1.0.233-portable-x64.zip",
            "hash": "5d14a2187e8ecb32fcd7f0ad8610af805dec95c2123731bce663c05bb57da406"
        },
        "arm64": {
            "url": "https://github.com/Eugeny/tabby/releases/download/v1.0.233/tabby-1.0.233-portable-arm64.zip",
            "hash": "e542c6838a0714676d5623901af8650ddd0678d8f8d3eba6550029de323ea92a"
        }
    },
    "extract_to": "app",
    "bin": "app\\Tabby.exe",
    "shortcuts": [
        [
            "app\\Tabby.exe",
            "Tabby"
        ]
    ],
    "persist": [
        [
            "app\\data",
            "AppData\\Roaming\\tabby"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Eugeny/tabby/releases/download/v$version/tabby-$version-portable-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/Eugeny/tabby/releases/download/v$version/tabby-$version-portable-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
