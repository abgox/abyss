{
    "version": "1.1.0",
    "description": "一个跨平台的开源剪贴板管理工具 | A cross-platform open-source clipboard manager",
    "homepage": "https://github.com/EcoPasteHub/EcoPaste",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/EcoPasteHub/EcoPaste/releases/download/v1.1.0/EcoPaste_1.1.0_x64-setup.exe#/dl.7z",
            "hash": "8a437d9f2cd960184942e0b1a2d1063566501928ead07cf82bc0959da534b5bf"
        },
        "arm64": {
            "url": "https://github.com/EcoPasteHub/EcoPaste/releases/download/v1.1.0/EcoPaste_1.1.0_arm64-setup.exe#/dl.7z",
            "hash": "94a8efaf4fbb5b2be13f705da6da49a826d8e7efd2ff8f74fb88a12184d36f14"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\EcoPaste.exe",
            "EcoPaste"
        ]
    ],
    "link": "$env:AppData\\com.ayangweb.EcoPaste",
    "cleanup": "$env:LocalAppData\\com.ayangweb.EcoPaste",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/EcoPasteHub/EcoPaste/releases/download/v$version/EcoPaste_$version_x64-setup.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/EcoPasteHub/EcoPaste/releases/download/v$version/EcoPaste_$version_arm64-setup.exe#/dl.7z"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
