{
    "version": "2.4.0",
    "description": "一款隐私优先、跨平台的文本扩展器，采用 Rust 语言编写 | A Privacy-first, Cross-platform Text Expander written in Rust",
    "homepage": "https://espanso.org",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/espanso/espanso/releases/download/v2.4.0/Espanso-Win-Installer-x86_64.exe",
            "hash": "2301f98fe5516720528606318b6a05f9f5d142eaaca9e0e397337015d288b415"
        }
    },
    "bin": [
        "app\\espanso.cmd",
        "app\\espansod.exe"
    ],
    "shortcuts": [
        [
            "app\\espansod.exe",
            "Espanso"
        ]
    ],
    "link": [
        "$env:AppData\\espanso",
        "$env:LocalAppData\\espanso"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/espanso/espanso/releases/download/v$version/Espanso-Win-Installer-x86_64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
