{
    "version": "1.73.100",
    "description": "Eclipse Theia 是一款基于 Theia 平台构建的适用于云端和桌面端的现代化、原生支持人工智能的集成开发环境 | Eclipse Theia is a modern, AI-native IDE for cloud and desktop built on the Theia Platform",
    "homepage": "https://theia-ide.org",
    "license": {
        "identifier": "EPL-2.0|GPL-2.0|MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://download.eclipse.org/theia/ide/1.73.100/windows/TheiaIDESetup-1.73.100.exe",
            "hash": "fd5b09c1c5d6fe8217bea0b14bebbdbdd796693149e3dad9a92c28869f292ca3"
        }
    },
    "shortcuts": [
        [
            "app\\TheiaIDE.exe",
            "TheiaIDE"
        ]
    ],
    "link": [
        "$env:AppData\\Theia IDE",
        "$home\\.theia-ide"
    ],
    "cleanup": "$env:LocalAppData\\theia-ide-electron-app-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall TheiaIDE.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'EclipseFoundation.TheiaIDE' 'exe'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_user.InstallerSha256"
                }
            }
        }
    }
}
