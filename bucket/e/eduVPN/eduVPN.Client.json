{
    "version": "4.6",
    "description": "使用加密连接访问您所在机构的网络或互联网 | Access your institute's network or the Internet using an encrypted connection",
    "homepage": "https://www.eduvpn.org",
    "license": {
        "identifier": "GPL-3.0-or-later",
        "url": "https://codeberg.org/eduVPN/windows/src/branch/master/LICENSE"
    },
    "architecture": {
        "64bit": {
            "url": "https://codeberg.org/eduVPN/windows/releases/download/4.6/eduVPNClient_4.6_x64.msi#/dl.msi_",
            "hash": "3035ffa94283dfeab00227041099436c41b6354d524e01831003d0697101ffb4"
        },
        "arm64": {
            "url": "https://codeberg.org/eduVPN/windows/releases/download/4.6/eduVPNClient_4.6_ARM64.msi#/dl.msi_",
            "hash": "f546d9e69660d7cb4f83c2179e17bae5c0d59a1b827636e91850bfed532d5c82"
        }
    },
    "location": "$env:ProgramFiles\\eduVPN",
    "cleanup": "$env:LocalAppData\\eduVPN",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Msi"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Uninstall-Msi"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'eduVPN.Client' 'msi'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64#/dl.msi_",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_machine.InstallerSha256"
                }
            },
            "arm64": {
                "url": "$matchArm64#/dl.msi_",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.arm64_machine.InstallerSha256"
                }
            }
        }
    }
}
