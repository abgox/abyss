{
    "version": "145.0.7632.159-1.1",
    "description": "不依赖谷歌网络服务的 Google Chromium 浏览器 | Google Chromium without dependency on Google web services",
    "homepage": "https://github.com/ungoogled-software/ungoogled-chromium-windows",
    "license": {
        "identifier": "BSD-3-Clause"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/ungoogled-software/ungoogled-chromium-windows/releases/download/145.0.7632.159-1.1/ungoogled-chromium_145.0.7632.159-1.1_installer_x64.exe",
            "hash": "c633c4c85d03ce5c6472280825a90ca8f0470dc901328167e3d820fad6e9cb47"
        },
        "arm64": {
            "url": "https://github.com/ungoogled-software/ungoogled-chromium-windows/releases/download/145.0.7632.159-1.1/ungoogled-chromium_145.0.7632.159-1.1_installer_arm64.exe",
            "hash": "af6f08d2c7af58efd4a5879197cef44079b313cc606f0a4d14738fd6e6aabb61"
        }
    },
    "conflicts": [
        "Hibbiki.Chromium",
        "eloston.ungoogled-chromium"
    ],
    "location": "$env:LocalAppData\\Chromium",
    "link": "$env:LocalAppData\\Chromium\\User Data",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller \"$env:LocalAppData\\Chromium\\Application\\chrome.exe\" -ArgumentList '--silent','--install'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Uninstall-Manually \"$env:LocalAppData\\Chromium\\Application\"",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ungoogled-software/ungoogled-chromium-windows/releases/download/$version/ungoogled-chromium_$version_installer_x64.exe"
            },
            "arm64": {
                "url": "https://github.com/ungoogled-software/ungoogled-chromium-windows/releases/download/$version/ungoogled-chromium_$version_installer_arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
