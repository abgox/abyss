{
    "version": "149.0.7827.53-1.1",
    "description": "不依赖谷歌网络服务的 Google Chromium 浏览器 | Google Chromium without dependency on Google web services",
    "homepage": "https://github.com/ungoogled-software/ungoogled-chromium-windows",
    "license": {
        "identifier": "BSD-3-Clause"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/ungoogled-software/ungoogled-chromium-windows/releases/download/149.0.7827.53-1.1/ungoogled-chromium_149.0.7827.53-1.1_installer_x64.exe",
            "hash": "e1156fab615e7c322500fd792a320a62461288bc3de914aa55a663ffe9354656"
        },
        "arm64": {
            "url": "https://github.com/ungoogled-software/ungoogled-chromium-windows/releases/download/149.0.7827.53-1.1/ungoogled-chromium_149.0.7827.53-1.1_installer_arm64.exe",
            "hash": "01b408fce2aaea61f0ceabe1b4ec1d718742aed9d741c254d01ab998984db61d"
        }
    },
    "conflicts": [
        "Hibbiki.Chromium",
        "eloston.ungoogled-chromium"
    ],
    "location": "$env:LocalAppData\\Chromium",
    "link": "$env:LocalAppData\\Chromium\\User Data",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -ArgumentList '--silent', '--install'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "$Uninstaller = Get-ChildItem \"$env:LocalAppData\\Chromium\\Application\" setup.exe -Recurse | Sort-Object LastWriteTime -Descending | Select-Object -First 1",
        "A-Uninstall-App -Uninstaller $Uninstaller.FullName -ArgumentList '--uninstall', '--force-uninstall'",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ungoogled-software/ungoogled-chromium-windows/releases/download/$version/ungoogled-chromium_$version_installer_x64.exe"
            },
            "arm64": {
                "url": "https://github.com/ungoogled-software/ungoogled-chromium-windows/releases/download/$version/ungoogled-chromium_$version_installer_arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
