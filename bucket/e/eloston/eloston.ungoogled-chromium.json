{
    "version": "148.0.7778.96-1.1",
    "description": "不依赖谷歌网络服务的 Google Chromium 浏览器 | Google Chromium without dependency on Google web services",
    "homepage": "https://github.com/ungoogled-software/ungoogled-chromium-windows",
    "license": {
        "identifier": "BSD-3-Clause"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/ungoogled-software/ungoogled-chromium-windows/releases/download/148.0.7778.96-1.1/ungoogled-chromium_148.0.7778.96-1.1_installer_x64.exe",
            "hash": "3a29040c655956e9f48ca8ac79c71d494852ba786da5627020ea71fc75009fb0"
        },
        "arm64": {
            "url": "https://github.com/ungoogled-software/ungoogled-chromium-windows/releases/download/148.0.7778.96-1.1/ungoogled-chromium_148.0.7778.96-1.1_installer_arm64.exe",
            "hash": "f6f2dc1814a6a422a8563b87ca57235df246c44c2351f9c64ee79b98e15d6189"
        }
    },
    "conflicts": [
        "Hibbiki.Chromium",
        "eloston.ungoogled-chromium"
    ],
    "location": "$env:LocalAppData\\Chromium",
    "link": "$env:LocalAppData\\Chromium\\User Data",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -ArgumentList '--silent', '--install'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "$Uninstaller = Get-ChildItem \"$env:LocalAppData\\Chromium\\Application\" setup.exe -Recurse | Sort-Object LastWriteTime -Descending | Select-Object -First 1",
        "A-Uninstall-App -Uninstaller $Uninstaller.FullName -ArgumentList '--uninstall', '--force-uninstall'",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ungoogled-software/ungoogled-chromium-windows/releases/download/$version/ungoogled-chromium_$version_installer_x64.exe"
            },
            "arm64": {
                "url": "https://github.com/ungoogled-software/ungoogled-chromium-windows/releases/download/$version/ungoogled-chromium_$version_installer_arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
