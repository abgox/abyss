{
    "version": "1.4.7",
    "description": "一款基于 Flutter + Rust 的 Material 风格本地音乐播放器 | A Material-style local music player based on Flutter + Rust",
    "homepage": "https://github.com/Empty-57/ZeroBit-Player",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Empty-57/ZeroBit-Player/releases/download/v1.4.7/zerobit_player.zip",
            "hash": "430380f4c5095da0caca016d810efff616d8740cad397d5148d322bf5d287788"
        }
    },
    "extract_dir": "zerobit_player",
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\zerobit_player.exe",
            "ZeroBit Player"
        ]
    ],
    "link": "$home\\Documents\\zerobit_config",
    "cleanup": "$env:AppData\\com.zerobit\\zerobit_player",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Empty-57/ZeroBit-Player/releases/download/v$version/zerobit_player.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
