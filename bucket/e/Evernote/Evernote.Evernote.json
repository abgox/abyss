{
    "version": "11.13.2",
    "description": "在一处记住所有内容，并通过笔记、任务和日程处理一切 | Remember everything and tackle any project with your notes, tasks, and schedule all in one place",
    "homepage": "https://evernote.com/",
    "license": {
        "identifier": "Unknown",
        "url": "https://evernote.com/legal/terms-of-service"
    },
    "architecture": {
        "64bit": {
            "url": "https://win.desktop.evernote.com/builds/Evernote-11.13.2-win-ddl-stage-20260417082602-e1b1f4983c32f618805c4b4caee7de99656fd14d-setup.exe",
            "hash": "3295de3d0932897b56bbc3146e9285d88b577a16faf56207b6bda69721a73fda"
        }
    },
    "location": "$env:LocalAppData\\Programs\\Evernote",
    "link": "$env:AppData\\Evernote",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'Uninstall Evernote.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\evernote-client-updater\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'Evernote.Evernote' 'exe'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_user.InstallerSha256"
                }
            }
        }
    }
}
