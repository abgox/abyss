{
    "version": "3.2.2",
    "description": "一款定制化 Discord 应用，Vesktop 的分支版本，旨在为你提供更出色的性能表现 | A custom Discord App, Vesktop fork, aiming to give you better performance",
    "homepage": "https://github.com/Equicord/Equibop",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Equicord/Equibop/releases/download/v3.2.2/Equibop-Setup-3.2.2.exe",
            "hash": "41bf7515166cefb8c60612b7dbe8f6c2b171bba8da4db5669049519c52a54fd5"
        },
        "arm64": {
            "url": "https://github.com/Equicord/Equibop/releases/download/v3.2.2/Equibop-Setup-3.2.2.exe",
            "hash": "41bf7515166cefb8c60612b7dbe8f6c2b171bba8da4db5669049519c52a54fd5"
        }
    },
    "shortcuts": [
        [
            "app\\equibop.exe",
            "Equibop"
        ]
    ],
    "link": "$env:AppData\\equibop",
    "cleanup": "$env:LocalAppData\\equibop-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Equibop.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Equicord/Equibop/releases/download/v$version/Equibop-Setup-$version.exe"
            },
            "arm64": {
                "url": "https://github.com/Equicord/Equibop/releases/download/v$version/Equibop-Setup-$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
