{
    "version": "3.1.9",
    "description": "一款定制化 Discord 应用，Vesktop 的分支版本，旨在为你提供更出色的性能表现 | A custom Discord App, Vesktop fork, aiming to give you better performance",
    "homepage": "https://github.com/Equicord/Equibop",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Equicord/Equibop/releases/download/v3.1.9/Equibop-Setup-3.1.9.exe",
            "hash": "be1127b16fb8959349acdaae07e191c38715318f1d4d17405fe7a858dc5b2140"
        },
        "arm64": {
            "url": "https://github.com/Equicord/Equibop/releases/download/v3.1.9/Equibop-Setup-3.1.9.exe",
            "hash": "be1127b16fb8959349acdaae07e191c38715318f1d4d17405fe7a858dc5b2140"
        }
    },
    "shortcuts": [
        [
            "app\\equibop.exe",
            "Equibop"
        ]
    ],
    "link": "$env:AppData\\equibop",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Equibop.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\equibop-updater\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Equicord/Equibop/releases/download/v$version/Equibop-Setup-$version.exe"
            },
            "arm64": {
                "url": "https://github.com/Equicord/Equibop/releases/download/v$version/Equibop-Setup-$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
