{
    "version": "1.3.0",
    "description": "适用于 Windows 11 的剪贴板历史、截图与屏幕录制工具，突破系统原生功能的各项限制 | Clipboard history, screen capture and screen recording for Windows 11, without the native limits",
    "homepage": "https://github.com/PoBruno/klip",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/PoBruno/klip/releases/download/v1.3.0/Klip-Setup-1.3.0.exe",
            "hash": "ff28a8d29d2f8e3e9590eee97a2531aaf9d23fb920897bc7206455dd5e78ea1a"
        }
    },
    "shortcuts": [
        [
            "app\\Klip.exe",
            "Klip"
        ]
    ],
    "link": "$env:LocalAppData\\Klip",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/PoBruno/klip/releases/download/v$version/Klip-Setup-$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
