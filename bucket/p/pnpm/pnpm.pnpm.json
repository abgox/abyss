{
    "version": "11.0.9",
    "description": "一款快速且节省磁盘空间的 Node 包管理器 | A fast and disk space efficient Node package manager",
    "homepage": "https://pnpm.io/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/pnpm/pnpm/releases/download/v11.0.9/pnpm-win32-x64.zip",
            "hash": "608c56dc746444f133ca901a5a0a32be779d28dcbcf4e7d7bf48372b005b907a"
        },
        "arm64": {
            "url": "https://github.com/pnpm/pnpm/releases/download/v11.0.9/pnpm-win32-arm64.zip",
            "hash": "c7c823246345541ea512a417028c4f682deb05954d19d945e290a4a174d2bd3c"
        }
    },
    "extract_to": "app",
    "bin": [
        "app\\pnpm.exe",
        [
            "app\\pnpm.exe",
            "pnpx",
            "dlx"
        ]
    ],
    "link": [
        "$env:LocalAppData\\pnpm",
        "$env:LocalAppData\\pnpm-state",
        "$env:LocalAppData\\pnpm-cache"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/pnpm/pnpm/releases/download/v$version/pnpm-win32-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/pnpm/pnpm/releases/download/v$version/pnpm-win32-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
