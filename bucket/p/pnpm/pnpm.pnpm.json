{
    "version": "11.5.0",
    "description": "一款快速且节省磁盘空间的 Node 包管理器 | A fast and disk space efficient Node package manager",
    "homepage": "https://pnpm.io/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/pnpm/pnpm/releases/download/v11.5.0/pnpm-win32-x64.zip",
            "hash": "f85f5c399caa41e2fbce8a2127b69ea4d2ab9b45296756a557b26110d01dcefd"
        },
        "arm64": {
            "url": "https://github.com/pnpm/pnpm/releases/download/v11.5.0/pnpm-win32-arm64.zip",
            "hash": "9c3475645cc150b3ffdadb5ef8e995d4f2e95f89875a4d3dc005122a9ff2572f"
        }
    },
    "extract_to": "app",
    "bin": [
        "app\\pnpm.exe",
        [
            "app\\pnpm.exe",
            "pnpx",
            "dlx"
        ]
    ],
    "link": [
        "$env:LocalAppData\\pnpm",
        "$env:LocalAppData\\pnpm-state",
        "$env:LocalAppData\\pnpm-cache"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/pnpm/pnpm/releases/download/v$version/pnpm-win32-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/pnpm/pnpm/releases/download/v$version/pnpm-win32-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
