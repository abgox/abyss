{
    "version": "10.32.0",
    "description": "一款快速且节省磁盘空间的 Node 包管理器 | A fast and disk space efficient Node package manager",
    "homepage": "https://pnpm.io/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/pnpm/pnpm/releases/download/v10.32.0/pnpm-win-x64.exe#/pnpm.exe",
            "hash": "8bdb2c94278f92eb9dc8272d5e1211be4489273917bc212c657241e6aca79dcc"
        },
        "arm64": {
            "url": "https://github.com/pnpm/pnpm/releases/download/v10.32.0/pnpm-win-arm64.exe#/pnpm.exe",
            "hash": "406298f523eff22e9074e72678496193b5b0420d5f1edf431d6440ac96c1d465"
        }
    },
    "bin": [
        "pnpm.exe",
        [
            "pnpm.exe",
            "pnpx",
            "dlx"
        ]
    ],
    "link": [
        "$env:LocalAppData\\pnpm",
        "$env:LocalAppData\\pnpm-state",
        "$env:LocalAppData\\pnpm-cache"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/pnpm/pnpm/releases/download/v$version/pnpm-win-x64.exe#/pnpm.exe"
            },
            "arm64": {
                "url": "https://github.com/pnpm/pnpm/releases/download/v$version/pnpm-win-arm64.exe#/pnpm.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
