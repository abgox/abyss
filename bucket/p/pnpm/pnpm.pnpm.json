{
    "version": "11.1.1",
    "description": "一款快速且节省磁盘空间的 Node 包管理器 | A fast and disk space efficient Node package manager",
    "homepage": "https://pnpm.io/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/pnpm/pnpm/releases/download/v11.1.1/pnpm-win32-x64.zip",
            "hash": "486a8d063b3143c80be9e1ed21a0d53eb3fa19fe7b1d8f1973a91112d321e709"
        },
        "arm64": {
            "url": "https://github.com/pnpm/pnpm/releases/download/v11.1.1/pnpm-win32-arm64.zip",
            "hash": "056ae0ac11412efe0ee848b6fb09cb6be3968b179030ee3314d67b5e1f753d0e"
        }
    },
    "extract_to": "app",
    "bin": [
        "app\\pnpm.exe",
        [
            "app\\pnpm.exe",
            "pnpx",
            "dlx"
        ]
    ],
    "link": [
        "$env:LocalAppData\\pnpm",
        "$env:LocalAppData\\pnpm-state",
        "$env:LocalAppData\\pnpm-cache"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/pnpm/pnpm/releases/download/v$version/pnpm-win32-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/pnpm/pnpm/releases/download/v$version/pnpm-win32-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
