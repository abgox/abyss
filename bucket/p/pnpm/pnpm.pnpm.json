{
    "version": "11.12.0",
    "description": "一款快速且节省磁盘空间的 Node 包管理器 | A fast and disk space efficient Node package manager",
    "homepage": "https://pnpm.io",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/pnpm/pnpm/releases/download/v11.12.0/pnpm-win32-x64.zip",
            "hash": "7ac25ba81b8a9f213a307ae89198ba7e636e6c74fa0d775d554ba46e0187358b"
        },
        "arm64": {
            "url": "https://github.com/pnpm/pnpm/releases/download/v11.12.0/pnpm-win32-arm64.zip",
            "hash": "a2b7e3a3855dbe6c1ea99e90d0c54aa86aa33b407096fb670e4fc9f13f146cda"
        }
    },
    "extract_to": "app",
    "bin": [
        "app\\pnpm.exe",
        [
            "app\\pnpm.exe",
            "pnpx",
            "dlx"
        ]
    ],
    "link": [
        "$env:LocalAppData\\pnpm",
        "$env:LocalAppData\\pnpm-state",
        "$env:LocalAppData\\pnpm-cache"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/pnpm/pnpm/releases/download/v$version/pnpm-win32-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/pnpm/pnpm/releases/download/v$version/pnpm-win32-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
