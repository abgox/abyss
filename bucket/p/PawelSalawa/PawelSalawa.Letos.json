{
    "version": "4.0.1",
    "description": "用于浏览和编辑 SQLite 数据库文件的桌面应用程序 | Desktop application for browsing and editing SQLite database files",
    "homepage": "https://letos.org",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/pawelsalawa/letos/releases/download/4.0.1/Letos-4.0.1-windows-x64-setup.exe",
            "hash": "fac036588ebd274f8f146640565b808003d446c94246076b7b0048adbde72abd"
        },
        "arm64": {
            "url": "https://github.com/pawelsalawa/letos/releases/download/4.0.1/Letos-4.0.1-windows-arm64-setup.exe",
            "hash": "66a449f524a0aa8c868dd2f6bd28bbf57ca2ff00f4e5186988aa638830f79206"
        }
    },
    "shortcuts": [
        [
            "app\\letos.exe",
            "Letos"
        ]
    ],
    "link": "$env:AppData\\letos.org\\Letos",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/pawelsalawa/letos/releases/download/$version/Letos-$version-windows-x64-setup.exe"
            },
            "arm64": {
                "url": "https://github.com/pawelsalawa/letos/releases/download/$version/Letos-$version-windows-arm64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
