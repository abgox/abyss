{
    "version": "2.2.0",
    "description": "基于自定义规则的番剧采集 APP | A custom rule based anime collection APP",
    "homepage": "https://kazumi.app",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Predidit/Kazumi/releases/download/2.2.0/Kazumi_windows_2.2.0.zip",
            "hash": "0fa08dfeeced6cb897ff0689ed8e29245043b7d88daf3d620cc3103f45e973ea"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\kazumi.exe",
            "kazumi"
        ]
    ],
    "link": "$env:AppData\\com.example\\kazumi",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Predidit/Kazumi/releases/download/$version/Kazumi_windows_$version.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
