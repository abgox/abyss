{
    "version": "1.25.0",
    "description": "适用于 PowerShell 模块和脚本的静态代码检查器 | A static code checker for PowerShell modules and scripts",
    "homepage": "https://github.com/PowerShell/PSScriptAnalyzer",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://cdn.powershellgallery.com/packages/psscriptanalyzer.1.25.0.nupkg",
            "hash": "14e634c828eb98efb9f40b2918ba90f139ed5eccdf663a2a747736d996995d60"
        },
        "arm64": {
            "url": "https://cdn.powershellgallery.com/packages/psscriptanalyzer.1.25.0.nupkg",
            "hash": "14e634c828eb98efb9f40b2918ba90f139ed5eccdf663a2a747736d996995d60"
        }
    },
    "psmodule": {
        "name": "PSScriptAnalyzer"
    },
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://www.powershellgallery.com/packages/psscriptanalyzer",
        "regex": "<h2>([\\d.]+)</h2>"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://cdn.powershellgallery.com/packages/psscriptanalyzer.$version.nupkg"
            },
            "arm64": {
                "url": "https://cdn.powershellgallery.com/packages/psscriptanalyzer.$version.nupkg"
            }
        }
    }
}
