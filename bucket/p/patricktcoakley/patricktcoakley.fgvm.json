{
    "version": "2.1.0",
    "description": "一个友好的 Godot 版本管理器 | A friendly Godot version manager",
    "homepage": "https://fgvm.dev/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/patricktcoakley/fgvm/releases/download/v2.1.0/fgvm-win-x64.zip",
            "hash": "173e27b8c748d7db442aea9cffa016f7c531dc2ce943f4d31af92497058c43c6"
        }
    },
    "extract_to": "app",
    "env_set": {
        "FGVM_HOME": "$persist_dir"
    },
    "env_add_path": "fgvm\\bin",
    "bin": "app\\fgvm.exe",
    "link": "$home\\fgvm",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/patricktcoakley/fgvm/releases/download/v$version/fgvm-win-x64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
