{
    "version": "0.9.0",
    "description": "用 Rust 编写的 R 格式化工具和语言服务器 | R formatter and language server, written in Rust",
    "homepage": "https://posit-dev.github.io/air/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/posit-dev/air/releases/download/0.9.0/air-x86_64-pc-windows-msvc.zip",
            "hash": "29260d3fde911663e7221a99336a892ef3a1775d1c895021d0a4654dcebc2fe0"
        },
        "arm64": {
            "url": "https://github.com/posit-dev/air/releases/download/0.9.0/air-aarch64-pc-windows-msvc.zip",
            "hash": "8409957f6dec699852635ebf1f2139d55b35853b291a94bd510e90f8fa5cfeb7"
        }
    },
    "extract_to": "app",
    "bin": "app\\air.exe",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/posit-dev/air/releases/download/$version/air-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/posit-dev/air/releases/download/$version/air-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
