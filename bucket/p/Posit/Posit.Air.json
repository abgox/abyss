{
    "version": "0.11.0",
    "description": "用 Rust 编写的 R 格式化工具和语言服务器 | R formatter and language server, written in Rust",
    "homepage": "https://posit-dev.github.io/air",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/posit-dev/air/releases/download/0.11.0/air-x86_64-pc-windows-msvc.zip",
            "hash": "8b111f2400e7b9aaabbc9448424381c3969f03370d59124c4fbcb3d766dfc104"
        },
        "arm64": {
            "url": "https://github.com/posit-dev/air/releases/download/0.11.0/air-aarch64-pc-windows-msvc.zip",
            "hash": "5f3e390502e5a086bbb46ae480cfdc0de9d64e8f5cb0e419c91ff5ba04738648"
        }
    },
    "extract_to": "app",
    "bin": "app\\air.exe",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/posit-dev/air/releases/download/$version/air-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/posit-dev/air/releases/download/$version/air-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
