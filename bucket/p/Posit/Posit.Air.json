{
    "version": "0.8.2",
    "description": "用 Rust 编写的 R 格式化工具和语言服务器 | R formatter and language server, written in Rust",
    "homepage": "https://posit-dev.github.io/air/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/posit-dev/air/releases/download/0.8.2/air-x86_64-pc-windows-msvc.zip",
            "hash": "5dabc491a63dbe0c1a0b358c6c8a3b6b79f802fd255f61efeb62930beb01a324"
        },
        "arm64": {
            "url": "https://github.com/posit-dev/air/releases/download/0.8.2/air-aarch64-pc-windows-msvc.zip",
            "hash": "53f6391b52bf9d3e853c55c9b29b9d5bca7a938ab13a0e396ed80499158e41e2"
        }
    },
    "extract_to": "app",
    "bin": "app\\air.exe",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/posit-dev/air/releases/download/$version/air-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/posit-dev/air/releases/download/$version/air-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
