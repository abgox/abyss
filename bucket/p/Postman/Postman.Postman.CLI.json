{
    "version": "1.35.2",
    "description": "Postman 的一款安全的命令行配套工具 | A secure command-line companion for Postman",
    "homepage": "https://learning.postman.com/docs/postman-cli/postman-cli-overview/",
    "license": {
        "identifier": "Proprietary"
    },
    "architecture": {
        "64bit": {
            "url": "https://dl-cli.pstmn.io/download/version/1.35.2/win64#/dl.zip",
            "hash": "6b30db09fe39fccd5cbd572d35708084baf8efb0c823e23111e65c083b95c9a8"
        }
    },
    "extract_to": "app",
    "bin": "app\\postman-cli.exe",
    "link": "$home\\.postman",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://dl-cli.pstmn.io/changelog?channel=stable&platform=win64",
        "jsonpath": "$.changelog[0].name"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://dl-cli.pstmn.io/download/version/$version/win64#/dl.zip"
            }
        }
    }
}
