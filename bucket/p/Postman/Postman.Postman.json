{
    "version": "12.20.0",
    "description": "API 开发协作平台 | The Collaboration Platform for API Development",
    "homepage": "https://www.postman.com",
    "license": {
        "identifier": "Proprietary"
    },
    "architecture": {
        "64bit": {
            "url": "https://dl.pstmn.io/download/version/12.20.0/windows_64#/dl.exe",
            "hash": "eff360d93e80cc37d1e5556f07ee5443f5e4ac80b128f0ff18da55fffcc3a7a6"
        }
    },
    "location": "$env:LocalAppData\\Postman",
    "link": [
        "$env:AppData\\Postman",
        "$home\\Postman"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'Update.exe' -ArgumentList '--silent'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App -ArgumentList '--uninstall'"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://dl.pstmn.io/changelog?channel=stable&platform=win64",
        "jsonpath": "$.changelog[0].name"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://dl.pstmn.io/download/version/$version/windows_64#/dl.exe"
            }
        }
    }
}
