{
    "version": "0.8.4",
    "description": "一个非交互式终端模拟器，它能执行单个命令，在内部虚拟会话中渲染其输出，并将屏幕截图导出为 SVG 文件 | A non-interactive terminal emulator that executes a single command, renders its output in an internal virtual session, and exports a screenshot as an SVG file",
    "homepage": "https://github.com/pamburus/termframe",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/pamburus/termframe/releases/download/v0.8.4/termframe-windows.zip",
            "hash": "696f5f7ed1c3ada2d2cc0e578b15b5af582cae6d064e206d9680346aaeacbbb9"
        },
        "arm64": {
            "url": "https://github.com/pamburus/termframe/releases/download/v0.8.4/termframe-windows-arm64.zip",
            "hash": "877752c98d7586bab7324f1f3c12a60a5c39c360e550e1691130e3efe0eb9022"
        }
    },
    "extract_to": "app",
    "bin": "app\\termframe.exe",
    "link": "$env:AppData\\termframe",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/pamburus/termframe/releases/download/v$version/termframe-windows.zip"
            },
            "arm64": {
                "url": "https://github.com/pamburus/termframe/releases/download/v$version/termframe-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
