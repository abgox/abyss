{
    "version": "0.8.5",
    "description": "一个非交互式终端模拟器，它能执行单个命令，在内部虚拟会话中渲染其输出，并将屏幕截图导出为 SVG 文件 | A non-interactive terminal emulator that executes a single command, renders its output in an internal virtual session, and exports a screenshot as an SVG file",
    "homepage": "https://github.com/pamburus/termframe",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/pamburus/termframe/releases/download/v0.8.5/termframe-windows.zip",
            "hash": "de7227f8d108b97649a249f7b2091abe1dace53f794f9d7bd5eb980c8dd5dcdc"
        },
        "arm64": {
            "url": "https://github.com/pamburus/termframe/releases/download/v0.8.5/termframe-windows-arm64.zip",
            "hash": "651d7cef0bfd75e918425aa8e1bb6dbcdf9f44b7599d889a36ede5afeeb19925"
        }
    },
    "extract_to": "app",
    "bin": "app\\termframe.exe",
    "link": "$env:AppData\\termframe",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/pamburus/termframe/releases/download/v$version/termframe-windows.zip"
            },
            "arm64": {
                "url": "https://github.com/pamburus/termframe/releases/download/v$version/termframe-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
