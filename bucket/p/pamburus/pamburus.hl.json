{
    "version": "0.36.1",
    "description": "高性能的日志查看器和处理器，可将 JSON 和 logfmt 格式的日志转换为人类可读的输出 | High-performance log viewer and processor that transforms logs in JSON and logfmt formats into a human-readable output",
    "homepage": "https://github.com/pamburus/hl",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/pamburus/hl/releases/download/v0.36.1/hl-windows.zip",
            "hash": "0acec89c23ad85d9ca1ae474937870172d41af0e72f74de77229e4d0850b5aba"
        },
        "arm64": {
            "url": "https://github.com/pamburus/hl/releases/download/v0.36.1/hl-windows-arm64.zip",
            "hash": "7777bb08057dd20acfef1089d6b52fe62975cc5c2362dc02820fb6669bfac1a0"
        }
    },
    "extract_to": "app",
    "bin": "app\\hl.exe",
    "link": "$env:AppData\\hl",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/pamburus/hl/releases/download/v$version/hl-windows.zip"
            },
            "arm64": {
                "url": "https://github.com/pamburus/hl/releases/download/v$version/hl-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
