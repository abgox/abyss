{
    "version": "0.4.1",
    "description": "现代化、跨平台的休息提醒应用 | A modern, cross-platform break reminder application",
    "homepage": "https://github.com/pilgrimlyieu/Focust",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/pilgrimlyieu/Focust/releases/download/v0.4.1/focust_0.4.1_windows_installer.exe",
            "hash": "3ad88d7ec321de332e826b385fc83181a365f62b01bf6f939b6a15f846194f94"
        }
    },
    "shortcuts": [
        [
            "app\\focust.exe",
            "Focust"
        ]
    ],
    "link": "$env:AppData\\com.fesmoph.focust",
    "cleanup": "$env:LocalAppData\\com.fesmoph.focust",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/pilgrimlyieu/Focust/releases/download/v$version/focust_$version_windows_installer.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
