{
    "version": "5.0.3",
    "description": "一个用 PowerShell 编写的构建自动化工具 | A build automation tool written in PowerShell",
    "homepage": "https://psake.dev/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://cdn.powershellgallery.com/packages/psake.5.0.3.nupkg",
            "hash": "dec6cdf9b186e53eec89d73cd5883c53008b453a63b2e22238887e1646c2bccb"
        },
        "arm64": {
            "url": "https://cdn.powershellgallery.com/packages/psake.5.0.3.nupkg",
            "hash": "dec6cdf9b186e53eec89d73cd5883c53008b453a63b2e22238887e1646c2bccb"
        }
    },
    "psmodule": {
        "name": "psake"
    },
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromPowerShellGallery"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://cdn.powershellgallery.com/packages/psake.$version.nupkg"
            },
            "arm64": {
                "url": "https://cdn.powershellgallery.com/packages/psake.$version.nupkg"
            }
        }
    }
}
