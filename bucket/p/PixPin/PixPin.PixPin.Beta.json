{
    "version": "3.0.6.0",
    "description": "一个功能强大使用简单的截图/贴图/录屏工具 | A powerful and simple screenshot/stick/screen recording tool",
    "homepage": "https://pixpin.cn/",
    "license": {
        "identifier": "Freemium",
        "url": "https://pixpin.cn/docs/policy/tos_zh_CN.html"
    },
    "architecture": {
        "64bit": {
            "url": "https://download.pixpinapp.com/PixPin_cn_zh-cn_3.0.6.0.exe",
            "hash": "26be9b761156ce00cd21f19eba6023c02c91f196faaac0d441f2648d58e9569f"
        }
    },
    "conflicts": [
        "PixPin.PixPin",
        "PixPin.PixPin.Beta"
    ],
    "bin": "app\\PixPin.exe",
    "shortcuts": [
        [
            "app\\PixPin.exe",
            "PixPin"
        ]
    ],
    "link": "$env:LocalAppData\\PixPin",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Require-Admin",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Require-Admin",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'PixPin.PixPin.Beta' 'exe'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_machine.InstallerSha256"
                }
            }
        }
    }
}
