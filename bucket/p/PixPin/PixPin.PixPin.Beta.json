{
    "version": "3.4.2.1",
    "description": "一个功能强大使用简单的截图/贴图/录屏工具 | A powerful and simple screenshot/stick/screen recording tool",
    "homepage": "https://pixpin.cn",
    "license": {
        "identifier": "Freemium",
        "url": "https://pixpin.cn/docs/policy/tos_zh_CN.html"
    },
    "architecture": {
        "64bit": {
            "url": "https://download.pixpinapp.com/PixPin_win_3.4.2.1.exe",
            "hash": "02f23a4a71ec8f8fd60f071fa6157b83a0478bb2b478e2a00598c1cf752c9287"
        }
    },
    "conflicts": [
        "PixPin.PixPin",
        "PixPin.PixPin.Beta"
    ],
    "bin": "app\\PixPin.exe",
    "shortcuts": [
        [
            "app\\PixPin.exe",
            "PixPin"
        ]
    ],
    "link": "$env:LocalAppData\\PixPin",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'PixPin.PixPin.Beta' 'exe'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_machine.InstallerSha256"
                }
            }
        }
    }
}
