{
    "version": "26.7.3",
    "description": "一款支持 Markdown 格式且能与 Nextcloud / ownCloud 集成的纯文本文件记事本和待办事项管理器 | A plain-text file notepad and todo-list manager with Markdown support and Nextcloud / ownCloud integration",
    "homepage": "https://www.qownnotes.org",
    "license": {
        "identifier": "GPL-2.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/pbek/QOwnNotes/releases/download/v26.7.3/QOwnNotes.zip",
            "hash": "58eb5d628c5219e1c2a2edf14affd4fbf9d851e48e14812a385a32101a61433b"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\QOwnNotes.exe",
            "QOwnNotes",
            "--portable"
        ]
    ],
    "persist": [
        [
            "app\\Data",
            "AppData\\Roaming\\PBE\\QOwnNotes"
        ],
        [
            "app\\Data\\Notes",
            "Notes"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/pbek/QOwnNotes/releases/download/v$version/QOwnNotes.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
