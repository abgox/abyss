{
    "version": "3.89.1",
    "description": "高度可扩展的 Markdown 编辑器 | A highly extensible Markdown editor",
    "homepage": "https://yank-note.com/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/purocean/yn/releases/download/v3.89.1/Yank-Note-win-x64-3.89.1.zip",
            "hash": "0f0b180bfb6c5eaad46282b9e6f8f803148f29258c1f9ea044b1f26562bfd07f"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\Yank Note.exe",
            "Yank Note"
        ]
    ],
    "link": [
        "$env:AppData\\yank.note",
        "$home\\yank-note"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/purocean/yn/releases/download/v$version/Yank-Note-win-x64-$version.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
