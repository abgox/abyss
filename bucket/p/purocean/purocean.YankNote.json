{
    "version": "3.92.1",
    "description": "高度可扩展的 Markdown 编辑器 | A highly extensible Markdown editor",
    "homepage": "https://yank-note.com",
    "license": {
        "identifier": "AGPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/purocean/yn/releases/download/v3.92.1/Yank-Note-win-x64-3.92.1.zip",
            "hash": "c559a839f3ddb7be991d0e0e2408601dadbd113d84421981ae4e21b8abf4f664"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\Yank Note.exe",
            "Yank Note"
        ]
    ],
    "link": [
        "$env:AppData\\yank.note",
        "$home\\yank-note"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/purocean/yn/releases/download/v$version/Yank-Note-win-x64-$version.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
