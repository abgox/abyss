{
    "version": "3.0.1",
    "description": "由 vue-cli-electron-builder 构建的简洁美观的图片上传工具 | A simple & beautiful tool for pictures uploading built by vue-cli-electron-builder",
    "homepage": "https://molunerfinn.com/PicGo",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Molunerfinn/PicGo/releases/download/v3.0.1/PicGo-3.0.1-x64.exe",
            "hash": "a5929dad48ff7c8a0bfe3037121772cafc3d9ddb644e182f57fc5260a7dc37e3"
        },
        "arm64": {
            "url": "https://github.com/Molunerfinn/PicGo/releases/download/v3.0.1/PicGo-3.0.1-arm64.exe",
            "hash": "9168023db7d68c09473b1d7c211e4f0e96afc7fd8abde6d94083e2a7dd5a736f"
        }
    },
    "shortcuts": [
        [
            "app\\PicGo.exe",
            "PicGo"
        ]
    ],
    "link": "$env:AppData\\picgo",
    "cleanup": "$env:LocalAppData\\picgo-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall PicGo.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Molunerfinn/PicGo/releases/download/v$version/PicGo-$version-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/Molunerfinn/PicGo/releases/download/v$version/PicGo-$version-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
