{
    "version": "26.06.01",
    "description": "一款支持终端控制与多数据库的原生 WinUI 桌面清理工具 | A real WinUI desktop cleaner with terminal control and multi-database support",
    "homepage": "https://github.com/builtbybel/FluentCleaner",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/builtbybel/FluentCleaner/releases/download/26.06.01/FluentCleaner-win-x64.zip",
            "hash": "cc17c2f319c30ffa3ac125a8042fe676e571f0b5176f444e5730236f91b84488",
            "extract_dir": "FluentCleaner-win-x64"
        }
    },
    "extract_to": "app",
    "bin": "app\\FCleaner.exe",
    "shortcuts": [
        [
            "app\\FCleaner.exe",
            "FluentCleaner"
        ]
    ],
    "link": "$env:AppData\\FluentCleaner",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/builtbybel/FluentCleaner/releases/download/$version/FluentCleaner-win-x64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
