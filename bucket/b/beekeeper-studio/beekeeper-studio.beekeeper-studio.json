{
    "version": "5.9.0",
    "description": "一款跨平台的 SQL 编辑器和数据库管理器 | A cross-platform SQL editor and database manager",
    "homepage": "https://www.beekeeperstudio.io",
    "license": {
        "identifier": "Freemium"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/beekeeper-studio/beekeeper-studio/releases/download/v5.9.0/Beekeeper-Studio-Setup-5.9.0.exe",
            "hash": "f7b55be50225f55dc8d33c7ba75b644acf3633065f3a2ca1153916fab66cacae"
        }
    },
    "shortcuts": [
        [
            "app\\Beekeeper Studio.exe",
            "Beekeeper Studio"
        ]
    ],
    "link": "$env:AppData\\beekeeper-studio",
    "cleanup": "$env:LocalAppData\\beekeeper-studio-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Beekeeper Studio.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/beekeeper-studio/beekeeper-studio/releases/download/v$version/Beekeeper-Studio-Setup-$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
