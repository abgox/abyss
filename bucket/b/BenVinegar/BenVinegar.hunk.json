{
    "version": "0.17.0",
    "description": "面向智能体生成变更集的优先审阅型终端差异查看器 | A review-first terminal diff viewer for agent-authored changesets",
    "homepage": "https://hunk.dev",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/modem-dev/hunk/releases/download/v0.17.0/hunkdiff-windows-x64.tar.gz",
            "hash": "f27a130df772a3076cac71b7894ea49e243e48dbb4d80d41ce10590d7c42cca2",
            "extract_dir": "hunkdiff-windows-x64"
        }
    },
    "extract_to": "app",
    "bin": "app\\hunk.exe",
    "link": "$home\\.config\\hunk",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/modem-dev/hunk/releases/download/v$version/hunkdiff-windows-x64.tar.gz"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
