        },
        "arm64": {
            "url": "https://github.com/brave/brave-browser/releases/download/v1.90.91/brave-v1.90.91-win32-arm64.zip",
            "hash": "52b9710189cf60479210ff05ed1a4466d3953caa86838f7becd70c019102e97c"
