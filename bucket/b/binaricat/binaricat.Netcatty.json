{
    "version": "1.1.71",
    "description": "一款现代化 SSH 管理与终端应用，支持主机分组、SFTP 传输、密钥管理、端口转发，并配备精美丰富的用户界面 | A modern SSH manager and terminal app with host grouping, SFTP, keychain, port forwarding, and a rich UI",
    "homepage": "https://netcatty.app",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/binaricat/Netcatty/releases/download/v1.1.71/Netcatty-1.1.71-win-x64.exe",
            "hash": "8683666b21281c0c4123a348ec56ff909cfae73f440bce1c4e3e4e8c72bebc9e"
        },
        "arm64": {
            "url": "https://github.com/binaricat/Netcatty/releases/download/v1.1.71/Netcatty-1.1.71-win-arm64.exe",
            "hash": "193fbf68400bad102dc91be663bcd99269e5488de379a2d5bb6bc4b3b14511f9"
        }
    },
    "shortcuts": [
        [
            "app\\Netcatty.exe",
            "Netcatty"
        ]
    ],
    "link": [
        "$env:AppData\\Netcatty",
        "$home\\.netcatty"
    ],
    "cleanup": "$env:LocalAppData\\netcatty-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Netcatty.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/binaricat/Netcatty/releases/download/v$version/Netcatty-$version-win-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/binaricat/Netcatty/releases/download/v$version/Netcatty-$version-win-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
