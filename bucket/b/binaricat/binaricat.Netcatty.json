{
    "version": "1.0.98",
    "description": "一款现代化 SSH 管理与终端应用，支持主机分组、SFTP 传输、密钥管理、端口转发，并配备精美丰富的用户界面 | A modern SSH manager and terminal app with host grouping, SFTP, keychain, port forwarding, and a rich UI",
    "homepage": "https://netcatty.app/",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/binaricat/Netcatty/releases/download/v1.0.98/Netcatty-1.0.98-win-x64.exe",
            "hash": "eb39bb0afea554030e0baf3e0742036b8fc6630ba6f4f7422dbc64dcfd4fece7"
        },
        "arm64": {
            "url": "https://github.com/binaricat/Netcatty/releases/download/v1.0.98/Netcatty-1.0.98-win-arm64.exe",
            "hash": "ec6cfa6da3d18b3aa084c6ee3275a5f3fd1674d2d97e36276026c4705186c3fc"
        }
    },
    "shortcuts": [
        [
            "app\\Netcatty.exe",
            "Netcatty"
        ]
    ],
    "link": [
        "$env:AppData\\Netcatty",
        "$home\\.netcatty"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Netcatty.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\netcatty-updater\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/binaricat/Netcatty/releases/download/v$version/Netcatty-$version-win-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/binaricat/Netcatty/releases/download/v$version/Netcatty-$version-win-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
