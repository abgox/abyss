{
    "version": "1.0.94",
    "description": "一款现代化 SSH 管理与终端应用，支持主机分组、SFTP 传输、密钥管理、端口转发，并配备精美丰富的用户界面 | A modern SSH manager and terminal app with host grouping, SFTP, keychain, port forwarding, and a rich UI",
    "homepage": "https://netcatty.app/",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/binaricat/Netcatty/releases/download/v1.0.94/Netcatty-1.0.94-win-x64.exe",
            "hash": "dba226fe64299d9c77d1692014f0744f401de95e0161b9597dfbc18f7e34fa3f"
        },
        "arm64": {
            "url": "https://github.com/binaricat/Netcatty/releases/download/v1.0.94/Netcatty-1.0.94-win-arm64.exe",
            "hash": "b944a31c1ca38f005951ab60a407bcb9400a4e264c8e89ced1f3bfb726f6a203"
        }
    },
    "shortcuts": [
        [
            "app\\Netcatty.exe",
            "Netcatty"
        ]
    ],
    "link": [
        "$env:AppData\\Netcatty",
        "$home\\.netcatty"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Netcatty.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\netcatty-updater\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/binaricat/Netcatty/releases/download/v$version/Netcatty-$version-win-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/binaricat/Netcatty/releases/download/v$version/Netcatty-$version-win-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
