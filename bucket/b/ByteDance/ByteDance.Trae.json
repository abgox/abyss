{
    "version": "2.3.17433",
    "description": "字节跳动的一个 AI 驱动的代码 IDE | An AI-powered code IDE by ByteDance",
    "homepage": "https://www.trae.ai/",
    "license": {
        "identifier": "Unknown",
        "url": "https://www.trae.ai/terms-of-service"
    },
    "architecture": {
        "64bit": {
            "url": "https://lf-cdn.trae.ai/obj/trae-ai-sg/pkg/app/releases/stable/2.3.17433/win32/Trae-Setup-x64.exe",
            "hash": "fc3c60b2b13deb8bc2adc0c32e6a0876b95e23c5846d9543be815e66c8cf8fe7"
        }
    },
    "env_add_path": "app\\bin",
    "commands": "trae",
    "shortcuts": [
        [
            "app\\Trae.exe",
            "Trae"
        ]
    ],
    "link": [
        "$env:AppData\\Trae",
        "$home\\.trae"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Require-Admin",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Require-Admin",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://api.trae.ai/icube/api/v1/native/version/trae/latest",
        "jsonpath": "$.data.manifest.win32.version"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://lf-cdn.trae.ai/obj/trae-ai-sg/pkg/app/releases/stable/$version/win32/Trae-Setup-x64.exe"
            }
        }
    }
}
