{
    "version": "1.0.69",
    "description": "一款面向飞书开放平台的命令行工具 | A command-line tool for Lark/Feishu Open Platform",
    "homepage": "https://www.larksuite.com",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/larksuite/cli/releases/download/v1.0.69/lark-cli-1.0.69-windows-amd64.zip",
            "hash": "74bbed7906ceceab3934cf1b5493a3d052313cb29d15cf19ec9c6ffc1386653f"
        },
        "arm64": {
            "url": "https://github.com/larksuite/cli/releases/download/v1.0.69/lark-cli-1.0.69-windows-arm64.zip",
            "hash": "6d44a6cb29a25f5b551969e22cd3638ac55c5015e514a82b583f98e0b0bf3ffb"
        }
    },
    "extract_to": "app",
    "env_set": {
        "LARKSUITE_CLI_CONFIG_DIR": "$persist_dir\\.lark-cli"
    },
    "bin": "app\\lark-cli.exe",
    "link": "$home\\.lark-cli",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/larksuite/cli/releases/download/v$version/lark-cli-$version-windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/larksuite/cli/releases/download/v$version/lark-cli-$version-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
