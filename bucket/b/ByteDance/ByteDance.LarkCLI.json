{
    "version": "1.0.15",
    "description": "一款面向飞书开放平台的命令行工具 | A command-line tool for Lark/Feishu Open Platform",
    "homepage": "https://www.larksuite.com/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/larksuite/cli/releases/download/v1.0.15/lark-cli-1.0.15-windows-amd64.zip",
            "hash": "9fe878019aea573b6d146cda122af457cda10bd3872b6b3ba8efd93461e5c52e"
        },
        "arm64": {
            "url": "https://github.com/larksuite/cli/releases/download/v1.0.15/lark-cli-1.0.15-windows-arm64.zip",
            "hash": "8e682dc9fe60f545fc0744854ce4d2343455a8f1315c100836a9fcd570257dc5"
        }
    },
    "extract_to": "app",
    "env_set": {
        "LARKSUITE_CLI_CONFIG_DIR": "$persist_dir\\.lark-cli"
    },
    "bin": "app\\lark-cli.exe",
    "link": "$home\\.lark-cli",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/larksuite/cli/releases/download/v$version/lark-cli-$version-windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/larksuite/cli/releases/download/v$version/lark-cli-$version-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
