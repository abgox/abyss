{
    "version": "1.0.18",
    "description": "一款面向飞书开放平台的命令行工具 | A command-line tool for Lark/Feishu Open Platform",
    "homepage": "https://www.larksuite.com/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/larksuite/cli/releases/download/v1.0.18/lark-cli-1.0.18-windows-amd64.zip",
            "hash": "b203aa1cc6459c496dbf90418f77861658f8ac506c257c8d72e0349c71f6ab90"
        },
        "arm64": {
            "url": "https://github.com/larksuite/cli/releases/download/v1.0.18/lark-cli-1.0.18-windows-arm64.zip",
            "hash": "0f806ea9882442825b0d4248fa8c0b9549ecd5a47427f43266050071e49bd5a6"
        }
    },
    "extract_to": "app",
    "env_set": {
        "LARKSUITE_CLI_CONFIG_DIR": "$persist_dir\\.lark-cli"
    },
    "bin": "app\\lark-cli.exe",
    "link": "$home\\.lark-cli",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/larksuite/cli/releases/download/v$version/lark-cli-$version-windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/larksuite/cli/releases/download/v$version/lark-cli-$version-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
