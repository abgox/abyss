{
    "version": "1.0.52",
    "description": "一款面向飞书开放平台的命令行工具 | A command-line tool for Lark/Feishu Open Platform",
    "homepage": "https://www.larksuite.com/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/larksuite/cli/releases/download/v1.0.52/lark-cli-1.0.52-windows-amd64.zip",
            "hash": "76498ef9330f60687c186ff644a8c61d8b113c2bdf347879329dc4fd85b8b2e4"
        },
        "arm64": {
            "url": "https://github.com/larksuite/cli/releases/download/v1.0.52/lark-cli-1.0.52-windows-arm64.zip",
            "hash": "7f4348881f28319daabcff7180bd8fb2ec2d3830c24ecd7132a2d6b4bf4f07cf"
        }
    },
    "extract_to": "app",
    "env_set": {
        "LARKSUITE_CLI_CONFIG_DIR": "$persist_dir\\.lark-cli"
    },
    "bin": "app\\lark-cli.exe",
    "link": "$home\\.lark-cli",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/larksuite/cli/releases/download/v$version/lark-cli-$version-windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/larksuite/cli/releases/download/v$version/lark-cli-$version-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
