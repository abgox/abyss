{
    "version": "1.0.75",
    "description": "一款面向飞书开放平台的命令行工具 | A command-line tool for Lark/Feishu Open Platform",
    "homepage": "https://www.larksuite.com",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/larksuite/cli/releases/download/v1.0.75/lark-cli-1.0.75-windows-amd64.zip",
            "hash": "b80cd88a5ebfc1702e635d70311ab29d9d8bde6622130aa6b686b5e0233b2604"
        },
        "arm64": {
            "url": "https://github.com/larksuite/cli/releases/download/v1.0.75/lark-cli-1.0.75-windows-arm64.zip",
            "hash": "1379987089e4cdedaf450673576d7edaf22cdb3b9fe1636801692d90b80c99ba"
        }
    },
    "extract_to": "app",
    "env_set": {
        "LARKSUITE_CLI_CONFIG_DIR": "$persist_dir\\.lark-cli"
    },
    "bin": "app\\lark-cli.exe",
    "link": "$home\\.lark-cli",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/larksuite/cli/releases/download/v$version/lark-cli-$version-windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/larksuite/cli/releases/download/v$version/lark-cli-$version-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
