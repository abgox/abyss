{
    "version": "1.20.3",
    "description": "一个可使用 ChatGPT、Claude 和其他 LLM 的桌面客户端 | A desktop client for ChatGPT, Claude and other LLMs",
    "homepage": "https://chatboxai.app/",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://download.chatboxai.app/releases/Chatbox-1.20.3-Setup.exe",
            "hash": "874171c6c7358ff3915f01412eb036154a5ded7a76c4663fb0f592d2c5c23b13"
        },
        "arm64": {
            "url": "https://download.chatboxai.app/releases/Chatbox-1.20.3-Setup.exe",
            "hash": "874171c6c7358ff3915f01412eb036154a5ded7a76c4663fb0f592d2c5c23b13"
        }
    },
    "shortcuts": [
        [
            "app\\Chatbox.exe",
            "Chatbox"
        ]
    ],
    "link": "$env:AppData\\xyz.chatboxapp.app",
    "cleanup": "$env:LocalAppData\\xyz.chatboxapp.app-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Chatbox.exe' -ArgumentList '/CurrentUser','/S',\"/D=$dir\\app\""
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'Bin-Huang.Chatbox' 'exe'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_user.InstallerSha256"
                }
            },
            "arm64": {
                "url": "$matchArm64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.arm64_user.InstallerSha256"
                }
            }
        }
    }
}
