{
    "version": "1.21.1",
    "description": "一个可使用 ChatGPT、Claude 和其他 LLM 的桌面客户端 | A desktop client for ChatGPT, Claude and other LLMs",
    "homepage": "https://chatboxai.app",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://download.chatboxai.app/releases/Chatbox-1.21.1-Setup.exe",
            "hash": "6eee2f536ba32336042fc7bdc6f2f90bb1d2c68ad24b3117d6f4689280c5e55c"
        },
        "arm64": {
            "url": "https://download.chatboxai.app/releases/Chatbox-1.21.1-Setup.exe",
            "hash": "6eee2f536ba32336042fc7bdc6f2f90bb1d2c68ad24b3117d6f4689280c5e55c"
        }
    },
    "shortcuts": [
        [
            "app\\Chatbox.exe",
            "Chatbox"
        ]
    ],
    "link": "$env:AppData\\xyz.chatboxapp.app",
    "cleanup": "$env:LocalAppData\\xyz.chatboxapp.app-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Chatbox.exe' -ArgumentList '/CurrentUser','/S',\"/D=$dir\\app\""
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget 'Bin-Huang.Chatbox' 'exe'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_user.InstallerSha256"
                }
            },
            "arm64": {
                "url": "$matchArm64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.arm64_user.InstallerSha256"
                }
            }
        }
    }
}
