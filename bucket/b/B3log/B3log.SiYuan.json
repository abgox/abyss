{
    "version": "3.6.1",
    "description": "一款以隐私为首要原则、可自行托管且完全开源的个人知识管理软件 | A privacy-first, self-hosted, fully open source personal knowledge management software",
    "homepage": "https://b3log.org/siyuan/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/siyuan-note/siyuan/releases/download/v3.6.1/siyuan-3.6.1-win.exe",
            "hash": "0e9f8fec00e2a519d129f95627d1d62ca25c1a14b416ad83078728bdec29fd2a"
        },
        "arm64": {
            "url": "https://github.com/siyuan-note/siyuan/releases/download/v3.6.1/siyuan-3.6.1-win-arm64.exe",
            "hash": "e027ca03b769259cc77daef2f3dc847daadabd451dcabc7104ecd9f2d9a5837e"
        }
    },
    "shortcuts": [
        [
            "app\\SiYuan.exe",
            "SiYuan"
        ]
    ],
    "link": [
        "$home\\SiYuan",
        "$home\\.config\\siyuan"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall SiYuan.exe' -ArgumentList '/CurrentUser','/S',\"/D=$dir\\app\""
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:AppData\\SiYuan-Electron\",\"$env:LocalAppData\\siyuan-updater\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/siyuan-note/siyuan/releases/download/v$version/siyuan-$version-win.exe"
            },
            "arm64": {
                "url": "https://github.com/siyuan-note/siyuan/releases/download/v$version/siyuan-$version-win-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
