    "homepage": "https://b3log.org/siyuan",
    "license": {
        "identifier": "AGPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/siyuan-note/siyuan/releases/download/v3.7.2/siyuan-3.7.2-win.exe",
            "hash": "944a61e885e20f61b4a4ce01ada1b8c21e49efb030eb22fc33b53d96cdfd2aa7"
        },
        "arm64": {
            "url": "https://github.com/siyuan-note/siyuan/releases/download/v3.7.2/siyuan-3.7.2-win-arm64.exe",
            "hash": "a0704271dfa4f5d1db1d1f5c28767f750ececef0dafe8a03aaddde43874293b3"
        }
    },
    "shortcuts": [
        [
            "app\\SiYuan.exe",
            "SiYuan"
        ]
    ],
    "link": [
        "$home\\SiYuan",
        "$home\\.config\\siyuan"
    ],
    "cleanup": [
        "$env:AppData\\SiYuan-Electron",
        "$env:LocalAppData\\siyuan-updater"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall SiYuan.exe' -ArgumentList '/CurrentUser','/S',\"/D=$dir\\app\""
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/siyuan-note/siyuan/releases/download/v$version/siyuan-$version-win.exe"
            },
            "arm64": {
                "url": "https://github.com/siyuan-note/siyuan/releases/download/v$version/siyuan-$version-win-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
