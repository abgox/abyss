{
    "version": "7.23.3",
    "description": "一个适用于 Windows 的 V2Ray 客户端，支持 Xray & v2fly 核心 | A V2Ray client for Windows, support Xray & v2fly core",
    "homepage": "https://github.com/2dust/v2rayN",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/2dust/v2rayN/releases/download/7.23.3/v2rayN-windows-64-desktop.zip",
            "hash": "8c22be3aa2be7ddfa791907bf0a124f78da0e163668388da9828820094ef9f50",
            "extract_dir": "v2rayN-windows-64"
        },
        "arm64": {
            "url": "https://github.com/2dust/v2rayN/releases/download/7.23.3/v2rayN-windows-arm64-desktop.zip",
