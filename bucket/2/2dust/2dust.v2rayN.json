{
    "version": "7.20.2",
    "description": "一个适用于 Windows 的 V2Ray 客户端，支持 Xray & v2fly 核心 | A V2Ray client for Windows, support Xray & v2fly core",
    "homepage": "https://github.com/2dust/v2rayN",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/2dust/v2rayN/releases/download/7.20.2/v2rayN-windows-64-desktop.zip",
            "hash": "5886f8bf25b5807248eaad16c8d78486e390806776778c219742833a56c02ac5",
            "extract_dir": "v2rayN-windows-64"
        },
        "arm64": {
            "url": "https://github.com/2dust/v2rayN/releases/download/7.20.2/v2rayN-windows-arm64-desktop.zip",
            "hash": "477f25a325c113a8e055328f5c608ef38cc34fc855b9af3c05a5c0c55c2985c1",
            "extract_dir": "v2rayN-windows-arm64"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\v2rayN.exe",
            "v2rayN"
        ]
    ],
    "persist": [
        [
            "app\\guiConfigs",
            "guiConfigs"
        ],
        [
            "app\\binConfigs",
            "binConfigs"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/2dust/v2rayN/releases/download/$version/v2rayN-windows-64-desktop.zip"
            },
            "arm64": {
                "url": "https://github.com/2dust/v2rayN/releases/download/$version/v2rayN-windows-arm64-desktop.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
