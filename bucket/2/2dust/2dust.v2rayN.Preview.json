{
    "version": "7.21.2",
    "description": "一个适用于 Windows 的 V2Ray 客户端，支持 Xray & v2fly 核心 | A V2Ray client for Windows, support Xray & v2fly core",
    "homepage": "https://github.com/2dust/v2rayN",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/2dust/v2rayN/releases/download/7.21.2/v2rayN-windows-64-desktop.zip",
            "hash": "772c3f15b79c623d3b77166e47cb5f81c89571d69cf24cfbcebdbaa7320b260e",
            "extract_dir": "v2rayN-windows-64"
        },
        "arm64": {
            "url": "https://github.com/2dust/v2rayN/releases/download/7.21.2/v2rayN-windows-arm64-desktop.zip",
            "hash": "dd473ff2a6b756230e550f7922595ca7135707b9572493c4cc0afdedd81bd045",
            "extract_dir": "v2rayN-windows-arm64"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\v2rayN.exe",
            "v2rayN Preview"
        ]
    ],
    "persist": [
        [
            "app\\guiConfigs",
            "guiConfigs"
        ],
        [
            "app\\binConfigs",
            "binConfigs"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-NewestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/2dust/v2rayN/releases/download/$version/v2rayN-windows-64-desktop.zip"
            },
            "arm64": {
                "url": "https://github.com/2dust/v2rayN/releases/download/$version/v2rayN-windows-arm64-desktop.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
