{
    "version": "7.24.1",
    "description": "一个适用于 Windows 的 V2Ray 客户端，支持 Xray & v2fly 核心 | A V2Ray client for Windows, support Xray & v2fly core",
    "homepage": "https://github.com/2dust/v2rayN",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/2dust/v2rayN/releases/download/7.24.1/v2rayN-windows-64-desktop.zip",
            "hash": "7c31ab2c8e8e68c48859df41a3a7d90c3a104253f66c487224c3e12eb1f2e407",
            "extract_dir": "v2rayN-windows-64"
        },
        "arm64": {
            "url": "https://github.com/2dust/v2rayN/releases/download/7.24.1/v2rayN-windows-arm64-desktop.zip",
            "hash": "c0bff6e28c4ca5a240eeb9ce60f7a1ea71e075b294e4e3b83e71e73a6b3705e8",
            "extract_dir": "v2rayN-windows-arm64"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\v2rayN.exe",
            "v2rayN Preview"
        ]
    ],
    "persist": [
        [
            "app\\guiConfigs",
            "guiConfigs"
        ],
        [
            "app\\binConfigs",
            "binConfigs"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-NewestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/2dust/v2rayN/releases/download/$version/v2rayN-windows-64-desktop.zip"
            },
            "arm64": {
                "url": "https://github.com/2dust/v2rayN/releases/download/$version/v2rayN-windows-arm64-desktop.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
