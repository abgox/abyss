{
    "version": "0.22.0",
    "description": "一个支持 IPTV 播放列表播放 (m3u、m3u8) 的视频播放器应用程序 | A video player application that provides support for the playback of IPTV playlists (m3u, m3u8)",
    "homepage": "https://iptvnator.vercel.app",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/4gray/iptvnator/releases/download/v0.22.0/iptvnator-0.22.0-windows-x64-setup.exe",
            "hash": "faf88943cf51e0775c9088fcfc65c8bad68a8bba1bae2c0ea4733761ef14e67d"
        }
    },
    "shortcuts": [
        [
            "app\\iptvnator.exe",
            "IPTVnator"
        ]
    ],
    "link": "$env:AppData\\iptvnator",
    "cleanup": "$env:LocalAppData\\iptvnator-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall IPTVnator.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/4gray/iptvnator/releases/download/v$version/iptvnator-$version-windows-x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
