{
    "version": "0.41.0",
    "description": "Jujutsu，又叫 jj，是一款既简单又强大的与 Git 兼容的版本控制系统 | Jujutsu, also called jj, is a Git-compatible VCS that is both simple and powerful",
    "homepage": "https://jj-vcs.dev/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "suggest": {
        "completions": "abyss/abgox.PSCompletions",
        "TUI": "abyss/IbrahimDursun.jjui"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/jj-vcs/jj/releases/download/v0.41.0/jj-v0.41.0-x86_64-pc-windows-msvc.zip",
            "hash": "1c5ac3015caf0b15ae81cbafa1d94024dbd17b5dff933204d489787dfb95f835"
        },
        "arm64": {
            "url": "https://github.com/jj-vcs/jj/releases/download/v0.41.0/jj-v0.41.0-aarch64-pc-windows-msvc.zip",
            "hash": "9fce194dbce7393752ad562bba430027d7857ffb3e3f12c08e763c58b204c0c3"
        }
    },
    "extract_to": "app",
    "bin": "app\\jj.exe",
    "link": "$env:AppData\\jj",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/jj-vcs/jj/releases/download/v$version/jj-v$version-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/jj-vcs/jj/releases/download/v$version/jj-v$version-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
