{
    "version": "0.39.0",
    "description": "Jujutsu，又叫 jj，是一款既简单又强大的与 Git 兼容的版本控制系统 | Jujutsu, also called jj, is a Git-compatible VCS that is both simple and powerful",
    "homepage": "https://jj-vcs.dev/",
    "license": {
        "identifier": "Apache-2.0"
    },
    "suggest": {
        "completions": "abyss/abgox.PSCompletions",
        "TUI": "abyss/IbrahimDursun.jjui"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/jj-vcs/jj/releases/download/v0.39.0/jj-v0.39.0-x86_64-pc-windows-msvc.zip",
            "hash": "53be7e277e5f0396621ccdda509904e4f88fe8e517b78ce20176269b7e97d378"
        },
        "arm64": {
            "url": "https://github.com/jj-vcs/jj/releases/download/v0.39.0/jj-v0.39.0-aarch64-pc-windows-msvc.zip",
            "hash": "c3da2f7bec13dd2f5360d60b479436f70908152ec348673360154399cf06ad70"
        }
    },
    "extract_to": "app",
    "bin": "app\\jj.exe",
    "link": "$env:AppData\\jj",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/jj-vcs/jj/releases/download/v$version/jj-v$version-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/jj-vcs/jj/releases/download/v$version/jj-v$version-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
