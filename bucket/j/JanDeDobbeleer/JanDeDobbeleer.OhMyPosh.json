        },
        "arm64": {
            "url": [
                "https://github.com/JanDeDobbeleer/oh-my-posh/releases/download/v29.9.4/themes.zip",
                "https://github.com/JanDeDobbeleer/oh-my-posh/releases/download/v29.9.4/posh-windows-arm64.exe#/oh-my-posh.exe"
            ],
            "hash": [
                "e99955ddbd23ff81e406335fc173b502f398ca2bedfe1e698774e2799fecb59f",
