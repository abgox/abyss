{
    "version": "0.6.0",
    "description": "一个轻量级、低内存占用的 SSH / 终端客户端 | A lightweight, low-memory SSH / terminal client",
    "homepage": "https://github.com/jeff141/meatshell",
    "license": {
        "identifier": "Unknown"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/jeff141/meatshell/releases/download/v0.6.0/meatshell-v0.6.0-windows-x86_64.zip",
            "hash": "d1d58ac9782d24053c2e7403cfd500b12274f9188a55440090ddf904373c7ed9",
            "extract_dir": "meatshell-v0.6.0-windows-x86_64"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\meatshell.exe",
            "meatshell"
        ]
    ],
    "link": "$env:AppData\\meatshell",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/jeff141/meatshell/releases/download/v$version/meatshell-v$version-windows-x86_64.zip",
                "extract_dir": "meatshell-v$version-windows-x86_64"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
