{
    "version": "1.14.0",
    "description": "一款现代化的自托管音乐播放器 | A modern self-hosted music player",
    "homepage": "https://github.com/jeffvli/feishin",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/jeffvli/feishin/releases/download/v1.14.0/Feishin-1.14.0-win-x64.zip",
            "hash": "5f615ce50507272778ac7b147f8477179d6d220ab080e0d95bf982e6f3b9c089"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\Feishin.exe",
            "Feishin"
        ]
    ],
    "link": "$env:AppData\\feishin",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/jeffvli/feishin/releases/download/v$version/Feishin-$version-win-x64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
