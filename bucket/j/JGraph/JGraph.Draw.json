{
    "version": "30.3.13",
    "description": "一款基于 Electron 的桌面绘图应用程序，它封装了 draw.io 核心编辑器 | A diagramming desktop app based on Electron that wraps the core draw.io editor",
    "homepage": "https://www.diagrams.net",
    "license": {
        "identifier": "Apache-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/jgraph/drawio-desktop/releases/download/v30.3.13/draw.io-30.3.13-windows.zip",
            "hash": "8bdedbe148bcff3bb12950e8277c72a5f0cca8420a163f6352b7a0f0ed7234b7"
        }
    },
    "extract_to": "app",
    "bin": "app\\draw.io.exe",
    "shortcuts": [
        [
            "app\\draw.io.exe",
            "draw.io"
        ]
    ],
    "link": "$env:AppData\\draw.io",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/jgraph/drawio-desktop/releases/download/v$version/draw.io-$version-windows.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
