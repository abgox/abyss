{
    "version": "2026.6.3",
    "description": "多语言工具版本管理器、环境变量管理器和任务运行器 | Polyglot tool version manager, env vars manager and task runner",
    "homepage": "https://mise.jdx.dev/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/jdx/mise/releases/download/v2026.6.3/mise-v2026.6.3-windows-x64.zip",
            "hash": "a547220eb5633953d8f2e5a711857d6ccad466789607afd4fc101cb01659e07a"
        },
        "arm64": {
            "url": "https://github.com/jdx/mise/releases/download/v2026.6.3/mise-v2026.6.3-windows-arm64.zip",
            "hash": "de146400032bc20665076528a244e5677da72a452a8ed607713857c3ad58f0d2"
        }
    },
    "extract_dir": "mise",
    "extract_to": "app",
    "env_add_path_expand": "$env:LocalAppData\\mise\\shims",
    "bin": "app\\bin\\mise.exe",
    "link": [
        "$home\\.config\\mise",
        "$env:LocalAppData\\mise"
    ],
    "cleanup": "$home\\.local\\state\\mise",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/jdx/mise/releases/download/v$version/mise-v$version-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/jdx/mise/releases/download/v$version/mise-v$version-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
