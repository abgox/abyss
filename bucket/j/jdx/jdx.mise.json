{
    "version": "2026.7.5",
    "description": "多语言工具版本管理器、环境变量管理器和任务运行器 | Polyglot tool version manager, env vars manager and task runner",
    "homepage": "https://mise.jdx.dev",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/jdx/mise/releases/download/v2026.7.5/mise-v2026.7.5-windows-x64.zip",
            "hash": "0ccdde5cd132a4d1f5078bef2bbc49275f803ba672121446f0b7429a48d59df9"
        },
        "arm64": {
            "url": "https://github.com/jdx/mise/releases/download/v2026.7.5/mise-v2026.7.5-windows-arm64.zip",
            "hash": "e086d317a3275fdc2a72cbaa3b2055bddf4c109402f31242dfac8ab96523492a"
        }
    },
    "extract_dir": "mise",
    "extract_to": "app",
    "env_add_path_expand": "$env:LocalAppData\\mise\\shims",
    "bin": "app\\bin\\mise.exe",
    "link": [
        "$home\\.config\\mise",
        "$env:LocalAppData\\mise"
    ],
    "cleanup": "$home\\.local\\state\\mise",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/jdx/mise/releases/download/v$version/mise-v$version-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/jdx/mise/releases/download/v$version/mise-v$version-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
