{
    "version": "2026.5.18",
    "description": "多语言工具版本管理器、环境变量管理器和任务运行器 | Polyglot tool version manager, env vars manager and task runner",
    "homepage": "https://mise.jdx.dev/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/jdx/mise/releases/download/v2026.5.18/mise-v2026.5.18-windows-x64.zip",
            "hash": "8cd368e73308c6f650ba5ee08230c781e4a76fc022177bc8cc4dee2dec8a2f7d"
        },
        "arm64": {
            "url": "https://github.com/jdx/mise/releases/download/v2026.5.18/mise-v2026.5.18-windows-arm64.zip",
            "hash": "c65fc20c623f10a73f62a00c3b0e4d3929d3d7f1d30928a8cca69b940dea9531"
        }
    },
    "extract_dir": "mise",
    "extract_to": "app",
    "env_add_path_expand": "$env:LocalAppData\\mise\\shims",
    "bin": "app\\bin\\mise.exe",
    "link": [
        "$home\\.config\\mise",
        "$env:LocalAppData\\mise"
    ],
    "cleanup": "$home\\.local\\state\\mise",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/jdx/mise/releases/download/v$version/mise-v$version-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/jdx/mise/releases/download/v$version/mise-v$version-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
