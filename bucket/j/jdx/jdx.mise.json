{
    "version": "2026.4.0",
    "description": "多语言工具版本管理器、环境变量管理器和任务运行器 | Polyglot tool version manager, env vars manager and task runner",
    "homepage": "https://mise.jdx.dev/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/jdx/mise/releases/download/v2026.4.0/mise-v2026.4.0-windows-x64.zip",
            "hash": "59e82ebc9497b1cde6e6815807d0297b4d35c601aad2446cb8e101bb369f9b4d"
        },
        "arm64": {
            "url": "https://github.com/jdx/mise/releases/download/v2026.4.0/mise-v2026.4.0-windows-arm64.zip",
            "hash": "b40d20a2e0b17d7e454e8f4c3a19e0da45d28c3b484d9fad35e7a1513acb865d"
        }
    },
    "extract_dir": "mise",
    "extract_to": "app",
    "env_add_path_expand": "$env:LocalAppData\\mise\\shims",
    "bin": "app\\bin\\mise.exe",
    "link": [
        "$home\\.config\\mise",
        "$env:LocalAppData\\mise"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Remove-TempData \"$home\\.local\\state\\mise\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/jdx/mise/releases/download/v$version/mise-v$version-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/jdx/mise/releases/download/v$version/mise-v$version-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
