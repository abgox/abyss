{
    "version": "1.17.0",
    "description": "通过加密或云服务提供商来管理密钥 | Manage secrets with encryption or cloud providers",
    "homepage": "https://fnox.jdx.dev/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/jdx/fnox/releases/download/v1.17.0/fnox-x86_64-pc-windows-msvc.zip",
            "hash": "eb14fe5095ba6cfeea4376c41457ea9a3f4ef62237f6a441fb7352a6022a344d"
        },
        "arm64": {
            "url": "https://github.com/jdx/fnox/releases/download/v1.17.0/fnox-aarch64-pc-windows-msvc.zip",
            "hash": "10e487b87a05db29db51b7f4db945bd96026717f1ce01b184dcdf032e997702e"
        }
    },
    "extract_to": "app",
    "bin": "app\\fnox.exe",
    "link": "$home\\.config\\fnox",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/jdx/fnox/releases/download/v$version/fnox-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/jdx/fnox/releases/download/v$version/fnox-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
