{
    "version": "18.5.0",
    "description": "一个高级待办事项列表应用，具备时间限制和时间跟踪功能，支持从日历、Jira、GitHub 等平台导入任务 | An advanced todo list app with timeboxing & time tracking capabilities that supports importing tasks from your calendar, Jira, GitHub and others",
    "homepage": "https://super-productivity.com/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/johannesjo/super-productivity/releases/download/v18.5.0/Super-Productivity-Setup-x64.exe",
            "hash": "343301e5503561c274095fe4fb218a9bc988fb1cac13df58f771fffc2739ce80"
        },
        "arm64": {
            "url": "https://github.com/johannesjo/super-productivity/releases/download/v18.5.0/Super-Productivity-Setup-arm64.exe",
            "hash": "fc0f4b40ee9f5d54e3f960523cdb4d560bcd284bb9152e5ffbcfaef6e66f00cf"
        }
    },
    "shortcuts": [
        [
            "app\\Super Productivity.exe",
            "Super Productivity"
        ]
    ],
    "link": "$env:AppData\\superProductivity",
    "cleanup": "$env:LocalAppData\\superproductivity-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Super Productivity.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/johannesjo/super-productivity/releases/download/v$version/Super-Productivity-Setup-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/johannesjo/super-productivity/releases/download/v$version/Super-Productivity-Setup-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
