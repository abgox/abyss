{
    "version": "18.15.1",
    "description": "一个高级待办事项列表应用，具备时间限制和时间跟踪功能，支持从日历、Jira、GitHub 等平台导入任务 | An advanced todo list app with timeboxing & time tracking capabilities that supports importing tasks from your calendar, Jira, GitHub and others",
    "homepage": "https://super-productivity.com",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/johannesjo/super-productivity/releases/download/v18.15.1/Super-Productivity-Setup-x64.exe",
            "hash": "a0a813cf1fb693c828ddaaf4c48b64b4efe5c7e768307a42319414e57054968b"
        },
        "arm64": {
            "url": "https://github.com/johannesjo/super-productivity/releases/download/v18.15.1/Super-Productivity-Setup-arm64.exe",
            "hash": "4330cd28383acd80af23ba334e6cea9bc4054363e1e805dbb885a46f4fc0a401"
        }
    },
    "shortcuts": [
        [
            "app\\Super Productivity.exe",
            "Super Productivity"
        ]
    ],
    "link": "$env:AppData\\superProductivity",
    "cleanup": "$env:LocalAppData\\superproductivity-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Super Productivity.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/johannesjo/super-productivity/releases/download/v$version/Super-Productivity-Setup-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/johannesjo/super-productivity/releases/download/v$version/Super-Productivity-Setup-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
