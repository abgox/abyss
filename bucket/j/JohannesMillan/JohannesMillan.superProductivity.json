{
    "version": "18.8.0",
    "description": "一个高级待办事项列表应用，具备时间限制和时间跟踪功能，支持从日历、Jira、GitHub 等平台导入任务 | An advanced todo list app with timeboxing & time tracking capabilities that supports importing tasks from your calendar, Jira, GitHub and others",
    "homepage": "https://super-productivity.com/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/johannesjo/super-productivity/releases/download/v18.8.0/Super-Productivity-Setup-x64.exe",
            "hash": "a120e8d337844ee7cc169d71b6234245eabacc8b78a4ef56e34199696baff829"
        },
        "arm64": {
            "url": "https://github.com/johannesjo/super-productivity/releases/download/v18.8.0/Super-Productivity-Setup-arm64.exe",
            "hash": "cef09e3412f82dab0b369a520bc0191f9ad10d4e8454b46d1f6041dcec493e7d"
        }
    },
    "shortcuts": [
        [
            "app\\Super Productivity.exe",
            "Super Productivity"
        ]
    ],
    "link": "$env:AppData\\superProductivity",
    "cleanup": "$env:LocalAppData\\superproductivity-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Super Productivity.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/johannesjo/super-productivity/releases/download/v$version/Super-Productivity-Setup-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/johannesjo/super-productivity/releases/download/v$version/Super-Productivity-Setup-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
