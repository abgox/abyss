{
    "version": "0.8.1",
    "description": "ChatGPT 的开源替代品，可在计算机上百分百脱机运行 | An open source alternative to ChatGPT that runs 100% offline on your computer",
    "homepage": "https://jan.ai/",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/menloresearch/jan/releases/download/v0.8.1/Jan_0.8.1_x64-setup.exe",
            "hash": "ebf82c7223545baeb6102f2aebff24fcf465e1d82a4af8b8cafa24cc89d352d2"
        }
    },
    "bin": "app\\jan.exe",
    "shortcuts": [
        [
            "app\\jan.exe",
            "Jan"
        ]
    ],
    "link": "$env:AppData\\jan",
    "cleanup": "$env:LocalAppData\\jan-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/menloresearch/jan/releases/download/v$version/Jan_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
