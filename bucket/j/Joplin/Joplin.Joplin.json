{
    "version": "3.6.14",
    "description": "一款免费的开源笔记和待办事项应用程序 | A free, open source note taking and to-do application",
    "homepage": "https://joplinapp.org/",
    "license": {
        "identifier": "Unknown"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/laurent22/joplin/releases/download/v3.6.14/Joplin-Setup-3.6.14.exe",
            "hash": "4ac91174220d28a93538aca8fefd87f4d9f358d98388a5a001432d506898e650"
        }
    },
    "shortcuts": [
        [
            "app\\Joplin.exe",
            "Joplin"
        ]
    ],
    "link": "$home\\.config\\joplin-desktop",
    "cleanup": [
        "$env:AppData\\joplin",
        "$env:LocalAppData\\@joplinapp-desktop-updater"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Joplin.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/laurent22/joplin/releases/download/v$version/Joplin-Setup-$version.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
