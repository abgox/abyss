{
    "version": "0.2.1",
    "description": "一种高效的编程语言，能够用于构建高效、快速、可靠且安全的软件，同时保持简洁性 | An effective programming language to build efficient, fast, reliable and safe software while maintaining simplicity",
    "homepage": "https://jule.dev/",
    "license": {
        "identifier": "BSD-3-Clause"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/julelang/jule/releases/download/jule0.2.1/jule0.2.1-windows-amd64.zip",
            "hash": "5cef1424566afe03f3e548175539a274abdd18dd606e6de4e812fed4636e61d0"
        },
        "arm64": {
            "url": "https://github.com/julelang/jule/releases/download/jule0.2.1/jule0.2.1-windows-arm64.zip",
            "hash": "37620ed96699aa8507525b53b093fe9496719bb2b0301cf9b6ec85e6abc74642"
        }
    },
    "extract_dir": "jule",
    "extract_to": "app",
    "env_add_path": "app\\bin",
    "commands": "julec",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "jule(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/julelang/jule/releases/download/jule$version/jule$version-windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/julelang/jule/releases/download/jule$version/jule$version-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
