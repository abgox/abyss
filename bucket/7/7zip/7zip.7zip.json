{
    "version": "26.00",
    "description": "一个拥有极高压缩比的开源压缩软件 | A file archiver with a high compression ratio",
    "homepage": "https://7-zip.org/",
    "license": {
        "identifier": "Unknown",
        "url": "https://7-zip.org/license.txt"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/ip7z/7zip/releases/download/26.00/7z2600-x64.msi#/dl.msi_",
            "hash": "c388d0444871ca11b21237001af158cfddad7e137851795e5b65cee69b518495"
        }
    },
    "location": "$env:ProgramFiles\\7-Zip",
    "env_add_path_expand": "$env:ProgramFiles\\7-Zip",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Require-Admin",
        "A-Install-Msi"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "if ($cmd -eq 'update') {",
        "  A-Require-Admin",
        "  return",
        "}",
        "A-Uninstall-Manually"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ip7z/7zip/releases/download/$version/7z$cleanVersion-x64.msi#/dl.msi_"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
