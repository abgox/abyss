{
    "version": "3.2.1.0",
    "description": "123 云盘，一款云存储服务产品 | A cloud storage service product",
    "homepage": "https://www.123pan.com",
    "license": {
        "identifier": "Freemium",
        "url": "https://www.123pan.com/UserAgreement"
    },
    "architecture": {
        "64bit": {
            "url": "https://app.123957.com/pc-pro/windows/321/123pan_3.2.1.exe",
            "hash": "7ae74899321d32b4c169c8e4111fa2b95d0681c0f33662089628837db38a1516"
        }
    },
    "location": "$env:LocalAppData\\123pan",
    "link": "$env:AppData\\123pan\\config.json",
    "cleanup": "$env:AppData\\123pan",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -ArgumentList '/S'",
        "A-Hold-App"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Uninstall-Manually",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "$res, $out = A-Get-InstallerInfoFromWinget '123.123pan' 'exe'",
            "$out"
        ],
        "regex": "(?:.*ver:(?<version>[^;]+))(?:.*x64:(?<x64>[^;]+))?(?:.*x86:(?<x86>[^;]+))?(?:.*arm64:(?<arm64>[^;]+))?"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchX64",
                "hash": {
                    "url": "temp-autoupdate.json",
                    "jsonpath": "$.x64_machine.InstallerSha256"
                }
            }
        }
    }
}
