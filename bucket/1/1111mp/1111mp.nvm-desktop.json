{
    "version": "4.3.2",
    "description": "一个用于管理多个 Node.js 版本的桌面应用程序 | A desktop application to manage multiple active Node.js versions",
    "homepage": "https://github.com/1111mp/nvm-desktop",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/1111mp/nvm-desktop/releases/download/v4.3.2/NVM.Desktop_4.3.2_x64-setup.exe",
            "hash": "67f9df062993a0e2c3ca6d4a979d05ef130653a290ef5adc1b3b629cf489daa8"
        },
        "arm64": {
            "url": "https://github.com/1111mp/nvm-desktop/releases/download/v4.3.2/NVM.Desktop_4.3.2_arm64-setup.exe",
            "hash": "1ec492c73ebc022dfb1452bfb18f391b69e88128a76afa71c1047af3cc2da067"
        }
    },
    "commands": "nvmd",
    "shortcuts": [
        [
            "app\\nvm-desktop.exe",
            "NVM Desktop"
        ]
    ],
    "link": "$home\\.nvmd",
    "cleanup": "$env:LocalAppData\\io.github.1111mp.nvm-desktop",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/1111mp/nvm-desktop/releases/download/v$version/NVM.Desktop_$version_x64-setup.exe"
            },
            "arm64": {
                "url": "https://github.com/1111mp/nvm-desktop/releases/download/v$version/NVM.Desktop_$version_arm64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
