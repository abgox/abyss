{
    "version": "4.3.0",
    "description": "一个用于管理多个 Node.js 版本的桌面应用程序 | A desktop application to manage multiple active Node.js versions",
    "homepage": "https://github.com/1111mp/nvm-desktop",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/1111mp/nvm-desktop/releases/download/v4.3.0/NVM.Desktop_4.3.0_x64-setup.exe",
            "hash": "f35bc03fd46d23ba26a31033012d080852382dfbc24219afbdfff5efb4c0007e"
        },
        "arm64": {
            "url": "https://github.com/1111mp/nvm-desktop/releases/download/v4.3.0/NVM.Desktop_4.3.0_arm64-setup.exe",
            "hash": "8de00310d34866247e39178645048d014ad7facba0f06a7c876a4fe846003fbf"
        }
    },
    "shortcuts": [
        [
            "app\\nvm-desktop.exe",
            "NVM Desktop"
        ]
    ],
    "link": "$home\\.nvmd",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Require-Admin",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Require-Admin",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\io.github.1111mp.nvm-desktop\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/1111mp/nvm-desktop/releases/download/v$version/NVM.Desktop_$version_x64-setup.exe"
            },
            "arm64": {
                "url": "https://github.com/1111mp/nvm-desktop/releases/download/v$version/NVM.Desktop_$version_arm64-setup.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
