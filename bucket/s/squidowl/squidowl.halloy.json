{
    "version": "2026.7.2",
    "description": "一款用 Rust 编写的开源 IRC 客户端，采用 Iced 图形用户界面库 | An open-source IRC client written in Rust, with the Iced GUI library",
    "homepage": "https://halloy.chat",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/squidowl/halloy/releases/download/2026.7.2/halloy-installer.exe",
            "hash": "f74342417154ff21df3e40168cc548374a9c38a5cf558637991f52154c21fb25"
        }
    },
    "conflicts": [
        "squidowl.halloy",
        "squidowl.halloy.nightly"
    ],
    "shortcuts": [
        [
            "app\\halloy.exe",
            "Halloy"
        ]
    ],
    "link": "$env:AppData\\halloy",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Inno"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-Inno"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/squidowl/halloy/releases/download/$version/halloy-installer.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
