    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Ensure-Directory \"$env:AppData\\Rime\"",
        "Write-Host \"Copying $dir\\moqi_moe.dict.yaml => $env:AppData\\Rime\" -ForegroundColor Yellow",
        "Copy-Item \"$dir\\moqi_moe.dict.yaml\" $env:AppData\\Rime -Force"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "Remove-Item \"$env:AppData\\Rime\\moqi_moe.dict.yaml\" -Force -ErrorAction SilentlyContinue"
