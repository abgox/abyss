{
    "version": "0.5.0",
    "description": "一款采用 Rust 与 GPUI 编写的跨平台轻量级剪贴板管理工具 | Cross-platform, lightweight clipboard manager written in Rust and GPUI",
    "homepage": "https://github.com/StudentWeis/ropy",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/StudentWeis/ropy/releases/download/0.5.0/ropy-x86_64-pc-windows-msvc.zip",
            "hash": "b89c3d411ac691822b4bfeb915d2653bbe0a2a897f029e1c20321ba9bc0a4ec6"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\ropy.exe",
            "Ropy"
        ]
    ],
    "link": [
        "$env:AppData\\ropy",
        "$env:LocalAppData\\ropy"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/StudentWeis/ropy/releases/download/$version/ropy-x86_64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
