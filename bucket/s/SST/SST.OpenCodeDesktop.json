{
    "version": "1.15.0",
    "description": "开源的编码助手 | The open source coding agent",
    "homepage": "https://opencode.ai/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/anomalyco/opencode/releases/download/v1.15.0/opencode-desktop-win-x64.exe",
            "hash": "e4e8ad94e0fc1ec9efecd7d39e6fc722036be4f1eee808d0b6ff7d08ddb670b5"
        },
        "arm64": {
            "url": "https://github.com/anomalyco/opencode/releases/download/v1.15.0/opencode-desktop-win-arm64.exe",
            "hash": "9dead768387dbf70b4f5b8ef217940bb757e5af5fea755f92e81d873e0441fe1"
        }
    },
    "shortcuts": [
        [
            "app\\OpenCode.exe",
            "OpenCode"
        ]
    ],
    "link": "$env:AppData\\ai.opencode.desktop",
    "cleanup": "$env:LocalAppData\\ai.opencode.desktop",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/anomalyco/opencode/releases/download/v$version/opencode-desktop-win-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/anomalyco/opencode/releases/download/v$version/opencode-desktop-win-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
