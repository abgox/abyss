{
    "version": "1.17.0",
    "description": "开源的编码助手 | The open source coding agent",
    "homepage": "https://opencode.ai/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/anomalyco/opencode/releases/download/v1.17.0/opencode-desktop-win-x64.exe",
            "hash": "2e1e6a936e61fa2fa81aabd29fd5d962bcca59c350f1151e06d18880e88a14fb"
        },
        "arm64": {
            "url": "https://github.com/anomalyco/opencode/releases/download/v1.17.0/opencode-desktop-win-arm64.exe",
            "hash": "bb43911ab1e47410863c8905cf0897ada2a868415a6cef42ef9d9a8cb28771d5"
        }
    },
    "shortcuts": [
        [
            "app\\OpenCode.exe",
            "OpenCode"
        ]
    ],
    "link": "$env:AppData\\ai.opencode.desktop",
    "cleanup": "$env:LocalAppData\\ai.opencode.desktop",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/anomalyco/opencode/releases/download/v$version/opencode-desktop-win-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/anomalyco/opencode/releases/download/v$version/opencode-desktop-win-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
