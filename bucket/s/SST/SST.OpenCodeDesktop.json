{
    "version": "1.3.12",
    "description": "开源的编码助手 | The open source coding agent",
    "homepage": "https://opencode.ai/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/anomalyco/opencode/releases/download/v1.3.12/opencode-desktop-windows-x64.exe",
            "hash": "0bf7cfe97f2b81d15a58b4dd89b7aef4f3d136c8d1ff37e941703775d280255e"
        },
        "arm64": {
            "url": "https://github.com/anomalyco/opencode/releases/download/v1.3.12/opencode-desktop-windows-arm64.exe",
            "hash": "f00836fa828d71653a231d1aa00cd5d7caac33b7df443ca8fac106549e9ce5e0"
        }
    },
    "shortcuts": [
        [
            "app\\OpenCode.exe",
            "OpenCode"
        ]
    ],
    "link": "$env:AppData\\ai.opencode.desktop",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\ai.opencode.desktop\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/anomalyco/opencode/releases/download/v$version/opencode-desktop-windows-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/anomalyco/opencode/releases/download/v$version/opencode-desktop-windows-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
