{
    "version": "1.4.3",
    "description": "开源的编码助手 | The open source coding agent",
    "homepage": "https://opencode.ai/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/anomalyco/opencode/releases/download/v1.4.3/opencode-desktop-windows-x64.exe",
            "hash": "2183b048ea4482e987b067bdf57cd58b3053ec7fd4e5e4d491a9ae6ad6e78e13"
        },
        "arm64": {
            "url": "https://github.com/anomalyco/opencode/releases/download/v1.4.3/opencode-desktop-windows-arm64.exe",
            "hash": "8463019fdef27819dce9e146b3f6d2dca10b6440aba4638dc59461857c927239"
        }
    },
    "shortcuts": [
        [
            "app\\OpenCode.exe",
            "OpenCode"
        ]
    ],
    "link": "$env:AppData\\ai.opencode.desktop",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\uninstall.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\ai.opencode.desktop\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/anomalyco/opencode/releases/download/v$version/opencode-desktop-windows-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/anomalyco/opencode/releases/download/v$version/opencode-desktop-windows-arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
