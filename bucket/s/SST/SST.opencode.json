{
    "version": "1.14.32",
    "description": "专为终端打造的 AI 编程助手 | The AI coding agent built for the terminal",
    "homepage": "https://opencode.ai/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/sst/opencode/releases/download/v1.14.32/opencode-windows-x64.zip",
            "hash": "80ef72536ec725413db02273ea803362f75c003f96cc439efa6993244f972272"
        },
        "arm64": {
            "url": "https://github.com/sst/opencode/releases/download/v1.14.32/opencode-windows-arm64.zip",
            "hash": "eca01d92ee8ea45d07fd97f868aab00952e4a129506567fa2f360d5b577e4c77"
        }
    },
    "extract_to": "app",
    "bin": "app\\opencode.exe",
    "shortcuts": [
        [
            "app\\opencode.exe",
            "OpenCode"
        ]
    ],
    "link": [
        "$home\\.config\\opencode",
        "$home\\.local\\share\\opencode",
        "$home\\.local\\state\\opencode"
    ],
    "cleanup": "$home\\.cache\\opencode",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/sst/opencode/releases/download/v$version/opencode-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/sst/opencode/releases/download/v$version/opencode-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
