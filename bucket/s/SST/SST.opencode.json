{
    "version": "1.4.1",
    "description": "专为终端打造的 AI 编程助手 | The AI coding agent built for the terminal",
    "homepage": "https://opencode.ai/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/sst/opencode/releases/download/v1.4.1/opencode-windows-x64.zip",
            "hash": "65a7601a5f45c30ca9a4d3ba2a7cc35b74e2b33807a78379222f1836f26256d0"
        },
        "arm64": {
            "url": "https://github.com/sst/opencode/releases/download/v1.4.1/opencode-windows-arm64.zip",
            "hash": "36afccb58fcac6705b9f0198cff256f1bddc6dd2e5befec9a757d294d5ca330e"
        }
    },
    "extract_to": "app",
    "bin": "app\\opencode.exe",
    "shortcuts": [
        [
            "app\\opencode.exe",
            "OpenCode"
        ]
    ],
    "link": [
        "$home\\.config\\opencode",
        "$home\\.local\\share\\opencode",
        "$home\\.local\\state\\opencode"
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Remove-TempData \"$home\\.cache\\opencode\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/sst/opencode/releases/download/v$version/opencode-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/sst/opencode/releases/download/v$version/opencode-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
