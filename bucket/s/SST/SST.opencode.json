{
    "version": "1.14.30",
    "description": "专为终端打造的 AI 编程助手 | The AI coding agent built for the terminal",
    "homepage": "https://opencode.ai/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/sst/opencode/releases/download/v1.14.30/opencode-windows-x64.zip",
            "hash": "954698a20ed338a03ea6416e5a21053a75140e3642413b232f8665e09df73b20"
        },
        "arm64": {
            "url": "https://github.com/sst/opencode/releases/download/v1.14.30/opencode-windows-arm64.zip",
            "hash": "1f7d1bf97693688beefcfd388aec1ce2e9b6c2af5de174762c8357e4475dc008"
        }
    },
    "extract_to": "app",
    "bin": "app\\opencode.exe",
    "shortcuts": [
        [
            "app\\opencode.exe",
            "OpenCode"
        ]
    ],
    "link": [
        "$home\\.config\\opencode",
        "$home\\.local\\share\\opencode",
        "$home\\.local\\state\\opencode"
    ],
    "cleanup": "$home\\.cache\\opencode",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/sst/opencode/releases/download/v$version/opencode-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/sst/opencode/releases/download/v$version/opencode-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
