{
    "version": "1.14.40",
    "description": "专为终端打造的 AI 编程助手 | The AI coding agent built for the terminal",
    "homepage": "https://opencode.ai/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/sst/opencode/releases/download/v1.14.40/opencode-windows-x64.zip",
            "hash": "6e418e787f3d34523b5b8a90600f2c4516fcdd6ff3ea9d29eff4757d33f7eedb"
        },
        "arm64": {
            "url": "https://github.com/sst/opencode/releases/download/v1.14.40/opencode-windows-arm64.zip",
            "hash": "a375d557587b32820f49c33ab6da881aead02c6c8b88ff692fcbbc37a9ee865f"
        }
    },
    "extract_to": "app",
    "bin": "app\\opencode.exe",
    "shortcuts": [
        [
            "app\\opencode.exe",
            "OpenCode"
        ]
    ],
    "link": [
        "$home\\.config\\opencode",
        "$home\\.local\\share\\opencode",
        "$home\\.local\\state\\opencode"
    ],
    "cleanup": "$home\\.cache\\opencode",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/sst/opencode/releases/download/v$version/opencode-windows-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/sst/opencode/releases/download/v$version/opencode-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
