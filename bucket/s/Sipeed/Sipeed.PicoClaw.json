            "hash": "77b564f36da6d1e02169d0ecc837728eecb9ef983c317d9186ac9651798b924c"
        },
        "arm64": {
            "url": "https://github.com/sipeed/picoclaw/releases/download/v0.2.6/picoclaw_Windows_arm64.zip",
            "hash": "05046c0c41b47f77940c42059e97edd89b2883c19b06e5b88feb6c6ea2b6a86d"
        }
    },
    "extract_to": "app",
    "bin": "app\\picoclaw.exe",
    "link": "$home\\.picoclaw",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/sipeed/picoclaw/releases/download/v$version/picoclaw_Windows_x86_64.zip"
            },
            "arm64": {
                "url": "https://github.com/sipeed/picoclaw/releases/download/v$version/picoclaw_Windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
