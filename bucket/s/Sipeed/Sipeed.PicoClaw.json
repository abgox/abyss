{
    "version": "0.2.8",
    "description": "小巧、快速、随处可部署 —— 自动化繁琐任务，释放你的创造力 | Tiny, Fast, and Deployable anywhere - automate the mundane, unleash your creativity",
    "homepage": "https://picoclaw.io/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/sipeed/picoclaw/releases/download/v0.2.8/picoclaw_Windows_x86_64.zip",
            "hash": "fb2aad44d832309d95ce1927529288688f1816a8288ed2e73577f32cfa99a77a"
        },
        "arm64": {
            "url": "https://github.com/sipeed/picoclaw/releases/download/v0.2.8/picoclaw_Windows_arm64.zip",
            "hash": "20307fdc01b022c217955388ca3304d070bb552b43ba707226ef7c449830c4d1"
        }
    },
    "extract_to": "app",
    "bin": "app\\picoclaw.exe",
    "link": "$home\\.picoclaw",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/sipeed/picoclaw/releases/download/v$version/picoclaw_Windows_x86_64.zip"
            },
            "arm64": {
                "url": "https://github.com/sipeed/picoclaw/releases/download/v$version/picoclaw_Windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
