            "hash": "65da5c0e349fcccb8c63d670a1125166dfcd585f7181904d076863f96d7d24cb"
        },
        "arm64": {
            "url": "https://github.com/sipeed/picoclaw/releases/download/v0.2.7/picoclaw_Windows_arm64.zip",
            "hash": "6b154ee28bbe0f3e9ec6e4eec51cb0e0f0f42eb7dfeca45a31ce57b1fe2ac368"
        }
    },
    "extract_to": "app",
    "bin": "app\\picoclaw.exe",
    "link": "$home\\.picoclaw",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/sipeed/picoclaw/releases/download/v$version/picoclaw_Windows_x86_64.zip"
            },
            "arm64": {
                "url": "https://github.com/sipeed/picoclaw/releases/download/v$version/picoclaw_Windows_arm64.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
