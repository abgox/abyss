{
    "version": "0.12.0",
    "description": "适用于 WinGet 的终端用户界面 | A TUI for WinGet",
    "homepage": "https://github.com/shanselman/winget-tui",
    "license": {
        "identifier": "Unknown"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/shanselman/winget-tui/releases/download/v0.12.0/winget-tui-x64.exe#/winget-tui.exe",
            "hash": "79a931f48e43aadef3eeab39c732069a6570798555a1eac98d9c974e0cdaf236"
        },
        "arm64": {
            "url": "https://github.com/shanselman/winget-tui/releases/download/v0.12.0/winget-tui-arm64.exe#/winget-tui.exe",
            "hash": "ee72961d04853e74ca5ea2232e55f05a75ea603a14e3931668d74818e34c9f29"
        }
    },
    "bin": "winget-tui.exe",
    "link": "$env:AppData\\winget-tui",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/shanselman/winget-tui/releases/download/v$version/winget-tui-x64.exe#/winget-tui.exe"
            },
            "arm64": {
                "url": "https://github.com/shanselman/winget-tui/releases/download/v$version/winget-tui-arm64.exe#/winget-tui.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
