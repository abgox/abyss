{
    "version": "0.11.0",
    "description": "适用于 WinGet 的终端用户界面 | A TUI for WinGet",
    "homepage": "https://github.com/shanselman/winget-tui",
    "license": {
        "identifier": "Unknown"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/shanselman/winget-tui/releases/download/v0.11.0/winget-tui-x64.exe#/winget-tui.exe",
            "hash": "40fea53425d3a85f840b99586512a0c6d1b36668b69d133151bb881a1e621681"
        },
        "arm64": {
            "url": "https://github.com/shanselman/winget-tui/releases/download/v0.11.0/winget-tui-arm64.exe#/winget-tui.exe",
            "hash": "8584eb7cbd28f06e3c037eec0ae7f51839aa4b0dc594020c365f1f2cb7aa4488"
        }
    },
    "bin": "winget-tui.exe",
    "link": "$env:AppData\\winget-tui",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/shanselman/winget-tui/releases/download/v$version/winget-tui-x64.exe#/winget-tui.exe"
            },
            "arm64": {
                "url": "https://github.com/shanselman/winget-tui/releases/download/v$version/winget-tui-arm64.exe#/winget-tui.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
