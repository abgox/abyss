{
    "version": "0.10.0",
    "description": "适用于 WinGet 的终端用户界面 | A TUI for WinGet",
    "homepage": "https://github.com/shanselman/winget-tui",
    "license": {
        "identifier": "Unknown"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/shanselman/winget-tui/releases/download/v0.10.0/winget-tui-x64.exe#/winget-tui.exe",
            "hash": "dc024669ce779dfe2e4f07d23e92ec3ac9a25ac64126f0adf108df0f8d029402"
        },
        "arm64": {
            "url": "https://github.com/shanselman/winget-tui/releases/download/v0.10.0/winget-tui-arm64.exe#/winget-tui.exe",
            "hash": "9c79c04e3dd0d8125edb23fbe62eb9bc9e905528221b238f7e59745c8c82f3f1"
        }
    },
    "bin": "winget-tui.exe",
    "link": "$env:AppData\\winget-tui",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/shanselman/winget-tui/releases/download/v$version/winget-tui-x64.exe#/winget-tui.exe"
            },
            "arm64": {
                "url": "https://github.com/shanselman/winget-tui/releases/download/v$version/winget-tui-arm64.exe#/winget-tui.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
