{
    "version": "0.8.1",
    "description": "适用于 WinGet 的终端用户界面 | A TUI for WinGet",
    "homepage": "https://github.com/shanselman/winget-tui",
    "license": {
        "identifier": "Unknown"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/shanselman/winget-tui/releases/download/v0.8.1/winget-tui-x64.exe#/winget-tui.exe",
            "hash": "b74dfe5c13515988679fb955732a4175cb6db7ca84210e4f30f7410fb2803457"
        },
        "arm64": {
            "url": "https://github.com/shanselman/winget-tui/releases/download/v0.8.1/winget-tui-arm64.exe#/winget-tui.exe",
            "hash": "22cad706ce30b05b4e34dc1f9afe42f9df28d2715541a9e972e2450cccc2d1cf"
        }
    },
    "bin": "winget-tui.exe",
    "link": "$env:AppData\\winget-tui",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/shanselman/winget-tui/releases/download/v$version/winget-tui-x64.exe#/winget-tui.exe"
            },
            "arm64": {
                "url": "https://github.com/shanselman/winget-tui/releases/download/v$version/winget-tui-arm64.exe#/winget-tui.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
