{
    "version": "3.3.14",
    "description": "一款完全开源且端到端加密的笔记应用，可替代 Evernote | A fully open source & end-to-end encrypted note taking alternative to Evernote",
    "homepage": "https://github.com/streetwriters/notesnook",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/streetwriters/notesnook/releases/download/v3.3.14/notesnook_win_x64.exe",
            "hash": "929fd5126c0c280ebb0e27a36e6df8068df8df482a7a3a3151b589aa490b87f7"
        },
        "arm64": {
            "url": "https://github.com/streetwriters/notesnook/releases/download/v3.3.14/notesnook_win_arm64.exe",
            "hash": "7c3a20463e527844477dc53b2cfdc3c196279b5c6c76383515a45e917ca38f0f"
        }
    },
    "shortcuts": [
        [
            "app\\Notesnook.exe",
            "Notesnook"
        ]
    ],
    "link": "$env:AppData\\Notesnook",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Notesnook.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\@notesnookdesktop-updater\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-LatestVersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/streetwriters/notesnook/releases/download/v$version/notesnook_win_x64.exe"
            },
            "arm64": {
                "url": "https://github.com/streetwriters/notesnook/releases/download/v$version/notesnook_win_arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
