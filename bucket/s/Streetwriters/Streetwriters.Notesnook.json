{
    "version": "3.3.22",
    "description": "一款完全开源且端到端加密的笔记应用，可替代 Evernote | A fully open source & end-to-end encrypted note taking alternative to Evernote",
    "homepage": "https://github.com/streetwriters/notesnook",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/streetwriters/notesnook/releases/download/v3.3.22/notesnook_win_x64.exe",
            "hash": "cb6566fce72d133b80181126ffe75fe238ae29f7e25375bb756e52f549858241"
        },
        "arm64": {
            "url": "https://github.com/streetwriters/notesnook/releases/download/v3.3.22/notesnook_win_arm64.exe",
            "hash": "9db839ac6cd83202ea8a7b2e0ec186eccdee10695c7fa104ab7594fef15e1850"
        }
    },
    "shortcuts": [
        [
            "app\\Notesnook.exe",
            "Notesnook"
        ]
    ],
    "link": "$env:AppData\\Notesnook",
    "cleanup": "$env:LocalAppData\\@notesnookdesktop-updater",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Notesnook.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/streetwriters/notesnook/releases/download/v$version/notesnook_win_x64.exe"
            },
            "arm64": {
                "url": "https://github.com/streetwriters/notesnook/releases/download/v$version/notesnook_win_arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
