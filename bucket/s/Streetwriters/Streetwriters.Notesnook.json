{
    "version": "3.3.10",
    "description": "一款完全开源且端到端加密的笔记应用，可替代 Evernote | A fully open source & end-to-end encrypted note taking alternative to Evernote",
    "homepage": "https://github.com/streetwriters/notesnook",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/streetwriters/notesnook/releases/download/v3.3.10/notesnook_win_x64.exe",
            "hash": "4f3fb65c3f334504877eb904d2fa5002fad9636736573e3f6c8bcc5ab00ffa8d"
        },
        "arm64": {
            "url": "https://github.com/streetwriters/notesnook/releases/download/v3.3.10/notesnook_win_arm64.exe",
            "hash": "b56df437bc2966e1435621103f4e770a4674c6fda1142f049ddb04c935c26740"
        }
    },
    "shortcuts": [
        [
            "app\\Notesnook.exe",
            "Notesnook"
        ]
    ],
    "link": "$env:AppData\\Notesnook",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install",
        "A-Install-App -Uninstaller 'app\\Uninstall Notesnook.exe'"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link",
        "A-Uninstall-App",
        "A-Remove-TempData \"$env:LocalAppData\\@notesnookdesktop-updater\""
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\script\\utils.ps1",
            "A-Get-VersionFromGithubAPI"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/streetwriters/notesnook/releases/download/v$version/notesnook_win_x64.exe"
            },
            "arm64": {
                "url": "https://github.com/streetwriters/notesnook/releases/download/v$version/notesnook_win_arm64.exe"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
