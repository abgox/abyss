{
    "version": "2.6.1",
    "description": "一款适用于 Windows 系统的免费、轻量级图像和动画查看器 | A free, lightweight image and animation viewer for Windows",
    "homepage": "https://www.nyam.pe.kr/dev/imagine",
    "license": {
        "identifier": "Freeware",
        "url": "https://www.nyam.pe.kr/dev/imagine/#license"
    },
    "architecture": {
        "64bit": {
            "url": "https://raw.githubusercontent.com/nyam1003/imagine/main/x64/Imagine_2.6.1_x64_Unicode_Full.zip",
            "hash": "5acf193ce44164cb91455dc143bebc221669c75ec02ef7a1496d1d8465220055",
            "bin": [
                "app\\Imagine64.exe",
                [
                    "app\\Imagine64.exe",
                    "Imagine"
                ]
            ],
            "shortcuts": [
                [
                    "app\\Imagine64.exe",
                    "Imagine"
                ]
            ]
        },
        "arm64": {
            "url": "https://raw.githubusercontent.com/nyam1003/imagine/main/arm64/Imagine_2.6.1_arm64_Unicode_Full.zip",
            "hash": "f7eee9795021e079f5f296ae4c4aa4b5a55e85b3bdb286b19c2a3b87f47385a5",
            "bin": [
                "app\\ImagineA64.exe",
                [
                    "app\\ImagineA64.exe",
                    "Imagine"
                ]
            ],
            "shortcuts": [
                [
                    "app\\ImagineA64.exe",
                    "Imagine"
                ]
            ]
        }
    },
    "extract_to": "app",
    "link": "$env:AppData\\Imagine",
    "persist": [
        [
            "app\\Imagine.ini",
            "Imagine.ini"
        ],
        [
            "app\\PlugInst.inf",
            "PlugInst.inf"
        ],
        [
            "app\\Plugin",
            "Plugin"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://www.nyam.pe.kr/dev/imagine/",
        "regex": "v(\\d[\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://raw.githubusercontent.com/nyam1003/imagine/main/x64/Imagine_$version_x64_Unicode_Full.zip"
            },
            "arm64": {
                "url": "https://raw.githubusercontent.com/nyam1003/imagine/main/arm64/Imagine_$version_arm64_Unicode_Full.zip"
            }
        }
    }
}
