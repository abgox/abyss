{
    "version": "2.5.3",
    "description": "一款适用于 Windows 系统的免费、轻量级图像和动画查看器 | A free, lightweight image and animation viewer for Windows",
    "homepage": "https://www.nyam.pe.kr/dev/imagine/",
    "license": {
        "identifier": "Freeware",
        "url": "https://www.nyam.pe.kr/dev/imagine/#license"
    },
    "architecture": {
        "64bit": {
            "url": "https://raw.githubusercontent.com/nyam1003/imagine/main/x64/Imagine_2.5.3_x64_Unicode_Full.zip",
            "hash": "e3becaa3227adedb3a482e84937a6ae623539540a487f5da667f2992265d28f3",
            "bin": [
                "app\\Imagine64.exe",
                [
                    "app\\Imagine64.exe",
                    "Imagine"
                ]
            ],
            "shortcuts": [
                [
                    "app\\Imagine64.exe",
                    "Imagine"
                ]
            ]
        },
        "arm64": {
            "url": "https://raw.githubusercontent.com/nyam1003/imagine/main/arm64/Imagine_2.5.3_arm64_Unicode_Full.zip",
            "hash": "8c5a1b6cc2a8cdf570e92e0055ff2f93d8f5bc2566812a955c0f1169ed8dd336",
            "bin": [
                "app\\ImagineA64.exe",
                [
                    "app\\ImagineA64.exe",
                    "Imagine"
                ]
            ],
            "shortcuts": [
                [
                    "app\\ImagineA64.exe",
                    "Imagine"
                ]
            ]
        }
    },
    "extract_to": "app",
    "link": "$env:AppData\\Imagine",
    "persist": [
        [
            "app\\Imagine.ini",
            "Imagine.ini"
        ],
        [
            "app\\PlugInst.inf",
            "PlugInst.inf"
        ],
        [
            "app\\Plugin",
            "Plugin"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://www.nyam.pe.kr/dev/imagine/",
        "regex": "v(\\d[\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://raw.githubusercontent.com/nyam1003/imagine/main/x64/Imagine_$version_x64_Unicode_Full.zip"
            },
            "arm64": {
                "url": "https://raw.githubusercontent.com/nyam1003/imagine/main/arm64/Imagine_$version_arm64_Unicode_Full.zip"
            }
        }
    }
}
