{
    "version": "2.5.4",
    "description": "一款适用于 Windows 系统的免费、轻量级图像和动画查看器 | A free, lightweight image and animation viewer for Windows",
    "homepage": "https://www.nyam.pe.kr/dev/imagine/",
    "license": {
        "identifier": "Freeware",
        "url": "https://www.nyam.pe.kr/dev/imagine/#license"
    },
    "architecture": {
        "64bit": {
            "url": "https://raw.githubusercontent.com/nyam1003/imagine/main/x64/Imagine_2.5.4_x64_Unicode_Full.zip",
            "hash": "4af04c3eec9e5d54e4f50305649bbe219d6b42b038b54812231e52568dc41e74",
            "bin": [
                "app\\Imagine64.exe",
                [
                    "app\\Imagine64.exe",
                    "Imagine"
                ]
            ],
            "shortcuts": [
                [
                    "app\\Imagine64.exe",
                    "Imagine"
                ]
            ]
        },
        "arm64": {
            "url": "https://raw.githubusercontent.com/nyam1003/imagine/main/arm64/Imagine_2.5.4_arm64_Unicode_Full.zip",
            "hash": "31a38131e54f7da0b75573ccc7c09d18dcfbb5878ab781ab93174db144fa3d1a",
            "bin": [
                "app\\ImagineA64.exe",
                [
                    "app\\ImagineA64.exe",
                    "Imagine"
                ]
            ],
            "shortcuts": [
                [
                    "app\\ImagineA64.exe",
                    "Imagine"
                ]
            ]
        }
    },
    "extract_to": "app",
    "link": "$env:AppData\\Imagine",
    "persist": [
        [
            "app\\Imagine.ini",
            "Imagine.ini"
        ],
        [
            "app\\PlugInst.inf",
            "PlugInst.inf"
        ],
        [
            "app\\Plugin",
            "Plugin"
        ]
    ],
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\script\\utils.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "url": "https://www.nyam.pe.kr/dev/imagine/",
        "regex": "v(\\d[\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://raw.githubusercontent.com/nyam1003/imagine/main/x64/Imagine_$version_x64_Unicode_Full.zip"
            },
            "arm64": {
                "url": "https://raw.githubusercontent.com/nyam1003/imagine/main/arm64/Imagine_$version_arm64_Unicode_Full.zip"
            }
        }
    }
}
