{
    "version": "17.12.1",
    "description": "免费的数据库模式发现与理解工具 | Free database schema discovery and comprehension tool",
    "homepage": "https://www.schemacrawler.com",
    "license": {
        "identifier": "EPL-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/schemacrawler/SchemaCrawler-Installers/releases/download/v17.12.1/SchemaCrawler-17.12.1.msi#/dl.msi_",
            "hash": "157166ab567b40bb6be04c8902b372af28c42a911e8b6b43eca59a3abb74f0e0"
        }
    },
    "location": "$env:ProgramFiles\\SchemaCrawler",
    "env_add_path_expand": "$env:ProgramFiles\\SchemaCrawler",
    "commands": "SchemaCrawler",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Msi"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Uninstall-Msi"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/schemacrawler/SchemaCrawler-Installers/releases/download/v$version/SchemaCrawler-$version.msi#/dl.msi_"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
