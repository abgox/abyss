{
    "version": "17.11.2",
    "description": "免费的数据库模式发现与理解工具 | Free database schema discovery and comprehension tool",
    "homepage": "https://www.schemacrawler.com/",
    "license": {
        "identifier": "EPL-2.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/schemacrawler/SchemaCrawler-Installers/releases/download/v17.11.2/SchemaCrawler-17.11.2.msi#/dl.msi_",
            "hash": "fc64a4582316dcc45a7c9dbec2287f19dbb4ce8e98fff8be1932d5178a97d62b"
        }
    },
    "location": "$env:ProgramFiles\\SchemaCrawler",
    "env_add_path_expand": "$env:ProgramFiles\\SchemaCrawler",
    "commands": "SchemaCrawler",
    "admin": true,
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install",
        "A-Install-Msi"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Uninstall-Msi"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/schemacrawler/SchemaCrawler-Installers/releases/download/v$version/SchemaCrawler-$version.msi#/dl.msi_"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
