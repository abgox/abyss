{
    "version": "16.2.1",
    "description": "用于处理 JSON Schema 的命令行界面 (CLI) | The CLI for working with JSON Schema",
    "homepage": "https://github.com/sourcemeta/jsonschema",
    "license": {
        "identifier": "AGPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/sourcemeta/jsonschema/releases/download/v16.2.1/jsonschema-16.2.1-windows-x86_64.zip",
            "hash": "97d5e60749858736e81150b839b79e16c2fabc9d92d4e6e66d9232e491e2f41d",
            "extract_dir": "jsonschema-16.2.1-windows-x86_64"
        }
    },
    "extract_to": "app",
    "bin": "app\\bin\\jsonschema.exe",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/sourcemeta/jsonschema/releases/download/v$version/jsonschema-$version-windows-x86_64.zip",
                "extract_dir": "jsonschema-$version-windows-x86_64"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
