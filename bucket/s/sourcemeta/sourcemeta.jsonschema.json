{
    "version": "15.10.0",
    "description": "用于处理 JSON Schema 的命令行界面 (CLI) | The CLI for working with JSON Schema",
    "homepage": "https://github.com/sourcemeta/jsonschema",
    "license": {
        "identifier": "AGPL-3.0-only"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/sourcemeta/jsonschema/releases/download/v15.10.0/jsonschema-15.10.0-windows-x86_64.zip",
            "hash": "c78a5c311cd79583f81757dcc0ff2eb2949b45a84936a0a86c9f936fcdd53901",
            "extract_dir": "jsonschema-15.10.0-windows-x86_64"
        }
    },
    "extract_to": "app",
    "bin": "app\\bin\\jsonschema.exe",
    "pre_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = (scoop config).'abgox-abyss-bucket-name' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-VersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/sourcemeta/jsonschema/releases/download/v$version/jsonschema-$version-windows-x86_64.zip",
                "extract_dir": "jsonschema-$version-windows-x86_64"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
