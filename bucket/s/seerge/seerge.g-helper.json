{
    "version": "0.264",
    "description": "适用于华硕笔记本电脑的轻量级开源控制工具 | Lightweight control tool for Asus laptops",
    "homepage": "https://g-helper.com",
    "license": {
        "identifier": "GPL-3.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/seerge/g-helper/releases/download/v0.264/GHelper.zip",
            "hash": "99c7c1a270fe3740681624bc5698c9a52d38cacf7ba529be1f31d99ca8fd804c"
        }
    },
    "extract_to": "app",
    "shortcuts": [
        [
            "app\\GHelper.exe",
            "G-Helper"
        ]
    ],
    "link": "$env:AppData\\GHelper",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/seerge/g-helper/releases/download/v$version/GHelper.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
