{
    "version": "0.4.4",
    "description": "一个基于终端的文本编辑器 | A terminal-based text editor",
    "homepage": "https://sinelaw.github.io/fresh",
    "license": {
        "identifier": "GPL-2.0-or-later"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/sinelaw/fresh/releases/download/v0.4.4/fresh-editor-x86_64-pc-windows-msvc.zip",
            "hash": "282bbad85f0ec29c663509301f1c50ef67b1b4bb8d89d489e416e838015e2786"
        }
    },
    "extract_to": "app",
    "bin": "app\\fresh.exe",
    "link": "$env:AppData\\fresh",
    "pre_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Install"
    ],
    "post_install": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Install"
    ],
    "pre_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Start-Uninstall",
        "A-Stop-Process",
        "A-Remove-Link"
    ],
    "post_uninstall": [
        "if (!$bucket) { $bucket = 'abyss' }",
        ". $bucketsdir\\$bucket\\util\\1.ps1",
        "A-Complete-Uninstall"
    ],
    "checkver": {
        "script": [
            ". $pwd\\util\\1.ps1",
            "A-Get-LatestVersionFromGithub"
        ],
        "regex": "(.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/sinelaw/fresh/releases/download/v$version/fresh-editor-x86_64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "mode": "github"
        }
    }
}
